---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Welcome to AG-Website" } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=Inter+Tight:wght@800&family=Syne:wght@800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-grid">
		<slot />
	</body>
</html>
