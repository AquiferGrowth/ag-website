---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = 'AquiferGrowth builds and manages AI-powered operating systems for modern businesses — replacing manual ops roles with autonomous systems that scale.',
	image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.aquifergrowth.com');

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="shortcut icon" href="/favicon-32.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Site Verification -->
		<meta name="google-site-verification" content="a_0xis4vfMml_KqDQGx97U1blifoeumz63B8GGGwoVY" />

		<!-- Primary SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#FF4D6D" />

		<!-- Open Graph (Facebook, LinkedIn, Slack, iMessage previews) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site ?? 'https://aquifergrowth.com')} />
		<meta property="og:site_name" content="AquiferGrowth" />

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site ?? 'https://aquifergrowth.com')} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=Inter+Tight:wght@800&family=Syne:wght@800&display=swap" rel="stylesheet">

		<!-- Page-specific head injections (e.g. schema markup) -->
		<slot name="head" />
	</head>
	<body class="bg-grid">
		<slot />
	</body>
</html>
