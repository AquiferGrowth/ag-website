---
const today = new Date();
---

<footer class="glass container" style="margin-top: var(--space-xl); margin-bottom: var(--space-md); padding: var(--space-md);">
	<div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-sm);">
		<p>&copy; {today.getFullYear()} AG-Website. Built with Astro & Cloudflare.</p>
		<div style="display: flex; gap: var(--space-md);">
			<a href="https://twitter.com/divjot" target="_blank" class="accent">Twitter</a>
			<a href="https://github.com/AquiferGrowth" target="_blank" class="accent">GitHub</a>
		</div>
	</div>
</footer>

<style>
	.accent {
		color: var(--accent-primary);
		font-weight: 700;
	}
	.accent:hover {
		color: var(--accent-secondary);
		text-shadow: 0 0 10px var(--accent-glow);
	}
</style>
