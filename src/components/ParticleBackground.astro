---
/**
 * ParticleBackground Component
 * Uses tsParticles with the "Hyperspace" preset.
 * Configured with Aquifer Growth branding colors.
 */
---

<div id="tsparticles"></div>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadAll } from "@tsparticles/all";

  async function initParticles() {
    // Check if it's already initialized to avoid duplicates
    if (tsParticles.dom().length > 0) {
        tsParticles.dom().forEach(p => p.destroy());
    }

    // Load ALL features for maximum compatibility
    await loadAll(tsParticles);

    await tsParticles.load({
      id: "tsparticles",
      options: {
        background: {
          color: {
            value: "transparent",
          },
        },
        fpsLimit: 120,
        particles: {
          color: {
            value: ["#FF4D6D", "#FF7E5F", "#8B5CF6", "#3B82F6"], 
          },
          move: {
            enable: true,
            speed: 6.5, // Faster star warp
            direction: "outside",
            trail: {
              enable: true,
              fillColor: "#F9F7F2", // Cleanly blend into existing background
              length: 15
            },
            outModes: {
              default: "out",
            },
            random: false,
            straight: false,
            center: {
                x: 50,
                y: 50,
                mode: "percent"
            }
          },
          number: {
            value: 300,
            density: {
               enable: true,
               area: 800
            }
          },
          opacity: {
            value: { min: 0.5, max: 0.95 }, 
            animation: {
              enable: true,
              speed: 2,
              sync: false,
            },
          },
          size: {
            value: { min: 1.5, max: 3 }, 
          },
          shape: {
            type: "circle"
          }
        },
        detectRetina: true,
        fullScreen: {
          enable: true,
          zIndex: 1, /* Above html background, but behind site-wrapper at z-index: 10 */
        },
      },
    });
  }

  // Initialize on page load
  if (document.readyState === "complete") {
    initParticles();
  } else {
    window.addEventListener("load", initParticles);
  }

  // Handle Astro View Transitions (if enabled)
  document.addEventListener("astro:after-swap", initParticles);
</script>

<style>
  /* The canvas is managed by fullScreen mode in the options above */
</style>
