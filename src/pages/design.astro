    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }
  .dd-pdp__stars { font-size: 0.72rem; color: var(--text-secondary); margin: 0; }
  .dd-pdp__stars span { color: #f5a623; letter-spacing: 1px; }
  .dd-pdp__price { font-weight: 800; font-size: 1.05rem; margin: 0; font-variant-numeric: tabular-nums; }
  .dd-pdp__price s { color: #b9b3a6; font-weight: 400; font-size: 0.85rem; margin-left: 0.35rem; }
  .dd-pdp__variants { display: flex; gap: 6px; flex-wrap: wrap; }
  .dd-pdp__variants span {
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-pill);
    font-size: 0.68rem;
    font-weight: 700;
