  .dd-pdp .dd-el.dd-pdp__atc.in.pressed { transform: scale(0.96); box-shadow: 0 2px 6px rgba(255, 77, 109, 0.3); }
  .dd-pdp__meta { font-size: 0.66rem; color: var(--text-secondary); margin: 0; }

  .dd-pdp__toast {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #1a1a1a;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.5rem 0.9rem;
