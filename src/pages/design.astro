  .dd-pdp__thumbs span:first-child { border-color: #1a1a1a; }

  .dd-pdp__info {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }
  .dd-pdp__brand {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-secondary);
