<script>
  const onReady = (fn) => {
    if (document.readyState !== 'loading') fn();
    else document.addEventListener('DOMContentLoaded', fn);
  };
  const rmQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
  const prefersReduced = () => rmQuery.matches;
  const onMotionPrefChange = (fn) => {
    if (rmQuery.addEventListener) rmQuery.addEventListener('change', fn);
    else if (rmQuery.addListener) rmQuery.addListener(fn);
  };

  /* ───── Scroll reveal ───── */
  onReady(() => {
    const targets = document.querySelectorAll('.dd-reveal');
    if (!targets.length) return;
    if (!('IntersectionObserver' in window) || prefersReduced()) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
    );
    targets.forEach((el) => io.observe(el));
  });

  /* ───── Hero PDP assembly loop ───── */
  onReady(() => {
    const scene = document.getElementById('ddHeroScene');
    if (!scene) return;
    const pdp = scene.querySelector('.dd-pdp');
    const els = {};
    scene.querySelectorAll('.dd-el').forEach((el) => {
      els[el.dataset.el] = el;
    });
    const atc = scene.querySelector('.dd-pdp__atc');
    if (!pdp || !atc) return;

    // Land the cursor on the real Add-to-cart position (layout varies by viewport)
    const positionCursor = () => {
      if (!els.cursor) return;
      const pr = pdp.getBoundingClientRect();
      const ar = atc.getBoundingClientRect();
      els.cursor.style.left = `${ar.left - pr.left + ar.width * 0.55 - 6}px`;
      els.cursor.style.top = `${ar.top - pr.top + ar.height * 0.5 - 4}px`;
    };

    const STEPS = [
      { t: 0, els: ['media'] },
      { t: 500, els: ['brand', 'name'] },
      { t: 850, els: ['stars'] },
      { t: 1100, els: ['price'] },
      { t: 1400, els: ['variants'] },
      { t: 1800, els: ['atc', 'meta'] },
      { t: 2500, els: ['cursor'] },
      { t: 3500, fn: () => { els.cursor?.classList.add('press'); atc.classList.add('pressed'); } },
      { t: 3680, fn: () => {
          els.cursor?.classList.remove('press');
          atc.classList.remove('pressed');
          els.toast?.classList.add('in');
          els.cartbadge?.classList.add('in');
        } },
      { t: 6800, fn: () => {
          pdp.classList.add('dd-pdp--out');
          // badge lives in the browser bar (outside .dd-pdp), so retire it with the fade
          els.cartbadge?.classList.remove('in');
        } },
      { t: 7300, fn: () => {
          pdp.classList.add('dd-pdp--snap');
          Object.values(els).forEach((el) => el.classList.remove('in', 'press'));
          atc.classList.remove('pressed');
          // force reflow so the snap (no-transition) reset applies before replaying
          void pdp.offsetWidth;
          pdp.classList.remove('dd-pdp--out', 'dd-pdp--snap');
        } },
    ];
    const CYCLE = 7900;

    let inView = false;
    let running = false;
    let timers = [];

    const resetScene = () => {
      timers.forEach(clearTimeout);
      timers = [];
      pdp.classList.add('dd-pdp--snap');
      Object.values(els).forEach((el) => el.classList.remove('in', 'press'));
      atc.classList.remove('pressed');
      // force reflow so the snap (no-transition) reset applies before replaying
      void pdp.offsetWidth;
      pdp.classList.remove('dd-pdp--out', 'dd-pdp--snap');
    };
    const syncStatic = () => {
      if (prefersReduced()) {
        resetScene();
        pdp.setAttribute('data-static', 'true');
        running = false;
      } else {
        pdp.setAttribute('data-static', 'false');
      }
    };
    syncStatic();

    const runCycle = () => {
      if (!inView || document.hidden || prefersReduced()) {
        running = false;
        return;
      }
      running = true;
      positionCursor();
      timers = STEPS.map((step) =>
        setTimeout(() => {
          if (step.els) step.els.forEach((k) => els[k]?.classList.add('in'));
          if (step.fn) step.fn();
        }, step.t)
      );
      timers.push(setTimeout(runCycle, CYCLE));
    };
    const maybeStart = () => {
      if (!running && inView && !document.hidden && !prefersReduced()) runCycle();
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            inView = entry.isIntersecting;
            maybeStart();
          });
        },
        { threshold: 0.25 }
      );
      io.observe(scene);
    } else {
      inView = true;
      maybeStart();
    }
    document.addEventListener('visibilitychange', maybeStart);
    onMotionPrefChange(() => {
      syncStatic();
      maybeStart();
    });
  });

  /* ───── Pillar 3: motion stage ───── */
  onReady(() => {
    const stage = document.getElementById('ddStage');
    const replay = document.getElementById('ddStageReplay');
    if (!stage) return;

    const counters = stage.querySelectorAll('[data-count]');
    const animateCounters = () => {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.count || '0', 10);
        if (prefersReduced()) {
          el.textContent = target.toLocaleString('en-US');
          return;
        }
        const dur = 1400;
        const start = performance.now();
        const tick = (now) => {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * eased).toLocaleString('en-US');
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    };
    const play = () => {
      stage.classList.remove('play');
      // force reflow so re-adding .play restarts the CSS animations
      void stage.offsetWidth;
      stage.classList.add('play');
      animateCounters();
    };

    if (prefersReduced()) {
      // markup already shows final values; CSS lands .play in its end state
      stage.classList.add('play');
    } else if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              play();
              io.unobserve(stage);
            }
          });
        },
        { threshold: 0.35 }
      );
      io.observe(stage);
    } else {
      play();
    }
    if (replay) replay.addEventListener('click', play);
  });

  /* ───── Case study stat counters ───── */
  onReady(() => {
    const counts = document.querySelectorAll('.dd-count');
    if (!counts.length) return;
    const animate = (el) => {
      const target = parseInt(el.dataset.count || '0', 10);
      const dur = 1300;
      const start = performance.now();
      const tick = (now) => {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(target * eased));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    // markup already contains the final values (no-JS, screen readers, reduced motion)
    if (!('IntersectionObserver' in window) || prefersReduced()) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    counts.forEach((el) => io.observe(el));
  });
</script>
