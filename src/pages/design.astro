---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const clients = [
  'LIVE HEALTHILLIE',
  'PULSEFX',
  'INOKI BATHHOUSE',
  'SUKOSHI MART',
  'STAYGOLDEN',
  'HAIR STRONG',
  'FOUR THREE SEVEN',
  'STEP SCIENCES',
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Design & Development',
  serviceType: 'Web design, development, and product motion',
  url: 'https://www.aquifergrowth.com/design/',
  description:
    'The design and development arm of AquiferGrowth. Product pages that convert, storefronts on Shopify, Webflow, or custom code, and product motion that sells.',
  provider: {
    '@type': 'Organization',
    name: 'AquiferGrowth',
    url: 'https://www.aquifergrowth.com',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Design & Development Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Web Design & Build', description: 'Shopify, Webflow, and custom-code storefronts and marketing sites, designed and built end to end.' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Product & UX Design', description: 'PDP redesigns, design systems, and UX and accessibility audits that remove the reasons buyers hesitate.' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Product Motion & Interactive Content', description: 'Hero animations, feature videos, and embedded interactive demos for SaaS and product launches.' },
      },
    ],
  },
};
---

<Layout
  title="Web Design, Development & Product Motion | AquiferGrowth"
  description="The design & development arm of AquiferGrowth. Product pages that convert, storefronts on Shopify or custom code, and product motion that sells."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <noscript slot="head">
    <style>
      .dd-reveal { opacity: 1 !important; transform: none !important; }
      .dd-stage__line { stroke-dashoffset: 0 !important; }
      .dd-stage__area { opacity: 1 !important; }
      .dd-stage__toast { opacity: 1 !important; transform: none !important; }
      .dd-stage__replay { display: none !important; }
    </style>
  </noscript>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 1. HERO                                     -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-hero">
      <div class="dd-hero__bg-blur"></div>
      <div class="dd-hero__bg-blur dd-hero__bg-blur--right"></div>
      <div class="dd-hero__inner container">

        <div class="dd-hero__copy">
          <span class="badge">AquiferGrowth · Design &amp; Development</span>
          <h1 class="dd-hero__title">
            Show, don't <br /><span class="text-gradient">screenshot.</span>
          </h1>
          <p class="dd-hero__subtitle">
            We design, build, and animate the surfaces where your product sells —
            product pages that convert, storefronts that feel alive, and demos
            people actually watch.
          </p>
          <div class="dd-hero__cta-row">
            <a href="/contact" class="ec-btn ec-btn--hero">
              <span>Book a call</span>
              <span class="ec-animated-dots"><span></span><span></span><span></span></span>
            </a>
          </div>
        </div>

        <div class="dd-hero__stage">
          <div class="dd-browser" id="ddHeroScene">
            <div class="dd-browser__bar" aria-hidden="true">
              <span class="dd-browser__dot dd-browser__dot--r"></span>
              <span class="dd-browser__dot dd-browser__dot--y"></span>
              <span class="dd-browser__dot dd-browser__dot--g"></span>
              <span class="dd-browser__url">livehealthillie.com/products/minerals-chill</span>
              <span class="dd-browser__cart">
                <span class="dd-browser__cart-bag"></span>
                <span class="dd-browser__cart-badge dd-el" data-el="cartbadge">1</span>
              </span>
            </div>
            <div class="dd-pdp" data-static="true" aria-hidden="true">
              <div class="dd-pdp__media dd-el" data-el="media">
                <span class="dd-pdp__chip">Best Seller</span>
                <div class="dd-packet">
                  <span class="dd-packet__crimp"></span>
                  <span class="dd-packet__brand">Live Healthillie</span>
                  <span class="dd-packet__title">Minerals<br />&amp; Chill</span>
                  <span class="dd-packet__flavor">Tropical Punch</span>
                  <span class="dd-packet__fruit"></span>
                  <span class="dd-packet__crimp dd-packet__crimp--bottom"></span>
                  <span class="dd-packet__shadow"></span>
                </div>
                <div class="dd-pdp__thumbs">
                  <span></span><span></span><span></span>
                </div>
              </div>
              <div class="dd-pdp__info">
                <p class="dd-pdp__brand dd-el" data-el="brand">Live Healthillie</p>
                <p class="dd-pdp__name dd-el" data-el="name">Minerals &amp; Chill — Stick Packs</p>
                <p class="dd-pdp__stars dd-el" data-el="stars"><span>★★★★★</span> 4.7 · 275 reviews</p>
                <p class="dd-pdp__price dd-el" data-el="price">$44.99 <s>$49.99</s></p>
                <div class="dd-pdp__variants dd-el" data-el="variants">
                  <span class="is-selected">Orange</span>
                  <span>Lemon Lime</span>
                  <span>Tropical Punch</span>
                </div>
                <div class="dd-pdp__atc dd-el" data-el="atc">Add to cart</div>
                <p class="dd-pdp__meta dd-el" data-el="meta">Subscribe &amp; save 10% · Free shipping over $125</p>
              </div>
              <div class="dd-pdp__toast dd-el" data-el="toast">✓ Added to cart</div>
              <div class="dd-cursor dd-el" data-el="cursor">
                <svg viewBox="0 0 24 24" width="22" height="22">
                  <path d="M5 3l14 8.5-6.1 1.3L10.5 19 5 3z" fill="#1A1A1A" stroke="#fff" stroke-width="1.5" />
                </svg>
              </div>
            </div>
          </div>
          <p class="dd-hero__caption">
            Not a video. Built in code, animated by hand — like everything on this page.
          </p>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 2. PROOF STRIP                              -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-logos" aria-label="Brands we work with">
      <div class="container">
        <p class="dd-logos__label">Trusted by brands that ship</p>
      </div>
      <div class="dd-logos__marquee" tabindex="0" aria-label="Client list — focus or hover to pause scrolling">
        <ul class="dd-logos__track">
          {[...clients, ...clients].map((c, i) => <li aria-hidden={i >= clients.length ? 'true' : undefined}>{c}</li>)}
        </ul>
        <ul class="dd-logos__track" aria-hidden="true">
          {[...clients, ...clients].map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 3. PILLAR 1 — WEB DESIGN & BUILD            -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-pillar">
      <div class="container">
        <div class="dd-sheet dd-pillar__sheet dd-reveal">
          <div class="dd-pillar__grid">
            <div class="dd-pillar__text">
              <p class="dd-eyebrow">01 · Web Design &amp; Build</p>
              <h2 class="dd-h2">Designed to convert. <span class="text-gradient">Built to last.</span></h2>
              <p class="dd-body">
                Shopify, Webflow, or fully custom code — we design and build the
                whole surface, from first wireframe to production deploy. Fast
                pages, clean handoff, and a codebase your next developer will
                thank you for.
              </p>
              <div class="dd-chips">
                <span>Shopify</span><span>Webflow</span><span>Custom code</span>
              </div>
              <p class="dd-proofline">
                Latest ship for Live Healthillie: a subscription loyalty portal built inside Recharge — a closed platform that doesn't natively run custom code.
              </p>
            </div>
            <div class="dd-pillar__visual">
              <div class="dd-p1scene" aria-hidden="true">
                <div class="dd-code">
                  <div class="dd-code__line" style="--i: 0"><span class="dd-code__fill"><i class="k">&lt;header</i> <i class="a">class</i>=<i class="s">"nav"</i><i class="k">&gt;</i></span></div>
                  <div class="dd-code__line" style="--i: 1"><span class="dd-code__fill"><i class="k">&lt;section</i> <i class="a">class</i>=<i class="s">"hero"</i><i class="k">&gt;</i></span></div>
                  <div class="dd-code__line" style="--i: 2"><span class="dd-code__fill">&nbsp;&nbsp;<i class="k">&lt;ProductCard</i> <i class="a">sku</i>=<i class="s">"01"</i> <i class="k">/&gt;</i></span></div>
                  <div class="dd-code__line" style="--i: 3"><span class="dd-code__fill">&nbsp;&nbsp;<i class="k">&lt;ProductCard</i> <i class="a">sku</i>=<i class="s">"02"</i> <i class="k">/&gt;</i></span></div>
                  <div class="dd-code__line" style="--i: 4"><span class="dd-code__fill"><i class="k">&lt;footer</i><i class="k">&gt;</i> <i class="c">// ship it</i></span></div>
                </div>
                <div class="dd-store">
                  <div class="dd-store__block dd-store__nav" style="--i: 0"></div>
                  <div class="dd-store__block dd-store__hero" style="--i: 1"><span></span></div>
                  <div class="dd-store__row">
                    <div class="dd-store__block dd-store__card" style="--i: 2"><b></b><span></span></div>
                    <div class="dd-store__block dd-store__card" style="--i: 3"><b></b><span></span></div>
                    <div class="dd-store__block dd-store__card" style="--i: 3"><b></b><span></span></div>
                  </div>
                  <div class="dd-store__block dd-store__footer" style="--i: 4"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 4. PILLAR 2 — PRODUCT & UX DESIGN           -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-pillar">
      <div class="container">
        <div class="dd-sheet dd-pillar__sheet dd-reveal">
          <div class="dd-pillar__grid dd-pillar__grid--flip">
            <div class="dd-pillar__text">
              <p class="dd-eyebrow">02 · Product &amp; UX Design</p>
              <h2 class="dd-h2">Product pages that <span class="text-gradient">pull their weight.</span></h2>
              <p class="dd-body">
                PDP redesigns, design systems, UX and accessibility audits. We
                find where buyers hesitate — then remove the reason. Every
                recommendation tied to a number, not a mood board.
              </p>
              <p class="dd-proofline">
                Minerals &amp; Chill PDP for Live Healthillie: ~42% more add-to-carts, ~47% more completed checkouts in the first 60 days.
              </p>
            </div>
            <div class="dd-pillar__visual">
              <div class="dd-ba" aria-hidden="true">
                <div class="dd-ba__panel dd-ba__panel--before">
                  <span class="dd-ba__tag">Before</span>
                  <div class="dd-ba__before-img"></div>
                  <div class="dd-ba__lines">
                    <i></i><i></i><i></i><i></i><i></i><i></i>
                  </div>
                  <div class="dd-ba__tinybtn">Buy</div>
                </div>
                <div class="dd-ba__panel dd-ba__panel--after">
                  <span class="dd-ba__tag dd-ba__tag--after">After</span>
                  <div class="dd-ba__after-grid">
                    <div class="dd-ba__after-img"></div>
                    <div class="dd-ba__after-info">
                      <i class="dd-ba__t1"></i>
                      <i class="dd-ba__t2"></i>
                      <div class="dd-ba__pills"><span></span><span></span></div>
                      <div class="dd-ba__bigbtn">Add to cart</div>
                      <p class="dd-ba__trust">✓ 4.9★ · Free returns</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 5. PILLAR 3 — PRODUCT MOTION & INTERACTIVE  -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-pillar">
      <div class="container">
        <div class="dd-sheet dd-pillar__sheet dd-reveal">
          <div class="dd-pillar__grid">
            <div class="dd-pillar__text">
              <p class="dd-eyebrow">03 · Product Motion &amp; Interactive</p>
              <h2 class="dd-h2">Demos people <span class="text-gradient">actually watch.</span></h2>
              <p class="dd-body">
                Hero animations, feature videos, and interactive embeds for SaaS
                and product launches. Your product explained in seconds — in
                motion, in the browser, not in a 40-slide deck.
              </p>
              <p class="dd-proofline">
                Proof? You're looking at it. Every animation on this page was hand-built in code.
              </p>
            </div>
            <div class="dd-pillar__visual">
              <div class="dd-stagewrap">
                <div class="dd-stage" id="ddStage" aria-hidden="true">
                  <div class="dd-stage__head">
                    <p class="dd-stage__title">Launch dashboard</p>
                    <span class="dd-stage__live"><i></i>Live</span>
                  </div>
                  <div class="dd-stage__kpis">
                    <div class="dd-stage__kpi">
                      <span class="dd-stage__kpi-label">Trials</span>
                      <span class="dd-stage__kpi-num" data-count="1284">1,284</span>
                    </div>
                    <div class="dd-stage__kpi">
                      <span class="dd-stage__kpi-label">Conversion</span>
                      <span class="dd-stage__kpi-num"><span data-count="38">38</span>%</span>
                    </div>
                  </div>
                  <div class="dd-stage__chart">
                    <svg viewBox="0 0 280 90" preserveAspectRatio="none">
                      <line x1="0" y1="30" x2="280" y2="30" class="dd-stage__grid" />
                      <line x1="0" y1="60" x2="280" y2="60" class="dd-stage__grid" />
                      <path class="dd-stage__area" d="M0,78 C40,74 60,66 90,58 C120,50 150,54 180,38 C210,24 240,20 280,10 L280,90 L0,90 Z" />
                      <path class="dd-stage__line" d="M0,78 C40,74 60,66 90,58 C120,50 150,54 180,38 C210,24 240,20 280,10" />
                    </svg>
                  </div>
                  <div class="dd-stage__toast">↑ Trial signups up 38% this week</div>
                </div>
                <button type="button" class="dd-stage__replay" id="ddStageReplay" aria-hidden="true" tabindex="-1">
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M12 5V1L7 6l5 5V7a5 5 0 1 1-5 5H5a7 7 0 1 0 7-7z" fill="currentColor"/></svg>
                  Replay
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 6. FEATURED CASE STUDY — LIVE HEALTHILLIE   -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-case">
      <div class="container">
        <div class="dd-case__sheet dd-reveal">
          <p class="dd-eyebrow dd-eyebrow--ondark">Featured work · Live Healthillie</p>
          <h2 class="dd-h2 dd-h2--ondark">One product page. <span class="text-gradient">Two numbers that moved.</span></h2>

          <div class="dd-case__media">
            <figure class="dd-case__media-item dd-case__media-item--product">
              <img
                src="/images/design/mc-product-dark.jpg"
                alt="Minerals & Chill stick pack — Live Healthillie's hero product"
                width="900"
                height="1125"
                loading="lazy"
              />
            </figure>
            <figure class="dd-case__media-item dd-case__media-item--ui">
              <img
                src="/images/design/mc-buybox.webp"
                alt="The rebuilt Minerals & Chill buy box: flavor selector, subscribe-and-save purchase options, and add to cart"
                width="1000"
                height="1288"
                loading="lazy"
              />
            </figure>
          </div>

          <div class="dd-case__beats">
            <div class="dd-case__beat">
              <p class="dd-case__beat-label">The problem</p>
              <p class="dd-case__beat-body">
                Minerals &amp; Chill is Live Healthillie's hero product — the
                SKU that drives subscriptions, wholesale, and loyalty. It was
                selling on the same generic template as every other product in
                the catalog: no flavor merchandising, no dedicated social
                proof, and variant imagery slowing down the store's
                most-trafficked page.
              </p>
            </div>
            <div class="dd-case__beat">
              <p class="dd-case__beat-label">The build</p>
              <p class="dd-case__beat-body">
                We prototyped the page in Figma, got sign-off, then gave the
                hero SKU its own PDP template on Shopify Plus — flavor
                swatches, promo messaging under the price, filterable reviews,
                quick-add straight into the cart tray — with variant assets
                moved to a CDN. Shipped without touching the rest of the
                catalog.
              </p>
            </div>
            <div class="dd-case__beat">
              <p class="dd-case__beat-label">The result</p>
              <div class="dd-case__stats">
                <div class="dd-case__stat">
                  <span class="dd-case__stat-num">+<span class="dd-count" data-count="42">42</span>%</span>
                  <span class="dd-case__stat-label">add-to-carts</span>
                </div>
                <div class="dd-case__stat">
                  <span class="dd-case__stat-num">+<span class="dd-count" data-count="47">47</span>%</span>
                  <span class="dd-case__stat-label">completed checkouts</span>
                </div>
                <p class="dd-case__stat-note">First 60 days live vs. the 60 days prior.</p>
              </div>
            </div>
          </div>

          <figure class="dd-case__quote">
            <blockquote>
              “AquiferGrowth owns our design and development initiatives and has
              been a true extension of our team. They handle it all so we don't
              have to — and the quality of the work consistently reflects that
              level of ownership.”
            </blockquote>
            <figcaption>Matt Balaj — CEO, Live Healthillie</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 7. HOW WE WORK                              -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-work">
      <div class="container">
        <div class="dd-sheet dd-reveal">
          <div class="section-header">
            <span class="badge">How we work</span>
            <h2 class="dd-h2">Two ways to <span class="text-gradient">plug us in.</span></h2>
          </div>
          <div class="dd-work__grid">
            <div class="dd-work__card">
              <p class="dd-eyebrow">Project</p>
              <h3 class="dd-work__title">Scoped. Shipped. Yours.</h3>
              <p class="dd-body">
                A defined build with a start, an end, and a deliverable you own —
                a new storefront, a PDP redesign, a launch site, a demo.
              </p>
              <ul class="dd-work__list">
                <li>Fixed scope, quoted up front</li>
                <li>Discovery → design → build → handoff</li>
                <li>You own every file and every pixel</li>
              </ul>
            </div>
            <div class="dd-work__card">
              <p class="dd-eyebrow">Embedded</p>
              <h3 class="dd-work__title">Your design &amp; dev team, without the hire.</h3>
              <p class="dd-body">
                A monthly retainer for brands that ship constantly — design,
                development, and motion on tap, the same embedded model
                AquiferGrowth runs operations with.
              </p>
              <ul class="dd-work__list">
                <li>Standing monthly capacity</li>
                <li>One Slack channel, no ticket queue</li>
                <li>Scales with your roadmap</li>
              </ul>
            </div>
          </div>
          <div class="dd-work__cta">
            <p class="dd-work__cta-note">Not sure which fits? That's what the call is for.</p>
            <a href="/contact" class="ec-btn ec-btn--hero">
              <span>Book a call</span>
              <span class="ec-animated-dots"><span></span><span></span><span></span></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 8. ABOUT / WHO YOU WORK WITH                -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-about">
      <div class="container">
        <div class="dd-about__inner dd-reveal">
          <p class="dd-eyebrow">The team</p>
          <h2 class="dd-h2">Small team. <span class="text-gradient">Senior work.</span></h2>
          <p class="dd-body dd-about__body">
            The design &amp; development arm of AquiferGrowth is led by Ashwin,
            Head of Design &amp; Development, with a team of developers behind
            him. We work with Shopify and DTC brands — and SaaS founders who
            need product motion — most of whom were sent here by someone we've
            already shipped for.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 9. FINAL CTA                                -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="ec-inline-cta-section dd-final" aria-label="Book a call">
      <div class="container">
        <div class="ec-inline-cta dd-reveal">
          <p class="ec-inline-cta__lead">
            We design, build, and animate<br />
            <span class="text-gradient">the surfaces where your product sells.</span>
          </p>
          <p class="dd-final__note">If someone sent you here, you've already seen the work. Let's talk about yours.</p>
          <a href="/contact" class="ec-btn ec-btn--hero">
            <span>Book a call</span>
            <span class="ec-animated-dots"><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  main { overflow-x: hidden; }

  /* ───── Shared text-gradient ───── */
  .text-gradient {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  /* ───── Section header / badge (house pattern) ───── */
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .badge {
    background: #1A1A1A;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-indent: 0.12em;
    display: inline-block;
  }

  /* ───── Primary CTA (matches ecommerce page) ───── */
  .ec-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    background: #FF7A7A;
    color: #1A1A1A;
    padding: 0.9rem 1.5rem;
    border: 2px solid #000;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: none;
    text-decoration: none;
    letter-spacing: -0.005em;
    box-shadow: 4px 4px 0 #000;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                box-shadow 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                background 0.2s ease;
  }
  .ec-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
    background: #ff9d9d;
  }
