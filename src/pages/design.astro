    pointer-events: none;
  }
  /* high specificity so cursor motion beats the generic .dd-pdp .dd-el reveal rules */
  .dd-pdp .dd-el.dd-cursor {
    transform: translate(70px, 90px);
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }
  .dd-pdp .dd-el.dd-cursor.in { transform: translate(0, 0); opacity: 1; }
  .dd-pdp .dd-el.dd-cursor.press { transform: translate(0, 0) scale(0.85); }

  /* Static fallback (reduced motion / no JS): show assembled PDP */
  .dd-pdp[data-static="true"] .dd-el { opacity: 1; transform: none; transition: none; }
  .dd-pdp[data-static="true"] .dd-el.dd-cursor,
  .dd-pdp[data-static="true"] .dd-el.dd-pdp__toast { opacity: 0; transform: none; transition: none; }

  /* ═══════ 2. PROOF STRIP ═══════ */
  .dd-logos { padding: 1.5rem 0 3.5rem; }
  .dd-logos__label {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.6rem;
  }
  .dd-logos__marquee {
    display: flex;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);
  }
  .dd-logos__track {
    display: flex;
    align-items: center;
    gap: 4rem;
    padding-right: 4rem;
    flex-shrink: 0;
    min-width: max-content;
    list-style: none;
    margin: 0;
    animation: dd-marquee 42s linear infinite;
  }
  .dd-logos__marquee:hover .dd-logos__track,
  .dd-logos__marquee:focus-within .dd-logos__track,
  .dd-logos__marquee:focus-visible .dd-logos__track { animation-play-state: paused; }
  .dd-logos__marquee:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .dd-logos__track li {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  @keyframes dd-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dd-logos__track { animation: none; flex-wrap: wrap; justify-content: center; min-width: 0; row-gap: 1rem; }
    .dd-logos__track[aria-hidden="true"] { display: none; }
    .dd-logos__marquee { -webkit-mask-image: none; mask-image: none; }
  }

  /* ═══════ 3-5. PILLARS ═══════ */
  .dd-pillar { padding: 1.75rem 0; }
  .dd-pillar__grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 3rem;
    align-items: center;
  }
  .dd-pillar__grid--flip .dd-pillar__text { order: 2; }
  .dd-pillar__grid--flip .dd-pillar__visual { order: 1; }
  .dd-pillar__visual { min-width: 0; }

  /* ── Pillar 1: code → storefront ── */
  .dd-p1scene {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 0.9rem;
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 18px;
    padding: 1rem;
  }
  .dd-code {
    background: #1d1d1f;
    border-radius: 12px;
    padding: 1rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    overflow: hidden;
  }
  .dd-code__line { min-height: 0.9rem; }
  .dd-code__fill {
    display: inline-block;
    white-space: nowrap;
    overflow: hidden;
    vertical-align: top;
    max-width: 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1.4;
    color: #d8d4cb;
    animation: dd-type 9s cubic-bezier(0.3, 0, 0.6, 1) infinite;
    animation-delay: calc(var(--i) * 1s + 0.2s);
  }
  .dd-code__fill i { font-style: normal; }
  .dd-code__fill .k { color: #ff8aa1; }
  .dd-code__fill .a { color: #ffc98a; }
  .dd-code__fill .s { color: #9ee09e; }
  .dd-code__fill .c { color: #7a7a80; }
  @keyframes dd-type {
    0% { max-width: 0; opacity: 1; }
    8% { max-width: 220px; opacity: 1; }
    82% { max-width: 220px; opacity: 1; }
    90% { max-width: 220px; opacity: 0; }
    100% { max-width: 0; opacity: 0; }
  }
  .dd-store {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 12px;
    padding: 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .dd-store__block {
    opacity: 0;
    animation: dd-build 9s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    animation-delay: calc(var(--i) * 1s + 0.75s);
    border-radius: 7px;
  }
  .dd-store__nav { height: 14px; background: #f0ede4; }
  .dd-store__hero {
    height: 52px;
    background: linear-gradient(135deg, #ffe3d5, #ffd9e2);
    display: flex;
    align-items: center;
    padding-left: 0.6rem;
  }
  .dd-store__hero span { width: 42%; height: 6px; border-radius: 3px; background: rgba(26, 26, 26, 0.75); }
  .dd-store__row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.55rem; }
  .dd-store__card {
    height: 58px;
    background: #faf8f2;
    border: 1px solid rgba(0, 0, 0, 0.06);
    padding: 0.4rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 4px;
  }
  .dd-store__card b { display: block; flex: 1; border-radius: 4px; background: linear-gradient(150deg, #ffe9dd, #ffdce5); }
  .dd-store__card span { display: block; width: 70%; height: 4px; border-radius: 2px; background: #d9d2c4; }
  .dd-store__footer { height: 12px; background: #1a1a1a; opacity: 0; }
  @keyframes dd-build {
    0% { opacity: 0; transform: translateY(8px); }
    5% { opacity: 1; transform: translateY(0); }
    82% { opacity: 1; transform: translateY(0); }
    90% { opacity: 0; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dd-code__fill { animation: none; max-width: 220px; }
    .dd-store__block { animation: none; opacity: 1; }
  }

  /* ── Pillar 2: before / after ── */
  .dd-ba {
    position: relative;
    display: grid;
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 18px;
    overflow: hidden;
    min-height: 300px;
  }
  .dd-ba__panel {
    grid-area: 1 / 1;
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    animation: dd-ba-a 10s ease-in-out infinite;
  }
  .dd-ba__panel--after { animation-name: dd-ba-b; display: flex; justify-content: center; }
  @keyframes dd-ba-a {
