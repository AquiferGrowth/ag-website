---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hello World | AG-Website">
	<main class="container" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center;">
		<div class="glass animate-fade-in" style="padding: var(--space-xl); max-width: 600px;">
			<h1 style="font-size: 4rem; margin-bottom: var(--space-md);">Hello World! 🚀</h1>
			<p style="font-size: 1.5rem; color: var(--text-secondary); margin-bottom: var(--space-lg);">
				The new AG-Website is alive and kicking.
			</p>
			<a href="/" class="btn-primary" style="padding: 1rem 2rem; border-radius: 8px; font-weight: 600; background: var(--accent-primary); color: white;">Back Home</a>
		</div>
	</main>
</Layout>
