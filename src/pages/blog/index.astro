---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect unique categories
const allCategories = ['All', ...new Set(allPosts.map(p => p.data.category).filter(Boolean))] as string[];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			body {
				background-color: var(--bg-primary);
			}
			.blog-hero {
				text-align: center;
				padding: var(--space-xl) 0 var(--space-md);
			}
			.blog-hero .badge {
				display: inline-block;
				background: var(--bg-dark);
				color: var(--text-on-dark);
				padding: 0.4rem 1.1rem;
				border-radius: var(--radius-pill);
				font-size: 0.72rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: var(--space-sm);
			}
			.blog-hero h1 {
				font-size: clamp(2.5rem, 6vw, 4.5rem);
				margin: 0 0 var(--space-sm);
			}
			.blog-hero p {
				color: var(--text-secondary);
				font-size: 1.1rem;
				max-width: 560px;
				margin: 0 auto;
			}

			/* Category filter tabs */
			.category-filters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				justify-content: center;
				padding: var(--space-md) 0 var(--space-lg);
			}
			.filter-btn {
				padding: 0.5rem 1.25rem;
				border-radius: var(--radius-pill);
				border: 2px solid var(--border-color);
				background: transparent;
				color: var(--text-primary);
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				cursor: pointer;
				transition: var(--transition-fast);
			}
			.filter-btn:hover,
			.filter-btn.active {
				background: var(--accent-primary);
				border-color: var(--accent-primary);
				color: white;
			}

			/* Post grid */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1.75rem;
				padding-bottom: var(--space-xl);
			}
			.post-card {
				background: var(--bg-secondary);
				border: 2px solid var(--border-color);
				border-radius: var(--radius-lg);
				overflow: hidden;
				display: flex;
				flex-direction: column;
				transition: var(--transition-fast);
				text-decoration: none;
				color: inherit;
			}
			.post-card:hover {
				transform: translateY(-6px) rotate(-0.5deg);
				box-shadow: 8px 8px 0px var(--border-color);
				border-color: var(--accent-primary);
			}
			.post-card img {
				width: 100%;
				height: 200px;
				object-fit: cover;
				display: block;
			}
			.post-card-img-placeholder {
				width: 100%;
				height: 200px;
				background: var(--bg-dark);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3rem;
				color: var(--accent-primary);
			}
			.post-card-body {
				padding: 1.25rem 1.5rem 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				flex: 1;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				flex-wrap: wrap;
			}
			.post-category {
				display: inline-block;
				background: var(--accent-primary);
				color: white;
				padding: 0.2rem 0.75rem;
				border-radius: var(--radius-pill);
				font-size: 0.65rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
			.post-date {
				color: var(--text-secondary);
				font-size: 0.8rem;
				font-weight: 600;
			}
			.post-title {
				font-family: var(--font-display);
				font-size: 1.3rem;
				font-weight: 900;
				line-height: 1.2;
				color: var(--text-primary);
				margin: 0;
			}
			.post-description {
				color: var(--text-secondary);
				font-size: 0.9rem;
				line-height: 1.5;
				margin: 0;
			}
			.read-more {
				margin-top: auto;
				padding-top: 0.75rem;
				font-weight: 700;
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--accent-primary);
			}

			/* hidden by JS filter */
			.post-card-wrapper[hidden] { display: none; }

			@media (max-width: 600px) {
				.posts-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="container">
			<div class="blog-hero animate-fade-in">
				<div class="badge">Latest Insights</div>
				<h1>The <span style="color: var(--accent-primary)">Blog</span></h1>
				<p>Thoughts on growth, AI, design, and building in public.</p>
			</div>

			<!-- Category filter buttons -->
			<div class="category-filters" id="category-filters">
				{allCategories.map((cat, i) => (
					<button
						class={`filter-btn${i === 0 ? ' active' : ''}`}
						data-category={cat}
					>{cat}</button>
				))}
			</div>

			<!-- Posts grid -->
			<div class="posts-grid" id="posts-grid">
				{allPosts.map((post) => {
					const iconMap = {
						'Growth': '📈',
						'AI & Automation': '🤖',
						'Design': '🎨',
						'Dev': '💻',
						'Strategy': '♟️',
					};
					const icon = post.data.category ? (iconMap[post.data.category] ?? '📝') : '📝';
					return (
						<div class="post-card-wrapper" data-category={post.data.category ?? ''}>
							<a href={`/blog/${post.id}/`} class="post-card">
								{post.data.heroImage
									? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
									: <div class="post-card-img-placeholder">{icon}</div>
								}
								<div class="post-card-body">
									<div class="post-meta">
										{post.data.category && <span class="post-category">{post.data.category}</span>}
										<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-description">{post.data.description}</p>
									<span class="read-more">Read more →</span>
								</div>
							</a>
						</div>
					);
				})}
			</div>
		</main>
		<Footer />

		<script>
			const filterBtns = document.querySelectorAll('.filter-btn');
			const cards = document.querySelectorAll('.post-card-wrapper');

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					filterBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					const selected = btn.dataset.category;
					cards.forEach(card => {
						const matches = selected === 'All' || card.dataset.category === selected;
						card.hidden = !matches;
					});
				});
			});
		</script>
	</body>
</html>
