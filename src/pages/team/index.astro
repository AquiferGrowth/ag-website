---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const members = (await getCollection('team')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<Layout title={`Team — ${SITE_TITLE}`} description="Meet the people behind Aquifer Growth.">
  <Header />
  <main class="container">
    <div class="team-hero animate-fade-in">
      <div class="badge">The People</div>
      <h1>Meet the <span style="color: var(--accent-primary)">Team</span></h1>
      <p>A small, focused group obsessed with performance, design, and results.</p>
    </div>

    <div class="team-grid">
      {members.map((member) => (
        <div class="member-card">
          <div class="member-photo">
            {member.data.photo
              ? <img src={member.data.photo} alt={member.data.name} />
              : <div class="photo-placeholder">{member.data.name[0]}</div>
            }
          </div>
          <div class="member-info">
            <h3>{member.data.name}</h3>
            <p class="member-role">{member.data.role}</p>
            <p class="member-bio">{member.data.bio}</p>
            <div class="member-links">
              {member.data.twitter && (
                <a href={member.data.twitter} target="_blank" rel="noopener" class="social-link">
                  𝕏 Twitter
                </a>
              )}
              {member.data.linkedin && (
                <a href={member.data.linkedin} target="_blank" rel="noopener" class="social-link">
                  in LinkedIn
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .team-hero {
    text-align: center;
    padding: var(--space-xl) 0 var(--space-lg);
  }
  .team-hero .badge {
    display: inline-block;
    background: var(--bg-dark);
    color: var(--text-on-dark);
    padding: 0.4rem 1.1rem;
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }
  .team-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0 0 var(--space-sm);
  }
  .team-hero p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding-bottom: var(--space-xl);
  }

  .member-card {
    background: var(--bg-secondary);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: var(--transition-fast);
  }
  .member-card:hover {
    transform: translateY(-6px);
    border-color: var(--accent-primary);
    box-shadow: 6px 6px 0 var(--border-color);
  }

  .member-photo img,
  .photo-placeholder {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }
  .photo-placeholder {
    background: var(--bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 5rem;
    font-weight: 900;
    color: var(--accent-primary);
  }

  .member-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .member-info h3 {
    font-size: 1.4rem;
    margin: 0;
  }
  .member-role {
    color: var(--accent-primary);
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }
  .member-bio {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0.25rem 0;
  }
  .member-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .social-link {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    border: 2px solid var(--border-color);
    transition: var(--transition-fast);
    color: var(--text-primary);
  }
  .social-link:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }
</style>
