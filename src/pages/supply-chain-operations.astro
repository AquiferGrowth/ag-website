---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Supply Chain Operations for Ecommerce Brands | AquiferGrowth"
  description="Forecasting, MRP, procurement, inventory, production, S&OP, risk. Your whole supply chain, run end to end on subscription. Skip the hire, own the function."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- HERO                                        -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="sco-hero">
      <div class="sco-hero__bg-blur"></div>
      <div class="sco-hero__bg-blur sco-hero__bg-blur--right"></div>
      <div class="sco-hero__inner container">
        <div class="sco-hero__copy">
          <h1 class="sco-hero__title">
            We own your supply chain.<br />
            <span class="text-gradient">You own the business.</span>
          </h1>
          <p class="sco-hero__subtitle">
            Forecasting, purchase orders, supplier follow-ups, receiving, counts. We run all of it as a managed service, wired together with automations and AI agents and we own the outcome when something breaks.
          </p>
          <div class="sco-hero__cta-row">
            <a href="/contact" class="sco-btn">
              <span>Let's Chat</span>
              <span class="sco-animated-dots"><span></span><span></span><span></span></span>
            </a>
          </div>
        </div>

        <!-- Ops dashboard mock -->
        <div class="sco-hero__mock" aria-hidden="true">
          <div class="sco-ops-mock">
            <div class="sco-ops-mock__head">
              <span class="sco-ops-mock__live"><span class="sco-ops-mock__live-dot"></span> Supply Chain &middot; Live</span>
              <span class="sco-ops-mock__meta">Synced 2m ago</span>
            </div>
            <div class="sco-ops-mock__stats">
              <div class="sco-ops-mock__stat">
                <span class="sco-ops-mock__stat-label">SKUs tracked</span>
                <span class="sco-ops-mock__stat-val">12,463</span>
              </div>
              <div class="sco-ops-mock__stat">
                <span class="sco-ops-mock__stat-label">Stock on hand</span>
                <span class="sco-ops-mock__stat-val">$482K</span>
              </div>
              <div class="sco-ops-mock__stat">
                <span class="sco-ops-mock__stat-label">Open POs</span>
                <span class="sco-ops-mock__stat-val">14</span>
              </div>
              <div class="sco-ops-mock__stat">
                <span class="sco-ops-mock__stat-label">Locations</span>
                <span class="sco-ops-mock__stat-val">4</span>
              </div>
            </div>
            <div class="sco-ops-mock__alerts">
              <div class="sco-ops-mock__alert sco-ops-mock__alert--ok">
                <span class="sco-ops-mock__alert-mark">&#10003;</span>
                Weekly count reconciled
              </div>
              <div class="sco-ops-mock__alert sco-ops-mock__alert--warn">
                <span class="sco-ops-mock__alert-mark">&#9888;</span>
                2 SKUs approaching reorder point
              </div>
              <div class="sco-ops-mock__alert">
                <span class="sco-ops-mock__alert-mark">&#9679;</span>
                Q4 forecast on track
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 02 · THE REALITY                           -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="sco-section">
      <div class="container">
        <div class="sco-sheet">
          <div class="sco-intro">
            <h2 class="sco-section__title">Nobody owns the supply chain. <span class="text-gradient">So you do.</span></h2>
            <p class="sco-section__subtitle">The 3PL moves boxes. The manufacturer makes product. Nobody reconciles what was ordered against what landed against what's live. That gap has a name on it, and it's yours.</p>
          </div>

          <div class="sco-args">
            <!-- 01 -->
            <article class="sco-arg">
              <div class="sco-arg__viz">
                <div class="sco-viz-files">
                  <div class="sco-viz-file">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span>inventory_FINAL_v4.xlsx</span>
                    <em>12,090?</em>
                  </div>
                  <div class="sco-viz-file">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span>stock_count_AUG(2).csv</span>
                    <em>11,834?</em>
                  </div>
                  <div class="sco-viz-file">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span>counts_v2_USE_THIS.xlsx</span>
                    <em>12,388?</em>
                  </div>
                </div>
              </div>
              <div class="sco-arg__body">
                <div class="sco-arg__num">01</div>
                <h3 class="sco-arg__title">The count never matches.</h3>
                <p class="sco-arg__copy">Three files, three answers. The warehouse guy said close enough. Nobody's numbers are right, and every decision downstream inherits that lie.</p>
              </div>
            </article>

            <!-- 02 -->
            <article class="sco-arg">
              <div class="sco-arg__viz">
                <div class="sco-viz-cal">
                  <div class="sco-viz-cal__row"><span>Sat</span><span>Rebuild the count</span></div>
                  <div class="sco-viz-cal__row"><span>Sun</span><span>Cut next month's POs</span></div>
                  <div class="sco-viz-cal__row sco-viz-cal__row--now"><span>Mon</span><span>Pretend to run the business</span></div>
                </div>
              </div>
              <div class="sco-arg__body">
                <div class="sco-arg__num">02</div>
                <h3 class="sco-arg__title">Sunday night is inventory night.</h3>
                <p class="sco-arg__copy">Your team went home Friday. You spent the weekend on ops. You are not the person who should still be doing this work.</p>
              </div>
            </article>

            <!-- 03 -->
            <article class="sco-arg">
              <div class="sco-arg__viz">
                <div class="sco-viz-order">
                  <div class="sco-viz-order__row">
                    <span class="sco-viz-order__badge sco-viz-order__badge--warn">Oversold</span>
                    <span class="sco-viz-order__sku">Hydration Sticks &middot; Amazon</span>
                  </div>
                  <div class="sco-viz-order__row sco-viz-order__row--refund">
                    <span class="sco-viz-order__lbl">Refund issued</span>
                    <span class="sco-viz-order__amt">$48.60</span>
                  </div>
                  <div class="sco-viz-order__row sco-viz-order__row--refund">
                    <span class="sco-viz-order__lbl">Refund issued</span>
                    <span class="sco-viz-order__amt">$48.60</span>
                  </div>
                  <div class="sco-viz-order__row sco-viz-order__row--refund">
                    <span class="sco-viz-order__lbl">Refund issued</span>
                    <span class="sco-viz-order__amt">$48.60</span>
                  </div>
                </div>
              </div>
              <div class="sco-arg__body">
                <div class="sco-arg__num">03</div>
                <h3 class="sco-arg__title">You're refunding your own store's oversells.</h3>
                <p class="sco-arg__copy">Friday's count didn't make Shopify. Amazon sold three of what wasn't there. Monday morning is apologies. That's not ops, it's a slow leak.</p>
              </div>
            </article>

            <!-- 04 -->
            <article class="sco-arg">
              <div class="sco-arg__viz">
                <div class="sco-viz-forecast">
                  <div class="sco-viz-forecast__label">Q4 &middot; Demand</div>
                  <svg viewBox="0 0 200 90" class="sco-viz-forecast__svg" aria-hidden="true">
                    <defs>
                      <linearGradient id="scoBand" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#FF4D6D" stop-opacity="0.35" />
                        <stop offset="100%" stop-color="#FF4D6D" stop-opacity="0" />
                      </linearGradient>
                    </defs>
                    <polygon points="100,44 200,10 200,70 100,54" fill="url(#scoBand)" />
                    <polyline points="4,66 24,64 44,60 64,58 84,52 100,44" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round"/>
                    <polyline points="100,44 130,30 160,20 196,12" fill="none" stroke="#FF4D6D" stroke-width="2" stroke-dasharray="5 4" stroke-linecap="round"/>
                  </svg>
                  <span class="sco-viz-forecast__q">?</span>
                </div>
              </div>
              <div class="sco-arg__body">
                <div class="sco-arg__num">04</div>
                <h3 class="sco-arg__title">Q4 is a guess.</h3>
                <p class="sco-arg__copy">You're planning peak against three months of data that doesn't reconcile. The plan is instinct plus a prayer. Fine at $2M. Ruinous at $20M.</p>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 03 · THE COST                              -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="sco-section">
      <div class="container">
        <div class="sco-sheet">
          <div class="sco-intro">
            <h2 class="sco-section__title">The cost of <span class="text-gradient">nobody owning it</span>.</h2>
            <p class="sco-section__subtitle">Nobody sends you an invoice for the chaos. It just comes out of margin, cash, and your week.</p>
          </div>
          <div class="sco-cost__stats">
            <div class="sco-cost__stat">
              <div class="sco-cost__stat-title">Cash Trapped</div>
              <div class="sco-cost__stat-num">30<span class="sco-cost__stat-unit">%</span></div>
              <div class="sco-cost__stat-label">That's how much inventory cash typically sleeps in SKUs that won't move, while your bestsellers go dark.</div>
            </div>
            <div class="sco-cost__stat">
              <div class="sco-cost__stat-title">Sales Lost</div>
              <div class="sco-cost__stat-num">90<span class="sco-cost__stat-unit">days</span></div>
              <div class="sco-cost__stat-label">Behind on every stockout the moment you notice it. Lead time doesn't pause while you catch up.</div>
            </div>
            <div class="sco-cost__stat">
              <div class="sco-cost__stat-title">Hours Wasted</div>
              <div class="sco-cost__stat-num">10+<span class="sco-cost__stat-unit">hrs/wk</span></div>
              <div class="sco-cost__stat-label">Founder time lost every week to reconciling counts, chasing POs, and playing the system.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 04 · THE RELIEF                            -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="sco-section">
      <div class="container">
        <div class="sco-sheet">
          <div class="sco-intro">
            <h2 class="sco-section__title">We own the function. <span class="text-gradient">You run the company</span>.</h2>
          </div>

          <div class="sco-relief">
            <div class="sco-relief__card">
              <div class="sco-relief__num">01</div>
              <h3 class="sco-relief__title">You stop reconciling.</h3>
              <p class="sco-relief__copy">One live count across every location and channel. The spreadsheets go in a drawer.</p>
            </div>
            <div class="sco-relief__card sco-relief__card--hero">
              <div class="sco-relief__num">02</div>
              <h3 class="sco-relief__title">You stop forecasting.</h3>
              <p class="sco-relief__copy">Forecasts run against real sell-through. Reorder points move themselves.</p>
            </div>
            <div class="sco-relief__card">
              <div class="sco-relief__num">03</div>
              <h3 class="sco-relief__title">You stop being the system.</h3>
              <p class="sco-relief__copy">Decisions stop routing through you. Exceptions land in one thread, on your schedule.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 05 · THE MACHINE                           -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="sco-section sco-section--caps" id="covered">
      <div class="container">
        <div class="sco-sheet">
          <div class="sco-intro">
            <h2 class="sco-section__title">Every workstream, <span class="text-gradient">owned end to end</span>.</h2>
            <p class="sco-section__subtitle">Eight functions, one team, one cadence. Daily, weekly, and monthly rhythms that keep the operation running so you never have to.</p>
          </div>

          <div class="sco-caps">
            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-flow">
                  <span class="sco-viz-flow__node">Data</span>
                  <span class="sco-viz-flow__arrow">&rarr;</span>
                  <span class="sco-viz-flow__node sco-viz-flow__node--hot">AI Agent</span>
                  <span class="sco-viz-flow__arrow">&rarr;</span>
                  <span class="sco-viz-flow__node">Action</span>
                </div>
              </div>
              <div class="sco-cap__num">01</div>
              <h3 class="sco-cap__title">Strategic Planning &amp; Automation</h3>
              <p class="sco-cap__copy">Supply chain initiatives that cut cost and lift throughput. AI-first workflows across procurement analysis, supply planning scenarios, exception management, and risk monitoring.</p>
              <ul class="sco-cap__list">
                <li>LLM-driven procurement analysis</li>
                <li>Scenario planning &amp; capacity modeling</li>
                <li>Exception dashboards, live</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-po">
                  <div class="sco-viz-po__head">
                    <span class="sco-viz-po__id">PO-4521</span>
                    <span class="sco-viz-po__meta">Receiving</span>
                  </div>
                  <div class="sco-viz-po__row"><span>Ordered</span><b>500</b></div>
                  <div class="sco-viz-po__row"><span>Received</span><b>462</b></div>
                  <div class="sco-viz-po__row sco-viz-po__row--warn"><span>Short</span><b>38</b></div>
                </div>
              </div>
              <div class="sco-cap__num">02</div>
              <h3 class="sco-cap__title">Materials Requirement Planning</h3>
              <p class="sco-cap__copy">Supply planning translated from the approved demand plan into executable POs. Packaging and raw materials land on time, capacity constraints are flagged before they hit.</p>
              <ul class="sco-cap__list">
                <li>PO placement &amp; tracking</li>
                <li>Lead-time variability monitoring</li>
                <li>Shortage &amp; excess auto-flagging</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-supplier">
                  <div class="sco-viz-supplier__row">
                    <span class="sco-viz-supplier__name">Northline</span>
                    <span class="sco-viz-supplier__bar"><span style="width:84%; background:#22c55e;"></span></span>
                    <span class="sco-viz-supplier__grade">A</span>
                  </div>
                  <div class="sco-viz-supplier__row">
                    <span class="sco-viz-supplier__name">Kestrel</span>
                    <span class="sco-viz-supplier__bar"><span style="width:56%; background:#f59e0b;"></span></span>
                    <span class="sco-viz-supplier__grade">B</span>
                  </div>
                  <div class="sco-viz-supplier__row">
                    <span class="sco-viz-supplier__name">Mizuno</span>
                    <span class="sco-viz-supplier__bar"><span style="width:32%; background:#ff4d6d;"></span></span>
                    <span class="sco-viz-supplier__grade">C</span>
                  </div>
                </div>
              </div>
              <div class="sco-cap__num">03</div>
              <h3 class="sco-cap__title">Procurement &amp; Vendor Management</h3>
              <p class="sco-cap__copy">Supplier relationships, sourced and negotiated. Pricing agreements owned, performance measured, risk clustered so you know who to press and who to protect.</p>
              <ul class="sco-cap__list">
                <li>Supplier performance scorecards</li>
                <li>Pricing trend &amp; negotiation insights</li>
                <li>Supplier risk clustering</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-forecast-mini">
                  <div class="sco-viz-forecast-mini__label">Demand &middot; Fleece Hoodie</div>
                  <svg viewBox="0 0 200 60" preserveAspectRatio="none" class="sco-viz-forecast-mini__svg" aria-hidden="true">
                    <defs>
                      <linearGradient id="scoForecastBand" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#FF4D6D" stop-opacity="0.32"/>
                        <stop offset="100%" stop-color="#FF4D6D" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <polygon points="112,32 200,4 200,44 112,50" fill="url(#scoForecastBand)"/>
                    <polyline points="4,48 32,44 60,40 88,36 112,32" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round"/>
                    <polyline points="112,32 140,24 168,14 196,6" fill="none" stroke="#FF4D6D" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round"/>
                    <circle cx="112" cy="32" r="3.5" fill="#1a1a1a"/>
                  </svg>
                  <span class="sco-viz-forecast-mini__badge">Reorder in 12d</span>
                </div>
              </div>
              <div class="sco-cap__num">04</div>
              <h3 class="sco-cap__title">Inventory Management &amp; Forecasting</h3>
              <p class="sco-cap__copy">Levels, forecasting, replenishment strategies. Stockouts down, excess down, working capital freed. Predictive analytics on safety stock and warehouse capacity.</p>
              <ul class="sco-cap__list">
                <li>SKU-level demand vs forecast tracking</li>
                <li>Safety stock &amp; working capital optimization</li>
                <li>Warehouse capacity utilization</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-gantt">
                  <div class="sco-viz-gantt__row">
                    <span class="sco-viz-gantt__lbl">Line A</span>
                    <span class="sco-viz-gantt__track"><span class="sco-viz-gantt__fill" style="left:8%; width:42%; background:#3b82f6;"></span></span>
                  </div>
                  <div class="sco-viz-gantt__row">
                    <span class="sco-viz-gantt__lbl">Line B</span>
                    <span class="sco-viz-gantt__track"><span class="sco-viz-gantt__fill" style="left:26%; width:52%; background:#8b5cf6;"></span></span>
                  </div>
                  <div class="sco-viz-gantt__row">
                    <span class="sco-viz-gantt__lbl">Line C</span>
                    <span class="sco-viz-gantt__track"><span class="sco-viz-gantt__fill" style="left:48%; width:40%; background:#f59e0b;"></span></span>
                  </div>
                </div>
              </div>
              <div class="sco-cap__num">05</div>
              <h3 class="sco-cap__title">Production &amp; Master Scheduling</h3>
              <p class="sco-cap__copy">Production plans and shift-level scheduling that hit forecast without wasting capacity. Changeovers minimized, run sequencing modeled, exceptions surfaced live.</p>
              <ul class="sco-cap__list">
                <li>Shift-level production schedules</li>
                <li>Run sequencing &amp; changeover reduction</li>
                <li>Real-time exception dashboards</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-week">
                  <div class="sco-viz-week__label">Supply Review &middot; Weekly</div>
                  <div class="sco-viz-week__grid">
                    <span class="sco-viz-week__day sco-viz-week__day--done">M</span>
                    <span class="sco-viz-week__day sco-viz-week__day--done">T</span>
                    <span class="sco-viz-week__day sco-viz-week__day--now">W</span>
                    <span class="sco-viz-week__day">T</span>
                    <span class="sco-viz-week__day">F</span>
                  </div>
                  <div class="sco-viz-week__event">Wed 10am &middot; Ops sign-off</div>
                </div>
              </div>
              <div class="sco-cap__num">06</div>
              <h3 class="sco-cap__title">S&amp;OP Leadership</h3>
              <p class="sco-cap__copy">We own the Supply Review inside your S&amp;OP/IBP cycle. Supply feasibility, inventory strategy, capacity planning, and operational risk translated into a weekly cadence your team actually runs.</p>
              <ul class="sco-cap__list">
                <li>SKU-level demand vs forecast tools</li>
                <li>Weekly cadence with brand stakeholders</li>
                <li>AI-driven risk dashboards</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-alerts">
                  <div class="sco-viz-alerts__row sco-viz-alerts__row--err">
                    <span class="sco-viz-alerts__ic">&#9888;</span>
                    <span>Port strike &middot; Rotterdam</span>
                  </div>
                  <div class="sco-viz-alerts__row sco-viz-alerts__row--warn">
                    <span class="sco-viz-alerts__ic">&#9888;</span>
                    <span>Lead time &middot; 32&rarr;41d</span>
                  </div>
                  <div class="sco-viz-alerts__row sco-viz-alerts__row--ok">
                    <span class="sco-viz-alerts__ic">&#10003;</span>
                    <span>Supplier B, cleared</span>
                  </div>
                </div>
              </div>
              <div class="sco-cap__num">07</div>
              <h3 class="sco-cap__title">Risk Management</h3>
              <p class="sco-cap__copy">Supply disruptions, transportation delays, and compliance issues caught before they blow up the month. Geopolitical, supplier concentration, and lead-time volatility monitored in real time.</p>
              <ul class="sco-cap__list">
                <li>Geopolitical exposure alerts</li>
                <li>Supplier concentration monitoring</li>
                <li>Transportation delay tracking</li>
              </ul>
            </article>

            <article class="sco-cap">
              <div class="sco-cap__viz">
                <div class="sco-viz-matrix">
                  <div class="sco-viz-matrix__cell sco-viz-matrix__cell--keep">
                    <span class="sco-viz-matrix__lbl">Keep</span>
                    <span class="sco-viz-matrix__count">42</span>
                  </div>
                  <div class="sco-viz-matrix__cell sco-viz-matrix__cell--grow">
                    <span class="sco-viz-matrix__lbl">Grow</span>
                    <span class="sco-viz-matrix__count">18</span>
                  </div>
                  <div class="sco-viz-matrix__cell sco-viz-matrix__cell--reduce">
                    <span class="sco-viz-matrix__lbl">Reduce</span>
                    <span class="sco-viz-matrix__count">24</span>
                  </div>
                  <div class="sco-viz-matrix__cell sco-viz-matrix__cell--kill">
                    <span class="sco-viz-matrix__lbl">Kill</span>
