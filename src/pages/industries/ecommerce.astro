---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="AI-Managed Ecommerce Operations | Aquifer Growth" description="Aquifer Growth engineers and manages autonomous AI commerce operations for Shopify brands replacing fragmented ops roles with a single AI-powered system that scales.">
	<Header />
	
	<main>
		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO SECTION                               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-hero">
			<div class="ec-hero__bg-blur"></div>
			<div class="ec-hero__bg-blur ec-hero__bg-blur--right"></div>
			<div class="ec-hero__inner container">
				<h1 class="ec-hero__title">
					FOCUS ON SCALING YOUR STORE.<br>
					WE'LL HANDLE THE <span class="ec-hero__title-accent">OPERATIONS.</span>
				</h1>
				<p class="ec-hero__subtitle">
					Managing product operations, inventory, and catalog health is a full-time<br class="hide-mobile">
					job, one that doesn't scale. We take over the operational layer so you can<br class="hide-mobile">
					focus on growth, brand, and customer experience.
				</p>

				<div class="ec-hero__cta-row">
					<a href="/contact" class="ec-btn ec-btn--hero">
						<span class="ec-cta-full">Scale Your Ecommerce Operations &rarr; Let's Chat</span>
						<span class="ec-cta-mobile">Let's Chat</span>
						<span class="ec-animated-dots">
							<span></span><span></span><span></span><span></span>
						</span>
					</a>
				</div>

				<!-- System Demo Tabs -->
				<div class="ec-demo-wrap">

					<!-- Tab Nav -->
					<div class="ec-demo-tabs">
						<button class="ec-demo-tab active" data-tab="catalog">Catalog Management</button>
						<button class="ec-demo-tab" data-tab="inventory">Inventory Management</button>
						<button class="ec-demo-tab" data-tab="forecasting">Inventory Forecasting</button>
						<button class="ec-demo-tab" data-tab="po">PO Management</button>
						<button class="ec-demo-tab" data-tab="warehouse">Warehouse Stock</button>
						<button class="ec-demo-tab" data-tab="cogs">COGS</button>
						<button class="ec-demo-tab" data-tab="supplier">Supplier</button>
					</div>

					<!-- TAB 1: Catalog Management -->
					<!-- TAB 1: Catalog Management -->
					<!-- TAB 1: Catalog Management -->
					<div class="ec-demo-panel active" data-panel="catalog">
						<div class="ec-pipeline">
							<!-- Source -->
							<div class="ec-pipe-col ec-pipe-col--source">
								<div class="ec-pipe-header">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#0f9d58"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M7 7h10v2H7zm0 4h10v2H7zm0 4h7v2H7z" fill="#fff"/></svg>
									catalog_FINAL_v3_USE_THIS_ONE.xlsx
								</div>
								<div class="ec-ss-grid ec-ss-grid--catalog">
									<div class="ec-ss-head"><span>A</span><span>B</span><span>C</span><span>D</span><span>E</span></div>
									<div class="ec-ss-subhead"><span>Product ID</span><span>Name</span><span>Category</span><span>Price</span><span>Status</span></div>
									<div class="ec-ss-row ec-ss-err"><span class="ec-src-id">TSHRT-001</span><span>Classic Tee</span><span class="ec-src-err">#REF!</span><span>$24</span><span class="ec-src-warn">ASK JOHN</span></div>
									<div class="ec-ss-row"><span class="ec-src-id">jkt002</span><span class="ec-src-warn">puffer jacket BLACK</span><span>Outerwear</span><span class="ec-src-err">#VALUE!</span><span></span></div>
									<div class="ec-ss-row ec-ss-err"><span class="ec-src-id">DRSS-001</span><span class="ec-src-warn">which dress??</span><span class="ec-src-err">DUPLICATE?</span><span>$78</span><span>Draft</span></div>
									<div class="ec-ss-row"><span class="ec-src-id">PNTS-002</span><span>Cargo Pants</span><span>Bottoms</span><span class="ec-src-warn">see sheet 2</span><span></span></div>
									<div class="ec-ss-row ec-ss-err"><span class="ec-src-id">SWTR-001</span><span>Chunky Knit</span><span class="ec-src-err">#REF!</span><span>$55</span><span class="ec-src-warn">fix later</span></div>
									<div class="ec-ss-row ec-ss-fade"><span class="ec-src-id">HODI-003</span><span class="ec-src-warn">hoodie (which one)</span><span>Tops</span><span>$42</span><span></span></div>
								</div>
								<div class="ec-src-tabs"><span class="a">catalog_v2</span><span>FINAL</span><span>FINAL_USE_THIS</span><span>archive</span></div>
							</div>
							<!-- Engine -->
							<div class="ec-pipe-col ec-pipe-col--engine">
								<div class="ec-engine-badge"><span class="ec-engine-pulse"></span>AQ</div>
								<div class="ec-engine-label">Syncing &amp; cleaning</div>
								<div class="ec-packets">
									<div class="ec-packet" style="animation-delay:0s"></div>
									<div class="ec-packet" style="animation-delay:0.7s"></div>
									<div class="ec-packet" style="animation-delay:1.4s"></div>
									<div class="ec-packet" style="animation-delay:2.1s"></div>
									<div class="ec-packet" style="animation-delay:2.8s"></div>
								</div>
								<div class="ec-engine-steps">
									<div class="ec-step ec-step--done">✓ Deduplicated</div>
									<div class="ec-step ec-step--done">✓ Standardised IDs</div>
									<div class="ec-step ec-step--active">⟳ Syncing Shopify</div>
								</div>
							</div>
							<!-- Output: Shopify -->
							<div class="ec-pipe-col ec-pipe-col--output">
								<div class="ec-pipe-header ec-pipe-header--shopify">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#96bf48"><path d="M20.9 6.6c0-.1-.1-.2-.2-.2l-2-.2-1.5-1.5c-.1-.1-.4-.1-.5 0L15.3 5c-.3-.9-.8-1.8-1.7-2.5C12.7 1.8 11.9 1.5 11 1.5c-.3 0-.5 0-.8.1-.2-.3-.5-.5-.9-.7C8.6.4 7.6.7 6.8 1.8 6.2 2.7 5.9 3.8 5.9 4.9l-1.6.5c-.5.2-.5.2-.6.6L2 18.9l14.2 2.1 6.8-1.5S20.9 6.7 20.9 6.6z"/></svg>
									Shopify · Products
								</div>
								<div class="ec-ss-grid ec-ss-grid--output">
									<div class="ec-ss-head"><span>Product</span><span>Category</span><span>SKUs</span><span>Price</span><span>Status</span></div>
									<div class="ec-ss-row ec-out-row--in">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#8ecef9"></span>Classic Tee</span>
										<span>Tops</span><span>4</span><span>$24.00</span>
										<span><em class="ec-badge ec-badge--green">Active</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.2s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#b39ddb"></span>Puffer Jacket</span>
										<span>Outerwear</span><span>3</span><span>$89.00</span>
										<span><em class="ec-badge ec-badge--green">Active</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.4s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#f48fb1"></span>Wrap Dress</span>
										<span>Dresses</span><span>6</span><span>$78.00</span>
										<span><em class="ec-badge ec-badge--yellow">Draft</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.6s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#80cbc4"></span>Cargo Pants</span>
										<span>Bottoms</span><span>5</span><span>$62.00</span>
										<span><em class="ec-badge ec-badge--green">Active</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.8s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#ffcc80"></span>Chunky Knit</span>
										<span>Knitwear</span><span>2</span><span>$55.00</span>
										<span><em class="ec-badge ec-badge--red">Archived</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:1s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#a5d6a7"></span>Zip Hoodie</span>
										<span>Tops</span><span>3</span><span>$42.00</span>
										<span><em class="ec-badge ec-badge--green">Active</em></span>
									</div>
								</div>
								<div class="ec-out-sync">↻ Last synced 2 min ago · 142 products</div>
							</div>
						</div>
					</div>

					<!-- TAB 2: Inventory Management -->
					<div class="ec-demo-panel" data-panel="inventory">
						<div class="ec-pipeline">
							<div class="ec-pipe-col ec-pipe-col--source">
								<div class="ec-pipe-header">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#0f9d58"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M7 7h10v2H7zm0 4h10v2H7zm0 4h7v2H7z" fill="#fff"/></svg>
									Stock_Check_Monday_REAL.xlsx
								</div>
								<div class="ec-ss-grid ec-ss-grid--inv">
									<div class="ec-ss-head"><span>A</span><span>B</span><span>C</span><span>D</span><span>E</span></div>
									<div class="ec-ss-subhead"><span>Product</span><span>In Stock</span><span>Reserved</span><span>Available</span><span>Notes</span></div>
									<div class="ec-ss-row ec-ss-err"><span>Wrap Dress</span><span class="ec-src-err">42?? or 24</span><span>10</span><span class="ec-src-err">#REF!</span><span class="ec-src-warn">check WH</span></div>
									<div class="ec-ss-row ec-ss-err"><span>Puffer Jacket</span><span>17</span><span class="ec-src-warn">idk</span><span class="ec-src-err">#VALUE!</span><span class="ec-src-warn">sold some?</span></div>
									<div class="ec-ss-row"><span>Classic Tee</span><span>785</span><span class="ec-src-strike">32</span><span class="ec-src-warn">Mike updated</span><span></span></div>
									<div class="ec-ss-row ec-ss-err"><span>Cargo Pants</span><span class="ec-src-err">334 or 343</span><span>18</span><span>316</span><span class="ec-src-warn">two versions?</span></div>
									<div class="ec-ss-row"><span>Zip Hoodie</span><span>413</span><span>24</span><span class="ec-src-warn">see WH B</span><span></span></div>
									<div class="ec-ss-row ec-ss-fade"><span>Chunky Knit</span><span class="ec-src-err">#REF!</span><span>0</span><span class="ec-src-err">#REF!</span><span class="ec-src-warn">fix later</span></div>
								</div>
								<div class="ec-src-tabs"><span class="a">Stock_Mon</span><span>Stock_Tue</span><span>OLD DO NOT USE</span><span>WH B</span></div>
							</div>
							<div class="ec-pipe-col ec-pipe-col--engine">
								<div class="ec-engine-badge"><span class="ec-engine-pulse"></span>AQ</div>
								<div class="ec-engine-label">Reconciling stock</div>
								<div class="ec-packets">
									<div class="ec-packet" style="animation-delay:0.2s"></div>
									<div class="ec-packet" style="animation-delay:0.9s"></div>
									<div class="ec-packet" style="animation-delay:1.6s"></div>
									<div class="ec-packet" style="animation-delay:2.3s"></div>
									<div class="ec-packet" style="animation-delay:3.0s"></div>
								</div>
								<div class="ec-engine-steps">
									<div class="ec-step ec-step--done">✓ Merged 3 sheets</div>
									<div class="ec-step ec-step--done">✓ Resolved conflicts</div>
									<div class="ec-step ec-step--active">⟳ Updating Shopify</div>
								</div>
							</div>
							<div class="ec-pipe-col ec-pipe-col--output">
								<div class="ec-pipe-header ec-pipe-header--shopify">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#96bf48"><path d="M20.9 6.6c0-.1-.1-.2-.2-.2l-2-.2-1.5-1.5c-.1-.1-.4-.1-.5 0L15.3 5c-.3-.9-.8-1.8-1.7-2.5C12.7 1.8 11.9 1.5 11 1.5c-.3 0-.5 0-.8.1-.2-.3-.5-.5-.9-.7C8.6.4 7.6.7 6.8 1.8 6.2 2.7 5.9 3.8 5.9 4.9l-1.6.5c-.5.2-.5.2-.6.6L2 18.9l14.2 2.1 6.8-1.5S20.9 6.7 20.9 6.6z"/></svg>
									Shopify · Inventory
								</div>
								<div class="ec-ss-grid ec-ss-grid--inv-out">
									<div class="ec-ss-head"><span>Product</span><span>Stock</span><span>Reserved</span><span>Available</span><span>Status</span></div>
									<div class="ec-ss-row ec-out-row--in">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#8ecef9"></span>Classic Tee</span>
										<span>785</span><span>32</span><span>753</span>
										<span><em class="ec-badge ec-badge--green">Healthy</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.2s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#80cbc4"></span>Cargo Pants</span>
										<span>334</span><span>18</span><span>316</span>
										<span><em class="ec-badge ec-badge--green">Healthy</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.4s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#a5d6a7"></span>Zip Hoodie</span>
										<span>413</span><span>24</span><span>389</span>
										<span><em class="ec-badge ec-badge--green">Healthy</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.6s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#f48fb1"></span>Wrap Dress</span>
										<span class="ec-val--red">42</span><span>10</span><span class="ec-val--red">32</span>
										<span><em class="ec-badge ec-badge--red">Low Stock</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.8s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#b39ddb"></span>Puffer Jacket</span>
										<span class="ec-val--red">17</span><span>5</span><span class="ec-val--red">12</span>
										<span><em class="ec-badge ec-badge--red">Low Stock</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:1s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#ffcc80"></span>Chunky Knit</span>
										<span>219</span><span>0</span><span>219</span>
										<span><em class="ec-badge ec-badge--green">Healthy</em></span>
									</div>
								</div>
								<div class="ec-out-sync ec-out-sync--warn">⚠ 2 items below threshold POs auto-drafted</div>
							</div>
						</div>
					</div>

					<!-- TAB 3: Inventory Forecasting -->
					<div class="ec-demo-panel" data-panel="forecasting">
						<div class="ec-pipeline">
							<div class="ec-pipe-col ec-pipe-col--source">
								<div class="ec-pipe-header">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#0f9d58"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><path d="M7 7h10v2H7zm0 4h10v2H7zm0 4h7v2H7z" fill="#fff"/></svg>
									Forecast_Q4_guesses.xlsx
								</div>
								<div class="ec-ss-grid ec-ss-grid--fc">
									<div class="ec-ss-head"><span>A</span><span>B</span><span>C</span><span>D</span><span>E</span></div>
									<div class="ec-ss-subhead"><span>Product</span><span>Last Month</span><span>Next Guess</span><span>Order?</span><span>Who decides</span></div>
									<div class="ec-ss-row ec-ss-err"><span>Wrap Dress</span><span>180</span><span class="ec-src-warn">maybe 200?</span><span class="ec-src-err">YES URGENT</span><span class="ec-src-warn">Sarah</span></div>
									<div class="ec-ss-row ec-ss-err"><span>Puffer Jacket</span><span class="ec-src-strike">90</span><span class="ec-src-warn">100 or 50 idk</span><span class="ec-src-err">ASAP!!!</span><span class="ec-src-warn">ask Mike</span></div>
									<div class="ec-ss-row"><span>Classic Tee</span><span>340</span><span>~350</span><span class="ec-src-warn">probably fine</span><span></span></div>
									<div class="ec-ss-row ec-ss-err"><span>Zip Hoodie</span><span class="ec-src-err">#REF!</span><span class="ec-src-err">#REF!</span><span class="ec-src-warn">broken formula</span><span class="ec-src-warn">fix later</span></div>
									<div class="ec-ss-row"><span>Cargo Pants</span><span>150</span><span>~180</span><span class="ec-src-warn">ask Mike</span><span></span></div>
									<div class="ec-ss-row ec-ss-fade"><span>Chunky Knit</span><span>60</span><span class="ec-src-warn">70 maybe?</span><span></span><span></span></div>
								</div>
								<div class="ec-src-tabs"><span class="a">Forecast</span><span>Q3 (old)</span><span>Mike's version</span><span>DO NOT TOUCH</span></div>
							</div>
							<div class="ec-pipe-col ec-pipe-col--engine">
								<div class="ec-engine-badge"><span class="ec-engine-pulse"></span>AQ</div>
								<div class="ec-engine-label">Calculating forecasts</div>
								<div class="ec-packets">
									<div class="ec-packet" style="animation-delay:0.1s"></div>
									<div class="ec-packet" style="animation-delay:0.8s"></div>
									<div class="ec-packet" style="animation-delay:1.5s"></div>
									<div class="ec-packet" style="animation-delay:2.2s"></div>
									<div class="ec-packet" style="animation-delay:2.9s"></div>
								</div>
								<div class="ec-engine-steps">
									<div class="ec-step ec-step--done">✓ Pulled sales data</div>
									<div class="ec-step ec-step--done">✓ Modelled demand</div>
									<div class="ec-step ec-step--active">⟳ Generating alerts</div>
								</div>
							</div>
							<div class="ec-pipe-col ec-pipe-col--output">
								<div class="ec-pipe-header ec-pipe-header--shopify">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#96bf48"><path d="M20.9 6.6c0-.1-.1-.2-.2-.2l-2-.2-1.5-1.5c-.1-.1-.4-.1-.5 0L15.3 5c-.3-.9-.8-1.8-1.7-2.5C12.7 1.8 11.9 1.5 11 1.5c-.3 0-.5 0-.8.1-.2-.3-.5-.5-.9-.7C8.6.4 7.6.7 6.8 1.8 6.2 2.7 5.9 3.8 5.9 4.9l-1.6.5c-.5.2-.5.2-.6.6L2 18.9l14.2 2.1 6.8-1.5S20.9 6.7 20.9 6.6z"/></svg>
									Forecast Dashboard
								</div>
								<div class="ec-ss-grid ec-ss-grid--fc-out">
									<div class="ec-ss-head"><span>Product</span><span>Trend</span><span>Days Left</span><span>Avg/Day</span><span>Action</span></div>
									<div class="ec-ss-row ec-out-row--in ec-ss-err">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#f48fb1"></span>Wrap Dress</span>
										<div class="ec-fc-mini"><div style="width:8%;background:#e74c3c"></div></div>
										<span class="ec-val--red">5d ⚠</span><span>8/day</span>
										<span><em class="ec-badge ec-badge--red">Order Now</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in ec-ss-err" style="animation-delay:0.2s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#b39ddb"></span>Puffer Jacket</span>
										<div class="ec-fc-mini"><div style="width:4%;background:#e74c3c"></div></div>
										<span class="ec-val--red">3d ⚠</span><span>5/day</span>
										<span><em class="ec-badge ec-badge--red">Order Now</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.4s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#a5d6a7"></span>Zip Hoodie</span>
										<div class="ec-fc-mini"><div style="width:56%;background:#f39c12"></div></div>
										<span style="color:#f39c12">45d</span><span>9/day</span>
										<span><em class="ec-badge ec-badge--blue">Order Soon</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.6s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#80cbc4"></span>Cargo Pants</span>
										<div class="ec-fc-mini"><div style="width:68%;background:#27ae60"></div></div>
										<span class="ec-val--green">55d</span><span>6/day</span>
										<span><em class="ec-badge ec-badge--green">On Track</em></span>
									</div>
									<div class="ec-ss-row ec-out-row--in" style="animation-delay:0.8s">
										<span class="ec-out-prod"><span class="ec-out-dot" style="background:#8ecef9"></span>Classic Tee</span>
										<div class="ec-fc-mini"><div style="width:82%;background:#27ae60"></div></div>
										<span class="ec-val--green">65d</span><span>12/day</span>
