					<!-- TAB 4: PO Management -->
					<div class="ec-demo-panel" data-panel="po">
						<div class="ec-pipeline">
							<div class="ec-pipe-col ec-pipe-col--source">
								<div class="ec-pipe-label">BEFORE</div>
								<div class="ec-pipe-header">
									<span style="font-size:0.85rem">📧</span>
									WhatsApp + Email + Sheets
								</div>
								<div class="ec-ss-grid ec-ss-grid--po">
									<div class="ec-ss-head"><span>A</span><span>B</span><span>C</span><span>D</span><span>E</span></div>
