<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Tab switching for the demo
		const tabs = document.querySelectorAll('.ec-demo-tab');
		const panels = document.querySelectorAll('.ec-demo-panel');
		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				const target = tab.getAttribute('data-tab');
				tabs.forEach((t) => t.classList.remove('active'));
				panels.forEach((p) => p.classList.remove('active'));
				tab.classList.add('active');
				const panel = document.querySelector(`.ec-demo-panel[data-panel="${target}"]`);
				if (panel) panel.classList.add('active');
			});
		});

		// Scroll reveal
		const revealEls = document.querySelectorAll('.scroll-reveal');
		if ('IntersectionObserver' in window) {
			const io = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
						io.unobserve(entry.target);
					}
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
			revealEls.forEach((el) => io.observe(el));
		} else {
			revealEls.forEach((el) => el.classList.add('is-visible'));
		}

		// Wrap "What we run" + "The outcome" in <details> for each service block
		const summaryHTML = `
			<span class="ec-service__more-show">Read more</span>
			<span class="ec-service__more-hide">Show less</span>
			<svg class="ec-service__more-caret" width="12" height="12" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		`;
		document.querySelectorAll('.ec-service__text').forEach((textEl) => {
			const blocks = Array.from(textEl.querySelectorAll(':scope > .ec-service__block'));
			if (blocks.length < 3) return;
			const whatWeRun = blocks[1];
			const outcome = blocks[2];
			const details = document.createElement('details');
			details.className = 'ec-service__details';
			const summary = document.createElement('summary');
			summary.className = 'ec-service__more';
			summary.innerHTML = summaryHTML;
			details.appendChild(summary);
			whatWeRun.parentNode.insertBefore(details, whatWeRun);
			details.appendChild(whatWeRun);
			details.appendChild(outcome);
		});
	});
</script>
