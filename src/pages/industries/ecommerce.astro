---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<Layout title="AI-Managed Ecommerce Operations | Aquifer Growth" description="Aquifer Growth engineers and manages autonomous AI commerce operations for Shopify brands — replacing fragmented ops roles with a single AI-powered system that scales.">
	<Header />
	
	<main>
		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO SECTION                               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-hero">
			<div class="ec-hero__bg-blur"></div>
			<div class="ec-hero__bg-blur ec-hero__bg-blur--right"></div>
			<div class="ec-hero__inner container">
				<h1 class="ec-hero__title">
					Focus on scaling your store.<br>
					We'll handle the operations<br>
					behind your catalog.
				</h1>
				<p class="ec-hero__subtitle">
					Managing product operations, inventory, and catalog health is a full-time<br class="hide-mobile">
					job — one that doesn't scale. We take over the operational layer so you can<br class="hide-mobile">
					focus on growth, brand, and customer experience.
				</p>

				<div class="ec-hero__cta-row">
					<a href="/contact" class="ec-btn ec-btn--primary">See Our Process</a>
					<a href="/contact" class="ec-btn ec-btn--outline">Book a Call</a>
				</div>

				<!-- Mock Product Table -->
				<div class="ec-hero__table-wrap">
					<div class="ec-table-mock">
						<!-- Top Tabs -->
						<div class="ec-table-mock__toolbar">
							<div class="ec-table-mock__tabs">
								<span class="ec-table-mock__tab active">Product Catalog Management</span>
								<span class="ec-table-mock__tab">Collection Data Management</span>
								<span class="ec-table-mock__tab">Inventory Management</span>
								<span class="ec-table-mock__tab">Multi-channel Inventory Management</span>
							</div>
						</div>

						<!-- Table Header -->
						<div class="ec-table-mock__header">
							<span class="col-pid">ProductID</span>
							<span class="col-color-label">Color</span>
							<span class="col-ptype">Product Type</span>
							<span class="col-imgs">Images</span>
							<span class="col-qty col-qty--sm">Received</span>
							<span class="col-qty col-qty--sm">Sold</span>
							<span class="col-qty col-qty--sm">In Stock</span>
						</div>

						<!-- Row 1 — highlighted (selected) -->
						<div class="ec-table-mock__row ec-table-mock__row--highlight">
							<span class="col-pid">TSHRT-001</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--white"></span>White</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--tshirt">T-shirt</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"><img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=80&h=80&fit=crop" alt="White T-shirt" /></span></span>
							<span class="col-qty">751</span>
							<span class="col-qty"></span>
							<span class="col-qty">785</span>
						</div>

						<!-- Row 2 -->
						<div class="ec-table-mock__row ec-table-mock__row--highlight-alt">
							<span class="col-pid">TSHRT-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--black"></span>Black</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--tshirt">T-shirt</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">296</span>
							<span class="col-qty"></span>
							<span class="col-qty">978</span>
						</div>

						<!-- Row 3 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">JKT-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--purple"></span>Purple</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--jacket">Jacket</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">278</span>
							<span class="col-qty"></span>
							<span class="col-qty">372</span>
						</div>

						<!-- Row 4 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">PNTS-001</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--blue"></span>Blue</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--pants">Pants</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">296</span>
							<span class="col-qty"></span>
							<span class="col-qty">334</span>
						</div>

						<!-- Row 5 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">PNTS-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--red"></span>Red</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--pants">Pants</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">137</span>
							<span class="col-qty"></span>
							<span class="col-qty">—</span>
						</div>

						<!-- Row 6 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">DRSS-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--purple"></span>Purple</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--dress">Dress</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">312</span>
							<span class="col-qty"></span>
							<span class="col-qty">162</span>
						</div>

						<!-- Row 7 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">DRSS-001</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--blue"></span>Blue</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--dress">Dress</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">179</span>
							<span class="col-qty"></span>
							<span class="col-qty">471</span>
						</div>

						<!-- Row 8 (partially visible) -->
						<div class="ec-table-mock__row">
							<span class="col-pid">SWTR-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--white"></span></span>
							<span class="col-ptype"></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">813</span>
							<span class="col-qty"></span>
							<span class="col-qty">893</span>
						</div>

						<!-- Row 9 -->
						<div class="ec-table-mock__row">
							<span class="col-pid">SKRT-001</span>
							<span class="col-color-label"></span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--skirt">Skirt</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">—</span>
							<span class="col-qty"></span>
							<span class="col-qty">279</span>
						</div>

						<!-- Rows 10-11 (bottom, partially covered) -->
						<div class="ec-table-mock__row">
							<span class="col-pid">HODI-002</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--green"></span>Green</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--hoodie">Hoodie</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">298</span>
							<span class="col-qty">462</span>
							<span class="col-qty">499</span>
						</div>

						<div class="ec-table-mock__row">
							<span class="col-pid">HODI-003</span>
							<span class="col-color-label"><span class="ec-color-dot ec-color-dot--black"></span>Black</span>
							<span class="col-ptype"><span class="ec-type-badge ec-type-badge--hoodie">Hoodie</span></span>
							<span class="col-imgs"><span class="ec-img-thumb"></span></span>
							<span class="col-qty">497</span>
							<span class="col-qty"></span>
							<span class="col-qty">413</span>
						</div>

						<!-- ─── Floating Product Detail Card ─── -->
						<div class="ec-product-card">
							<div class="ec-product-card__cursor">
								<span class="ec-product-card__cursor-tag">You</span>
							</div>
							<div class="ec-product-card__img">
								<img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=300&h=300&fit=crop" alt="White T-shirt" />
							</div>
							<div class="ec-product-card__details">
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">Product ID</span>
									<span class="ec-product-card__value">TSHRT-001</span>
								</div>
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">Color</span>
									<span class="ec-product-card__value"><span class="ec-color-dot ec-color-dot--white" style="margin-right:4px;"></span>White</span>
								</div>
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">Product Type</span>
									<span class="ec-product-card__value"><span class="ec-type-badge ec-type-badge--tshirt" style="font-size:0.65rem;">T-shirt</span></span>
								</div>
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">Received Quantity</span>
									<span class="ec-product-card__value ec-product-card__value--blue">751</span>
								</div>
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">Sold Quantity</span>
									<span class="ec-product-card__value ec-product-card__value--blue">740</span>
								</div>
								<div class="ec-product-card__row">
									<span class="ec-product-card__label">In Stock</span>
									<span class="ec-product-card__value ec-product-card__value--blue">785</span>
								</div>
								<div class="ec-product-card__actions">
									<button class="ec-product-card__btn">Receive Product</button>
									<button class="ec-product-card__btn">Sell Product</button>
								</div>
							</div>
						</div>

						<!-- ─── "Saved hours" Toast ─── -->
						<div class="ec-toast">
							<span class="ec-toast__icon">✓</span>
							<span class="ec-toast__text">Saved 5.35 hours by not Ctrl+C / Ctrl+V</span>
						</div>

						<!-- ─── Import Bar ─── -->
						<div class="ec-import-bar">
							<div class="ec-import-bar__file">
								<span class="ec-import-bar__file-icon">📄</span>
								<span class="ec-import-bar__file-info">
									<strong>Inventory for Aug - Oct 2024, I guess?.csv</strong>
									<span>Last edited 25 Nov 2024</span>
								</span>
							</div>
							<button class="ec-import-bar__btn">Import from Sheets</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- LOGO BAR                                   -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-logos">
			<div class="container">
				<div class="ec-logos__row">
					<span class="ec-logo-item">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#1A1A1A" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Shopify
					</span>
					<span class="ec-logo-item">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#1A1A1A" stroke-width="1.5"/><path d="M2 17l10 5 10-5" stroke="#1A1A1A" stroke-width="1.5"/><path d="M2 12l10 5 10-5" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Asana
					</span>
					<span class="ec-logo-item">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="#1A1A1A" stroke-width="1.5"/><path d="M9 9h6M9 12h6M9 15h3" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Framer
					</span>
					<span class="ec-logo-item">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 4h16v16H4z" stroke="#1A1A1A" stroke-width="1.5"/><path d="M4 12h8v8" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Webflow
					</span>
					<span class="ec-logo-item">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#1A1A1A" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Attentive
					</span>
					<span class="ec-logo-item">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l3-9 4 18 3-9h4" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Klaviyo
					</span>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- WHY WE'RE THE BEST                          -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-why">
			<div class="container">
				<div class="ec-why__grid">
					<div class="ec-why__left">
						<h2 class="ec-why__title">
							Why are we the best<br>for the job
						</h2>
					</div>
					<div class="ec-why__right">
						<p class="ec-why__body">
							We're not a SaaS tool. We're not a freelancer. We're an operations partner that builds and manages the systems your catalog needs — from taxonomy to fulfillment readiness. We embed into your stack, systematize what's broken, and keep it running.
						</p>
						<div class="ec-why__features">
							<div class="ec-why__feature">
								<span class="ec-why__feature-icon">⚡</span>
								<div>
									<strong>Built for Shopify Brands</strong>
									<p>We specialize in the operational gaps that grow as your SKU count grows.</p>
								</div>
							</div>
							<div class="ec-why__feature">
								<span class="ec-why__feature-icon">🔁</span>
								<div>
									<strong>Managed, Not Just Built</strong>
									<p>We don't hand you a tool and disappear. We run it for you, continuously.</p>
								</div>
							</div>
							<div class="ec-why__feature">
								<span class="ec-why__feature-icon">📊</span>
								<div>
									<strong>AI-Powered at the Core</strong>
									<p>Every system we deploy uses AI to automate, classify, and surface insights.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- THE STEP AWAY QUESTION                     -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-question">
			<div class="container">
				<div class="ec-question__badge">Managed Operations</div>
				<h2 class="ec-question__title">
					When was the last time you could actually step away<br class="hide-mobile">
					from day-to-day operations?
				</h2>
				<p class="ec-question__body">
					Most ecommerce brands hit a wall around 5,000 SKUs. Catalog quality drops, inventory errors compound, and the team is constantly firefighting. Sound familiar?
				</p>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- SIMPLIFY OPERATIONS — DARK SECTION         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-capabilities">
			<div class="container">
				<h2 class="ec-capabilities__title">Simplify Operations. Unlock Growth.</h2>
				<div class="ec-capabilities__subtitle-row">
					<a href="/contact" class="ec-btn ec-btn--pink-sm">See What We Manage →</a>
				</div>

				<div class="ec-capabilities__grid">
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">🏗️</div>
						<h3>Product Catalog Management</h3>
						<p>Centralized AI-synced hierarchies that scale across your entire catalog, attributes, and variant groups.</p>
					</div>
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">📦</div>
						<h3>Catalog Enrichment</h3>
						<p>Automated title optimization, description generation, and attribute standardization across thousands of SKUs.</p>
					</div>
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">⚡</div>
						<h3>Increased Store Visibility</h3>
						<p>AI-driven collection logic, tagging, and discoverability improvements that directly boost conversion.</p>
					</div>
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">📈</div>
						<h3>Intelligent Data Cleaning &amp; Sorting</h3>
						<p>Rule-based and AI-powered deduplication, normalization, and cataloging that keeps your data pristine.</p>
					</div>
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">🔍</div>
						<h3>Effortless SEO Management</h3>
						<p>Automated meta tags, structured data, and crawlable taxonomies engineered for search dominance.</p>
					</div>
					<div class="ec-cap-card">
						<div class="ec-cap-card__icon">🧠</div>
						<h3>Full-cycle BI Integration</h3>
						<p>Real-time dashboards connecting catalog health, inventory velocity, and revenue impact in one view.</p>
					</div>
				</div>

				<!-- Testimonial -->
				<div class="ec-capabilities__testimonial">
					<blockquote>
						"I used Contractors/Freelancers/In-house staff, now time and mainly Aquifer has saved me time by auto-categorizing our full collection more accurately."
					</blockquote>
					<div class="ec-capabilities__testimonial-author">
						<div class="ec-capabilities__testimonial-avatar"></div>
						<div>
							<strong>Sarah Chen</strong>
							<span>Head of Operations • StyleVault</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- OUR PROCESS                                 -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-process">
			<div class="container">
				<h2 class="ec-process__title">
					Our process makes it<br>
					easier than ever before
				</h2>

				<div class="ec-process__steps">
					<div class="ec-process__step">
						<div class="ec-process__step-num">01</div>
						<div class="ec-process__step-content">
							<h3>Initial Consulting</h3>
							<p>We audit your current catalog, inventory systems, and operational workflows to identify where AI can create immediate improvement.</p>
						</div>
					</div>
					<div class="ec-process__step">
						<div class="ec-process__step-num">02</div>
						<div class="ec-process__step-content">
							<h3>System Architecture</h3>
							<p>We design and build the autonomous systems tailored to your specific brand operations — no cookie-cutter templates.</p>
						</div>
					</div>
					<div class="ec-process__step">
						<div class="ec-process__step-num">03</div>
						<div class="ec-process__step-content">
							<h3>Deployment &amp; Embedding</h3>
							<p>We integrate directly into your Shopify stack, connect data sources, and deploy the managed operations layer.</p>
						</div>
					</div>
					<div class="ec-process__step">
						<div class="ec-process__step-num">04</div>
						<div class="ec-process__step-content">
							<h3>Ongoing Managed Operations</h3>
							<p>We continuously monitor, optimize, and evolve your systems — you focus on growth, we handle the backend.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- STATS BAR                                  -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-stats">
			<div class="container">
				<div class="ec-stats__grid">
					<div class="ec-stat">
						<span class="ec-stat__number">130%</span>
						<span class="ec-stat__label">Avg. catalog quality improvement</span>
					</div>
					<div class="ec-stat">
						<span class="ec-stat__number">$358K</span>
						<span class="ec-stat__label">Revenue recovered from data fixes</span>
					</div>
					<div class="ec-stat">
						<span class="ec-stat__number">21,424</span>
						<span class="ec-stat__label">Products managed autonomously</span>
					</div>
					<div class="ec-stat">
						<span class="ec-stat__number">2,436 Hrs</span>
						<span class="ec-stat__label">Manual work eliminated per year</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- TESTIMONIALS                                -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="ec-testimonials">
			<div class="container">
				<h2 class="ec-testimonials__title">Hear From Our Customers</h2>
				<div class="ec-testimonials__grid">
					<div class="ec-testimonial-card">
						<div class="ec-testimonial-card__stars">★★★★★</div>
						<p>"Of course we use Aquifer. They replaced all the manual data cleanup our team was doing. Within 2 months, our catalog error rate went from 23% to near zero."</p>
						<div class="ec-testimonial-card__author">
							<div class="ec-testimonial-card__avatar ec-testimonial-card__avatar--1"></div>
							<div>
								<strong>James Rivera</strong>
								<span>CEO, ModernGoods Co.</span>
							</div>
						</div>
					</div>
					<div class="ec-testimonial-card">
						<div class="ec-testimonial-card__stars">★★★★★</div>
						<p>"We went from 3 full-time catalog managers to 1 person overseeing the AI systems. The ROI was clear within the first quarter."</p>
						<div class="ec-testimonial-card__author">
							<div class="ec-testimonial-card__avatar ec-testimonial-card__avatar--2"></div>
							<div>
								<strong>Michelle Park</strong>
								<span>VP Operations, UrbanThread</span>
							</div>
						</div>
