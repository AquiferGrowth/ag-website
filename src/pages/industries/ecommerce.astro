								</a>
							) : (
								<a href={`/case-study/${cs.slug}`} class={`cs-listing-colour cs-lc--${cs.slug}`}>
									<svg class="cs-lc-blob" viewBox="0 0 400 220" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<ellipse cx="330" cy="50" rx="140" ry="110" opacity="0.18"/>
										<ellipse cx="70" cy="190" rx="110" ry="85" opacity="0.13"/>
										<ellipse cx="200" cy="120" rx="75" ry="55" opacity="0.09"/>
									</svg>
									{cs.data.industry && (
										<span class="cs-listing-tag">{cs.data.industry}</span>
									)}
									<span class="cs-lc-title">{cs.data.title}</span>
								</a>
							)}
							<div class="cs-listing-content">
								<h2 class="cs-listing-headline">{cs.data.headline}</h2>
								<a href={`/case-study/${cs.slug}`} class="cs-listing-cta">
									Read case study <span class="cs-cta-arrow">→</span>
								</a>
							</div>
						</article>
					))}
				</div>

				<div class="cs-view-more">
					<a href="/case-studies" class="btn btn-secondary">View All Case Studies →</a>
				</div>
			</div>
		</section>

	</main>
	<Footer />
</Layout>

