</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Tab switching
		const tabs = document.querySelectorAll('.ec-demo-tab');
		const panels = document.querySelectorAll('.ec-demo-panel');
		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				tabs.forEach(t => t.classList.remove('active'));
				panels.forEach(p => p.classList.remove('active'));
				tab.classList.add('active');
				const target = tab.dataset.tab;
				document.querySelector(`.ec-demo-panel[data-panel="${target}"]`)?.classList.add('active');
			});
		});

		// Testimonials expand
		const expandBtn = document.getElementById('ec-testimonials-expand-btn');
		const expandWrap = document.getElementById('ec-testimonials-expand-wrap');
		const expandLabel = document.getElementById('ec-expand-label');
		const extraCards = document.querySelectorAll('#ec-testimonials-grid .testimonial-extra');
		if (extraCards.length === 0) expandWrap?.style.setProperty('display', 'none');
		expandBtn?.addEventListener('click', () => {
			const isExpanded = expandBtn.classList.toggle('expanded');
			extraCards.forEach(c => c.classList.toggle('visible', isExpanded));
			if (expandLabel) expandLabel.textContent = isExpanded ? 'Show less' : 'More reviews';
		});

		// Read more toggles
		document.querySelectorAll('.quote-toggle-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				const card = btn.closest('.testimonial-card');
				const truncated = card?.querySelector('.quote-truncated');
				const full = card?.querySelector('.quote-full');
				const isExpanded = full?.style.display !== 'none';
				if (truncated) truncated.style.display = isExpanded ? '' : 'none';
				if (full) full.style.display = isExpanded ? 'none' : '';
				btn.textContent = isExpanded ? 'Read more' : 'Show less';
			});
		});
	});
</script>
