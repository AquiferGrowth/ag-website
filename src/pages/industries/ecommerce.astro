---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = (await getCollection('caseStudies')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// Pin a specific set + order for the ecommerce page (PB added explicitly)
const featuredSlugs = ['staygolden', 'hairstrong', 'pb'];
const featuredCaseStudies = featuredSlugs
  .map(slug => allCaseStudies.find(cs => cs.slug === slug))
  .filter(Boolean);
---

<Layout title="Ecommerce Operations for Shopify Brands $1M-$10M | Aquifer Growth" description="Aquifer plugs in as your managed ecommerce operations team — inventory, forecasting, POs, COGS, supplier and catalog management for Shopify brands doing $1M-$10M.">
