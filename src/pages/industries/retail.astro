	}
	.rt-hub__block--center {
		background: rgba(255,77,109,0.04);
		border-color: rgba(255,77,109,0.2);
	}
	.rt-hub__block--exec {
		background: #0f0f0f;
	}

	.rt-hub__block-label {
		font-size: 0.5rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #999;
		margin-bottom: 0.45rem;
	}
	.rt-hub__block--exec .rt-hub__block-label { color: #555; }

	/* Block 1 chips */
	.rt-hub__chips {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.rt-hub__chip {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: #f7f7f7;
		border: 1px solid #e8e8e8;
		border-radius: 8px;
		padding: 0.3rem 0.55rem;
		font-size: 0.6rem;
		font-weight: 600;
		color: #333;
	}
	.rt-hub__chip-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	/* Down arrow between blocks */
	.rt-hub__down-arrow {
		display: flex;
		justify-content: center;
		padding: 0.2rem 0;
		color: var(--accent-primary);
		opacity: 0.6;
	}

	/* Block 2: Centralised table */
	.rt-hub__table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.56rem;
	}
	.rt-hub__table thead tr {
		border-bottom: 1px solid rgba(255,77,109,0.15);
	}
	.rt-hub__table th {
		text-align: left;
		font-weight: 700;
		color: #aaa;
		padding: 0 0.3rem 0.3rem;
		font-size: 0.48rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.rt-hub__table td {
		padding: 0.28rem 0.3rem;
		color: #333;
		border-bottom: 1px solid rgba(0,0,0,0.04);
		vertical-align: middle;
	}
	.rt-hub__table tbody tr:last-child td { border-bottom: none; }
	.rt-hub__td-mono {
		font-family: monospace;
		font-size: 0.52rem;
		color: #888;
	}
	.rt-hub__synced {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 14px;
		height: 14px;
		background: #dcfce7;
		color: #166534;
		border-radius: 50%;
		font-size: 0.5rem;
		font-weight: 800;
	}

	/* Block 3: Execution rows */
	.rt-hub__exec-rows {
		display: flex;
		flex-direction: column;
		gap: 0.32rem;
	}
	.rt-hub__exec-row {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.58rem;
		color: #666;
		font-family: monospace;
	}
	.rt-hub__exec-row--done { color: #aaa; }
	.rt-hub__exec-row--active { color: #e2e8f0; }
	.rt-hub__exec-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.rt-hub__exec-dot--green { background: #22c55e; }
	.rt-hub__exec-dot--pulse {
		background: var(--accent-primary);
		animation: rt-blink 1s ease-in-out infinite;
	}
	@keyframes rt-blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.2; }
	}

	/* ── Result listings ── */
	.rt-result-listings {
		background: #fff;
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid #e8e8e8;
	}
	.rt-result-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 0.65rem;
		border-bottom: 1px solid #f2f2f2;
		font-size: 0.62rem;
	}
	.rt-result-item:last-child { border-bottom: none; }
	.rt-result-check {
		width: 16px;
		height: 16px;
		background: #22c55e;
		color: #fff;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.5rem;
		font-weight: 700;
		flex-shrink: 0;
	}
	.rt-result-img {
		width: 28px;
		height: 28px;
		border-radius: 5px;
		flex-shrink: 0;
	}
	.rt-result-img--black { background: #1a1a1a; }
	.rt-result-img--denim { background: #3a5a8c; }
	.rt-result-img--white { background: #d4c5b2; }
	.rt-result-img--red   { background: #f5e6d3; }
	.rt-result-info { flex: 1; min-width: 0; }
	.rt-result-name { font-weight: 600; color: #222; font-size: 0.6rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.rt-result-meta { display: flex; align-items: center; gap: 0.3rem; margin-top: 1px; }
	.rt-result-sku { color: #aaa; font-size: 0.52rem; font-family: monospace; }
	.rt-result-stock { font-size: 0.52rem; margin-top: 1px; }
	.rt-result-stock--ok { color: #22c55e; }
	.rt-result-price { font-weight: 700; color: #111; font-size: 0.65rem; flex-shrink: 0; }

	/* ── System state ── */
	.rt-system {
		display: grid;
		grid-template-columns: 1fr auto 1fr auto 1fr;
		gap: 0;
		align-items: center;
	}
	.rt-sys-win {
		background: #fff;
		border: 1px solid #e5e5e5;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(0,0,0,0.07);
		position: relative;
	}
	.rt-sys-win__header {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid #f0f0f0;
		font-size: 0.68rem;
		font-weight: 700;
		color: #222;
		background: #fafafa;
	}
	.rt-sys-row--active td { background: rgba(255,77,109,0.04); }

	/* connectors */
	.rt-sys__connectors {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0;
		padding: 0 0.25rem;
	}
	.rt-sys__connector-line {
		width: 1px;
		height: 30px;
		background: #ddd;
	}
	.rt-sys__check {
		width: 22px;
		height: 22px;
		background: #22c55e;
		color: #fff;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.65rem;
		font-weight: 700;
		flex-shrink: 0;
		box-shadow: 0 2px 8px rgba(34,197,94,0.3);
	}

	/* Success badges — inline in flow */
	.rt-success-badge {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: #f0fdf4;
		border: 1px solid #bbf7d0;
		border-radius: 20px;
		padding: 0.3rem 0.7rem;
		font-size: 0.6rem;
		font-weight: 600;
		color: #166534;
		box-shadow: 0 2px 8px rgba(34,197,94,0.1);
	}
	.rt-success-badge__icon {
		display: inline-flex;
		width: 14px;
		height: 14px;
		background: #22c55e;
		color: #fff;
		border-radius: 50%;
		align-items: center;
		justify-content: center;
		font-size: 0.55rem;
		font-weight: 700;
		flex-shrink: 0;
	}
	/* tag cards */
	.rt-sys-win--tags {
		padding-top: 1.25rem;
	}
	.rt-tag-cards {
		display: flex;
		gap: 0.5rem;
		padding: 0.5rem;
	}
	.rt-tag-card {
		flex: 1;
		background: #fafafa;
		border: 1px solid #ebebeb;
		border-radius: 8px;
		overflow: hidden;
		font-size: 0.58rem;
	}
	.rt-tag-card--mid {
		opacity: 0.75;
		transform: scale(0.97);
	}
	.rt-tag-card__img {
		height: 42px;
		background: #eee;
	}
	.rt-tag-card__img--black { background: #1a1a1a; }
	.rt-tag-card__img--white { background: #f5f0e8; }
	.rt-tag-card__img--denim { background: #3a5a8c; }
	.rt-tag-card__meta { padding: 0.35rem 0.4rem; display: flex; flex-direction: column; gap: 2px; }
	.rt-tag-card__row { display: flex; align-items: center; justify-content: space-between; gap: 0.25rem; }
	.rt-tag-card__label { color: #aaa; font-size: 0.52rem; }
	.rt-tag-card__val { color: #333; font-weight: 500; font-size: 0.55rem; }
	.rt-tag-card__val--code { color: #888; font-family: monospace; }
	.rt-tag-badge {
		font-size: 0.5rem;
		font-weight: 600;
		padding: 1px 5px;
		border-radius: 10px;
	}
	.rt-tag-badge--tshirt { background: #fce7f3; color: #9d174d; }
	.rt-tag-badge--hoodie { background: #ede9fe; color: #5b21b6; }
	.rt-tag-badge--denim  { background: #dbeafe; color: #1e40af; }

	/* Color dots in catalog */
	.rt-color-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		border: 1px solid #ddd;
		vertical-align: middle;
	}
	.rt-color-dot--white { background: #fff; }
	.rt-color-dot--black { background: #111; border-color: #999; }
	.rt-color-dot--purple { background: #7c3aed; }
	.rt-color-dot--blue { background: #2563eb; }
	.rt-color-dot--red { background: #dc2626; }

	/* Type badges */
	.rt-type-badge {
		display: inline-block;
		font-size: 0.55rem;
		font-weight: 600;
		padding: 1px 6px;
		border-radius: 10px;
	}
	.rt-type-badge--tshirt { background: #fce7f3; color: #9d174d; }
	.rt-type-badge--jacket { background: #ede9fe; color: #5b21b6; }
	.rt-type-badge--pants  { background: #dbeafe; color: #1e40af; }

	/* Img thumb */
	.rt-img-thumb {
		display: inline-block;
		width: 18px;
		height: 18px;
		background: #f0f0f0;
		border-radius: 3px;
		border: 1px solid #e5e5e5;
	}

	@media (max-width: 900px) {
		.rt-flow {
			grid-template-columns: 1fr 28px 1fr;
		}
		/* hide 4th and 5th children (2nd arrow + result col) */
		.rt-flow > *:nth-child(4),
		.rt-flow > *:nth-child(5) { display: none; }
	}
	@media (max-width: 600px) {
		.rt-flow {
			grid-template-columns: 1fr;
		}
		.rt-flow__arrow { display: none; }
		.rt-flow > *:nth-child(4),
		.rt-flow > *:nth-child(5) { display: none; }
		.rt-sheets-stack { height: 130px; }
	}

	/* ═══════════════════════════════════════════════ */
	/* LOGO BAR                                       */
	/* ═══════════════════════════════════════════════ */
	.rt-logos {
		padding: 3.5rem 0;
		border-top: 1px solid var(--border-muted);
		border-bottom: 1px solid var(--border-muted);
		margin-top: 4rem;
	}
	.rt-logos__row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2.5rem;
		flex-wrap: wrap;
	}
	.rt-logo-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: #666;
		opacity: 0.7;
		transition: opacity 0.2s;
	}
	.rt-logo-item:hover { opacity: 1; }

	/* ═══════════════════════════════════════════════ */
	/* FEATURES BENTO GRID                            */
	/* ═══════════════════════════════════════════════ */
	.rt-features {
		padding: 6rem 0;
	}
	.rt-features__header {
		text-align: center;
		margin-bottom: 3rem;
	}
	.rt-features__title {
		font-size: clamp(1.8rem, 3.5vw, 2.8rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: 0.75rem;
	}
	.rt-features__subtitle {
		font-size: 1rem;
		color: var(--text-secondary);
		max-width: 520px;
		margin: 0 auto 1.5rem;
		line-height: 1.6;
	}

	/* Bento grid */
	.rt-bento {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-template-rows: auto auto auto;
		gap: 1rem;
	}
	.rt-bento-card {
		background: #fff;
		border: 1px solid #ebebeb;
		border-radius: 20px;
		padding: 1.75rem;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
		overflow: hidden;
	}
	.rt-bento-card:hover {
		box-shadow: 0 8px 40px rgba(0,0,0,0.07);
		transform: translateY(-2px);
	}
	.rt-bento-card--lg {
		grid-column: span 1;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.rt-bento-card--1 { grid-column: 1 / 2; grid-row: 1; }
	.rt-bento-card--2 { grid-column: 2 / 3; grid-row: 1; }
	.rt-bento-card--3 { grid-column: 3 / 4; grid-row: 1 / 3; }
	.rt-bento-card--4 { grid-column: 1 / 2; grid-row: 2; }
	.rt-bento-card--5 { grid-column: 2 / 3; grid-row: 2; }
	.rt-bento-card--6 {
		grid-column: 1 / 4;
		grid-row: 3;
		background: linear-gradient(135deg, #fff8f9 0%, #fff 100%);
	}
	.rt-bento-card--md {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.rt-bento-card__icon {
		font-size: 1.5rem;
		margin-bottom: 0.25rem;
	}
	.rt-bento-card h3 {
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text-primary);
	}
	.rt-bento-card p {
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.6;
	}
	.rt-bento-card__content {
		flex-shrink: 0;
	}
	.rt-bento-card__visual {
		flex: 1;
		display: flex;
		align-items: flex-end;
	}

	/* Mini task list dashboard */
	.rt-mini-dash {
		background: #fafafa;
		border: 1px solid #f0f0f0;
		border-radius: 10px;
		overflow: hidden;
		font-size: 0.68rem;
		width: 100%;
	}
	.rt-mini-dash__row {
		display: grid;
		grid-template-columns: 1fr auto auto;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		align-items: center;
		border-bottom: 1px solid #f0f0f0;
	}
	.rt-mini-dash__row:last-child { border-bottom: none; }
	.rt-mini-dash__row--header {
		background: #f5f5f5;
		font-weight: 600;
		color: #999;
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.rt-mini-dash__row--active { background: rgba(255,77,109,0.03); }
	.rt-badge {
		font-size: 0.6rem;
		font-weight: 600;
		padding: 2px 7px;
		border-radius: 20px;
		white-space: nowrap;
	}
	.rt-badge--green { background: #dcfce7; color: #16a34a; }
	.rt-badge--pink { background: rgba(255,77,109,0.1); color: var(--accent-primary); }
	.rt-badge--gray { background: #f3f4f6; color: #888; }

	/* Inventory bar chart */
	.rt-inv-chart {
		width: 100%;
	}
	.rt-inv-chart__label {
		font-size: 0.65rem;
		color: #999;
		font-weight: 500;
		margin-bottom: 0.75rem;
	}
	.rt-inv-bar-group {
		display: flex;
		align-items: flex-end;
		gap: 8px;
		height: 80px;
	}
	.rt-inv-bar-wrap {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		height: 100%;
		justify-content: flex-end;
	}
	.rt-inv-bar-wrap span {
		font-size: 0.55rem;
		color: #bbb;
		white-space: nowrap;
	}
	.rt-inv-bar {
		width: 100%;
		border-radius: 4px 4px 0 0;
	}
	.rt-inv-bar--full { background: var(--accent-primary); opacity: 0.85; }
	.rt-inv-bar--mid { background: var(--accent-primary); opacity: 0.5; }
	.rt-inv-bar--low { background: #ffb3c0; opacity: 0.6; }

	/* Testimonial bento card */
	.rt-bento-card--testimonial {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.rt-bento-quote {
		font-size: 1.05rem;
		font-style: italic;
		color: var(--text-primary);
		line-height: 1.6;
		font-weight: 500;
		margin: 0;
	}
	.rt-bento-quote__author {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: auto;
	}
	.rt-bento-quote__avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--accent-primary), #ff8fa3);
		flex-shrink: 0;
	}
	.rt-bento-quote__author strong {
		display: block;
		font-size: 0.85rem;
		font-weight: 700;
	}
	.rt-bento-quote__author span {
		font-size: 0.75rem;
		color: var(--text-secondary);
	}
	.rt-bento-quote__logo {
		margin-left: auto;
	}

	/* ═══════════════════════════════════════════════ */
	/* PROCESS SECTION                                */
	/* ═══════════════════════════════════════════════ */
	.rt-process {
		padding: 6rem 0;
		background: #fafafa;
		border-top: 1px solid var(--border-muted);
		border-bottom: 1px solid var(--border-muted);
	}
	.rt-process__layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
	}
	.rt-process__title {
		font-size: clamp(1.8rem, 3vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: 2.5rem;
	}
	.rt-process__steps {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.rt-process__step {
		padding-bottom: 1.75rem;
		padding-left: 1.5rem;
		border-left: 2px solid #eee;
		position: relative;
		margin-left: 0.5rem;
	}
	.rt-process__step:last-child {
		padding-bottom: 0;
		border-left-color: transparent;
	}
	.rt-process__step-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.5rem;
	}
	.rt-process__step-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #ddd;
		flex-shrink: 0;
		position: absolute;
		left: -6px;
		top: 4px;
	}
	.rt-process__step-dot--active {
		background: var(--accent-primary);
		box-shadow: 0 0 0 3px rgba(255,77,109,0.2);
	}
	.rt-process__step h3 {
		font-size: 1rem;
		font-weight: 700;
		color: var(--text-primary);
	}
	.rt-process__step p {
		font-size: 0.88rem;
		color: var(--text-secondary);
		line-height: 1.65;
	}

	/* Process mock */
	.rt-process__mock {
		background: #fff;
		border: 1px solid #e5e5e5;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 12px 40px rgba(0,0,0,0.07);
	}
	.rt-process__mock-header {
		padding: 0.65rem 1rem;
		background: #fafafa;
		border-bottom: 1px solid #eeeeee;
	}
	.rt-process__mock-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.rt-process-mock__row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 0;
	}
	.rt-process-mock__label {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--text-secondary);
	}
	.rt-process-mock__tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	.rt-tag {
		font-size: 0.65rem;
		font-weight: 600;
		padding: 3px 8px;
		border-radius: 20px;
		background: #f3f4f6;
		color: #888;
	}
	.rt-tag--active {
		background: rgba(255,77,109,0.1);
		color: var(--accent-primary);
	}
	.rt-tag--green {
		background: #dcfce7;
		color: #16a34a;
	}
	.rt-process-mock__divider {
		height: 1px;
		background: #f0f0f0;
	}
	.rt-process-mock__stat-row {
		display: flex;
		gap: 1.5rem;
		padding-top: 1rem;
	}
	.rt-process-mock__stat {
		display: flex;
