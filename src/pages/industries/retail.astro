---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="AI-Managed Retail Operations | AquiferGrowth" description="AquiferGrowth builds and manages AI-powered operating systems for retail businesses — replacing manual ops roles with autonomous systems that scale across every store function.">
	<Header />

	<main>
		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO SECTION                               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="rt-hero">
			<div class="rt-hero__bg-blur"></div>
			<div class="rt-hero__bg-blur rt-hero__bg-blur--right"></div>
			<div class="rt-hero__inner container">
				<h1 class="rt-hero__title">
					Automate retail operations
				</h1>
				<p class="rt-hero__subtitle">
					AquiferGrowth builds and manages the AI operating layer behind your retail business —<br class="hide-mobile">
					so you can focus on growing, not managing spreadsheets and chasing down tasks.
				</p>

				<div class="rt-hero__cta-row">
					<a href="/contact" class="rt-btn rt-btn--primary">Book a Demo</a>
					<a href="/contact" class="rt-btn rt-btn--outline">See Our Process</a>
				</div>

				<!-- Problem → Centralization → Solution -->
				<div class="rt-hero__visual-wrap">
					<div class="rt-flow">

						<!-- ── COL 1: PROBLEM ── -->
						<div class="rt-flow__col">
							<div class="rt-flow__label rt-flow__label--problem">The Problem</div>
							<div class="rt-flow__panel rt-flow__panel--chaos">
								<!-- Stacked messy spreadsheets -->
								<div class="rt-sheets-stack">
									<div class="rt-sheet rt-sheet--back">
										<div class="rt-sheet__titlebar">
											<span class="rt-sheet__icon rt-sheet__icon--excel"></span>
											Inventory for July 2025, I guess7.csv
											<span class="rt-sheet__close">✕</span>
										</div>
										<table class="rt-sheet__table">
											<thead><tr><th>A</th><th>B</th><th>C</th><th>D</th></tr></thead>
											<tbody>
												<tr><td>1</td><td>Product</td><td>Color</td><td>SKU</td></tr>
												<tr><td>2</td><td>Jacket</td><td></td><td>SKU12345</td></tr>
												<tr><td>3</td><td>Trendy Pants</td><td>Blue</td><td>SKU67890</td></tr>
												<tr><td>4</td><td></td><td></td><td><span class="rt-err-x">✕</span></td></tr>
											</tbody>
										</table>
									</div>
									<div class="rt-sheet rt-sheet--front">
										<div class="rt-sheet__titlebar">
											<span class="rt-sheet__icon rt-sheet__icon--excel"></span>
											Untitled.xlsx
											<span class="rt-sheet__close">✕</span>
										</div>
										<table class="rt-sheet__table">
											<thead><tr><th>A</th><th>B</th><th>C</th><th>D</th></tr></thead>
											<tbody>
												<tr><td>1</td><td>Product</td><td>Color</td><td>SKU</td></tr>
												<tr><td>2</td><td>Stylish Jacket</td><td>Red</td><td></td></tr>
												<tr><td>3</td><td>Trendy Pants</td><td></td><td><span class="rt-err-x">✕</span></td></tr>
												<tr><td>4</td><td>Chic Blouse</td><td>Green</td><td>SKU11223</td></tr>
											</tbody>
										</table>
									</div>
								</div>
								<!-- Problem badges -->
								<div class="rt-flow__badges">
									<div class="rt-warn-badge"><span class="rt-warn-badge__icon">⚠</span>Inaccurate Product Data from Manual Updates</div>
									<div class="rt-warn-badge"><span class="rt-warn-badge__icon">⚠</span>Lack of Alignment — No Single Source of Truth</div>
									<div class="rt-warn-badge"><span class="rt-warn-badge__icon">⚠</span>Unreliable Tagging from Manual Management</div>
								</div>
							</div>
						</div>

						<!-- ── ARROW ── -->
						<div class="rt-flow__arrow">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="var(--accent-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</div>

						<!-- ── COL 2: AQUIFERGROWTH AI HUB ── -->
						<div class="rt-flow__col rt-flow__col--center">
							<div class="rt-flow__label rt-flow__label--center">AquiferGrowth AI</div>
							<div class="rt-flow__panel rt-flow__panel--hub">
								<!-- AI Execution Layer: 3 blocks -->
								<div class="rt-hub">

									<!-- Block 1: Sources -->
									<div class="rt-hub__block">
										<div class="rt-hub__block-label">Sources</div>
										<div class="rt-hub__chips">
											<div class="rt-hub__chip">
												<span class="rt-hub__chip-dot" style="background:#96bf48"></span>
												Shopify
											</div>
											<div class="rt-hub__chip">
												<span class="rt-hub__chip-dot" style="background:#0f9d58"></span>
												Google Sheets
											</div>
											<div class="rt-hub__chip">
												<span class="rt-hub__chip-dot" style="background:#217346"></span>
												Excel / CSV
											</div>
										</div>
									</div>

									<!-- Down arrow -->
									<div class="rt-hub__down-arrow">
										<svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 1v16M2 12l6 6 6-6" stroke="var(--accent-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
									</div>

									<!-- Block 2: Centralized table -->
									<div class="rt-hub__block rt-hub__block--center">
										<div class="rt-hub__block-label">Centralised</div>
										<table class="rt-hub__table">
											<thead>
												<tr>
													<th>SKU</th>
													<th>Product</th>
													<th>Type</th>
													<th>Stock</th>
													<th></th>
												</tr>
											</thead>
											<tbody>
												<tr>
													<td class="rt-hub__td-mono">TSHRT-001</td>
													<td>Oversized Tee</td>
													<td><span class="rt-type-badge rt-type-badge--tshirt">T-shirt</span></td>
													<td>100</td>
													<td><span class="rt-hub__synced">✓</span></td>
												</tr>
												<tr>
													<td class="rt-hub__td-mono">JKT-002</td>
													<td>Slim Jacket</td>
													<td><span class="rt-type-badge rt-type-badge--jacket">Jacket</span></td>
													<td>278</td>
													<td><span class="rt-hub__synced">✓</span></td>
												</tr>
												<tr>
													<td class="rt-hub__td-mono">PNTS-001</td>
													<td>Chic Trousers</td>
													<td><span class="rt-type-badge rt-type-badge--pants">Pants</span></td>
													<td>334</td>
													<td><span class="rt-hub__synced">✓</span></td>
												</tr>
											</tbody>
										</table>
									</div>

									<!-- Down arrow -->
									<div class="rt-hub__down-arrow">
										<svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 1v16M2 12l6 6 6-6" stroke="var(--accent-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
									</div>

									<!-- Block 3: Execution -->
									<div class="rt-hub__block rt-hub__block--exec">
										<div class="rt-hub__block-label">Execution</div>
										<div class="rt-hub__exec-rows">
											<div class="rt-hub__exec-row rt-hub__exec-row--done">
												<span class="rt-hub__exec-dot rt-hub__exec-dot--green"></span>
												Synced 1,204 SKUs
											</div>
											<div class="rt-hub__exec-row rt-hub__exec-row--done">
												<span class="rt-hub__exec-dot rt-hub__exec-dot--green"></span>
												Tags normalised
											</div>
											<div class="rt-hub__exec-row rt-hub__exec-row--active">
												<span class="rt-hub__exec-dot rt-hub__exec-dot--pulse"></span>
												Pushing to Shopify…
											</div>
										</div>
									</div>

								</div>
							</div>
						</div>

						<!-- ── ARROW ── -->
						<div class="rt-flow__arrow">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="var(--accent-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</div>

						<!-- ── COL 3: THE RESULT ── -->
						<div class="rt-flow__col">
							<div class="rt-flow__label rt-flow__label--solution">The Result</div>
							<div class="rt-flow__panel rt-flow__panel--clean">
								<!-- Product listings with checkmarks -->
								<div class="rt-result-listings">
									<div class="rt-result-item">
										<span class="rt-result-check">✓</span>
										<div class="rt-result-img rt-result-img--black"></div>
										<div class="rt-result-info">
											<div class="rt-result-name">Oversized Tee — Black</div>
											<div class="rt-result-meta"><span class="rt-type-badge rt-type-badge--tshirt">T-shirt</span> <span class="rt-result-sku">TSHRT-001</span></div>
											<div class="rt-result-stock rt-result-stock--ok">✓ 100 in stock</div>
										</div>
										<div class="rt-result-price">$30.00</div>
									</div>
									<div class="rt-result-item">
										<span class="rt-result-check">✓</span>
										<div class="rt-result-img rt-result-img--denim"></div>
										<div class="rt-result-info">
											<div class="rt-result-name">Slim Jacket — Purple</div>
											<div class="rt-result-meta"><span class="rt-type-badge rt-type-badge--jacket">Jacket</span> <span class="rt-result-sku">JKT-002</span></div>
											<div class="rt-result-stock rt-result-stock--ok">✓ 278 in stock</div>
										</div>
										<div class="rt-result-price">$89.00</div>
									</div>
									<div class="rt-result-item">
										<span class="rt-result-check">✓</span>
										<div class="rt-result-img rt-result-img--white"></div>
										<div class="rt-result-info">
											<div class="rt-result-name">Chic Trousers — Blue</div>
											<div class="rt-result-meta"><span class="rt-type-badge rt-type-badge--pants">Pants</span> <span class="rt-result-sku">PNTS-001</span></div>
											<div class="rt-result-stock rt-result-stock--ok">✓ 334 in stock</div>
										</div>
										<div class="rt-result-price">$55.00</div>
									</div>
									<div class="rt-result-item">
										<span class="rt-result-check">✓</span>
										<div class="rt-result-img rt-result-img--red"></div>
										<div class="rt-result-info">
											<div class="rt-result-name">Classic Hoodie — Beige</div>
											<div class="rt-result-meta"><span class="rt-type-badge rt-type-badge--jacket">Hoodie</span> <span class="rt-result-sku">HOOD-001</span></div>
											<div class="rt-result-stock rt-result-stock--ok">✓ 499 in stock</div>
										</div>
										<div class="rt-result-price">$65.00</div>
									</div>
								</div>
								<!-- Success badges -->
								<div class="rt-flow__badges">
									<div class="rt-success-badge"><span class="rt-success-badge__icon">✓</span>Accurate, Centralised Product Data</div>
									<div class="rt-success-badge"><span class="rt-success-badge__icon">✓</span>Real-time Inventory Sync Across All Channels</div>
									<div class="rt-success-badge"><span class="rt-success-badge__icon">✓</span>Reliable Tagging with Systematic Governance</div>
								</div>
							</div>
						</div>

					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- LOGO BAR                                   -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="rt-logos">
			<div class="container">
				<div class="rt-logos__row">
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="#1A1A1A"/></svg>
						loops
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="#1A1A1A" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						CARTO
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="#1A1A1A" stroke-width="1.5"/><path d="M9 9h6M9 12h6M9 15h3" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Framer
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 4h16v16H4z" stroke="#1A1A1A" stroke-width="1.5"/><path d="M4 12h8v8" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						WebFlow
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#1A1A1A" stroke-width="1.5"/><path d="M8 12l3 3 5-5" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Shopify
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#1A1A1A" stroke-width="1.5"/><path d="M2 17l10 5 10-5" stroke="#1A1A1A" stroke-width="1.5"/><path d="M2 12l10 5 10-5" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Asana
					</span>
					<span class="rt-logo-item">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 12h4l3-9 4 18 3-9h4" stroke="#1A1A1A" stroke-width="1.5"/></svg>
						Klaviyo
					</span>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- FEATURES BENTO GRID                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="rt-features">
			<div class="container">
				<div class="rt-features__header">
					<h2 class="rt-features__title">Retail Runs Better with<br>Automated Operations</h2>
					<p class="rt-features__subtitle">From store ops to finance, we build and run the AI systems that keep every part of your retail business moving.</p>
					<a href="/contact" class="rt-btn rt-btn--pink-sm">Book a Demo →</a>
				</div>

				<div class="rt-bento">
					<!-- Card 1: Store Operations (large, top-left) -->
					<div class="rt-bento-card rt-bento-card--lg rt-bento-card--1">
						<div class="rt-bento-card__content">
							<div class="rt-bento-card__icon">🏪</div>
							<h3>Store Operations Management</h3>
							<p>Centralize and automate your store's daily workflows — from scheduling to task management — with AI that keeps everything on track.</p>
						</div>
						<div class="rt-bento-card__visual">
							<div class="rt-mini-dash">
								<div class="rt-mini-dash__row rt-mini-dash__row--header">
									<span>Task</span><span>Status</span><span>Due</span>
								</div>
								<div class="rt-mini-dash__row rt-mini-dash__row--done">
									<span>Floor restock</span><span class="rt-badge rt-badge--green">Done</span><span>9am</span>
								</div>
								<div class="rt-mini-dash__row rt-mini-dash__row--active">
									<span>EOD reporting</span><span class="rt-badge rt-badge--pink">Live</span><span>5pm</span>
								</div>
								<div class="rt-mini-dash__row">
									<span>Supplier follow-up</span><span class="rt-badge rt-badge--gray">Queued</span><span>Fri</span>
								</div>
							</div>
						</div>
					</div>

					<!-- Card 2: Inventory (large, top-right) -->
					<div class="rt-bento-card rt-bento-card--lg rt-bento-card--2">
						<div class="rt-bento-card__content">
							<div class="rt-bento-card__icon">📦</div>
							<h3>Inventory Management</h3>
							<p>Real-time stock tracking, automated reorder triggers, and AI-driven demand forecasting — no more stockouts or overbuying.</p>
						</div>
						<div class="rt-bento-card__visual">
							<div class="rt-inv-chart">
								<div class="rt-inv-chart__label">Stock Levels — Top SKUs</div>
								<div class="rt-inv-bar-group">
									<div class="rt-inv-bar-wrap">
										<div class="rt-inv-bar rt-inv-bar--full" style="height: 60px;"></div>
										<span>SKU-001</span>
									</div>
									<div class="rt-inv-bar-wrap">
										<div class="rt-inv-bar rt-inv-bar--mid" style="height: 40px;"></div>
										<span>SKU-002</span>
									</div>
									<div class="rt-inv-bar-wrap">
										<div class="rt-inv-bar rt-inv-bar--low" style="height: 18px;"></div>
										<span>SKU-003</span>
									</div>
									<div class="rt-inv-bar-wrap">
										<div class="rt-inv-bar rt-inv-bar--full" style="height: 52px;"></div>
										<span>SKU-004</span>
									</div>
									<div class="rt-inv-bar-wrap">
										<div class="rt-inv-bar rt-inv-bar--mid" style="height: 35px;"></div>
										<span>SKU-005</span>
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Card 3: Marketing (medium) -->
					<div class="rt-bento-card rt-bento-card--md rt-bento-card--3">
						<div class="rt-bento-card__icon">📣</div>
						<h3>Marketing Operations</h3>
						<p>AI-managed campaigns, promotions, and customer communications — launched and optimized automatically.</p>
					</div>

					<!-- Card 4: PBs & Admin (medium) -->
					<div class="rt-bento-card rt-bento-card--md rt-bento-card--4">
						<div class="rt-bento-card__icon">🗂️</div>
						<h3>PBs &amp; Admin Operations</h3>
						<p>Playbooks, SOPs, and admin workflows managed by AI — so nothing falls through the cracks as you scale.</p>
					</div>

					<!-- Card 5: Finance (medium) -->
					<div class="rt-bento-card rt-bento-card--md rt-bento-card--5">
						<div class="rt-bento-card__icon">💰</div>
						<h3>Finance</h3>
						<p>Automated reconciliation, spend tracking, and financial reporting — visibility without the manual grind.</p>
					</div>

					<!-- Card 6: Testimonial -->
					<div class="rt-bento-card rt-bento-card--testimonial rt-bento-card--6">
						<blockquote class="rt-bento-quote">
							"I used Contractors/Freelancers and an in-house team — now AquiferGrowth has saved me time by auto-categorizing our transactions more accurately."
						</blockquote>
						<div class="rt-bento-quote__author">
							<div class="rt-bento-quote__avatar"></div>
							<div>
								<strong>Sarah Chen</strong>
								<span>Head of Operations • RetailCore</span>
							</div>
							<svg class="rt-bento-quote__logo" width="80" height="20" viewBox="0 0 80 20"><text x="0" y="15" font-size="12" fill="#ccc" font-family="sans-serif">AquiferGrowth</text></svg>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════════ -->
		<!-- OUR PROCESS                                -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="rt-process">
			<div class="container">
				<div class="rt-process__layout">
					<div class="rt-process__left">
						<h2 class="rt-process__title">
							Our process makes it<br>
							easier than ever before
						</h2>

						<div class="rt-process__steps">
							<div class="rt-process__step">
								<div class="rt-process__step-header">
									<span class="rt-process__step-dot rt-process__step-dot--active"></span>
									<h3>Data Centrality</h3>
								</div>
								<p>We consolidate all your retail data — inventory, sales, ops, finance — into a single source of truth that AI can act on in real time.</p>
							</div>
							<div class="rt-process__step">
								<div class="rt-process__step-header">
									<span class="rt-process__step-dot"></span>
									<h3>Goal Communication</h3>
								</div>
								<p>We align with your business objectives and configure autonomous systems to optimize toward the outcomes that matter most to you.</p>
							</div>
							<div class="rt-process__step">
								<div class="rt-process__step-header">
									<span class="rt-process__step-dot"></span>
									<h3>Build Operations</h3>
								</div>
								<p>We deploy, manage, and continuously improve your AI-powered operations — handling every function from store ops to finance on autopilot.</p>
							</div>
						</div>
					</div>

					<div class="rt-process__right">
						<div class="rt-process__mock">
							<div class="rt-process__mock-header">
								<div class="rt-dash__dots">
									<span class="rt-dash__dot rt-dash__dot--red"></span>
									<span class="rt-dash__dot rt-dash__dot--yellow"></span>
									<span class="rt-dash__dot rt-dash__dot--green"></span>
								</div>
							</div>
							<div class="rt-process__mock-body">
								<div class="rt-process-mock__row">
									<span class="rt-process-mock__label">Data Sources</span>
									<div class="rt-process-mock__tags">
										<span class="rt-tag rt-tag--active">Shopify</span>
										<span class="rt-tag">Asana</span>
										<span class="rt-tag">Sheets</span>
									</div>
								</div>
								<div class="rt-process-mock__divider"></div>
								<div class="rt-process-mock__row">
									<span class="rt-process-mock__label">Goals Set</span>
