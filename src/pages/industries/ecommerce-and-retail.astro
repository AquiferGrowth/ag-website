  .en-vis-status__icon {
    width: 14px; height: 14px;
    background: var(--accent-primary);
    color: #fff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 800;
    margin-right: 0.3rem;
    line-height: 0;
    flex-shrink: 0;
  }
  .en-vis-status__icon svg {
    display: block;
  }
  .en-vis-status__label { color: #444; font-weight: 600; font-size: 0.7rem; flex: 1; }
  .en-vis-status__val { color: #1a1a1a; font-weight: 700; font-size: 0.7rem; }
  .en-vis-status__val--warn { color: #b45309; }
  .en-vis-status__tags { display: inline-flex; gap: 3px; }
  .en-vis-status__tags i {
    background: rgba(0,0,0,0.06);
    border-radius: 4px;
    padding: 0.15rem 0.35rem;
    font-style: normal;
    font-size: 0.62rem;
