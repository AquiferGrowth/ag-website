    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .badge {
    background: #1A1A1A;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-indent: 0.12em;
    display: inline-block;
  }

  /* ───── Primary CTA (matches ecommerce page) ───── */
  .ec-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    background: #FF7A7A;
    color: #1A1A1A;
    padding: 0.9rem 1.5rem;
    border: 2px solid #000;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: none;
    text-decoration: none;
    letter-spacing: -0.005em;
    box-shadow: 4px 4px 0 #000;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                box-shadow 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                background 0.2s ease;
  }
  .ec-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
    background: #ff9d9d;
  }
  .ec-btn:active {
    transform: translate(0, 0);
    box-shadow: 0 0 0 #000;
  }
  .ec-animated-dots {
    display: inline-flex;
    gap: 3px;
  }
  .ec-animated-dots span {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #1a1a1a;
    animation: en-dot-bounce 1.2s ease-in-out infinite;
  }
  .ec-animated-dots span:nth-child(2) { animation-delay: 0.15s; }
  .ec-animated-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes en-dot-bounce {
    0%, 80%, 100% { opacity: 0.4; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-2px); }
  }

  /* ═══════ HERO ═══════ */
  .en-hero {
    position: relative;
    padding: 3rem 0 1rem;
    text-align: center;
    overflow: hidden;
  }
  .en-hero__bg-blur {
    position: absolute;
    top: -120px;
    left: -120px;
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(255, 77, 109, 0.18), transparent 70%);
    pointer-events: none;
  }
  .en-hero__bg-blur--right {
    left: auto;
    right: -120px;
    background: radial-gradient(circle, rgba(255, 126, 95, 0.16), transparent 70%);
  }
  .en-hero__inner { position: relative; z-index: 1; max-width: 1080px; margin: 0 auto; padding: 0 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .en-hero .badge { margin: 0; }
  .en-hero__eyebrow {
    display: inline-block;
    background: var(--accent-primary);
    color: #fff;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }
  .en-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    text-transform: uppercase;
    margin: 0;
    text-wrap: balance;
  }
  .en-hero__title--fire {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    max-width: none;
  }
  .en-hero--fire {
    animation: enHeroFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes enHeroFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .en-hero__subtitle {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 56ch;
    margin: 0;
  }
  .en-hero__cta-row { display: flex; justify-content: center; gap: 1rem; }
  .en-hero__image {
    margin: 3rem auto 0;
    max-width: 1200px;
    width: 100%;
    padding: 0 1rem;
  }
  .en-hero__image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 18px;
  }

  /* ═══════ YOUR TYPICAL TUESDAY ═══════ */
  .en-tuesday { padding: 2.5rem 0; }
  .en-tuesday__sheet {
    background: var(--bg-secondary);
    border-radius: 44px;
    padding: 2.4rem 2rem 2rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
  }
  .en-tuesday__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 2rem;
  }
  .en-tuesday__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(1.75rem, 3.6vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .en-tuesday__subtitle {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }
  .en-tuesday__window {
    position: relative;
    height: 600px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
  }
  .en-tuesday__track-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.25rem 0;
    will-change: transform;
  }
  .en-tuesday__row {
    display: flex;
  }
  .en-tuesday__row--left  { justify-content: flex-start; }
  .en-tuesday__row--right { justify-content: flex-end; }
  .en-tuesday__card {
    display: flex;
    gap: 1rem;
    align-items: center;
    width: 48%;
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    padding: 0.8rem 1.1rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }
  .en-tuesday__card--left  { border-left: 3px solid var(--accent-primary); }
  .en-tuesday__card--right {
    border-right: 3px solid var(--accent-primary);
    flex-direction: row-reverse;
  }
  .en-tuesday__time {
    flex-shrink: 0;
    width: 92px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .en-tuesday__time-hh {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--accent-primary);
  }
  .en-tuesday__time-ampm {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--text-secondary);
    margin-top: 3px;
  }
  .en-tuesday__text {
    flex: 1;
    min-width: 0;
    text-align: left;
  }
  .en-tuesday__card--right .en-tuesday__text { text-align: right; }
  .en-tuesday__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0.2rem 0 0.3rem;
    text-transform: none;
  }
  .en-tuesday__detail {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0.3rem 0 0;
  }
  .en-tuesday__connector { height: 58px; }
  .en-tuesday__connector svg { width: 100%; height: 58px; display: block; }
  .en-tuesday__scrubber {
    max-width: 960px;
    margin: 1.75rem auto 0.25rem;
  }
  .en-tuesday__track {
    position: relative;
    height: 22px;
    display: flex;
    align-items: center;
    cursor: pointer;
    touch-action: none;
  }
  .en-tuesday__track-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    pointer-events: none;
  }
  .en-tuesday__dot {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--accent-primary);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 4px rgba(255, 77, 109, 0.15);
    pointer-events: none;
  }
  .en-tuesday__labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.85rem;
    flex-wrap: nowrap;
  }
  .en-tuesday__label-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    padding: 2px 3px;
    transition: color 0.15s ease;
  }
  .en-tuesday__label-btn:hover { color: var(--accent-primary); }

  /* ── Bridge + profile cards inside the Tuesday sheet ── */
  .en-tuesday__divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(0,0,0,0.08), transparent);
    margin: 2.75rem auto 0;
    max-width: 960px;
  }
  .en-tuesday__bridge {
    text-align: center;
    max-width: 720px;
    margin: 2.25rem auto 2rem;
  }
  .en-tuesday__bridge-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }
  .en-tuesday__bridge-title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(1.6rem, 3vw, 2.15rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    margin: 0 0 0.9rem;
    text-wrap: balance;
  }
  .en-tuesday__bridge-body {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto;
  }
  .en-tuesday__profile-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  .en-tuesday__profile {
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-top: 3px solid var(--accent-primary);
    border-radius: 14px;
    padding: 1.5rem 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .en-tuesday__profile-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 77, 109, 0.08);
    color: var(--accent-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.3rem;
  }
  .en-tuesday__profile-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--text-primary);
    text-transform: none;
    margin: 0;
  }
  .en-tuesday__profile-body {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }
  .en-tuesday__profile-body code {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.82em;
    color: var(--text-primary);
  }

  @media (max-width: 720px) {
    .en-tuesday__sheet { padding: 1.5rem 1rem; border-radius: 24px; }
    .en-tuesday__window { height: 520px; }
    .en-tuesday__card { width: 92%; }
    .en-tuesday__row--right,
    .en-tuesday__row--left { justify-content: center; }
    .en-tuesday__connector { height: 40px; }
    .en-tuesday__connector svg { height: 40px; }
    .en-tuesday__label-btn { font-size: 0.55rem; padding: 2px 1px; }
    .en-tuesday__time { width: 70px; }
    .en-tuesday__time-hh { font-size: 1.4rem; }
    .en-tuesday__headline { font-size: 0.95rem; }
    .en-tuesday__detail { font-size: 0.82rem; }
    .en-tuesday__profile-grid { grid-template-columns: 1fr; gap: 0.75rem; }
    .en-tuesday__bridge { margin: 1.75rem auto 1.5rem; }
    .en-tuesday__divider { margin-top: 1.75rem; }
  }

  /* ═══════ PRODUCTS CATALOG MOCKUP ═══════ */
  .en-mock { padding: 2.5rem 0 3rem; }
  .en-mock__feature-pills {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin: 0 auto 1.5rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .en-mock__div { color: #d1d1d1; }
  .en-mock__card {
    max-width: 1100px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  }
  .en-mock__chrome {
    background: #f6f5f1;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .en-mock__chrome > span:not(.en-mock__title) {
    width: 11px; height: 11px; border-radius: 50%; display: inline-block;
  }
  .en-mock__chrome > span:nth-child(1) { background: #ff5f57; }
  .en-mock__chrome > span:nth-child(2) { background: #ffbd2e; }
  .en-mock__chrome > span:nth-child(3) { background: #28c940; }
  .en-mock__title {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: #555;
    margin-left: 0.5rem;
    text-transform: none;
    letter-spacing: -0.01em;
  }
  .en-mock__body { padding: 1.25rem 1.25rem 1rem; }
  .en-mock__footer { font-size: 0.75rem; color: #666; padding: 0.75rem 0 0; text-align: center; }

  .en-cat-table { display: flex; flex-direction: column; gap: 2px; }
  .en-cat-head, .en-cat-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1.1fr 0.9fr 0.9fr 0.9fr;
    gap: 0.5rem;
    align-items: center;
    padding: 0.55rem 0.5rem;
    font-size: 0.78rem;
  }
  .en-cat-head {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #888;
    text-transform: uppercase;
    border-bottom: 1px solid #ececec;
    padding-bottom: 0.6rem;
  }
  .en-cat-row { border-bottom: 1px solid #f5f4f0; }
  .en-cat-id { font-family: var(--font-mono); font-size: 0.72rem; color: #1a1a1a; font-weight: 700; }
  .en-cat-color { display: flex; align-items: center; gap: 0.45rem; color: #444; }
  .en-cat-color i { display: inline-block; width: 12px; height: 12px; border-radius: 50%; }
  .en-cat-type {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-pill);
    font-size: 0.7rem;
    font-weight: 700;
    width: fit-content;
  }
  .en-cat-type--blue   { background: #dbeafe; color: #1d4ed8; }
  .en-cat-type--pink   { background: #fce7f3; color: #be185d; }
  .en-cat-type--yellow { background: #fef3c7; color: #b45309; }
  .en-cat-type--green  { background: #d1fae5; color: #047857; }
  .en-cat-type--purple { background: #ede9fe; color: #6d28d9; }
  .en-cat-type--coral  { background: #ffe4e6; color: #be123c; }

  /* ═══════ TRUST LOGO STRIP ═══════ */
  .en-trust { padding: 3rem 0 1.5rem; }
  .en-trust__caption {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }
  .en-trust__logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    opacity: 0.5;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: #555;
  }

  /* ═══════ WHY ARE WE THE BEST ═══════ */
  .en-why { padding: 3rem 0; }
  .en-why__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }
  .en-why__header { align-items: flex-start; text-align: left; margin-bottom: 1.5rem; }
  .en-why__header h2 { text-transform: uppercase; font-size: clamp(1.8rem, 3.2vw, 2.6rem); }
  .en-why__body {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0 0 1rem;
  }
  .en-why__cards { display: flex; flex-direction: column; gap: 0.85rem; }
  .en-why-card {
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .en-why-card:hover {
    transform: translateX(4px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.05);
  }
  .en-why-card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
  }
  .en-why-card__body { font-size: 0.85rem; color: #555; line-height: 1.5; margin: 0; }
  .en-why-card__icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  /* ═══════ THE COST ═══════ */
  .en-cost {
    background: transparent;
    color: var(--text-primary);
    padding: 2.5rem 0;
  }
  .en-cost__sheet {
    background: var(--bg-secondary);
    border-radius: 44px;
    padding: 3rem 2.5rem 3rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .en-cost__inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .en-cost__eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .en-cost__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    text-transform: uppercase;
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .en-cost__lead {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto 1.25rem;
  }
  .en-cost__body {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--text-secondary);
    text-transform: uppercase;
    max-width: 640px;
    margin: 0 auto 3rem;
  }
  /* ═══════ Chaos Orbit visualization ═══════ */
  .en-cost__orbit {
    max-width: 720px;
    margin: 2.5rem auto 0;
  }
  .en-cost__orbit-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    max-height: 520px;
    margin: 0 auto;
  }
  .en-cost__orbit-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #ff8a99, var(--accent-primary) 45%, var(--accent-orange));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 0 0 rgba(255, 77, 109, 0.35), 0 12px 40px rgba(255, 77, 109, 0.25);
    will-change: width, height, box-shadow;
  }
  .en-cost__orbit-center-label {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
    line-height: 1.1;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }
  .en-cost__orbit-metric {
    position: absolute;
    transform: translate(-50%, -50%);
    text-align: center;
    min-width: 130px;
    max-width: 170px;
    color: var(--text-primary);
    will-change: top, left;
    pointer-events: none;
  }
  .en-cost__orbit-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 850;
    color: var(--accent-primary);
    line-height: 1;
