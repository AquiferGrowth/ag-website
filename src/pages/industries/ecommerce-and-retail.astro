  /* ═══════ FAQ (Common Questions) ═══════ */
  .ec-faq { padding: 2rem 0; }
  .ec-faq__intro {
    text-align: center;
    margin: 0 auto 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .ec-faq__list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ec-faq__item {
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .ec-faq__item[open] {
    border-color: rgba(0, 0, 0, 0.12);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
  }
  .ec-faq__q {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1.4rem;
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    text-transform: none;
  }
  .ec-faq__q::-webkit-details-marker { display: none; }
  .ec-faq__q::after {
    content: '';
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-right: 2px solid var(--accent-primary);
    border-bottom: 2px solid var(--accent-primary);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    margin-bottom: 4px;
  }
  .ec-faq__item[open] .ec-faq__q::after {
    transform: rotate(-135deg);
    margin-bottom: 0;
    margin-top: 4px;
  }
  .ec-faq__a {
    padding: 0 1.4rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
  }

  /* ═══════ RESPONSIVE ═══════ */
  /* Story visuals adapt to the CARD's width, not the viewport — a narrow
     card happens both on phones and in 2-col desktop grids. */
  .en-out-card { container-type: inline-size; }
  @container (max-width: 560px) {
    .en-vis-file-chip--3 { display: none; }
    .en-vis-file-chip--1 { top: 10%; left: 5%; }
    .en-vis-file-chip--2 { top: 27%; left: 8%; }
    .en-vis-invmgmt-panel {
      top: auto; bottom: 6%; right: auto; left: 5%;
      transform: none;
      width: 64%;
    }
    .en-vis-stat-row span,
    .en-vis-panel__head { white-space: nowrap; }
    .en-vis-po-panel,
    .en-vis-supplier-panel,
    .en-vis-cogs-panel { width: 84%; }
    .en-vis-loc-panel { width: 86%; }
    .en-vis-callout,
    .en-vis-chartlabel { font-size: 0.56rem; }
  }
  @media (max-width: 900px) {
    .en-why__grid,
    .en-process__grid { grid-template-columns: 1fr; gap: 2rem; }
    .en-outcomes__grid { grid-template-columns: 1fr; gap: 1rem; }
    .en-out-card--wide,
    .en-out-card--narrow,
    .en-out-card--full { grid-column: span 1; }
    .en-cluster-header { padding: 0; }
    .en-stats__card { grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 1.5rem; }
    .en-stat { border-right: none; padding: 0; }
    .en-cat-head, .en-cat-row {
      grid-template-columns: 1.1fr 0.8fr 1fr 0.7fr 0.7fr;
      font-size: 0.7rem;
    }
    .en-cat-head span:nth-child(4), .en-cat-row span:nth-child(4) { display: none; }
    .cs-listing-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .en-testimonial { padding: 1.75rem 1.5rem; }
    .en-vis-channel-cols { grid-template-columns: 1fr; gap: 0.5rem; }
    .en-vis-channel-divider { display: none; }
    .ec-howwork__grid { grid-template-columns: 1fr; gap: 0.85rem; }
    .ec-howwork__card { padding: 1.4rem 1.25rem; }
    .ec-pricing__grid { grid-template-columns: 1fr; gap: 1rem; }
    .ec-pricing__card { padding: 1.5rem 1.25rem; }
    .ec-pricing__card--featured { transform: none; }
    .ec-pricing__amount { font-size: 2rem; }
  }
  @media (max-width: 720px) {
    .ec-comms__body { padding: 1.25rem 1.25rem; }
    .ec-comms__body p { font-size: 0.95rem; }
    .ec-faq__q { font-size: 0.95rem; padding: 0.95rem 1.1rem; }
    .ec-faq__a { padding: 0 1.1rem 1.1rem; font-size: 0.9rem; }
  }
  @media (max-width: 640px) {
    .en-stats__card { grid-template-columns: 1fr; }
    .en-out-card__visual { aspect-ratio: 4 / 3; }
  }
</style>

<script>
  // Outcome cluster tab switcher
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.en-outcomes__tab');
    const clusters = document.querySelectorAll('.en-outcomes__cluster');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-cluster');
        tabs.forEach(t => t.classList.toggle('is-active', t === tab));
        clusters.forEach(c => c.classList.toggle('is-active', c.getAttribute('data-cluster') === target));
      });
    });
  });

  // Cost gauge — interactive slider drives leak bar + 4 approximate stat cards.
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('enCostSlider');
    if (!slider) return;
    const fill = document.getElementById('enCostSliderFill');
    const thumb = document.getElementById('enCostSliderThumb');
    const revenueBar = document.getElementById('enCostRevenueFill');
    const revenueLabel = document.getElementById('enCostRevenueValue');

    const c1Val = document.getElementById('enCostCard1Val');
    const c2Val = document.getElementById('enCostCard2Val');
    const c3Val = document.getElementById('enCostCard3Val');
    const c4Val = document.getElementById('enCostCard4Val');

    const R   = 1_500_000;
    const AOV = 60;
    const HR  = 100;

    const roundTo = (v, n) => Math.round(v / n) * n;
    const approxK = (v, step) => '~$' + roundTo(v / 1000, step) + 'K';
    const approxNum = (v, step) => '~' + roundTo(v, step);

    let L = 70;
    let dragging = false;

    const render = () => {
      const l = L / 100;

      // Slider visual
      fill.style.width = L + '%';
      thumb.style.left = L + '%';
      slider.setAttribute('aria-valuenow', String(Math.round(L)));

      // Leak bar — proportional fill, approximate $ value
      const leak = R * (0.02 + l * 0.10);      // $30K → $180K
      const leakMax = R * 0.12;
      revenueBar.style.width = ((leak / leakMax) * 100) + '%';
      revenueLabel.textContent = approxK(leak, 10);

      // Card 1 — Hours Wasted (big = hrs/wk)
      const hrs = Math.max(5, roundTo(3 + l * 22, 5));
      c1Val.textContent = '~' + hrs;

      // Card 2 — Days Since Count (big = days)
      const daysBehind = Math.max(1, roundTo(1 + l * 29, 5));
      c2Val.textContent = '~' + daysBehind;

      // Card 3 — Sales Lost (big = $)
      const daysOut = roundTo(l * 45, 5);
      const lostRev = daysOut * (R / 365);
      c3Val.textContent = lostRev < 500 ? '~$0' : approxK(lostRev, 10);

      // Card 4 — Cash Trapped (big = $)
      const deadPct = roundTo(5 + l * 35, 5);
      const inventory = R / 4;
      const trapped = (deadPct / 100) * inventory;
      c4Val.textContent = approxK(trapped, 10);
    };

    // Slider interaction
    const setFromEvent = (e) => {
      const rect = slider.getBoundingClientRect();
      L = Math.max(0, Math.min(100, ((e.clientX - rect.left) / rect.width) * 100));
      render();
    };
    slider.addEventListener('pointerdown', (e) => {
      dragging = true;
      try { slider.setPointerCapture(e.pointerId); } catch (_) {}
      setFromEvent(e);
    });
    slider.addEventListener('pointermove', (e) => { if (dragging) setFromEvent(e); });
    const endDrag = (e) => {
      dragging = false;
      try { slider.releasePointerCapture(e.pointerId); } catch (_) {}
    };
    slider.addEventListener('pointerup', endDrag);
    slider.addEventListener('pointercancel', endDrag);
    slider.addEventListener('keydown', (e) => {
      const stepPct = e.shiftKey ? 10 : 5;
      let handled = true;
      if      (e.key === 'ArrowRight' || e.key === 'ArrowUp')   L = Math.min(100, L + stepPct);
      else if (e.key === 'ArrowLeft'  || e.key === 'ArrowDown') L = Math.max(0,   L - stepPct);
      else if (e.key === 'Home')                                L = 0;
      else if (e.key === 'End')                                 L = 100;
      else handled = false;
      if (handled) { e.preventDefault(); render(); }
    });

    render();
  });

  // Tuesday timeline — auto-scrolls when in view; user drag/click takes over briefly.
  document.addEventListener('DOMContentLoaded', () => {
    const inner = document.getElementById('enTuesdayTrackInner');
    const dot = document.getElementById('enTuesdayDot');
    const track = document.getElementById('enTuesdayTrack');
    if (!inner || !dot || !track) return;
    const viewport = inner.parentElement;
    const section = viewport.closest('.en-tuesday');

    const AUTO_SPEED_PX_PER_SEC = 40;   // ~55s for a ~2200px timeline
    const AUTO_END_PAUSE_MS     = 2000; // hold at the last stop before restarting
    const USER_PAUSE_MS         = 4000; // give the user 4s of quiet after they let go

    let pos = 0;
    let target = 0;
    let dragging = false;
    let inView = true;
    let lastUserTs = -Infinity;
    let atEndSince = null;

    const rows = () => Array.from(inner.children).filter(c => c.classList && c.classList.contains('en-tuesday__row'));
    const maxScroll = () => Math.max(0, inner.scrollHeight - viewport.clientHeight);

    const markUserAction = (ts) => {
      lastUserTs = ts != null ? ts : performance.now();
      atEndSince = null; // any user action clears the end-of-timeline dwell
    };

    const setScrubFromEvent = (e) => {
      const rect = track.getBoundingClientRect();
      const frac = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      target = frac * maxScroll();
      if (dragging) pos = target;
      markUserAction();
    };

    track.addEventListener('pointerdown', (e) => {
      dragging = true;
      try { track.setPointerCapture(e.pointerId); } catch (_) {}
      setScrubFromEvent(e);
    });
    track.addEventListener('pointermove', (e) => {
      if (dragging) setScrubFromEvent(e);
    });
    const endDrag = (e) => {
      dragging = false;
      try { track.releasePointerCapture(e.pointerId); } catch (_) {}
      markUserAction();
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);

    document.querySelectorAll('.en-tuesday__label-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.getAttribute('data-stop'));
        const card = rows()[idx];
        if (!card) return;
        const max = maxScroll();
        target = Math.max(0, Math.min(card.offsetTop - 16, max));
        markUserAction();
      });
    });

    // Only auto-run when the section is visible; pause otherwise so a visitor
    // doesn't come back to a mid-cycle timeline they never saw scrolling.
    if (section && 'IntersectionObserver' in window) {
      inView = false;
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { inView = entry.isIntersecting; });
      }, { threshold: 0.15 });
      io.observe(section);
    }

    let last = null;
    const step = (ts) => {
      if (last == null) last = ts;
      const dt = Math.min(0.05, (ts - last) / 1000);
      last = ts;
      const max = maxScroll();

      const userPaused = (ts - lastUserTs) < USER_PAUSE_MS;
      if (inView && !dragging && !userPaused) {
        if (atEndSince != null) {
          if (ts - atEndSince >= AUTO_END_PAUSE_MS) {
            // Reset to top and let the ease loop chase it there
            target = 0;
            atEndSince = null;
          }
        } else if (max > 0 && target >= max - 0.5) {
          atEndSince = ts;
        } else {
          target += AUTO_SPEED_PX_PER_SEC * dt;
          if (target > max) target = max;
        }
      }

      const t = Math.max(0, Math.min(target, max));
      pos += (t - pos) * Math.min(1, dt * 6);
      if (Math.abs(t - pos) < 0.5) pos = t;
      inner.style.transform = 'translateY(' + (-pos) + 'px)';
      dot.style.left = (max > 0 ? (pos / max) * 100 : 0) + '%';
      requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  });

  // Outcome cards — fade + slide in once when scrolled into view.
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.en-out-card');
    if (!cards.length) return;
    if (!('IntersectionObserver' in window)) {
      cards.forEach((c) => c.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
    cards.forEach((c) => io.observe(c));
  });

  /* Tool graphic: auto-cycle between Counts and Purchase Orders views */
  document.addEventListener('DOMContentLoaded', () => {
    const tool = document.getElementById('en-receive-tool');
    if (!tool) return;
    const tabs = Array.from(tool.querySelectorAll('.en-receive__tab'));
    const views = Array.from(tool.querySelectorAll('.en-receive__view'));
    if (tabs.length < 2 || views.length < 2) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setView = (name) => {
      tool.setAttribute('data-view', name);
      tabs.forEach((t) => {
        const active = t.dataset.tab === name;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      views.forEach((v) => {
        const active = v.dataset.view === name;
        v.classList.toggle('is-active', active);
        v.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
    };

    let idx = 0;
    let timer = null;
    const CYCLE_MS = 4500;
    const cycle = () => {
      idx = (idx + 1) % views.length;
      setView(views[idx].dataset.view);
    };
    const start = () => {
      if (timer || prefersReduced) return;
      timer = setInterval(cycle, CYCLE_MS);
    };
    const stop = () => {
      if (!timer) return;
      clearInterval(timer);
      timer = null;
    };

    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        idx = views.findIndex((v) => v.dataset.view === t.dataset.tab);
        setView(t.dataset.tab);
        stop();
        start();
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => (e.isIntersecting ? start() : stop()));
    }, { threshold: 0.2 });
    io.observe(tool);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });
  });
</script>
</Layout>
