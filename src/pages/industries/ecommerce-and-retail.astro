---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = (await getCollection('caseStudies')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredSlugs = ['staygolden', 'hairstrong', 'pb'];
const featuredCaseStudies = featuredSlugs
  .map(slug => allCaseStudies.find(cs => cs.slug === slug))
  .filter(Boolean);

const tuesdayStops = [
  { time: '8:00',  ampm: 'AM', label: '8:00a',  side: 'left',  headline: "You haven't had coffee. Inventory's already lying to you.", detail: "Three SKUs show sold out. At least one has stock in the warehouse. You make a note that joins forty others." },
  { time: '9:15',  ampm: 'AM', label: '9:15a',  side: 'right', headline: "The CFO wants numbers your count can't give.", detail: "Month-end counts are due. The last real count was eleven days and four deliveries ago. You reply \"sending today.\"" },
  { time: '10:40', ampm: 'AM', label: '10:40a', side: 'left',  headline: "You're refunding customers your own store oversold.", detail: "Two SKUs oversold all weekend. Friday's count never reached the store. You start issuing refunds." },
  { time: '12:30', ampm: 'PM', label: '12:30p', side: 'right', headline: "The truck's here, and receiving it is somehow your job.", detail: "Fourteen SKUs, dozens of boxes, all checked against the PO by hand. That someone is you, or it's nobody." },
  { time: '1:15',  ampm: 'PM', label: '1:15p',  side: 'left',  headline: "You paid for 2,000 units. Only 1,500 showed up.", detail: "The other 500, coming, damaged, or stuck at the depot? The manufacturer replies in two days." },
  { time: '2:15',  ampm: 'PM', label: '2:15p',  side: 'right', headline: "It launches tomorrow and doesn't exist in the system.", detail: "The new line was never assigned a SKU. Not in the system. Nobody's fault, which makes it yours." },
  { time: '3:00',  ampm: 'PM', label: '3:00p',  side: 'left',  headline: "One photoshoot, and your count is pure fiction.", detail: "Marketing pulled ten pairs for a shoot and logged nothing. Samples sit at someone's house." },
  { time: '4:20',  ampm: 'PM', label: '4:20p',  side: 'right', headline: "Thirty-seven boxes, every label lying to you.", detail: "Thirty-seven boxes, all mislabeled. The only way to know is to open each one. The pickup already left." },
  { time: '5:30',  ampm: 'PM', label: '5:30p',  side: 'left',  headline: "Customers found the defect before any log did.", detail: "A customer posts stains on the newest batch. There is no delivery log. You don't know how many shipped." },
  { time: '7:00',  ampm: 'PM', label: '7:00p',  side: 'right', headline: "Dinner with the family, Slack under the table.", detail: "Dinner. You check Slack under the table." },
  { time: '9:00',  ampm: 'PM', label: '9:00p',  side: 'left',  headline: "Tonight's guess won't hurt until October.", detail: "You plan the next PO. Lead time is 90 days. Whatever's wrong tonight, you learn too late to fix." },
];
---

<Layout
  title="Ecommerce Operations for Shopify Brands | AquiferGrowth"
  description="We build the custom systems and provide the expert team to run them, so you can focus on scaling, selling, and growing your business faster."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 1. HERO                                    -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-hero en-hero--fire">
      <div class="en-hero__bg-blur"></div>
      <div class="en-hero__bg-blur en-hero__bg-blur--right"></div>
      <div class="en-hero__inner container">
        <h1 class="en-hero__title en-hero__title--fire">
          Your Business Is Growing.<br /><span class="text-gradient">Your Ops Can't Keep Up.</span>
        </h1>
        <p class="en-hero__subtitle">
          More products, more orders, more suppliers. Same spreadsheets, same manual counts, same you at 11pm. The ops that got you here can't get you further.
        </p>
        <div class="en-hero__cta-row">
          <a href="/contact" class="ec-btn ec-btn--hero">
            <span>Let's Chat</span>
            <span class="ec-animated-dots"><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- YOUR TYPICAL TUESDAY (interactive timeline) -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-tuesday">
      <div class="container">
        <div class="en-tuesday__sheet">
          <div class="en-tuesday__header">
            <h2 class="en-tuesday__title">Nobody Likes Mondays. <span class="text-gradient">Yours Are Worse.</span></h2>
            <p class="en-tuesday__subtitle">Every stop below is a real incident that lands on the founder when nobody owns the operation.</p>
          </div>

          <div class="en-tuesday__window">
            <div class="en-tuesday__track-inner" id="enTuesdayTrackInner">
              {tuesdayStops.map((s, i) => (
                <>
                  {i > 0 && (
                    <div class="en-tuesday__connector">
                      {s.side === 'right' ? (
                        <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                          <path d="M24 0 C 24 62, 40 100, 76 100" fill="none" stroke="var(--accent-primary)" stroke-width="2.5" stroke-dasharray="0.5 8" stroke-linecap="round" vector-effect="non-scaling-stroke" />
                        </svg>
                      ) : (
                        <svg viewBox="0 0 100 100" preserveAspectRatio="none">
                          <path d="M76 0 C 76 62, 60 100, 24 100" fill="none" stroke="var(--accent-primary)" stroke-width="2.5" stroke-dasharray="0.5 8" stroke-linecap="round" vector-effect="non-scaling-stroke" />
                        </svg>
                      )}
                    </div>
                  )}
                  <div class={`en-tuesday__row en-tuesday__row--${s.side}`}>
                    <div class={`en-tuesday__card en-tuesday__card--${s.side}`}>
                      <div class="en-tuesday__time">
                        <span class="en-tuesday__time-hh">{s.time}</span>
                        <span class="en-tuesday__time-ampm">{s.ampm}</span>
                      </div>
                      <div class="en-tuesday__text">
                        <div class="en-tuesday__headline">{s.headline}</div>
                        <p class="en-tuesday__detail">{s.detail}</p>
                      </div>
                    </div>
                  </div>
                </>
              ))}
            </div>
          </div>

          <div class="en-tuesday__scrubber">
            <div class="en-tuesday__track" id="enTuesdayTrack">
              <div class="en-tuesday__track-line"></div>
              <div class="en-tuesday__dot" id="enTuesdayDot"></div>
            </div>
            <div class="en-tuesday__labels">
              {tuesdayStops.map((s, i) => (
                <button class="en-tuesday__label-btn" data-stop={i} type="button">{s.label}</button>
              ))}
            </div>
          </div>

          <div class="en-tuesday__divider" aria-hidden="true"></div>

          <div class="en-tuesday__bridge">
            <span class="en-tuesday__bridge-eyebrow">Why This Is Your Tuesday</span>
            <h3 class="en-tuesday__bridge-title">The brand scaled. <span class="text-gradient">The ops didn't.</span></h3>
            <p class="en-tuesday__bridge-body">You built a business that outgrew the way you were running it. The fix keeps getting pushed to the person who can least afford it &rarr; <span class="text-gradient en-tuesday__bridge-you">You</span>.</p>
          </div>

          <div class="en-tuesday__profile-grid">
            <div class="en-tuesday__profile">
              <div class="en-tuesday__profile-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <line x1="3" y1="9" x2="21" y2="9"/>
                  <line x1="3" y1="15" x2="21" y2="15"/>
                  <line x1="9" y1="3" x2="9" y2="21"/>
                  <line x1="15" y1="3" x2="15" y2="21"/>
                </svg>
              </div>
              <h4 class="en-tuesday__profile-title">You've outgrown spreadsheets</h4>
              <p class="en-tuesday__profile-body">Your ops live in <code>inventory_FINAL_v4.xlsx</code>. Half the SKUs are already out of date.</p>
            </div>
            <div class="en-tuesday__profile">
              <div class="en-tuesday__profile-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1"/>
                  <line x1="12" y1="6" x2="12" y2="10"/>
                  <path d="M10.5 7.5h2a1 1 0 0 1 0 2h-1a1 1 0 0 0 0 2h2"/>
                </svg>
              </div>
              <h4 class="en-tuesday__profile-title">You can't justify an ops hire yet</h4>
              <p class="en-tuesday__profile-body">An ops hire runs $80&ndash;120K fully loaded. Too much fixed cost for too narrow a scope.</p>
            </div>
            <div class="en-tuesday__profile">
              <div class="en-tuesday__profile-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
              </div>
              <h4 class="en-tuesday__profile-title">The ops work lands on you at 11pm</h4>
              <p class="en-tuesday__profile-body">Approving POs after the kids are in bed. Chasing suppliers for lead times.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- THE COST (dark band)                       -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-cost">
      <div class="container">
        <div class="en-cost__sheet">
        <span class="en-cost__eyebrow">What It's Costing You</span>
        <h2 class="en-cost__title">The margin doesn't leak. <span class="text-gradient">It drips.</span></h2>

        <!-- Interactive cost gauge -->
        <div class="en-cost__gap">
          <div class="en-cost__gap-caption">Drag the slider &rarr; watch the cost grow</div>

          <!-- Ops looseness slider -->
          <div class="en-cost__gap-row">
            <div class="en-cost__gap-slider-wrap">
              <div class="en-cost__gap-slider" id="enCostSlider" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="70" aria-label="Ops looseness" tabindex="0">
                <div class="en-cost__gap-slider-fill" id="enCostSliderFill" style="width: 70%;"></div>
                <div class="en-cost__gap-slider-thumb" id="enCostSliderThumb" style="left: 70%;"></div>
              </div>
              <div class="en-cost__gap-slider-endpoints">
                <span>Tight ops</span>
                <span>Loose ops</span>
              </div>
            </div>
          </div>

          <!-- Revenue leaking -->
          <div class="en-cost__gap-row">
            <div class="en-cost__gap-label-row">
              <span class="en-cost__gap-label en-cost__gap-label--pink">Revenue leaking / yr</span>
              <span class="en-cost__gap-value-inline en-cost__gap-value-inline--pink" id="enCostRevenueValue">~$140K</span>
            </div>
            <div class="en-cost__gap-bar-wrap">
              <div class="en-cost__gap-bar">
                <div class="en-cost__gap-fill en-cost__gap-fill--tight" id="enCostRevenueFill" style="width: 75%;"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stat cards -->
        <div class="en-cost__stats">
          <div class="en-cost__stat">
            <div class="en-cost__stat-title">Hours Wasted</div>
            <div class="en-cost__stat-num"><span id="enCostCard1Val">~20</span><span class="en-cost__stat-unit">hrs/wk</span></div>
            <div class="en-cost__stat-label">Your week disappears into counts, POs, and supplier chasing. Work you'd never hire yourself for gets the best of your week.</div>
          </div>

          <div class="en-cost__stat">
            <div class="en-cost__stat-title">Orders Oversold</div>
            <div class="en-cost__stat-num"><span id="enCostCard2Val">~20</span><span class="en-cost__stat-unit">days</span></div>
            <div class="en-cost__stat-label">You sold stock that wasn't on the shelf. The customer gets an apology, you refund the sale, and the ad spend that won it is gone.</div>
          </div>

          <div class="en-cost__stat">
            <div class="en-cost__stat-title">Sales Lost</div>
            <div class="en-cost__stat-num"><span id="enCostCard3Val">~$120K</span><span class="en-cost__stat-unit">lost / yr</span></div>
            <div class="en-cost__stat-label">Your best products go dark the exact days customers came to buy. The waitlist doesn't wait. It goes shopping somewhere else.</div>
          </div>

          <div class="en-cost__stat">
            <div class="en-cost__stat-title">Cash Trapped</div>
            <div class="en-cost__stat-num"><span id="enCostCard4Val">~$110K</span><span class="en-cost__stat-unit">trapped</span></div>
            <div class="en-cost__stat-label">Cash frozen in SKUs that won't move, bleeding holding costs monthly. The money for your next drop is aging on a shelf instead.</div>
          </div>
        </div>

        </div>
      </div>
    </section>

    <!-- Inline CTA after the cost section -->
    <section class="ec-inline-cta-section" aria-label="Book a call">
      <div class="container">
        <div class="ec-inline-cta">
          <p class="ec-inline-cta__lead">Stop the drip. <span class="text-gradient">Take the Monday back.</span></p>
          <a href="/contact" class="ec-btn ec-btn--hero">
            <span>Let's Chat</span>
            <span class="ec-animated-dots"><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- OUTCOMES — moved directly under the hero    -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-outcomes">
      <div class="container">
        <!-- ───── Intro block ───── -->
        <div class="en-outcomes__intro">
          <h2>You Felt The Cost. <span class="text-gradient">Here's The Fix.</span></h2>
          <p class="en-outcomes__body">
            We don't hand you software. We run your supply chain and merchandising every day and answer for the result.
          </p>
        </div>

        <!-- ───── Cluster filter pills ───── -->
        <div class="en-outcomes__tabs">
          <button class="en-outcomes__tab is-active" data-cluster="supply-chain" type="button">Supply Chain Operations</button>
          <button class="en-outcomes__tab" data-cluster="merchandising" type="button">Merchandising</button>
          <button class="en-outcomes__tab" data-cluster="design-dev" type="button">Design &amp; Dev</button>
        </div>

        <!-- ───── Cluster: Merchandising ───── -->
        <div class="en-outcomes__cluster" data-cluster="merchandising">
          <div class="en-outcomes__grid">

            <!-- 1. Product Catalog Management (wide) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-catalog">
                <div class="en-vis-photo en-vis-photo--jacket"></div>
                <span class="en-vis-chip en-vis-chip--brown" style="top:10%;left:8%;">＋ Brown</span>
                <span class="en-vis-chip en-vis-chip--pink" style="top:20%;right:42%;">＋ Jacket</span>
                <span class="en-vis-chip en-vis-chip--pink" style="top:48%;left:0;">＋ Leather</span>
                <span class="en-vis-chip en-vis-chip--pink" style="bottom:8%;left:25%;">＋ Chained</span>
                <div class="en-vis-status">
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__icon" aria-hidden="true"><svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M4 12a8 8 0 1 0 8-8" /></svg></span>
                    <span class="en-vis-status__label">Bulk Processing</span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Duplicates</span>
                    <span class="en-vis-status__val en-vis-status__val--ok">&#10003; None</span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Prices Synced</span>
                    <span class="en-vis-status__tags">
                      <i>$145</i><i>&euro;125</i><i>&pound;110</i>
                    </span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Dynamic Tagging</span>
                    <span class="en-vis-status__tags">
                      <i>Jacket</i><i>Leather</i><i>Brown</i>
                    </span>
                  </div>
                </div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Product Catalog Management</h3>
                <p class="en-out-card__body">Every product named, tagged, and priced right, everywhere. No CSV uploads at midnight, no duplicate SKUs, no "which version is live." Your catalog just stays clean.</p>
              </div>
            </div>

            <!-- 2. Collection Data Management (wide) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-collection">
                <div class="en-vis-coll-img en-vis-coll-img--top"></div>
                <div class="en-vis-coll-img en-vis-coll-img--main"></div>
                <div class="en-vis-coll-img en-vis-coll-img--bottom"></div>
                <span class="en-vis-chip en-vis-chip--hash" style="top:6%;left:2%;">#2025_Collection</span>
                <span class="en-vis-chip en-vis-chip--hash" style="top:14%;right:6%;">#Denims</span>
                <span class="en-vis-chip en-vis-chip--hash" style="top:48%;right:0;">#Hoodies</span>
                <span class="en-vis-chip en-vis-chip--hash" style="bottom:18%;left:0;">#Summer25</span>
                <span class="en-vis-chip en-vis-chip--hash" style="bottom:4%;right:18%;">#Pastels</span>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Collection Data Management</h3>
                <p class="en-out-card__body">Your storefront stays fresh without you touching it. Collections updated, organized, and merchandised on a cadence, so the products that sell are always the products people see.</p>
              </div>
            </div>

            <!-- 3. Streamlined Metafield Management (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-metafield">
                <div class="en-vis-metafield-img en-vis-metafield-img--main"></div>
                <div class="en-vis-metafield-img en-vis-metafield-img--side"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Streamlined Metafield Management</h3>
                <p class="en-out-card__body">Product data updated in minutes, not weekends. Change once, and it's correct across the store.</p>
              </div>
            </div>

            <!-- 4. Collection-Level SEO Management (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-seo">
                <div class="en-vis-seo-img"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Collection-Level SEO Management</h3>
                <p class="en-out-card__body">Your collections rank while you sleep. Titles, descriptions, and URLs optimized at scale, so search traffic compounds.</p>
              </div>
            </div>

            <!-- 5. Simplified International Pricing (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-pricing" id="enVisPricing">
                <div class="en-vis-worldmap" aria-hidden="true"></div>
                <span class="en-vis-pill en-vis-pill--white" style="top:14%;left:8%;">🇺🇸 $15.35</span>
                <span class="en-vis-pill en-vis-pill--white" style="top:24%;right:8%;">🇷🇺 ₽24.46</span>
                <span class="en-vis-pill en-vis-pill--white" style="top:54%;left:14%;">🇧🇷 R$62.43</span>
                <span class="en-vis-pill en-vis-pill--white" style="bottom:14%;right:14%;">🇪🇺 €16.15</span>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Simplified International Pricing</h3>
                <p class="en-out-card__body">Sell in every currency without pricing chaos. International prices mapped, adjusted, and kept consistent.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ───── Cluster: Supply Chain Operations (inventory + supplier merged) ───── -->
        <div class="en-outcomes__cluster is-active" data-cluster="supply-chain">
          <div class="en-outcomes__grid">

            <!-- 6. Inventory Management (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-invmgmt">
                <div class="en-vis-dotgrid" aria-hidden="true"></div>
                <div class="en-vis-glow en-vis-glow--invmgmt" aria-hidden="true"></div>
                <div class="en-vis-file-chip en-vis-file-chip--1">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  inventory_FINAL_v4.xlsx <em>12,090?</em>
                </div>
                <div class="en-vis-file-chip en-vis-file-chip--2">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  stock_count_AUG(2).csv <em>11,834?</em>
                </div>
                <div class="en-vis-file-chip en-vis-file-chip--3">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  counts_v2_USE_THIS.xlsx <em>12,388?</em>
                </div>
                <div class="en-vis-invmgmt-photo" aria-hidden="true"></div>
                <div class="en-vis-panel en-vis-invmgmt-panel">
                  <div class="en-vis-panel__head">
                    <span class="en-vis-panel__title">Live Inventory</span>
                    <span class="en-vis-panel__meta"><span class="en-vis-live-dot" aria-hidden="true"></span> Synced 2m ago</span>
                  </div>
                  <div class="en-vis-stat-row"><span>SKUs tracked</span><strong>12,463</strong></div>
                  <div class="en-vis-stat-row"><span>Stock on hand</span><strong>$482K</strong></div>
                  <div class="en-vis-stat-row"><span>Locations</span><strong>4</strong></div>
                </div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Inventory Management</h3>
                <p class="en-out-card__body">Know exactly what you have, where it is, and what it's worth, in real time.</p>
              </div>
            </div>

            <!-- 7. Inventory Forecasting (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-forecast">
                <div class="en-vis-dotgrid" aria-hidden="true"></div>
                <div class="en-vis-glow en-vis-glow--forecast" aria-hidden="true"></div>
                <span class="en-vis-chartlabel">Demand · Fleece Hoodie</span>
                <span class="en-vis-chartlabel-meta">Q4 forecast</span>
                <svg class="en-vis-forecast-chart" viewBox="0 0 200 90" preserveAspectRatio="none" aria-hidden="true">
                  <!-- forecast confidence band -->
