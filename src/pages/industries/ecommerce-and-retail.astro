    font-size: 0.68rem;
  }
  .en-vis-detail__row span { color: #777; font-weight: 600; }
  .en-vis-detail__row b { color: #1a1a1a; font-weight: 700; }

  /* World map (international pricing) */
  .en-vis-worldmap {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #d1d1d1 1.2px, transparent 1.6px);
    background-size: 12px 12px;
    opacity: 0.45;
    mask-image: radial-gradient(ellipse at center, #000 50%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 50%, transparent 75%);
  }

  /* Metafield mini table */
  .en-vis-mf-table {
    position: absolute;
    top: 8%;
    left: 5%;
    right: 5%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    z-index: 1;
