  .en-vis-mf-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.9fr;
    gap: 0.4rem;
    padding: 0.45rem 0.7rem;
    font-size: 0.68rem;
    align-items: center;
    border-bottom: 1px solid #f3f3f3;
  }
  .en-vis-mf-row:last-child { border-bottom: none; }
  .en-vis-mf-row--head { font-weight: 800; color: #888; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; background: #faf9f5; }
  .en-vis-mf-row span:first-child { font-family: var(--font-mono); color: #1a1a1a; font-weight: 700; }
  .en-vis-mf-row span i {
    display: inline-block;
    width: 9px; height: 9px;
    border-radius: 50%;
    margin-right: 0.3rem;
    vertical-align: middle;
  }

  /* Toast (metafield) */
  .en-vis-toast {
    position: absolute;
    bottom: 6%;
    left: 5%;
    background: #d1fae5;
    color: #047857;
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.68rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    z-index: 2;
  }

  /* Multi-channel layout */
  .en-vis-channel-cols {
    position: absolute;
    inset: 12% 5% 35% 5%;
    display: grid;
    grid-template-columns: 1fr 90px 1fr;
    gap: 0.65rem;
    align-items: center;
  }
  .en-vis-channel-col {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
