  /* "Show logic" collapsible */
  .en-cost__logic {
    max-width: 820px;
    margin: 1.25rem auto 0;
    text-align: left;
  }
  .en-cost__logic-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0;
    background: none;
    border: none;
    font-family: var(--font-mono);
