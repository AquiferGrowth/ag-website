    box-shadow: 0 10px 30px rgba(255, 77, 109, 0.08);
    transform: translateY(-4px);
  }
  .ec-pricing__card--featured::before {
    content: 'Most Common';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-primary);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .ec-pricing__tier {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
  }
  .ec-pricing__price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .ec-pricing__amount {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 850;
    letter-spacing: -0.03em;
    color: #1a1a1a;
    line-height: 1;
  }
  .ec-pricing__period {
    font-size: 0.95rem;
    color: #777;
    font-weight: 500;
  }
  .ec-pricing__body {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }
  .ec-pricing__meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.55);
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }
  .ec-pricing__footer {
    text-align: center;
