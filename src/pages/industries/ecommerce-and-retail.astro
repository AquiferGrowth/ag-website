  /* Collection — 3 layered photos with fade mask */
  .en-vis-coll-img {
    position: absolute;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }
  /* Main focal image — left half of the card */
  .en-vis-coll-img--main {
    top: 4%; left: 5%;
    width: 48%; height: 92%;
    background-image: url('/images/uploads/collection-data-mgmt-1.png');
  }
  /* Top-right horizontal strip */
  .en-vis-coll-img--top {
    top: 4%; right: 5%;
    width: 42%; height: 42%;
    background-image: url('/images/uploads/collection-data-mgmt-2.png');
  }
  /* Bottom-right hoodie image */
  .en-vis-coll-img--bottom {
    bottom: 4%; right: 5%;
    width: 42%; height: 50%;
    background-image: url('/images/uploads/collection-data-mgmt-3.png');
  }

  /* Order tracking image — fills the visual */
  .en-vis-orders-img {
    position: absolute;
    inset: 0;
    background: url('/images/uploads/centralized_order_tracking.png') center center / contain no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }

  /* Multi-Channel — 4 layered images mirroring the Figma composition */
  .en-vis-channel-img {
    position: absolute;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }
  /* Left cluster (Shopify products) */
  .en-vis-channel-img--1 {
    top: 6%; left: 0;
    width: 38%; height: 84%;
    background-image: url('/images/uploads/multi-channel-inventory-management-1.png');
    z-index: 1;
  }
  /* Right cluster (Amazon products) */
  .en-vis-channel-img--2 {
    top: 6%; right: 0;
    width: 38%; height: 84%;
    background-image: url('/images/uploads/multi-channel-inventory-management-2.png');
    z-index: 1;
  }
  /* Center "Inventory Syncing" pill */
  .en-vis-channel-img--3 {
    top: 30%; left: 50%;
    width: 36%; height: 22%;
    transform: translateX(-50%);
    background-image: url('/images/uploads/multi-channel-inventory-management-3.png');
    z-index: 3;
  }
  /* Bottom alerts strip */
  .en-vis-channel-img--4 {
    bottom: 4%; left: 50%;
    width: 56%; height: 28%;
    transform: translateX(-50%);
    background-image: url('/images/uploads/multi-channel-inventory-management-4.png');
    z-index: 2;
  }

  /* SEO image — sized 108% for prominence, soft fade on all four sides so any
     overflow at the edges reads as intentional rather than a hard clip */
  .en-vis-seo-img {
    position: absolute;
    inset: 0;
    background-image: url('/images/uploads/collection_level_seo_management.png');
    background-size: 108% auto;
    background-position: center center;
    background-repeat: no-repeat;
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 5%, #000 95%, transparent 100%);
    -webkit-mask-composite: source-in;
            mask-image:
      linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 5%, #000 95%, transparent 100%);
            mask-composite: intersect;
  }

  /* Metafield — two layered images (photo on left, table on right) */
  .en-vis-metafield-img {
    position: absolute;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 5%, #000 95%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 5%, #000 95%, transparent 100%);
  }
  .en-vis-metafield-img--main {
    top: 4%; right: 0;
    width: 84%; height: 92%;
    background-image: url('/images/uploads/streamlined_metafield_management_2.png');
    z-index: 1;
  }
  .en-vis-metafield-img--side {
    top: 8%; left: 0;
    width: 46%; height: 84%;
    background-image: url('/images/uploads/streamlined_metafield_management_1.png');
    z-index: 2;
  }

  /* Order tracking detail card */
  .en-vis-detail {
    position: absolute;
    bottom: 8%;
    right: 5%;
    width: 56%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 0.7rem 0.85rem;
