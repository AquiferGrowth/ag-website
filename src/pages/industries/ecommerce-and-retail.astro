  }
  .en-cost__gap-slider-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    background: rgba(26, 26, 26, 0.6);
    border-radius: 999px;
    pointer-events: none;
  }
  .en-cost__gap-slider-thumb {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #1a1a1a;
    border: 3px solid #fff;
