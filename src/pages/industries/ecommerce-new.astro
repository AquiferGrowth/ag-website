  }

  /* ═══════ WHY ARE WE THE BEST ═══════ */
  .en-why { padding: 3rem 0; }
  .en-why__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }
  .en-why__header { align-items: flex-start; text-align: left; margin-bottom: 1.5rem; }
  .en-why__header h2 { text-transform: uppercase; font-size: clamp(1.8rem, 3.2vw, 2.6rem); }
  .en-why__body {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0 0 1rem;
  }
  .en-why__cards { display: flex; flex-direction: column; gap: 0.85rem; }
  .en-why-card {
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 1rem 1.25rem;
