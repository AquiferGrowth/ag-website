---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = (await getCollection('caseStudies')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredSlugs = ['staygolden', 'hairstrong', 'pb'];
const featuredCaseStudies = featuredSlugs
  .map(slug => allCaseStudies.find(cs => cs.slug === slug))
  .filter(Boolean);
---

<Layout
  title="Ecommerce Operations for Shopify Brands | AquiferGrowth"
  description="We build the custom systems and provide the expert team to run them, so you can focus on scaling, selling, and growing your business faster."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 1. HERO                                    -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-hero">
      <div class="en-hero__bg-blur"></div>
      <div class="en-hero__bg-blur en-hero__bg-blur--right"></div>
      <div class="en-hero__inner container">
        <div class="en-hero__eyebrow">MANAGED E-COMMERCE OPS SERVICE</div>
        <h1 class="en-hero__title">
          Focus on the brand.<br>
          We <span class="text-gradient">run the operations.</span>
        </h1>
        <p class="en-hero__subtitle">
          Ecommerce ops is a real function. Run loosely, it costs you. Thin margins, dead stock, numbers you can't trust. We own inventory, PO reconciliation, COGS, and supplier coordination end to end, and run them on daily, weekly, and monthly cadences, so it never decays.
        </p>
        <div class="en-hero__cta-row">
          <a href="/contact" class="ec-btn ec-btn--hero">
            <span>Let's Chat</span>
            <span class="ec-animated-dots"><span></span><span></span><span></span></span>
          </a>
        </div>

        <div class="en-hero__image">
          <img src="/images/uploads/hero_ecom.png" alt="Ecommerce operations workflow" loading="eager" />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- BUILT FOR SCALING SHOPIFY BRANDS            -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="ec-who">
      <div class="container">
        <h2 class="ec-who__heading" style="font-weight: 850; letter-spacing: -0.02em;">Built for Scaling <span class="text-gradient">Shopify Brands</span></h2>
        <div class="ec-who__grid">
          <div class="ec-who__col">
            <div class="ec-who__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="3" y1="15" x2="21" y2="15"/>
                <line x1="9" y1="3" x2="9" y2="21"/>
                <line x1="15" y1="3" x2="15" y2="21"/>
              </svg>
            </div>
            <h3 class="ec-who__title">You've outgrown spreadsheets</h3>
            <p class="ec-who__body">Your ops live in a Google Sheet called <code>inventory_FINAL_v4.xlsx</code>. Someone updates it when they remember. Half the SKUs are out of date.</p>
          </div>
          <div class="ec-who__col">
            <div class="ec-who__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1"/>
                <line x1="12" y1="6" x2="12" y2="10"/>
                <path d="M10.5 7.5h2a1 1 0 0 1 0 2h-1a1 1 0 0 0 0 2h2"/>
              </svg>
            </div>
            <h3 class="ec-who__title">You can't justify an ops hire yet</h3>
            <p class="ec-who__body">A proper inventory planner or ops manager runs $80-120K fully loaded. At your revenue, it's too much fixed cost for too narrow a scope.</p>
          </div>
          <div class="ec-who__col">
            <div class="ec-who__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </div>
            <h3 class="ec-who__title">You are doing ops work at 11pm</h3>
            <p class="ec-who__body">You started this brand to build something. Now you're approving POs after the kids are in bed, chasing a supplier for lead time updates.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- PROBLEMS ENCOUNTERED                       -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-problems">
      <div class="container">
        <div class="en-problems__intro">
          <div class="section-header">
            <div class="badge">Problems Encountered</div>
            <h2 style="font-weight: 850; letter-spacing: -0.02em;">
              When was the last time you could actually <span class="text-gradient">step away</span> from daily operations?
            </h2>
          </div>
          <p class="en-problems__body">Manual processes and tedious store operations drain time, creativity, and momentum. When you're buried in the details, it's hard to launch new products, build customer experiences, or drive real growth. The cost of operational chaos isn't just time, it's missed opportunities.</p>
        </div>

        <div class="en-problems__grid">
          <div class="en-problems__track">
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/></svg></div>
              <p class="en-prob-card__text">Updating Product Information is a Slow, Error-Prone Process</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg></div>
              <p class="en-prob-card__text">Tracking Orders and Fulfillments is Scattered</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8H10a3 3 0 0 0 0 6h2a3 3 0 0 1 0 6H8"/></svg></div>
              <p class="en-prob-card__text">International Pricing is Complex and Inflexible</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 7v10M3 12h6"/></svg></div>
              <p class="en-prob-card__text">Managing Metafields Requires Extra Apps</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><polyline points="12 9 12 13 15 15"/><path d="M5 3L2 6M19 3l3 3"/></svg></div>
              <p class="en-prob-card__text">Inventory Updates Are Still Manual and Tedious</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"/><polyline points="15 7 21 7 21 13"/></svg></div>
              <p class="en-prob-card__text">Bulk Price Changes Are Risky and Time-Consuming</p>
            </div>
            <div class="en-prob-card">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
              <p class="en-prob-card__text">Tag Management Is a Messy, Manual Chore</p>
            </div>
            <!-- Duplicate set for seamless infinite loop -->
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/></svg></div>
              <p class="en-prob-card__text">Updating Product Information is a Slow, Error-Prone Process</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg></div>
              <p class="en-prob-card__text">Tracking Orders and Fulfillments is Scattered</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8H10a3 3 0 0 0 0 6h2a3 3 0 0 1 0 6H8"/></svg></div>
              <p class="en-prob-card__text">International Pricing is Complex and Inflexible</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 7v10M3 12h6"/></svg></div>
              <p class="en-prob-card__text">Managing Metafields Requires Extra Apps</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><polyline points="12 9 12 13 15 15"/><path d="M5 3L2 6M19 3l3 3"/></svg></div>
              <p class="en-prob-card__text">Inventory Updates Are Still Manual and Tedious</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"/><polyline points="15 7 21 7 21 13"/></svg></div>
              <p class="en-prob-card__text">Bulk Price Changes Are Risky and Time-Consuming</p>
            </div>
            <div class="en-prob-card" aria-hidden="true">
              <div class="en-prob-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
              <p class="en-prob-card__text">Tag Management Is a Messy, Manual Chore</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- OUTCOMES — moved directly under the hero    -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="en-outcomes">
      <div class="container">
        <!-- ───── Intro block ───── -->
        <div class="en-outcomes__intro">
          <span class="badge" style="align-self: center;">Outcomes</span>
          <h2>Simplify Operations. <span class="text-gradient">Unlock Growth.</span></h2>
          <p class="en-outcomes__body">
            Your product catalog, collections, inventory, and merchandising—streamlined by a tool built for you, and managed by experts.
          </p>
        </div>

        <!-- ───── Cluster filter pills ───── -->
        <div class="en-outcomes__tabs">
          <button class="en-outcomes__tab is-active" data-cluster="catalog" type="button">Catalog &amp; Merchandising</button>
          <button class="en-outcomes__tab" data-cluster="inventory" type="button">Inventory &amp; Stock</button>
          <button class="en-outcomes__tab" data-cluster="supplier" type="button">Supplier &amp; Finance</button>
        </div>

        <!-- ───── Cluster 1: Catalog & Merchandising ───── -->
        <div class="en-outcomes__cluster is-active" data-cluster="catalog">
          <div class="en-outcomes__grid">

            <!-- 1. Product Catalog Management (wide) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-catalog">
                <div class="en-vis-photo en-vis-photo--jacket"></div>
                <span class="en-vis-chip en-vis-chip--brown" style="top:10%;left:8%;">＋ Brown</span>
                <span class="en-vis-chip en-vis-chip--pink" style="top:20%;right:42%;">＋ Jacket</span>
                <span class="en-vis-chip en-vis-chip--pink" style="top:48%;left:0;">＋ Leather</span>
                <span class="en-vis-chip en-vis-chip--pink" style="bottom:8%;left:25%;">＋ Chained</span>
                <div class="en-vis-status">
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__icon">↻</span>
                    <span class="en-vis-status__label">Bulk Processing</span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Duplicates Found</span>
                    <span class="en-vis-status__val en-vis-status__val--warn">⚠ 15</span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Generating SKUs</span>
                    <span class="en-vis-status__val">753 / 12,463 done</span>
                  </div>
                  <div class="en-vis-status__row">
                    <span class="en-vis-status__label">Dynamic Tagging</span>
                    <span class="en-vis-status__tags">
                      <i>Jacket</i><i>Leather</i><i>Brown</i>
                    </span>
                  </div>
                </div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Product Catalog Management</h3>
                <p class="en-out-card__body">Quickly update product names, titles, tags, and attributes through a clean interface, no CSVs, no manual mistakes.</p>
              </div>
            </div>

            <!-- 2. Collection Data Management (wide) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-collection">
                <div class="en-vis-coll-img en-vis-coll-img--top"></div>
                <div class="en-vis-coll-img en-vis-coll-img--main"></div>
                <div class="en-vis-coll-img en-vis-coll-img--bottom"></div>
                <span class="en-vis-chip en-vis-chip--hash" style="top:6%;left:2%;">#2025_Collection</span>
                <span class="en-vis-chip en-vis-chip--hash" style="top:14%;right:6%;">#Denims</span>
                <span class="en-vis-chip en-vis-chip--hash" style="top:48%;right:0;">#Hoodies</span>
                <span class="en-vis-chip en-vis-chip--hash" style="bottom:18%;left:0;">#Summer25</span>
                <span class="en-vis-chip en-vis-chip--hash" style="bottom:4%;right:18%;">#Pastels</span>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Collection Data Management</h3>
                <p class="en-out-card__body">Optimize and update collections data at scale, keeping your storefront fresh, navigable, and built for conversion.</p>
              </div>
            </div>

            <!-- 3. Streamlined Metafield Management (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-metafield">
                <div class="en-vis-metafield-img en-vis-metafield-img--main"></div>
                <div class="en-vis-metafield-img en-vis-metafield-img--side"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Streamlined Metafield Management</h3>
                <p class="en-out-card__body">Edit all product metafields quickly through one connected spreadsheet, no extra apps required.</p>
              </div>
            </div>

            <!-- 4. Collection-Level SEO Management (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-seo">
                <div class="en-vis-seo-img"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Collection-Level SEO Management</h3>
                <p class="en-out-card__body">Optimize collections for search without the manual grind. Update SEO titles, meta descriptions, and URLs at scale.</p>
              </div>
            </div>

            <!-- 5. Simplified International Pricing (narrow) -->
            <div class="en-out-card en-out-card--narrow">
              <div class="en-out-card__visual en-vis-pricing">
                <div class="en-vis-worldmap" aria-hidden="true"></div>
                <span class="en-vis-pill en-vis-pill--white" style="top:14%;left:8%;">🇺🇸 $15.35</span>
                <span class="en-vis-pill en-vis-pill--white" style="top:24%;right:8%;">🇷🇺 ₽24.46</span>
                <span class="en-vis-pill en-vis-pill--white" style="top:54%;left:14%;">🇧🇷 R$62.43</span>
                <span class="en-vis-pill en-vis-pill--white" style="bottom:14%;right:14%;">🇪🇺 €16.15</span>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Simplified International Pricing</h3>
                <p class="en-out-card__body">Map and adjust international prices easily with workbook-style controls and Excel-like flexibility.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ───── Cluster 2: Inventory & Stock ───── -->
        <div class="en-outcomes__cluster" data-cluster="inventory">
          <div class="en-outcomes__grid">

            <!-- 6. Inventory Management (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-placeholder">
                <svg class="en-vis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                  <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                  <line x1="12" y1="22.08" x2="12" y2="12"/>
                </svg>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Inventory Management</h3>
                <p class="en-out-card__body">Know exactly what you have, where it is, and what it's worth, in real time.</p>
              </div>
            </div>

            <!-- 7. Inventory Forecasting (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-placeholder">
                <svg class="en-vis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                  <line x1="3" y1="20" x2="21" y2="20"/>
                </svg>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Inventory Forecasting</h3>
                <p class="en-out-card__body">Stop guessing. Stop stocking out. Stop tying up cash in dead SKUs.</p>
              </div>
            </div>

            <!-- 8. Multi-Location Inventory (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-placeholder">
                <svg class="en-vis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Multi-Location Inventory</h3>
                <p class="en-out-card__body">Know exactly where every unit is, across every warehouse, 3PL, and channel staging area.</p>
              </div>
            </div>

            <!-- 9. Multi-Channel Inventory Management (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-channel">
                <div class="en-vis-channel-img en-vis-channel-img--1"></div>
                <div class="en-vis-channel-img en-vis-channel-img--2"></div>
                <div class="en-vis-channel-img en-vis-channel-img--3"></div>
                <div class="en-vis-channel-img en-vis-channel-img--4"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Multi-Channel Inventory Management</h3>
                <p class="en-out-card__body">Sync and update inventory in bulk across Shopify, Amazon, and more from one central hub.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ───── Cluster 3: Supplier & Finance ───── -->
        <div class="en-outcomes__cluster" data-cluster="supplier">
          <div class="en-outcomes__grid">

            <!-- 10. Centralized Order Tracking (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-orders">
                <div class="en-vis-orders-img"></div>
              </div>
              <div class="en-out-card__text">
                <h3 class="en-out-card__title">Centralized Order Tracking</h3>
                <p class="en-out-card__body">View and manage all orders and fulfillment statuses in one place for faster, more accurate operations.</p>
              </div>
            </div>

            <!-- 11. Purchase Order Management (half — 2x2) -->
            <div class="en-out-card en-out-card--wide">
              <div class="en-out-card__visual en-vis-placeholder">
                <svg class="en-vis-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
