    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }
  .ec-who__body {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }
  .ec-who__body code {
    background: var(--bg-primary);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--text-primary);
  }

  /* ─────────── Ported: SEVEN OPERATIONAL DISCIPLINES intro ─────────── */
  .ec-services-header { padding: 3rem 0 2rem; }
  .ec-services__intro {
    text-align: center;
    max-width: 960px;
    margin: 0 auto;
  }
  .ec-services__intro .ec-section-title { text-wrap: balance; }
  .ec-services__subhead {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Shared section title (only adds rules not already provided by global h2) */
  .ec-section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 1.5rem;
  }

  @media (max-width: 768px) {
    .ec-who { padding: 2.5rem 0; }
    .ec-who__grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .ec-services-header { padding: 2rem 0 1rem; }
  }

  /* Hero illustrations for service cards — central element + floating chips */
  .en-vis-hero {
    background: linear-gradient(135deg, #fef5f7 0%, #fff5e8 100%);
    position: relative;
    overflow: hidden;
  }

  /* Inventory Mgmt — stack of boxes */
  .en-hero-stack {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
  }
  .en-hero-box {
    width: 88px;
    height: 32px;
    border-radius: 6px;
    border: 2px solid #1a1a1a;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.06);
  }
  .en-hero-box::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    width: 2px; height: 100%;
    background: #1a1a1a;
    transform: translateX(-50%);
  }
  .en-hero-box--top { background: linear-gradient(135deg, #ffd4ba, #ffb285); transform: translateX(-8px); }
  .en-hero-box--mid { background: linear-gradient(135deg, #fff, #ececec); }
  .en-hero-box--bot { background: linear-gradient(135deg, #ffe4e6, #ffb3c1); transform: translateX(6px); }

  /* Inventory Forecasting — line/area chart */
  .en-hero-curve {
    position: absolute;
    inset: 22% 8% 22% 8%;
    width: auto;
    height: auto;
  }

  /* Multi-Location — reuses .en-vis-worldmap (already styled) */

  /* PO Mgmt — stylized document with stamp */
  .en-hero-doc {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(-4deg);
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 12px 14px 14px;
    width: 130px;
    box-shadow: 0 10px 24px rgba(0,0,0,0.08);
  }
  .en-hero-doc__title {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .en-hero-doc__lines { display: flex; flex-direction: column; gap: 4px; }
  .en-hero-doc__line {
    height: 4px;
    background: #ececec;
    border-radius: 2px;
  }
  .en-hero-doc__line--short { width: 62%; }
  .en-hero-doc__stamp {
    position: absolute;
    bottom: -10px; right: -12px;
    background: rgba(255, 255, 255, 0.92);
    color: #047857;
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 5px 9px;
    border-radius: 5px;
    transform: rotate(10deg);
    border: 2px solid #047857;
    box-shadow: 0 3px 8px rgba(0,0,0,0.08);
  }

  /* Supplier Mgmt — stacked avatar circles */
  .en-hero-avatars {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
  }
  .en-hero-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 800;
    color: #fff;
    border: 3px solid #fff;
    box-shadow: 0 5px 12px rgba(0,0,0,0.12);
    letter-spacing: -0.02em;
  }
  .en-hero-avatar--1 { background: linear-gradient(135deg, #FF7E5F, #FF4D6D); z-index: 3; }
  .en-hero-avatar--2 { background: linear-gradient(135deg, #6d28d9, #1d4ed8); z-index: 2; margin-left: -14px; }
  .en-hero-avatar--3 { background: linear-gradient(135deg, #047857, #10b981); z-index: 1; margin-left: -14px; }

  /* COGS — vertical stacked bar */
  .en-hero-stackbar {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 150px;
    display: flex;
    flex-direction: column;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid #1a1a1a;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  }
  .en-hero-stackbar__seg {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }
  .en-hero-stackbar__seg span {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .en-hero-stackbar__seg--margin  { background: linear-gradient(135deg, #FF4D6D, #FF7E5F); height: 42%; }
  .en-hero-stackbar__seg--freight { background: #d99066; height: 16%; }
  .en-hero-stackbar__seg--duty    { background: #8b5a2b; height: 12%; }
  .en-hero-stackbar__seg--unit    { background: #1f2840; height: 30%; }

  /* Ported CSS mockup wrapper — fits into the 16:9 card visual area */
  .en-vis-mock-wrap {
    background: linear-gradient(135deg, #fef5f7 0%, #fff5e8 100%);
    overflow: hidden;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4% 5% 0;
  }
  .en-vis-mock-wrap .ec-mock {
    width: 100%;
    flex-shrink: 0;
  }
  .ec-mock {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
  }
  .ec-mock__body { padding: 0.6rem 0.7rem 0.5rem; }
  .ec-mock__footer {
    padding: 0.45rem 0.7rem;
    font-size: 0.62rem;
    color: #6b6b6b;
    border-top: 1px solid #f0f0f0;
    background: #fafafa;
  }

  /* Reconciliation table (Inventory Mgmt) */
  .ec-recon-table { display: flex; flex-direction: column; }
  .ec-recon-head,
  .ec-recon-row {
    display: grid;
    grid-template-columns: 1.8fr 0.7fr 0.7fr 0.8fr 0.9fr;
    gap: 0.35rem;
    padding: 0.32rem 0.25rem;
    align-items: center;
  }
  .ec-recon-head {
    font-size: 0.56rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
    border-bottom: 1px solid #ececec;
  }
  .ec-recon-row {
    font-size: 0.66rem;
    border-bottom: 1px solid #f4f4f4;
    color: #333;
  }
  .ec-recon-row:last-child { border-bottom: none; }
  .ec-recon-row--flag { background: #fff7f7; }
  .ec-recon-sku { font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ec-recon-num--off { color: #c0392b; font-weight: 600; }

  /* Status pills (shared) */
  .ec-pill {
    display: inline-block;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .ec-pill--green { background: #d4edda; color: #155724; }
  .ec-pill--coral { background: #ffe2e7; color: #c0392b; }
  .ec-pill--yellow { background: #fff3cd; color: #856404; }

  /* Forecast chart (Inventory Forecasting) */
  .ec-fc-chart {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 0.35rem;
    height: 130px;
    position: relative;
    padding-top: 0.3rem;
  }
  .ec-fc-y {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-size: 0.54rem;
    color: #999;
    text-align: right;
    padding-right: 0.2rem;
  }
  .ec-fc-plot {
    position: relative;
    border-left: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
  }
  .ec-fc-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 100%;
    padding: 0 0.3rem;
  }
  .ec-fc-bar {
    flex: 1;
    background: var(--accent-primary);
    border-radius: 2px 2px 0 0;
    min-height: 6px;
  }
  .ec-fc-bar--proj {
    background: repeating-linear-gradient(45deg, rgba(255,77,109,0.5), rgba(255,77,109,0.5) 3px, rgba(255,77,109,0.25) 3px, rgba(255,77,109,0.25) 6px);
    border: 1px dashed rgba(255,77,109,0.5);
    border-bottom: none;
  }
  .ec-fc-reorder {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    border-top: 1.5px dashed #1a73e8;
    z-index: 1;
  }
  .ec-fc-reorder::after {
    content: "Reorder";
    position: absolute;
    right: 2px;
    top: -10px;
    font-size: 0.5rem;
    color: #1a73e8;
    font-weight: 700;
    background: #fff;
    padding: 0 3px;
  }

  /* 3-way match (Purchase Order Mgmt) */
  .ec-3way { display: flex; flex-direction: column; gap: 0.55rem; padding: 0.3rem 0; }
  .ec-3way__row { display: flex; align-items: center; gap: 0.3rem; }
  .ec-3way__doc {
    flex: 1;
    background: #fafafa;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.4rem 0.3rem;
    text-align: center;
    min-width: 0;
  }
  .ec-3way__doc--flag {
    background: #fff5f5;
    border-color: #f5c6cb;
  }
  .ec-3way__icon { font-size: 0.85rem; margin-bottom: 0.1rem; }
  .ec-3way__label {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .ec-3way__sub { font-size: 0.55rem; color: #6b6b6b; }
  .ec-3way__sub--err { color: #c0392b; font-weight: 700; }
  .ec-3way__line {
    flex: 0 0 8px;
    height: 1.5px;
    background: #d1d1d1;
  }
  .ec-3way__row--err .ec-3way__line { background: #f5c6cb; }
  .ec-3way__node {
    flex: 0 0 auto;
    padding: 0.35rem 0.5rem;
    border-radius: 6px;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-align: center;
    white-space: nowrap;
  }
  .ec-3way__node--match { background: #d4edda; color: #155724; border: 1.5px solid #a5d6a7; }
  .ec-3way__node--err   { background: #fde8e8; color: #c0392b; border: 1.5px solid #f5c6cb; }

  /* Location grid (Multi-Location Inventory) */
  .ec-loc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
  }
  .ec-loc-card {
    background: #fafafa;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.5rem 0.55rem;
  }
  .ec-loc-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }
  .ec-loc-card__name {
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .ec-loc-card__qty {
    font-size: 0.62rem;
    font-weight: 800;
    color: var(--accent-primary);
  }
  .ec-loc-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .ec-loc-card__list li {
    display: flex;
    justify-content: space-between;
    font-size: 0.58rem;
    color: var(--text-secondary);
    padding: 0.1rem 0;
    border-bottom: 1px dashed #ececec;
  }
  .ec-loc-card__list li:last-child { border-bottom: none; }
  .ec-loc-card__list li span { font-weight: 600; color: var(--text-primary); }

  /* COGS table (COGS & Margin Tracking) */
  .ec-cogs-table { display: flex; flex-direction: column; }
  .ec-cogs-head,
  .ec-cogs-row {
    display: grid;
    grid-template-columns: 1.6fr 0.6fr 0.6fr 0.55fr 0.65fr 0.65fr 0.65fr;
    gap: 0.25rem;
    padding: 0.32rem 0.25rem;
    align-items: center;
  }
  .ec-cogs-head {
    font-size: 0.52rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
    border-bottom: 1px solid #ececec;
  }
  .ec-cogs-row {
    font-size: 0.6rem;
    border-bottom: 1px solid #f4f4f4;
    color: #333;
  }
  .ec-cogs-row:last-child { border-bottom: none; }
  .ec-cogs-row--bad { background: #fff0f2; }
  .ec-cogs-sku { font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ec-cogs-spike { color: #c0392b; font-weight: 700; }
  .ec-cogs-margin { font-weight: 800; }
  .ec-cogs-margin--good { color: #27ae60; }
  .ec-cogs-margin--bad { color: #c0392b; }

  /* Supplier scorecards (Supplier Mgmt) */
  .ec-sup-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .ec-sup-card {
    background: #fafafa;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.45rem 0.6rem;
  }
  .ec-sup-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.3rem;
  }
  .ec-sup-card__name {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .ec-sup-card__metrics { display: flex; flex-direction: column; gap: 0.2rem; }
  .ec-sup-metric {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.58rem;
  }
  .ec-sup-metric__label { color: #888; font-weight: 600; }
  .ec-sup-metric__val { font-weight: 700; color: var(--text-primary); text-align: right; }
  .ec-sup-bar {
    height: 4px;
    background: #ececec;
    border-radius: 3px;
    overflow: hidden;
  }
  .ec-sup-bar__fill { height: 100%; border-radius: 3px; }
  .ec-sup-stars {
    grid-column: 2 / 4;
    color: #f39c12;
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-align: right;
  }

  /* Icon-only placeholder visual for cards awaiting product photos */
  .en-vis-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fef5f7 0%, #fff5e8 100%);
  }
  .en-vis-icon {
    width: 64px;
    height: 64px;
    color: var(--accent-primary);
    opacity: 0.55;
  }

  /* Placeholder photo blocks (suggest products via gradients + silhouettes) */
  .en-vis-photo {
    position: relative;
    border-radius: 10px;
    background: linear-gradient(135deg, #e8e3da, #c4bdb0);
    box-shadow: 0 6px 14px rgba(0,0,0,0.08);
    overflow: hidden;
  }
  .en-vis-photo--jacket {
    width: 44%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 4%;
    background: url('/images/uploads/catalog-jacket.png') center center / contain no-repeat;
    box-shadow: none;
    border-radius: 0;
    /* Fade out top and bottom edges */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }
  .en-vis-photo--denim {
    background:
      radial-gradient(ellipse at top, rgba(255,255,255,0.15), transparent 60%),
      linear-gradient(160deg, #5a7daa, #2e4d72);
  }
  .en-vis-photo--hoodie {
    background:
      radial-gradient(ellipse at 50% 20%, rgba(255,255,255,0.15), transparent 55%),
      linear-gradient(160deg, #d4a373, #8b5a2b);
  }
  /* Shirt — clearly grey, with t-shirt collar + body silhouette */
  .en-vis-photo--shirt {
    background:
      radial-gradient(ellipse at 50% 22%, rgba(0,0,0,0.06), transparent 28%),
      linear-gradient(160deg, #f5f3ee, #c8c4ba);
    border: 1px solid #ddd;
  }
  .en-vis-photo--shirt::before {
    /* T-shirt collar notch */
    content: '';
    position: absolute;
    top: 0; left: 50%;
    width: 28%; height: 14%;
    background: var(--bg-primary);
    border-radius: 0 0 50% 50% / 0 0 100% 100%;
    transform: translateX(-50%);
    z-index: 1;
  }
  .en-vis-photo--shirt::after {
    /* Subtle sleeve hint */
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.08) 0 18%, transparent 18% 82%, rgba(0,0,0,0.08) 82% 100%);
    pointer-events: none;
  }
  .en-vis-photo--pants {
    background:
      radial-gradient(ellipse at top, rgba(255,255,255,0.15), transparent 60%),
      linear-gradient(160deg, #c9a87a, #8a6f4d);
  }
  .en-vis-photo--small {
    width: 32%;
    height: 70%;
    position: absolute;
    top: 15%;
    left: 5%;
  }
  .en-vis-photo--mini {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 8px;
  }

  /* Floating tag chips */
  .en-vis-chip {
    position: absolute;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 999px;
    padding: 0.32rem 0.7rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    color: #1a1a1a;
    box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    white-space: nowrap;
    z-index: 2;
  }
  .en-vis-chip--pink  { color: var(--accent-primary); border-color: rgba(255,77,109,0.25); }
  .en-vis-chip--brown { color: #8b5a2b; border-color: rgba(139,90,43,0.25); }
  .en-vis-chip--hash  {
    background: rgba(255,255,255,0.95);
    color: #1a1a1a;
    backdrop-filter: blur(4px);
  }

  /* Floating status pills */
  .en-vis-pill {
    position: absolute;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .en-vis-pill--coral   { background: #ffcdd2; color: #b71c1c; }
  .en-vis-pill--dark    { background: #1a1a1a; color: #fff; }
  .en-vis-pill--white   { background: #fff; color: #1a1a1a; border: 1px solid rgba(0,0,0,0.08); }
  .en-vis-pill--success { background: #d1fae5; color: #047857; }

  /* Status panel (catalog) */
  .en-vis-status {
    position: absolute;
    top: 14%;
    right: 5%;
    width: 52%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 0.7rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    z-index: 2;
  }
  .en-vis-status__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.7rem;
  }
  .en-vis-status__icon {
    width: 14px; height: 14px;
    background: var(--accent-primary);
    color: #fff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 800;
    margin-right: 0.3rem;
  }
  .en-vis-status__label { color: #444; font-weight: 600; font-size: 0.7rem; flex: 1; }
  .en-vis-status__val { color: #1a1a1a; font-weight: 700; font-size: 0.7rem; }
  .en-vis-status__val--warn { color: #b45309; }
  .en-vis-status__tags { display: inline-flex; gap: 3px; }
  .en-vis-status__tags i {
    background: rgba(0,0,0,0.06);
    border-radius: 4px;
    padding: 0.15rem 0.35rem;
    font-style: normal;
    font-size: 0.62rem;
    font-weight: 600;
  }

  /* Collection — 3 layered photos with fade mask */
  .en-vis-coll-img {
    position: absolute;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }
  /* Main focal image — left half of the card */
  .en-vis-coll-img--main {
    top: 4%; left: 5%;
    width: 48%; height: 92%;
    background-image: url('/images/uploads/collection-data-mgmt-1.png');
  }
  /* Top-right horizontal strip */
  .en-vis-coll-img--top {
    top: 4%; right: 5%;
    width: 42%; height: 42%;
    background-image: url('/images/uploads/collection-data-mgmt-2.png');
  }
  /* Bottom-right hoodie image */
  .en-vis-coll-img--bottom {
    bottom: 4%; right: 5%;
    width: 42%; height: 50%;
    background-image: url('/images/uploads/collection-data-mgmt-3.png');
  }

  /* Order tracking image — fills the visual */
  .en-vis-orders-img {
    position: absolute;
    inset: 0;
    background: url('/images/uploads/centralized_order_tracking.png') center center / contain no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }

  /* Multi-Channel — 4 layered images mirroring the Figma composition */
  .en-vis-channel-img {
    position: absolute;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }
  /* Left cluster (Shopify products) */
  .en-vis-channel-img--1 {
    top: 6%; left: 0;
    width: 38%; height: 84%;
    background-image: url('/images/uploads/multi-channel-inventory-management-1.png');
    z-index: 1;
  }
  /* Right cluster (Amazon products) */
  .en-vis-channel-img--2 {
    top: 6%; right: 0;
    width: 38%; height: 84%;
    background-image: url('/images/uploads/multi-channel-inventory-management-2.png');
    z-index: 1;
  }
  /* Center "Inventory Syncing" pill */
  .en-vis-channel-img--3 {
    top: 30%; left: 50%;
    width: 36%; height: 22%;
    transform: translateX(-50%);
    background-image: url('/images/uploads/multi-channel-inventory-management-3.png');
    z-index: 3;
  }
  /* Bottom alerts strip */
  .en-vis-channel-img--4 {
    bottom: 4%; left: 50%;
    width: 56%; height: 28%;
    transform: translateX(-50%);
    background-image: url('/images/uploads/multi-channel-inventory-management-4.png');
    z-index: 2;
  }

  /* SEO image — fills the visual */
  .en-vis-seo-img {
    position: absolute;
    inset: 0;
    background: url('/images/uploads/collection_level_seo_management.png') center center / contain no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }

  /* Metafield — two layered images (photo on left, table on right) */
  .en-vis-metafield-img {
    position: absolute;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }
  .en-vis-metafield-img--main {
    top: 8%; right: 0;
    width: 70%; height: 84%;
    background-image: url('/images/uploads/streamlined_metafield_management_2.png');
    z-index: 1;
  }
  .en-vis-metafield-img--side {
    top: 14%; left: 0;
    width: 38%; height: 72%;
    background-image: url('/images/uploads/streamlined_metafield_management_1.png');
    z-index: 2;
  }

  /* Order tracking detail card */
  .en-vis-detail {
    position: absolute;
    bottom: 8%;
    right: 5%;
    width: 56%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 0.7rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    z-index: 2;
  }
  .en-vis-detail__row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.68rem;
  }
  .en-vis-detail__row span { color: #777; font-weight: 600; }
  .en-vis-detail__row b { color: #1a1a1a; font-weight: 700; }

  /* World map (international pricing) */
  .en-vis-worldmap {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #d1d1d1 1.2px, transparent 1.6px);
    background-size: 12px 12px;
    opacity: 0.45;
    mask-image: radial-gradient(ellipse at center, #000 50%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, #000 50%, transparent 75%);
  }

  /* Metafield mini table */
  .en-vis-mf-table {
    position: absolute;
    top: 8%;
    left: 5%;
    right: 5%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    z-index: 1;
  }
  .en-vis-mf-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.9fr;
    gap: 0.4rem;
    padding: 0.45rem 0.7rem;
    font-size: 0.68rem;
    align-items: center;
    border-bottom: 1px solid #f3f3f3;
  }
  .en-vis-mf-row:last-child { border-bottom: none; }
  .en-vis-mf-row--head { font-weight: 800; color: #888; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; background: #faf9f5; }
  .en-vis-mf-row span:first-child { font-family: var(--font-mono); color: #1a1a1a; font-weight: 700; }
  .en-vis-mf-row span i {
    display: inline-block;
    width: 9px; height: 9px;
    border-radius: 50%;
    margin-right: 0.3rem;
    vertical-align: middle;
  }

  /* Toast (metafield) */
  .en-vis-toast {
    position: absolute;
    bottom: 6%;
    left: 5%;
    background: #d1fae5;
    color: #047857;
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.68rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    z-index: 2;
  }

  /* Multi-channel layout */
  .en-vis-channel-cols {
    position: absolute;
    inset: 12% 5% 35% 5%;
    display: grid;
    grid-template-columns: 1fr 90px 1fr;
    gap: 0.65rem;
    align-items: center;
  }
  .en-vis-channel-col {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    padding: 0.7rem;
    box-shadow: 0 6px 14px rgba(0,0,0,0.05);
  }
  .en-vis-channel-brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.85rem;
    margin-bottom: 0.55rem;
    color: #1a1a1a;
  }
  .en-vis-channel-col:nth-child(1) .en-vis-channel-brand { color: #96bf48; }
  .en-vis-channel-col:nth-child(3) .en-vis-channel-brand { color: #ff9900; }
  .en-vis-channel-row { display: flex; gap: 0.6rem; align-items: center; }
  .en-vis-channel-meta { display: flex; flex-direction: column; gap: 2px; }
  .en-vis-channel-meta b { font-size: 0.72rem; color: #1a1a1a; }
  .en-vis-channel-meta span { font-size: 0.65rem; color: #666; }
  .en-vis-channel-divider { display: flex; align-items: center; justify-content: center; }
  .en-vis-sync {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    color: #fff;
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 800;
    white-space: nowrap;
    box-shadow: 0 6px 14px rgba(255,77,109,0.3);
  }
  .en-vis-alerts {
    position: absolute;
    left: 5%;
    right: 5%;
    bottom: 8%;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .en-vis-alert {
    background: #fff7ed;
    color: #b45309;
    border: 1px solid #fed7aa;
    border-radius: 999px;
    padding: 0.32rem 0.7rem;
    font-size: 0.68rem;
    font-weight: 700;
  }

  /* SEO card */
  .en-vis-seo { background: linear-gradient(135deg, #fef5f7, #fff5e8); }
  .en-vis-seo__photo { top: 28% !important; left: 6% !important; width: 24% !important; height: 50% !important; z-index: 1; }
  .en-vis-seo-card {
    position: absolute;
    top: 32%;
    right: 5%;
    width: 60%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 0.7rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    z-index: 1;
  }
  .en-vis-seo-card__row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.66rem;
  }
  .en-vis-seo-card__row span { color: #777; font-weight: 600; }
  .en-vis-seo-card__row b { color: #1a1a1a; font-weight: 700; font-size: 0.66rem; }
  .en-vis-seo-card__url {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent-primary);
    margin-top: 0.3rem;
    padding-top: 0.4rem;
    border-top: 1px solid #f0f0f0;
    word-break: break-all;
  }

  /* ───── Testimonial card at bottom of outcomes ───── */
  .en-testimonial {
    max-width: 1200px;
    margin: 2.5rem auto 0;
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 18px;
    padding: 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .en-testimonial__quote {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.8vw, 1.5rem);
    font-weight: 700;
    line-height: 1.45;
    color: #1a1a1a;
    letter-spacing: -0.015em;
    margin: 0;
    text-transform: none;
  }
  .en-testimonial__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .en-testimonial__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1.5px solid rgba(255,77,109,0.3);
    border-radius: 999px;
    padding: 0.4rem 1rem 0.4rem 0.4rem;
  }
  .en-testimonial__avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.78rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .en-testimonial__meta { display: flex; flex-direction: column; }
  .en-testimonial__name { font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; color: #1a1a1a; }
  .en-testimonial__role { font-size: 0.72rem; color: #666; }
  .en-testimonial__logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    color: #999;
  }

  /* ═══════ STATS BAR ═══════ */
  .en-stats { padding: 1.5rem 0 3rem; background: #fff; }
  .en-stats__card {
    max-width: 1100px;
    margin: 0 auto;
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    padding: 2rem 2.5rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
  }
  .en-stat { text-align: center; border-right: 1px solid #ececec; padding: 0 1rem; }
  .en-stat:last-child { border-right: none; }
  .en-stat__val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 850;
    line-height: 1;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }
  .en-stat__lbl { font-size: 0.78rem; color: #777; line-height: 1.4; }

  /* ═══════ PROCESS ═══════ */
  .en-process { padding: 3rem 0; }
  .en-process__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }
  .en-process__header { align-items: flex-start; text-align: left; margin-bottom: 1.5rem; }
  .en-process__header h2 { text-transform: none; font-size: clamp(1.8rem, 3.2vw, 2.6rem); text-align: left; }
  .en-process__steps { display: flex; flex-direction: column; gap: 1rem; }
  .en-process-step {
    background: #fdfcf9;
    border: 1px solid rgba(0,0,0,0.06);
    border-left: 3px solid #d1d1d1;
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    opacity: 0.6;
    transition: opacity 0.2s ease, border-color 0.2s ease;
  }
  .en-process-step--active {
    opacity: 1;
    border-left-color: var(--accent-primary);
    box-shadow: 0 6px 20px rgba(0,0,0,0.04);
  }
  .en-process-step__head { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.4rem; }
  .en-process-step__num {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
  }
  .en-process-step__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .en-process-step__body { font-size: 0.88rem; line-height: 1.55; color: #555; margin: 0; }

  .en-process__visual .en-mock { background: #fdfcf9; border: 1px solid rgba(0,0,0,0.06); border-radius: 18px; overflow: hidden; }
  .ec-mock__chrome {
    background: #f6f5f1;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .ec-mock__chrome > span:not(.ec-mock__title) {
    width: 11px; height: 11px; border-radius: 50%; display: inline-block;
  }
  .ec-mock__chrome > span:nth-child(1) { background: #ff5f57; }
  .ec-mock__chrome > span:nth-child(2) { background: #ffbd2e; }
  .ec-mock__chrome > span:nth-child(3) { background: #28c940; }
  .ec-mock__title { font-family: var(--font-display); font-size: 0.78rem; font-weight: 700; color: #555; margin-left: 0.5rem; text-transform: none; }
  .en-flow { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .en-flow-row { display: flex; align-items: center; gap: 0.85rem; }
  .en-flow-node {
    flex: 1;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 999px;
    padding: 0.6rem 1rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    text-align: center;
  }
  .en-flow-node--purple { background: #6d28d9; }
  .en-flow-node--blue   { background: #1d4ed8; }
  .en-flow-node--green  { background: #047857; }
  .en-flow-node--amber  { background: #b45309; }
  .en-flow-node--coral  { background: var(--accent-primary); }
  .en-flow-node--teal   { background: #0f766e; }
  .en-flow-line { flex-shrink: 0; width: 20px; height: 2px; background: #d1d1d1; }

  /* ═══════ CASE STUDIES (re-uses cs-listing styles from ecommerce.astro pattern) ═══════ */
  .en-cases { padding: 3rem 0; }
  .en-cases .section-header { margin-bottom: 2.5rem; }
  .en-cases .section-header h2 { text-transform: none; font-size: clamp(2rem, 3.6vw, 3rem); }

  .cs-listing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .cs-listing-card {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .cs-listing-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
  .cs-listing-colour {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    aspect-ratio: 9 / 4;
    text-decoration: none;
    background: #1a1a1a;
    transition: opacity 0.2s ease;
  }
  .cs-listing-card:hover .cs-listing-colour { opacity: 0.92; }
  .cs-listing-image { background-size: cover; background-position: center; background-repeat: no-repeat; }
  .cs-listing-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.6) 100%); pointer-events: none; }
  .cs-lc--staygolden   { background: #4a3d0f; }
  .cs-lc--hairstrong   { background: #4a1f2d; }
  .cs-lc--pb           { background: #2d3d1a; }
  .cs-lc-blob ellipse                       { fill: #ffffff; }
  .cs-lc--staygolden   .cs-lc-blob ellipse  { fill: #fef3c7; }
  .cs-lc--hairstrong   .cs-lc-blob ellipse  { fill: #fecaca; }
  .cs-lc--pb           .cs-lc-blob ellipse  { fill: #d9f99d; }
  .cs-lc-blob { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
  .cs-lc-title {
    position: relative; z-index: 1; color: #fff;
    font-family: var(--font-display);
    font-size: 1.4rem; font-weight: 600;
    letter-spacing: -0.01em; text-transform: uppercase;
    text-align: center; padding: 0 1.25rem;
  }
  .cs-listing-tag {
    position: absolute; top: 1rem; left: 1rem; z-index: 2;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(6px); color: #fff;
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.35rem 0.9rem; border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.3);
  }
  .cs-listing-image .cs-listing-tag { top: auto; bottom: 1rem; background: rgba(0,0,0,0.45); border-color: rgba(255,255,255,0.2); }
  .cs-listing-content { padding: 1.75rem; display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }
  .cs-listing-headline {
    font-size: 0.98rem; font-weight: 700; color: #1a1a1a;
    line-height: 1.35; margin: 0; letter-spacing: -0.015em; flex: 1; text-transform: none;
  }
  .cs-listing-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-top: 0.5rem; padding: 0.6rem 1.25rem;
    border: 1.5px solid #1a1a1a; border-radius: 999px;
    font-size: 0.85rem; font-weight: 700; color: #1a1a1a;
    text-decoration: none; width: fit-content;
    transition: all 0.25s ease;
  }
  .cs-listing-cta:hover { background: #1a1a1a; color: #fff; }
  .cs-cta-arrow { transition: transform 0.2s ease; }
  .cs-listing-cta:hover .cs-cta-arrow { transform: translateX(3px); }


  /* ═══════ HOW WE PLUG-IN (Our Approach) ═══════ */
  .ec-howwork { padding: 2rem 0; }
  .ec-howwork__intro {
    text-align: center;
    max-width: 960px;
    margin: 0 auto 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .ec-howwork__intro h2 { text-wrap: balance; }
  .ec-howwork__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .ec-howwork__card {
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-top: 3px solid var(--accent-primary);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .ec-howwork__num {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
  }
  .ec-howwork__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    text-transform: none;
    margin: 0;
  }
  .ec-howwork__body {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* ═══════ HOW WE COMMUNICATE ═══════ */
  .ec-comms { padding: 2rem 0; }
  .ec-comms__intro {
    text-align: center;
    max-width: 960px;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .ec-comms__intro h2 { text-wrap: balance; }
  .ec-comms__body {
    max-width: 820px;
    margin: 0 auto 1.5rem;
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-left: 3px solid var(--accent-primary);
    border-radius: 14px;
    padding: 1.75rem 1.75rem;
  }
  .ec-comms__body-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    text-transform: none;
    margin: 0 0 0.75rem;
  }
  .ec-comms__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: #444;
  }

  /* ═══════ TIERED PRICING ═══════ */
  .ec-pricing { padding: 2rem 0; }
  .ec-pricing__intro {
    text-align: center;
    max-width: 960px;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .ec-pricing__intro h2 { text-wrap: balance; }
  .ec-pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .ec-pricing__card {
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 18px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .ec-pricing__card--featured {
    border: 1.5px solid var(--accent-primary);
    box-shadow: 0 10px 30px rgba(255, 77, 109, 0.08);
    transform: translateY(-4px);
  }
  .ec-pricing__card--featured::before {
    content: 'Most Common';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-primary);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .ec-pricing__tier {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--accent-primary);
    text-transform: uppercase;
  }
  .ec-pricing__price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .ec-pricing__amount {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 850;
    letter-spacing: -0.03em;
    color: #1a1a1a;
    line-height: 1;
  }
  .ec-pricing__period {
    font-size: 0.95rem;
    color: #777;
    font-weight: 500;
  }
  .ec-pricing__body {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }
  .ec-pricing__footer {
    text-align: center;
    margin: 2.5rem auto 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .ec-pricing__note {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ═══════ FAQ (Common Questions) ═══════ */
  .ec-faq { padding: 2rem 0; }
  .ec-faq__intro {
    text-align: center;
    margin: 0 auto 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .ec-faq__list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ec-faq__item {
    background: #fdfcf9;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .ec-faq__item[open] {
    border-color: rgba(0, 0, 0, 0.12);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
  }
  .ec-faq__q {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1.4rem;
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    text-transform: none;
  }
  .ec-faq__q::-webkit-details-marker { display: none; }
  .ec-faq__q::after {
    content: '';
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-right: 2px solid var(--accent-primary);
    border-bottom: 2px solid var(--accent-primary);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    margin-bottom: 4px;
  }
  .ec-faq__item[open] .ec-faq__q::after {
    transform: rotate(-135deg);
    margin-bottom: 0;
    margin-top: 4px;
  }
  .ec-faq__a {
    padding: 0 1.4rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
  }

  /* ═══════ RESPONSIVE ═══════ */
  @media (max-width: 900px) {
    .en-why__grid,
    .en-process__grid { grid-template-columns: 1fr; gap: 2rem; }
    .en-outcomes__grid { grid-template-columns: 1fr; gap: 1rem; }
    .en-out-card--wide,
    .en-out-card--narrow,
    .en-out-card--full { grid-column: span 1; }
    .en-cluster-header { padding: 0; }
    .en-stats__card { grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 1.5rem; }
    .en-stat { border-right: none; padding: 0; }
    .en-cat-head, .en-cat-row {
      grid-template-columns: 1.1fr 0.8fr 1fr 0.7fr 0.7fr;
      font-size: 0.7rem;
    }
    .en-cat-head span:nth-child(4), .en-cat-row span:nth-child(4) { display: none; }
    .cs-listing-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .en-testimonial { padding: 1.75rem 1.5rem; }
    .en-vis-channel-cols { grid-template-columns: 1fr; gap: 0.5rem; }
    .en-vis-channel-divider { display: none; }
    .ec-howwork__grid { grid-template-columns: 1fr; gap: 0.85rem; }
    .ec-howwork__card { padding: 1.4rem 1.25rem; }
    .ec-pricing__grid { grid-template-columns: 1fr; gap: 1rem; }
    .ec-pricing__card { padding: 1.5rem 1.25rem; }
    .ec-pricing__card--featured { transform: none; }
    .ec-pricing__amount { font-size: 2rem; }
  }
  @media (max-width: 720px) {
    .ec-comms__body { padding: 1.25rem 1.25rem; }
    .ec-comms__body p { font-size: 0.95rem; }
    .ec-faq__q { font-size: 0.95rem; padding: 0.95rem 1.1rem; }
    .ec-faq__a { padding: 0 1.1rem 1.1rem; font-size: 0.9rem; }
  }
  @media (max-width: 640px) {
    .en-stats__card { grid-template-columns: 1fr; }
    .en-problems__grid { grid-template-columns: 1fr 1fr; }
    .en-out-card__visual { aspect-ratio: 4 / 3; }
  }
</style>

<script>
  // Outcome cluster tab switcher
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.en-outcomes__tab');
    const clusters = document.querySelectorAll('.en-outcomes__cluster');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-cluster');
        tabs.forEach(t => t.classList.toggle('is-active', t === tab));
        clusters.forEach(c => c.classList.toggle('is-active', c.getAttribute('data-cluster') === target));
      });
    });
  });
</script>
</Layout>
