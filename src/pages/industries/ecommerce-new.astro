<style>
  main { overflow-x: hidden; }

  /* ───── Shared text-gradient ───── */
  .text-gradient {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  /* ───── Section header (shared with other pages) ───── */
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .badge {
    background: #1A1A1A;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-indent: 0.12em;
    display: inline-block;
  }

  /* ───── Primary CTA (matches ecommerce page) ───── */
  .ec-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    background: #FF7A7A;
    color: #1A1A1A;
    padding: 0.9rem 1.5rem;
    border: 2px solid #000;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    text-transform: none;
    text-decoration: none;
    letter-spacing: -0.005em;
    box-shadow: 4px 4px 0 #000;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                box-shadow 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                background 0.2s ease;
  }
  .ec-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
    background: #ff9d9d;
  }
  .ec-btn:active {
    transform: translate(0, 0);
    box-shadow: 0 0 0 #000;
  }
  .ec-animated-dots {
    display: inline-flex;
    gap: 3px;
  }
  .ec-animated-dots span {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #1a1a1a;
    animation: en-dot-bounce 1.2s ease-in-out infinite;
  }
  .ec-animated-dots span:nth-child(2) { animation-delay: 0.15s; }
  .ec-animated-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes en-dot-bounce {
    0%, 80%, 100% { opacity: 0.4; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-2px); }
  }

  /* ═══════ HERO ═══════ */
  .en-hero {
    position: relative;
    padding: 3rem 0 1rem;
    text-align: center;
    overflow: hidden;
  }
  .en-hero__bg-blur {
    position: absolute;
    top: -120px;
