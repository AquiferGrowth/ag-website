    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    border: 1.5px solid #e5e7eb;
  }
  .ec-who__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
