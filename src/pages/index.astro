---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<Header />
	<main class="container">
		<section class="hero animate-fade-in" style="padding: var(--space-xl) 0; text-align: center;">
			<h1 style="font-size: clamp(3rem, 8vw, 5rem); margin-bottom: var(--space-md); line-height: 1.1;">
				Elevating Digital <span style="color: var(--accent-primary);">Experiences</span>
			</h1>
			<p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto var(--space-lg) auto; font-size: 1.25rem;">
				High-performance, content-driven websites built with Astro, Cloudflare, and cutting-edge design principles.
			</p>
			<div style="display: flex; gap: var(--space-md); justify-content: center;">
				<a href="/blog" class="btn btn-primary">Read the Blog</a>
				<a href="/about" class="btn btn-outline">Learn More</a>
			</div>
		</section>

		<section class="grid grid-3" style="padding: var(--space-lg) 0;">
			<div class="glass card">
				<h3>Performance First</h3>
				<p>Astro ships zero JavaScript by default, ensuring lightning-fast load times.</p>
			</div>
			<div class="glass card">
				<h3>Content Managed</h3>
				<p>Integrated Git-based CMS allows for easy updates without leaving your workflow.</p>
			</div>
			<div class="glass card">
				<h3>Scalable Hosting</h3>
				<p>Deployed on Cloudflare's global edge network for maximum availability.</p>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.btn {
		padding: 0.8rem 2rem;
		border-radius: 8px;
		font-weight: 600;
		transition: var(--transition-fast);
	}
	.btn-primary {
		background: var(--accent-primary);
		color: white;
	}
	.btn-primary:hover {
		background: var(--accent-secondary);
		transform: translateY(-2px);
		box-shadow: 0 4px 20px var(--accent-glow);
	}
	.btn-outline {
		border: 1px solid var(--border-color);
	}
	.btn-outline:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--text-secondary);
	}
	.card {
		padding: var(--space-md);
		transition: var(--transition-fast);
	}
	.card:hover {
		border-color: var(--accent-primary);
		transform: translateY(-5px);
	}
	.card h3 {
		margin-bottom: var(--space-sm);
	}
</style>
