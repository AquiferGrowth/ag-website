		transform: translateX(-3px);
	}
	.uc-tag {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #94a3b8;
		background: rgba(255, 255, 255, 0.05);
		padding: 4px 10px;
		border-radius: 4px;
		display: inline-block;
		margin-bottom: 0.75rem;
	}
	.uc-title {
		font-size: 2rem;
		font-family: inherit;
		font-weight: 500;
		line-height: 1.1;
		color: #f8fafc;
		margin: 0;
	}


	.framework-console {
		display: grid;
		grid-template-columns: 220px 280px 1.4fr;
		gap: 0.75rem;
		align-items: start;
		position: relative;
		z-index: 2;
	}

	.stream-connections {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 10;
	}

	.console-panel {
		background: rgba(15, 23, 42, 0.4);
		backdrop-filter: blur(8px);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.panel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.03);
	}

	.panel-tag {
		font-size: 0.6rem;
		font-weight: 800;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 0.15em;
	}

	.panel-meta {
		font-size: 0.5rem;
		color: #475569;
		font-family: var(--font-mono, monospace);
	}

	/* Systems Source List */
	.systems-source-list {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.source-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.04);
		border-radius: 10px;
		position: relative;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.source-item.active {
		background: rgba(59, 130, 246, 0.05);
		border-color: rgba(59, 130, 246, 0.2);
	}

	.source-indicator {
		width: 6px;
		height: 6px;
		background: #1e293b;
		border-radius: 50%;
		flex-shrink: 0;
		transition: all 0.3s ease;
	}

	.source-item.active .source-indicator {
		background: #3b82f6;
		box-shadow: 0 0 8px #3b82f6;
	}

	.source-label {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.source-label span:first-child {
		font-size: 0.65rem;
		font-weight: 700;
		color: #94a3b8;
	}

	.source-item.active .source-label span:first-child { color: #f8fafc; }

	.s-type {
		font-size: 0.5rem;
		color: #475569;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.stream-anchor {
		position: absolute;
		right: 0;
		top: 50%;
		width: 1px;
		height: 1px;
	}

	.source-metrics {
		margin-top: auto;
		background: rgba(0,0,0,0.2);
		border-radius: 10px;
		padding: 0.75rem;
	}

	.mini-trend {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.mt-label { font-size: 0.5rem; color: #64748b; text-transform: uppercase; }
	.mt-footer { display: flex; justify-content: space-between; align-items: center; }
	.mt-val { font-family: var(--font-mono, monospace); font-size: 0.6rem; color: #3b82f6; }
	.mt-status { font-size: 0.5rem; color: #10b981; opacity: 0.8; }

	/* Execution Engine */
	.task-checklist {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.task-item {
		display: flex;
		gap: 1rem;
		opacity: 0.15;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		transform: translateX(-5px);
	}

	.task-item.is-active { opacity: 1; transform: translateX(0); }
	.task-item.is-done { opacity: 0.5; transform: translateX(0); }

	.checkbox-box {
		width: 16px;
		height: 16px;
		border: 1.5px solid rgba(255, 255, 255, 0.15);
		border-radius: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}

	.task-item.is-done .checkbox-box {
		background: #3b82f6;
		border-color: #3b82f6;
	}

	.checkbox-box svg { opacity: 0; transform: scale(0.6); transition: all 0.3s ease; }
	.task-item.is-done .checkbox-box svg { opacity: 1; transform: scale(1); }

	.task-label { font-size: 0.75rem; font-weight: 700; color: #f1f5f9; display: block; margin-bottom: 2px; }
	.task-detail { font-size: 0.6rem; color: #64748b; line-height: 1.3; }

	.oversight-column {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.oversight-dashboard {
		height: 100%;
		background: rgba(10, 15, 30, 0.9);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-top: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 16px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		transform-origin: center;
		transition: all 0.5s ease;
	}

	.oversight-dashboard.active {
		border-color: rgba(16, 185, 129, 0.3);
		box-shadow: 0 30px 60px -15px rgba(0, 185, 129, 0.1);
	}

	.dashboard-header {
		padding: 1rem 1.5rem;
		background: rgba(255,255,255,0.03);
		border-bottom: 1px solid rgba(255,255,255,0.06);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.dash-id { display: flex; flex-direction: column; }
	.dash-id .label { font-size: 0.5rem; color: #475569; letter-spacing: 0.05em; }
	.dash-id .val { font-family: var(--font-mono, monospace); font-size: 0.6rem; color: #94a3b8; }

	.dash-status { display: flex; align-items: center; gap: 0.75rem; }
	.ready-tag { font-size: 0.6rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; }
	.status-dot { width: 6px; height: 6px; background: #334155; border-radius: 50%; transition: all 0.5s ease; }
	.oversight-dashboard.active .status-dot { background: #10b981; box-shadow: 0 0 10px #10b981; }

	.dashboard-grid {
		padding: 1.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: auto 1fr;
		gap: 1.5rem;
		flex: 1;
	}

	.dash-main-chart { grid-column: span 2; display: flex; flex-direction: column; gap: 0.75rem; }
	.chart-header { display: flex; justify-content: space-between; align-items: flex-end; }
	.c-label { font-size: 0.6rem; color: #64748b; text-transform: uppercase; font-weight: 800; }
	.c-val { font-size: 1.2rem; font-weight: 800; color: #fff; font-family: var(--font-mono, monospace); }

	.confidence-bar { height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
	.confidence-bar-fill { width: 0%; height: 100%; background: linear-gradient(90deg, #3b82f6, #60a5fa); }
	.chart-axis { display: flex; justify-content: space-between; font-size: 0.5rem; color: #334155; padding-top: 4px; }

	.dash-stats { display: flex; align-items: center; justify-content: center; }
	.stat-circle { position: relative; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
	.stat-inner { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
	.stat-inner .s-val { font-family: var(--font-mono, monospace); font-size: 0.85rem; font-weight: 700; color: #fff; display: block; }
	.stat-inner .s-label { font-size: 0.4rem; color: #64748b; letter-spacing: 0.1em; font-weight: 800; }

	.stat-circle .ring-fill { transition: stroke-dashoffset 1s ease; }

	.dash-ledger { display: flex; flex-direction: column; gap: 0.5rem; }
	.dash-ledger .ledger-header { display: grid; grid-template-columns: 1fr 1fr 1fr; font-size: 0.5rem; color: #475569; font-weight: 800; text-transform: uppercase; padding-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,0.04); }
	.ledger-rows { display: flex; flex-direction: column; gap: 2px; }
	.l-row { display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: center; padding: 4px 0; font-size: 0.55rem; color: #94a3b8; }
	.l-row .l-status { font-weight: 700; color: #10b981; }
	.l-row.warn .l-status.highlight { color: #f59e0b; }

	.dash-activity { grid-column: span 1; }
	.activity-label { font-size: 0.5rem; color: #475569; text-transform: uppercase; font-weight: 800; margin-bottom: 6px; }
	.activity-viz { display: flex; align-items: flex-end; gap: 4px; height: 30px; }
	.a-bar { flex: 1; background: rgba(59, 130, 246, 0.1); border-radius: 1px; transition: all 0.3s ease; }

	.dash-details { grid-column: span 1; }
	.quality-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
	.q-item { background: rgba(255, 255, 255, 0.02); padding: 0.4rem; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.04); text-align: center; }
	.q-label { display: block; font-size: 0.35rem; color: #475569; text-transform: uppercase; margin-bottom: 2px; }
	.q-val { font-size: 0.6rem; font-weight: 700; color: #94a3b8; font-family: var(--font-mono, monospace); }

	.dash-audit { grid-column: span 2; }
	.audit-log { display: flex; flex-direction: column; gap: 4px; padding-top: 4px; border-top: 1px solid rgba(255,255,255,0.03); }
	.log-item { display: flex; gap: 8px; font-size: 0.5rem; color: #475569; }
	.log-time { color: #3b82f6; font-family: var(--font-mono, monospace); opacity: 0.6; }
	.log-txt { font-weight: 500; }

	.dashboard-footer { padding: 1rem 1.5rem; background: rgba(0,0,0,0.2); display: flex; justify-content: space-between; align-items: center; }
	.footer-meta { display: flex; gap: 1.5rem; }
	.meta-item { display: flex; flex-direction: column; }
	.m-label { font-size: 0.5rem; color: #475569; text-transform: uppercase; }
	.m-val { font-family: var(--font-mono, monospace); font-size: 0.8rem; font-weight: 700; color: #f8fafc; }

	.btn-approve-console {
		background: #3b82f6;
		color: #fff;
		border: none;
		padding: 0.75rem 1.25rem;
		border-radius: 8px;
		font-size: 0.65rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.1;
		transition: all 0.4s ease;
	}

	.oversight-dashboard.active .btn-approve-console {
		opacity: 1;
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
	}

	/* ── CRM Dashboard ────────────────────────────── */
	.crm-dashboard .dashboard-grid { display: none; } /* hide financial grid */

	.crm-stats-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5rem;
		margin-bottom: 0.75rem;
		padding: 0.75rem 1.25rem 0;
	}
	.crm-stat {
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 8px;
		padding: 0.5rem 0.6rem;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.crm-stat-val { font-size: 1rem; font-weight: 700; line-height: 1.2; }
	.crm-stat-label { font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; }

	.crm-table-section { margin-bottom: 0.6rem; padding: 0 1.25rem; }
	.crm-table-label {
		font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em;
		color: #64748b; margin-bottom: 0.4rem;
		display: flex; align-items: center; gap: 0.4rem;
	}
	.crm-badge {
		font-size: 0.5rem; background: rgba(59,130,246,0.15);
		color: #60a5fa; border: 1px solid rgba(59,130,246,0.3);
		border-radius: 4px; padding: 1px 5px; text-transform: uppercase;
	}
	.crm-table-wrapper { border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; overflow: hidden; }
	.crm-table-head {
		display: grid;
		grid-template-columns: 1.4fr 1.2fr 0.9fr 1.3fr 0.7fr;
		padding: 0.35rem 0.6rem;
		background: rgba(255,255,255,0.04);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		font-size: 0.52rem; text-transform: uppercase; letter-spacing: 0.06em; color: #475569;
	}
	.crm-table-body { display: flex; flex-direction: column; }
	.crm-row {
		display: grid;
		grid-template-columns: 1.4fr 1.2fr 0.9fr 1.3fr 0.7fr;
		padding: 0.4rem 0.6rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
		font-size: 0.62rem; align-items: center;
		transition: background 0.2s;
	}
	.crm-row:last-child { border-bottom: none; }
	.crm-row--new { background: rgba(59,130,246,0.05); }
	.crm-row--flag { background: rgba(245,158,11,0.05); }
	.crm-company { color: #e2e8f0; font-weight: 600; }
	.crm-contact { color: #94a3b8; }
	.crm-value { color: #a5b4fc; font-weight: 600; text-align: right; }

	.crm-source {
		font-size: 0.52rem; padding: 2px 6px; border-radius: 4px;
		font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
		display: inline-block; width: fit-content;
	}
	.src-web  { background: rgba(59,130,246,0.15); color: #60a5fa; }
	.src-li   { background: rgba(139,92,246,0.15); color: #a78bfa; }
	.src-apollo { background: rgba(245,158,11,0.15); color: #fbbf24; }

	.crm-stage {
		font-size: 0.55rem; padding: 2px 7px; border-radius: 20px;
		font-weight: 600; display: inline-block; width: fit-content;
	}
	.stage-qualified { background: rgba(59,130,246,0.15); color: #60a5fa; }
	.stage-proposal  { background: rgba(139,92,246,0.15); color: #a78bfa; }
	.stage-closed    { background: rgba(16,185,129,0.15); color: #34d399; }
	.stage-flag      { background: rgba(245,158,11,0.15); color: #fbbf24; }

	.crm-sources-section { margin-bottom: 0.6rem; padding: 0 1.25rem; }
	.crm-source-bars { display: flex; flex-direction: column; gap: 0.35rem; }
	.crm-src-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.6rem; }
	.crm-src-name { color: #94a3b8; width: 60px; flex-shrink: 0; }
	.crm-src-track {
		flex: 1; height: 5px; background: rgba(255,255,255,0.07);
		border-radius: 10px; overflow: hidden;
	}
	.crm-src-fill { height: 100%; border-radius: 10px; }
	.crm-src-pct { color: #64748b; font-size: 0.55rem; width: 28px; text-align: right; flex-shrink: 0; }


	/* ── Process Section ──────────────────────── */
	.process-section {
		padding: 8rem 0;
		background: transparent;
		overflow: visible;
		position: relative;
	}

	.process-container {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: flex-start;
	}

	.process-header {
		position: sticky;
		top: 15vh;
	}

	.step-tag {
		display: inline-flex;
		padding: 0.5rem 1rem;
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 700;
		color: #1A1A1A;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 2rem;
	}

	.process-title {
		font-size: clamp(3rem, 8vw, 5rem);
		line-height: 0.95;
		color: #1A1A1A;
		margin-bottom: 2rem;
		font-weight: 800;
	}

	.process-desc {
		font-size: 1.25rem;
		color: #555555;
		max-width: 480px;
		line-height: 1.6;
	}

	/* Success Path Indicator */
	.success-path-wrapper {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-top: 2rem;
		position: relative;
	}

	.path-line {
		position: absolute;
		left: 6px;
		top: 40px;
		bottom: 40px;
		width: 2px;
		background: #e5e7eb;
		z-index: 0;
	}

	.dots-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		z-index: 1;
	}

	.dot {
		width: 14px;
		height: 14px;
		background: #FFFFFF;
		border: 2px solid #e5e7eb;
		border-radius: 50%;
		position: relative;
		z-index: 1;
		transition: all 0.3s ease;
	}

	.dot.active {
		background: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: 0 0 10px rgba(255, 77, 109, 0.4);
	}

	/* Process steps cards */
	.process-steps {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.process-card {
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		padding: 3rem;
		position: relative;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
	}

	.process-card:hover {
		background: #FFFFFF;
		border-color: #d1d5db;
		transform: translateY(-5px);
	}

	.card-num {
		position: absolute;
		top: -20px;
		right: -10px;
		font-size: 12rem;
		font-weight: 900;
		color: rgba(0, 0, 0, 0.03);
		user-select: none;
		pointer-events: none;
		z-index: 0;
	}

	.card-content h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #1A1A1A;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		position: relative;
		z-index: 1;
	}

	.step-desc {
		font-size: 1.125rem;
		color: #555555;
		line-height: 1.6;
		margin-bottom: 2.5rem;
		position: relative;
		z-index: 1;
	}

	.step-features {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		list-style: none;
		padding: 0;
		position: relative;
		z-index: 1;
	}

	.step-features li {
		background: #F9F7F2;
		border: 1px solid #e5e7eb;
		padding: 0.4rem 0.8rem;
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 600;
		color: #1A1A1A;
	}

	@media (max-width: 1024px) {
		.process-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.process-header {
			position: relative;
			top: 0;
		}

		.process-desc {
			max-width: 100%;
		}
		
		.card-num { font-size: 5rem; top: 0; right: 20px; }
	}


	/* ── Order Fulfillment Dashboard ──────────────────────── */
	.ecom-dashboard .dashboard-grid { display: none; }
	
	.ecom-layout {
		display: flex;
		height: 290px;
		background: rgba(255,255,255,0.02);
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.ecom-sidebar {
		width: 100px;
		flex-shrink: 0;
		border-right: 1px solid rgba(255,255,255,0.07);
		background: rgba(0,0,0,0.2);
		padding: 1rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.sidebar-item {
		padding: 0.5rem 0.75rem;
		font-size: 0.65rem;
		font-weight: 600;
		color: #64748b;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		transition: all 0.2s;
		cursor: pointer;
	}

	.sidebar-item svg { opacity: 0.6; }
	.sidebar-item.active { color: #e2e8f0; background: rgba(255,255,255,0.04); }
	.sidebar-item.active svg { color: var(--primary-accent); opacity: 1; }

	.ecom-main {
		flex: 1;
		padding: 1.25rem;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.inventory-table {
		background: rgba(0,0,0,0.3);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 10px;
		overflow: hidden;
	}

	.inventory-table .table-head {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		padding: 0.5rem 0.75rem;
		background: rgba(255,255,255,0.03);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #475569;
	}

	.inventory-table .table-row {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid rgba(255,255,255,0.04);
		font-size: 0.65rem;
		align-items: center;
	}

	.inventory-table .table-row:last-child { border-bottom: none; }
	.inventory-table .table-row.highlight { background: rgba(239, 68, 68, 0.04); }

	.status-ok { color: #10b981; font-weight: 700; font-size: 0.55rem; }
	.status-warn { color: #ef4444; font-weight: 700; font-size: 0.55rem; animation: pulse-red 2s infinite; }

	@keyframes pulse-red {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.6; }
	}

	.exception-card {
		background: linear-gradient(to right, rgba(239, 68, 68, 0.08), transparent);
		border: 1px solid rgba(239, 68, 68, 0.2);
		border-radius: 10px;
		padding: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.exc-title {
		display: block;
		font-size: 0.6rem;
		font-weight: 800;
		color: #f87171;
		letter-spacing: 0.05em;
		margin-bottom: 2px;
	}

	.exc-meta {
		display: block;
		font-size: 0.65rem;
		color: #94a3b8;
	}

	.mini-chart {
		display: flex;
		align-items: flex-end;
		gap: 8px;
		height: 60px;
		padding: 0 1rem;
	}

	.mini-chart .bar {
		flex: 1;
		background: rgba(59, 130, 246, 0.4);
		border-radius: 4px 4px 0 0;
	}

	.stats-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.s-box {
		background: rgba(255, 255, 255, 0.03);
		padding: 1rem;
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.s-label {
		font-size: 0.7rem;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.s-val {
		font-size: 1.1rem;
		font-weight: 700;
		color: #fff;
	}

	.progress-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.progress-item {
		display: flex;
		gap: 1.25rem;
		opacity: 0.3;
		transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
		transform: translateX(-10px);
	}

	.progress-item.active {
		opacity: 1;
		transform: translateX(0);
	}

	.progress-item.done {
		opacity: 0.6;
		transform: translateX(0);
	}

	.step-icon {
		width: 40px;
		height: 40px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #94a3b8;
		flex-shrink: 0;
		transition: all 0.4s ease;
	}

	.progress-item.active .step-icon {
		background: rgba(255, 77, 109, 0.1);
		border-color: var(--accent-primary);
		color: var(--accent-primary);
		box-shadow: 0 0 20px rgba(255, 77, 109, 0.2);
	}

	.progress-item.done .step-icon {
		background: rgba(255, 255, 255, 0.1);
		color: #FFFFFF;
	}

	.step-title {
		font-size: 0.8rem;
		font-weight: 700;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.25rem;
		display: block;
	}

	/* Failure Mapping Visual Styles */
	.failure-mapping-diagram {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.mapping-header {
		display: grid;
		grid-template-columns: 1fr 40px 1.2fr;
		width: 100%;
		padding: 0;
		margin-bottom: 0.5rem;
	}

	.header-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #9ca3af;
		text-align: center; /* Center within grid column */
	}

	.header-label.color-damage {
		color: #f47b56;
	}

	.mapping-grid {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.mapping-row {
		display: grid;
		grid-template-columns: 1fr 40px 1.2fr;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		transform: translateX(-10px);
	}

	/* Compact Execution Layer Styles */
	.compact-dashboard {
		width: 100%;
		padding: 0.5rem;
	}

	.dashboard-rows {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}

	.compact-item {
		display: flex;
		gap: 0.75rem;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.5);
		border-radius: 8px;
		border: 1px solid rgba(0, 0, 0, 0.05);
		opacity: 0;
		transform: translateY(10px);
	}

	.roadmap-step.is-visible .compact-item {
		animation: compactReveal 0.6s ease forwards;
	}

	.roadmap-step.is-visible .compact-item:nth-child(2) { animation-delay: 0.2s; }
	.roadmap-step.is-visible .compact-item:nth-child(3) { animation-delay: 0.4s; }

	@keyframes compactReveal {
		to { opacity: 1; transform: translateY(0); }
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		margin-top: 4px;
		flex-shrink: 0;
	}

	.status-dot.green { background: #10b981; }
	.status-dot.orange { background: #f97316; }

	.status-dot.pulse {
		box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
		animation: dotPulse 2s infinite;
	}

	@keyframes dotPulse {
		0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
		70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
		100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
	}

	.compact-label {
		display: block;
		font-size: 0.65rem;
		font-weight: 700;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.15rem;
	}

	/* Step 3 Sleek Pills - Simple Connected System */
	.outcome-pills-container {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.75rem; /* Slightly tighter gap */
		justify-content: center;
		width: 100%;
		max-width: 650px; /* Narrower container */
		margin: 0 auto;
		padding: 1rem 0.5rem; /* Significantly tighter padding */
		position: relative;
	}

	.outcome-pill-item {
		display: flex;
		align-items: center;
		padding: 0.45rem 1rem; /* Back to sleek smaller size */
		background: #ffffff;
		border-radius: 100px;
		border: 1px solid rgba(15, 23, 42, 0.15);
		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
		opacity: 0;
		transform: translateY(10px);
		transition: all 0.3s ease;
		position: relative;
		z-index: 2;
	}

	/* Simple horizontal connector line after each pill */
	.outcome-pill-item::after {
		content: "";
		position: absolute;
		left: 100%;
		top: 50%;
		width: 1.75rem;
		height: 1px;
		background: rgba(15, 23, 42, 0.1);
		z-index: 1;
	}

	.outcome-pill-item:last-child::after {
		display: none;
	}

	.outcome-pill-item:hover {
		border-color: #0f172a;
		transform: translateY(-2px);
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
	}

	.roadmap-step.is-visible .outcome-pill-item {
		animation: pillReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.roadmap-step.is-visible .outcome-pill-item:nth-child(1) { animation-delay: 0.1s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(2) { animation-delay: 0.2s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(3) { animation-delay: 0.3s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(4) { animation-delay: 0.4s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(5) { animation-delay: 0.5s; }

	@keyframes pillReveal {
		to { opacity: 1; transform: translateY(0); }
	}

	.outcome-pill-item span {
		font-size: 0.725rem; /* Sleek smaller font restored */
		font-weight: 700;
		color: #0f172a;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.outcome-pill-item::after {
			display: none;
		}
		.outcome-pills-container {
			gap: 0.75rem;
		}
	}

	.compact-title {
		font-size: 0.75rem;
		font-weight: 700;
		color: #1e293b;
		margin: 0 !important;
	}

	.compact-sub {
		font-size: 0.75rem;
		color: #64748b;
		line-height: 1.3;
	}

	.mini-rows {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.mini-rows p {
		font-size: 0.8rem;
		font-weight: 600;
		color: #334155;
		margin: 0 !important;
	}

	.compact-outcomes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
		opacity: 0;
	}

	.roadmap-step.is-visible .compact-outcomes {
		animation: compactReveal 0.6s ease forwards 0.8s;
	}

	.outcome-pill {
		background: #0f172a;
		color: #ffffff;
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.4rem 0.6rem;
		border-radius: 4px;
		text-align: center;
		white-space: nowrap;
	}

	.roadmap-step.is-visible .mapping-row {
		animation: rowSlideIn 0.5s ease-out forwards;
	}

	/* Staggered Row Entry */
	.roadmap-step.is-visible .mapping-row:nth-child(1) { animation-delay: 0.4s; }
	.roadmap-step.is-visible .mapping-row:nth-child(2) { animation-delay: 0.6s; }
	.roadmap-step.is-visible .mapping-row:nth-child(3) { animation-delay: 0.8s; }
	.roadmap-step.is-visible .mapping-row:nth-child(4) { animation-delay: 1.0s; }
	.roadmap-step.is-visible .mapping-row:nth-child(5) { animation-delay: 1.2s; }

	@keyframes rowSlideIn {
		to { opacity: 1; transform: translateX(0); }
	}

	.func-pill, .damage-pill {
		padding: 0.45rem 0.75rem;
		border-radius: 100px;
		font-size: 0.68rem; /* Further reduced to fit smaller card width */
		font-weight: 800;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		min-height: 36px;
		white-space: nowrap;
	}

	.func-pill {
		background: #ffffff;
		border: 1.5px solid #e5e7eb;
		color: #111827;
		box-shadow: 0 2px 8px rgba(0,0,0,0.03);
	}

	.damage-pill {
		background: #fff7ed;
		border: 1.5px solid #fed7aa;
		color: #9a3412;
	}

	.progress-item.active .step-title {
		color: var(--accent-primary);
	}

	.step-text {
		font-size: 0.95rem;
		color: #cbd5e1;
		line-height: 1.5;
	}

	/* Liability Stack Visual Styles */
	.liability-stack-diagram.messy-mode {
		position: relative;
		overflow: hidden;
	}

	.fragmented-lines {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0;
		pointer-events: none;
		opacity: 0.15;
	}

	.f-line {
		fill: none;
		stroke: #f47b56;
		stroke-width: 1.5;
		stroke-dasharray: 4, 6;
		animation: lineDash 12s linear infinite, lineFlicker 3s infinite;
	}

	@keyframes lineFlicker {
		0%, 100% { opacity: 0.15; }
		50% { opacity: 0.05; }
		55% { opacity: 0.25; }
		60% { opacity: 0.15; }
	}

	@keyframes lineDash {
		to { stroke-dashoffset: -100; }
	}

	.liability-stack-diagram {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		padding: 1rem;
		width: 100%;
		position: relative;
		z-index: 1;
	}

	.operational-pills, .liability-pills {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.6rem;
		width: 100%;
	}

	.op-pill, .li-pill {
		padding: 0.5rem 1rem;
		border-radius: 100px;
		font-size: 0.85rem;
		font-weight: 500;
		white-space: nowrap;
		transition: all 0.3s ease;
		position: relative;
	}

	.op-pill {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		color: #475569;
		opacity: 0;
	}

	.roadmap-step.is-visible .op-pill {
		animation: fadeInSlideUp 0.6s ease-out forwards, driftPill 6s ease-in-out infinite;
	}

	.li-pill {
		background: #fef2f2;
		border: 1px solid #fee2e2;
		color: #b91c1c;
		opacity: 0;
	}

	.roadmap-step.is-visible .li-pill {
		animation: fadeInSlideUp 0.6s ease-out 0.8s forwards, jitterPill 4s ease-in-out infinite 1.2s;
	}

	/* Chaotic Animations */
	@keyframes driftPill {
		0%, 100% { transform: translateY(0) translateX(0); }
		33% { transform: translateY(-3px) translateX(2px); }
		66% { transform: translateY(2px) translateX(-4px); }
	}

	@keyframes jitterPill {
		0%, 100% { transform: scale(1) rotate(0); }
		10%, 20% { transform: scale(0.98) rotate(-1deg); }
		15% { transform: scale(1.02) rotate(1deg); }
		50% { transform: scale(1.01) rotate(0.5deg); }
	}

	.icon-error { color: #f43f5e; margin-right: 0.4rem; font-size: 0.8rem; }
	.icon-warning { color: #f59e0b; margin-right: 0.4rem; font-size: 0.8rem; }
	.icon-bolt { color: #b91c1c; margin-left: 0.4rem; font-size: 0.8rem; animation: flicker 2s infinite; }

	.blink-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		background: #ef4444;
		border-radius: 50%;
		margin-left: 0.5rem;
		box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
		animation: pulseRed 1.5s infinite;
	}

	@keyframes flicker {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	@keyframes pulseRed {
		0% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.4); opacity: 0.5; }
		100% { transform: scale(1); opacity: 1; }
	}

	.result-divider {
		display: flex;
		align-items: center;
		width: 100%;
		gap: 1rem;
		margin: 0.25rem 0;
		opacity: 0;
	}

	.roadmap-step.is-visible .result-divider {
		animation: expandWidth 0.8s ease-out 0.4s forwards;
	}

	.divider-line {
		flex: 1;
		height: 1px;
		background: linear-gradient(to right, transparent, #fee2e2, transparent);
	}

	.divider-text {
		color: #94a3b8;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		white-space: nowrap;
	}

	@keyframes fadeInSlideUp {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@keyframes expandWidth {
		from { opacity: 0; transform: scaleX(0.5); }
		to { opacity: 1; transform: scaleX(1); }
	}

	/* Sequential Delays for Pills */
	.op-pill:nth-child(2) { animation-delay: 0.1s; }
	.op-pill:nth-child(3) { animation-delay: 0.2s; }
	.op-pill:nth-child(4) { animation-delay: 0.3s; }
	.op-pill:nth-child(5) { animation-delay: 0.4s; }

	.li-pill:nth-child(1) { animation-delay: 0.8s; }
	.li-pill:nth-child(2) { animation-delay: 0.9s; }
	.li-pill:nth-child(3) { animation-delay: 1.0s; }
	.li-pill:nth-child(4) { animation-delay: 1.1s; }
	.li-pill:nth-child(5) { animation-delay: 1.2s; }

	/* Chart Styles */
	.outcome-card {
		background: linear-gradient(135deg, rgba(255, 77, 109, 0.1) 0%, rgba(15, 23, 42, 0.6) 100%);
		border-top: 2px solid var(--accent-primary);
		opacity: 0;
		transform: translateY(20px);
	}

	.outcome-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}

	.outcome-tag {
		background: var(--accent-primary);
		color: #FFFFFF;
		font-size: 0.6rem;
		font-weight: 800;
		text-transform: uppercase;
		padding: 0.25rem 0.6rem;
		border-radius: 100px;
	}

	.outcome-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.outcome-metric {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.metric-value {
		font-size: 1.5rem;
		font-weight: 800;
		color: #FFFFFF;
	}

	.metric-label {
		font-size: 0.7rem;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.outcome-summary {
		font-size: 1.1rem;
		line-height: 1.4;
		color: #cbd5e1;
		font-style: italic;
	}

	/* Context Card Tooling */
	.context-tools {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.5rem 0 2rem;
	}

	.tool-icon {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		padding: 0.75rem 1rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.tool-icon span {
		font-size: 0.85rem;
		color: #94a3b8;
	}

	.workflow-summary h4 {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
		color: #FFFFFF;
	}

	.workflow-summary p {
		font-size: 0.9rem;
		color: #94a3b8;
		line-height: 1.6;
	}

	.status-indicator {
		width: 12px;
		height: 12px;
		border: 2px solid rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		flex-shrink: 0;
		position: relative;
		transition: all 0.4s ease;
	}

	.progress-item.active .status-indicator {
		border-color: var(--accent-primary);
		background: rgba(255, 77, 109, 0.2);
	}

	.progress-item.done .status-indicator {
		background: #10b981;
		border-color: #10b981;
		box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
	}

	.progress-item.done .status-indicator::after {
		content: '✓';
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 8px;
		color: white;
		font-weight: 900;
	}

	.result-card {
		align-self: flex-end;
		text-align: right;
		min-width: 260px;
		background: linear-gradient(135deg, rgba(255, 77, 109, 0.25) 0%, rgba(15, 23, 42, 0.95) 100%);
		border: 1px solid rgba(255, 77, 109, 0.4);
		opacity: 0;
		transform: translateY(40px);
		box-shadow: 0 0 30px rgba(0,0,0,0.5);
	}

	.result-value {
		font-size: 3.5rem;
		font-weight: 900;
		color: #fff;
		line-height: 1;
		letter-spacing: -0.04em;
		text-shadow: 0 0 30px rgba(255, 77, 109, 0.4);
	}

	.result-desc {
		font-size: 0.9rem;
		color: #94a3b8;
		font-weight: 600;
		margin-top: 0.5rem;
	}

	.outcome-badge {
		display: inline-block;
		margin-top: 2rem;
		padding: 0.6rem 1.25rem;
		background: rgba(255, 77, 109, 0.1);
		color: var(--accent-primary);
		border-radius: var(--radius-pill);
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		border: 1px solid rgba(255, 77, 109, 0.2);
	}

	.framework-text h3 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
		color: #fff;
		line-height: 1.1;
