					{testimonials.map((t, i) => {
						const quote = t.data.quote;
						const maxLen = 120;
						const needsTruncation = quote.length > maxLen;
						const truncated = needsTruncation ? quote.slice(0, maxLen).trimEnd() + '…' : quote;
						return (
						<div class={`testimonial-card${i >= 3 ? ' testimonial-extra' : ''}`}>
							<blockquote>
								<span class="quote-truncated">"{truncated}"</span>
								{needsTruncation && (
