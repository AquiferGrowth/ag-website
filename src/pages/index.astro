<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	window.addEventListener('load', () => {
		const masterTimeline = gsap.timeline();

		// Set initial states
		gsap.set([".hero h1", ".hero p", ".cta-group .btn", ".badge", ".three-act-banner"], { opacity: 0, y: 30 });

		masterTimeline
			.to(".hero h1", { opacity: 1, y: 0, duration: 1.2, ease: "power4.out" })
			.to(".hero p", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, "-=0.8")
			.to(".badge", { opacity: 1, scale: 1, y: 0, duration: 0.6, ease: "back.out(1.7)" }, "-=0.8")
			.to(".cta-group .btn", { opacity: 1, y: 0, duration: 0.8, stagger: 0.2, ease: "power2.out" }, "-=0.4")
			.to(".three-act-banner", { opacity: 1, y: 0, duration: 1, ease: "power3.out" });



		// ── Three-Act Banner Animation (full rebuild) ───────────────
		const banner = document.querySelector('.three-act-banner');
		if (banner) {
			const setAct = (label) => {
				const el = banner.querySelector('.tab-act-text');
				if (!el) return;
				el.style.opacity = '0';
				setTimeout(() => { el.textContent = label; el.style.opacity = '1'; }, 250);
			};

			const runAnim = () => {
				const tl = gsap.timeline();

				// ── RESET ──────────────────────────────────────────────────
				const srcs      = banner.querySelectorAll('.tab-src');
				const steps     = banner.querySelectorAll('.tab-step');
				const tags      = banner.querySelectorAll('.tab-tag');
				const stats     = banner.querySelectorAll('.tab-stat');
				const tableWrap = banner.querySelector('.tab-table-wrap');
				const barsWrap  = banner.querySelector('.tab-bars-wrap');
				const fills     = banner.querySelectorAll('.tab-bar-fill');
				const rows      = banner.querySelectorAll('.tab-row');
				const footer    = banner.querySelector('.tab-dash-footer');
				const managed   = banner.querySelector('.tab-managed-badge');
				const hubNode   = banner.querySelector('.tab-hub-node');
				const hubLine   = banner.querySelector('.tab-hub-line');
				const nodeCount = banner.querySelector('.tab-node-count');
				const pipeline  = banner.querySelector('.tab-pipeline');
				const flagged   = banner.querySelector('.tab-flagged');
				const fpipeline = banner.querySelector('.tab-footer-pipeline');
				const fflagged  = banner.querySelector('.tab-footer-flagged');

				srcs.forEach(el => { gsap.set(el, { opacity:0, x:-12 }); el.classList.remove('connected'); });
				steps.forEach(el => { gsap.set(el, { opacity:0, y:8 }); el.classList.remove('done'); });
				tags.forEach(el => gsap.set(el, { opacity:0 }));
				stats.forEach(el => gsap.set(el, { opacity:0 }));
				rows.forEach(el => gsap.set(el, { opacity:0 }));
				fills.forEach(el => gsap.set(el, { width:'0%' }));
				if (tableWrap) gsap.set(tableWrap, { opacity:0 });
				if (barsWrap)  gsap.set(barsWrap,  { opacity:0 });
				if (footer)    gsap.set(footer,    { opacity:0 });
				if (managed)   gsap.set(managed,   { opacity:0 });
				if (hubNode)   hubNode.classList.remove('active');
				if (hubLine)   hubLine.classList.remove('active');
				if (nodeCount) nodeCount.textContent = '0 / 4';
				if (pipeline)  pipeline.textContent  = '$284k';
				if (flagged)   flagged.textContent   = '2';
				if (fpipeline) fpipeline.textContent = '$284k';
				if (fflagged)  fflagged.textContent  = '2 rec';
				setAct('PLUG IN');

				// ── ACT 1: PLUG IN (0-3s) ──────────────────────────────────
				const srcColors = ['rgba(99,102,241,0.6)','rgba(245,158,11,0.6)','rgba(139,92,246,0.6)','rgba(249,115,22,0.6)'];
				srcs.forEach((src, i) => {
					tl.to(src, {
						opacity:1, x:0, duration:0.55, ease:'back.out(1.4)',
						onStart: () => {
							src.classList.add('connected');
							if (nodeCount) nodeCount.textContent = (i+1) + ' / 4';
							// Light up hub when first source connects
							if (i === 0 && hubNode) hubNode.classList.add('active');
							if (i === srcs.length-1 && hubLine) hubLine.classList.add('active');
						}
					}, i === 0 ? '+=0' : '-=0.15');
				});

				tl.to({}, { duration:0.5 });

				// ── ACT 2: BUILD THE SYSTEM (3-7s) ────────────────────────
				tl.add(() => setAct('BUILD THE SYSTEM'));

				// Process steps appear one by one, tags pop in after each
				steps.forEach((step, i) => {
					const tag = step.querySelector('.tab-tag');
					tl.to(step, {
						opacity:1, y:0, duration:0.5, ease:'power2.out',
						onComplete: () => {
							step.classList.add('done');
							if (tag) gsap.to(tag, { opacity:1, duration:0.3 });
						}
					});
					// Dashboard builds alongside process steps
					if (i === 0 && stats[0]) tl.to(stats[0], { opacity:1, duration:0.4 }, '<+0.2');
					if (i === 1 && stats[1]) tl.to(stats[1], { opacity:1, duration:0.4 }, '<+0.2');
					if (i === 2) {
						if (stats[2]) tl.to(stats[2], { opacity:1, duration:0.4 }, '<+0.1');
						if (stats[3]) tl.to(stats[3], { opacity:1, duration:0.4 }, '<+0.2');
						// Table appears
						if (tableWrap) tl.to(tableWrap, { opacity:1, duration:0.4 }, '<+0.2');
						rows.forEach((r, ri) => { tl.to(r, { opacity:1, duration:0.3 }, '<+0.15'); });
					}
					if (i === 3 && barsWrap) {
						tl.to(barsWrap, { opacity:1, duration:0.3 }, '<+0.1');
						fills.forEach((f, fi) => {
							const pct = f.dataset.pct + '%';
							tl.to(f, { width: pct, duration:0.9, ease:'power1.out' }, '<+' + (fi*0.15));
						});
					}
				});

				tl.to({}, { duration:0.3 });

				// ── ACT 3: RUN YOUR OPERATIONS (7-12s) ────────────────────
				tl.add(() => {
					setAct('RUN');
					// Managed badge
					if (managed) gsap.to(managed, { opacity:1, duration:0.5 });
					// Footer appears
					if (footer) gsap.to(footer, { opacity:1, duration:0.5, delay:0.2 });
					// New row ticks in
					const newRow = banner.querySelector('.tab-row-new');
					if (newRow) gsap.to(newRow, { opacity:1, duration:0.5, delay:0.6 });
					// Pipeline $284k → $291k
					if (pipeline) {
						const o = { v:284 };
						gsap.to(o, { v:291, duration:2.5, ease:'power1.inOut', delay:0.3,
							onUpdate: () => {
								const val = '$' + Math.round(o.v) + 'k';
								pipeline.textContent = val;
								if (fpipeline) fpipeline.textContent = val;
							}
						});
					}
					// Flagged 2 → 3
					setTimeout(() => {
						if (flagged)  flagged.textContent  = '3';
						if (fflagged) fflagged.textContent = '3 rec';
					}, 2200);
				})
				.to({}, { duration:4 }); // hold on Act 3

				return tl;
			};

			let started = false;
			ScrollTrigger.create({
				trigger: banner,
				start: 'top 85%',
				onEnter: () => { if (!started) { started = true; runAnim(); } }
			});
		}

		gsap.from(".solution-header h2", {
			scrollTrigger: { trigger: ".solution-header", start: "top 85%" },
			y: 30, opacity: 0, duration: 1, ease: "power3.out"
		});

		gsap.from(".roadmap-step", {
			scrollTrigger: { trigger: ".roadmap-container", start: "top 80%" },
			x: -30, opacity: 0, stagger: 0.3, duration: 1.2, ease: "power2.out"
		});

		// IntersectionObserver: reveal roadmap step child elements via CSS transitions
		const roadmapObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					roadmapObserver.unobserve(entry.target);
				}
			});
		}, { threshold: 0.15 });
		document.querySelectorAll('.roadmap-step').forEach(step => {
			roadmapObserver.observe(step);
		});

		// ── Process Section Animations ────────────────────────
		const processCards = gsap.utils.toArray('.process-card');
		const dots = gsap.utils.toArray('.dots-list .dot');
		const pathFill = document.querySelector('.path-fill');

		processCards.forEach((card, i) => {
			gsap.to(card, {
				scrollTrigger: {
					trigger: card,
					start: "top 85%",
					toggleActions: "play none none reverse",
					onEnter: () => {
						// Update dots
						dots.forEach(d => d.classList.remove('active'));
						if (dots[i]) dots[i].classList.add('active');
						// Update path fill (20% increments for 5 steps)
						if (pathFill) {
							gsap.to(pathFill, { height: ((i + 1) / processCards.length) * 100 + "%", duration: 0.6 });
						}
					},
					onEnterBack: () => {
						dots.forEach(d => d.classList.remove('active'));
						if (dots[i]) dots[i].classList.add('active');
						if (pathFill) {
							gsap.to(pathFill, { height: ((i + 1) / processCards.length) * 100 + "%", duration: 0.6 });
						}
					}
				},
				opacity: 1,
				y: 0,
				duration: 0.8,
				ease: "power2.out"
			});
		});

		gsap.from(".process-header .sticky-content > *", {
			scrollTrigger: { trigger: ".process-section", start: "top 70%" },
			y: 30, opacity: 0, stagger: 0.2, duration: 1, ease: "power3.out"
		});

	});

	// Testimonials expand/collapse
	const expandBtn = document.getElementById('testimonials-expand-btn');
	const expandLabel = document.getElementById('expand-label');
	const extraCards = document.querySelectorAll('.testimonial-extra');

	if (expandBtn && extraCards.length === 0) {
		// No extra cards — hide the button entirely
		document.getElementById('testimonials-expand-wrap')?.style.setProperty('display', 'none');
	}

	expandBtn?.addEventListener('click', () => {
		const isExpanded = expandBtn.classList.toggle('expanded');
		extraCards.forEach(card => {
			card.classList.toggle('visible', isExpanded);
		});
		if (expandLabel) {
			expandLabel.textContent = isExpanded ? 'Show less' : 'More reviews';
		}
	});

	// Quote read-more / show-less toggle
	document.querySelectorAll('.quote-toggle-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const card = btn.closest('.testimonial-card');
			const truncSpan = card.querySelector('.quote-truncated');
			const fullSpan = card.querySelector('.quote-full');
			if (!truncSpan || !fullSpan) return;
			const isShowingFull = fullSpan.style.display !== 'none';
			truncSpan.style.display = isShowingFull ? '' : 'none';
			fullSpan.style.display = isShowingFull ? 'none' : '';
			btn.textContent = isShowingFull ? 'Read more' : 'Show less';
		});
	});
</script>

