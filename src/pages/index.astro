---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allCaseStudies = await getCollection('caseStudies');
const featuredCase = allCaseStudies.find(c => c.data.featured);
const otherCases = allCaseStudies.filter(c => c.slug !== featuredCase?.slug);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<ParticleBackground />
	<Header />
	<main class="container">
		<div class="hero-fold">
			<section class="hero">
				<div class="badge">YOUR PLUGIN OPS FIRM</div>
				<h1>
					WE <span class="text-gradient">BUILD</span> AND <span class="text-gradient">RUN</span> YOUR OPERATIONS
				</h1>
				<p class="hero-description">
					<span class="hero-text-light">Bloated spreadsheets, disconnected tools, and humans holding it all together is not a system, it's a liability. We build and run your operations as a managed service, combining your tools, integrations, AI agents, and people into one system. Your team stops holding it together and starts moving the business forward.</span>
				</p>
				<div class="cta-group">
					<a href="/contact" class="btn btn-hero-pink">
						<span class="cta-full">Plug Us In &rarr; Let's Chat</span><span class="cta-mobile">Let's Chat</span>
						<span class="animated-dots">
							<span></span><span></span><span></span><span></span>
						</span>
					</a>
				</div>
			</section>

				<!-- Three-Act Build Banner -->
				<section class="three-act-banner animate-fade-in">

					<!-- Act Phase Label -->
					<div class="tab-act-header">
						<div class="tab-act-pill">
							<span class="tab-act-dot"></span>
							<span class="tab-act-text">PLUG IN</span>
						</div>
					</div>

					<!-- 3-column grid: Sources | Process | Dashboard -->
					<div class="tab-grid">

						<!-- Column 1: Source Tools -->
						<div class="tab-sources">
							<div class="tab-col-label">Existing Stack <span class="tab-node-count">0 / 4</span></div>
							<div class="tab-source-list">
								<div class="tab-src" data-src="s1" style="opacity:0;transform:translateX(-12px)">
									<div class="tab-src-dot s1"></div>
									<div class="tab-src-info"><span>HubSpot CRM</span><span class="tab-src-type">API Sync</span></div>
								</div>
								<div class="tab-src" data-src="s2" style="opacity:0;transform:translateX(-12px)">
									<div class="tab-src-dot s2"></div>
									<div class="tab-src-info"><span>Website Forms</span><span class="tab-src-type">Webhook</span></div>
								</div>
								<div class="tab-src" data-src="s3" style="opacity:0;transform:translateX(-12px)">
									<div class="tab-src-dot s3"></div>
									<div class="tab-src-info"><span>LinkedIn</span><span class="tab-src-type">Scraper Feed</span></div>
								</div>
								<div class="tab-src" data-src="s4" style="opacity:0;transform:translateX(-12px)">
									<div class="tab-src-dot s4"></div>
									<div class="tab-src-info"><span>Apollo.io</span><span class="tab-src-type">Enrichment API</span></div>
								</div>
							</div>
							<!-- Connector lines drawn by JS/SVG -->
							<svg class="tab-src-svg" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;overflow:visible;z-index:5;">
								<line class="tab-line tab-line-s1" x1="0" y1="0" x2="0" y2="0" stroke="rgba(99,102,241,0.5)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0"/>
								<line class="tab-line tab-line-s2" x1="0" y1="0" x2="0" y2="0" stroke="rgba(245,158,11,0.5)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0"/>
								<line class="tab-line tab-line-s3" x1="0" y1="0" x2="0" y2="0" stroke="rgba(99,102,241,0.5)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0"/>
								<line class="tab-line tab-line-s4" x1="0" y1="0" x2="0" y2="0" stroke="rgba(245,158,11,0.5)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0"/>
							</svg>
						</div>

						<!-- Central hub -->
						<div class="tab-hub">
							<div class="tab-hub-node">
								<div class="tab-hub-inner"></div>
							</div>
							<div class="tab-hub-line"></div>
						</div>

						<!-- Column 2: Execution Layer -->
						<div class="tab-process">
							<div class="tab-col-label">Execution Layer</div>
							<ul class="tab-step-list">
								<li class="tab-step" data-step="1" style="opacity:0;transform:translateY(8px)">
									<div class="tab-step-check"></div>
									<div class="tab-step-body">
										<div class="tab-step-row">
											<span class="tab-step-name">Identify Stale Records</span>
											<span class="tab-tag tab-tag-auto" style="opacity:0">AUTOMATION</span>
										</div>
										<span class="tab-step-detail">Scanning deals with no activity in 14+ days</span>
									</div>
								</li>
								<li class="tab-step" data-step="2" style="opacity:0;transform:translateY(8px)">
									<div class="tab-step-check"></div>
									<div class="tab-step-body">
										<div class="tab-step-row">
											<span class="tab-step-name">Enrich Missing Data</span>
											<span class="tab-tag tab-tag-ai" style="opacity:0">AI AGENT</span>
										</div>
										<span class="tab-step-detail">Pulling contact info from source tools</span>
									</div>
								</li>
								<li class="tab-step" data-step="3" style="opacity:0;transform:translateY(8px)">
									<div class="tab-step-check"></div>
									<div class="tab-step-body">
										<div class="tab-step-row">
											<span class="tab-step-name">Normalise Deal Stages</span>
											<span class="tab-tag tab-tag-int" style="opacity:0">INTEGRATION</span>
										</div>
										<span class="tab-step-detail">Aligning probabilities to pipeline rules</span>
									</div>
								</li>
								<li class="tab-step" data-step="4" style="opacity:0;transform:translateY(8px)">
									<div class="tab-step-check"></div>
									<div class="tab-step-body">
										<div class="tab-step-row">
											<span class="tab-step-name">Flag Exceptions</span>
											<span class="tab-tag tab-tag-ai" style="opacity:0">AI AGENT</span>
										</div>
										<span class="tab-step-detail">Deals missing owner or value flagged</span>
									</div>
								</li>
								<li class="tab-step" data-step="5" style="opacity:0;transform:translateY(8px)">
									<div class="tab-step-check"></div>
									<div class="tab-step-body">
										<div class="tab-step-row">
											<span class="tab-step-name">Final Integrity Check</span>
											<span class="tab-tag tab-tag-team" style="opacity:0">OUR TEAM</span>
										</div>
										<span class="tab-step-detail">Reconciled against forecast model</span>
									</div>
								</li>
							</ul>
						</div>

						<!-- Column 3: CRM Dashboard -->
						<div class="tab-dashboard">
							<!-- Managed badge (Act 3) -->
							<div class="tab-managed-badge" style="opacity:0">
								<span class="tab-managed-dot"></span>MANAGED OPS — LIVE
							</div>

							<!-- Stats bar — each tile animates in separately -->
							<div class="tab-stats">
								<div class="tab-stat" style="opacity:0"><span class="tab-stat-val tab-pipeline" style="color:#3b82f6">$284k</span><span class="tab-stat-lbl">Pipeline</span></div>
								<div class="tab-stat" style="opacity:0"><span class="tab-stat-val tab-contacts" style="color:#8b5cf6">147</span><span class="tab-stat-lbl">Contacts</span></div>
								<div class="tab-stat" style="opacity:0"><span class="tab-stat-val tab-flagged" style="color:#f59e0b">2</span><span class="tab-stat-lbl">Flagged</span></div>
								<div class="tab-stat" style="opacity:0"><span class="tab-stat-val" style="color:#10b981">94%</span><span class="tab-stat-lbl">Coverage</span></div>
							</div>

							<!-- Contact records table — rows appear one by one -->
							<div class="tab-table-wrap" style="opacity:0">
								<div class="tab-table-label">Contact Records <span class="tab-live-chip">LIVE</span></div>
								<div class="tab-table">
									<div class="tab-table-head"><span>Company</span><span>Stage</span><span>Value</span></div>
									<div class="tab-row tab-row-1" style="opacity:0"><span>Acme Corp</span><span class="tab-stage-q">Qualified</span><span class="tab-val">$48k</span></div>
									<div class="tab-row tab-row-2" style="opacity:0"><span>Vertex AI</span><span class="tab-stage-p">Proposal</span><span class="tab-val">$112k</span></div>
									<div class="tab-row tab-row-flag" style="opacity:0"><span>Orbit SaaS</span><span class="tab-stage-f">⚑ No Owner</span><span class="tab-val">$29k</span></div>
									<div class="tab-row tab-row-new" style="opacity:0"><span>Luminary Co</span><span class="tab-stage-w">Won</span><span class="tab-val">$95k</span></div>
								</div>
							</div>

							<!-- Lead source bars — grow from 0 -->
							<div class="tab-bars-wrap" style="opacity:0">
								<div class="tab-bars-label">Lead Sources</div>
								<div class="tab-bar-row"><span class="tab-bar-name">Web Form</span><div class="tab-bar-track"><div class="tab-bar-fill" data-pct="52" style="width:0%;background:#3b82f6"></div></div><span class="tab-bar-pct">52%</span></div>
								<div class="tab-bar-row"><span class="tab-bar-name">LinkedIn</span><div class="tab-bar-track"><div class="tab-bar-fill" data-pct="28" style="width:0%;background:#8b5cf6"></div></div><span class="tab-bar-pct">28%</span></div>
								<div class="tab-bar-row"><span class="tab-bar-name">Apollo.io</span><div class="tab-bar-track"><div class="tab-bar-fill" data-pct="20" style="width:0%;background:#f59e0b"></div></div><span class="tab-bar-pct">20%</span></div>
							</div>

							<!-- Footer (Act 3) -->
							<div class="tab-dash-footer" style="opacity:0">
								<div class="tab-footer-item"><span class="tab-footer-lbl">Flagged</span><span class="tab-footer-val tab-footer-flagged">2 rec</span></div>
								<div class="tab-footer-item"><span class="tab-footer-lbl">Pipeline</span><span class="tab-footer-val tab-footer-pipeline">$284k</span></div>
								<div class="tab-running-chip">RUNNING ON SCHEDULE</div>
							</div>
						</div>

					</div><!-- /.tab-grid -->
				</section>
		</div><!-- /.hero-fold -->

		<section class="convergence-section animate-fade-in">
			<div class="convergence-outer section-white-card">
				<div class="convergence-header">
					<h2 class="convergence-title">From Scattered Sheets to One System</h2>
					<p class="convergence-subtitle">Your data lives in silos. Finance has a spreadsheet. CRM has another. Inventory lives somewhere else. We plug in and pull it all into one connected system your team can actually trust.</p>
				</div>

				<div class="convergence-layout">
					<!-- LEFT: Source Spreadsheets -->
					<div class="source-col">
						<!-- Sheet 1: Finance -->
						<div class="source-sheet source-sheet--1">
							<div class="source-sheet-chrome">
								<div class="ssc-dots"><span></span><span></span><span></span></div>
								<div class="ssc-name">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#0f9d58"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
									Finance_Q1.xlsx
								</div>
							</div>
							<div class="source-sheet-grid">
								<div class="sg-row sg-row--head"><span>Client</span><span>Amount</span><span>Status</span></div>
								<div class="sg-row"><span>Acme Co.</span><span>$12,400</span><span class="sg-err">Pending??</span></div>
								<div class="sg-row"><span>Vertex AI</span><span class="sg-formula">=SUM(B3)</span><span>Invoiced</span></div>
								<div class="sg-row sg-row--broken"><span>???</span><span class="sg-ref">#REF!</span><span class="sg-ref">#REF!</span></div>
							</div>
							<div class="source-sheet-tag source-sheet-tag--red">Last updated: 3 weeks ago</div>
						</div>

						<!-- Sheet 2: CRM -->
						<div class="source-sheet source-sheet--2">
							<div class="source-sheet-chrome">
								<div class="ssc-dots"><span></span><span></span><span></span></div>
								<div class="ssc-name">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#4285f4"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
									CRM_Contacts_v4.xlsx
								</div>
							</div>
							<div class="source-sheet-grid">
								<div class="sg-row sg-row--head"><span>Contact</span><span>Stage</span><span>Owner</span></div>
								<div class="sg-row"><span>Jordan Lee</span><span class="sg-yellow">Proposal</span><span>Sarah</span></div>
								<div class="sg-row"><span>Mike T.</span><span>Closed</span><span class="sg-empty">—</span></div>
								<div class="sg-row"><span>???</span><span class="sg-err">Overdue</span><span>???</span></div>
							</div>
							<div class="source-sheet-tag source-sheet-tag--red">Missing 34 contacts</div>
						</div>

						<!-- Sheet 3: Inventory -->
						<div class="source-sheet source-sheet--3">
							<div class="source-sheet-chrome">
								<div class="ssc-dots"><span></span><span></span><span></span></div>
								<div class="ssc-name">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#ea4335"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
									Inventory_MASTER.xlsx
								</div>
							</div>
							<div class="source-sheet-grid">
								<div class="sg-row sg-row--head"><span>SKU</span><span>Stock</span><span>Status</span></div>
								<div class="sg-row"><span>AQ-001</span><span>142</span><span class="sg-green">OK</span></div>
								<div class="sg-row"><span>AQ-002</span><span class="sg-ref">#REF!</span><span class="sg-err">Critical</span></div>
								<div class="sg-row"><span>AQ-003</span><span class="sg-empty">—</span><span class="sg-empty">—</span></div>
							</div>
							<div class="source-sheet-tag source-sheet-tag--red">Counts don't match WMS</div>
						</div>

						<!-- Sheet 4: Ops -->
						<div class="source-sheet source-sheet--4">
							<div class="source-sheet-chrome">
								<div class="ssc-dots"><span></span><span></span><span></span></div>
								<div class="ssc-name">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="#fbbc04"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/></svg>
									Ops_Tracker_FINAL2.xlsx
								</div>
							</div>
							<div class="source-sheet-grid">
								<div class="sg-row sg-row--head"><span>Task</span><span>Due</span><span>Status</span></div>
								<div class="sg-row"><span>Report</span><span>Jan 15</span><span class="sg-err">Overdue</span></div>
								<div class="sg-row"><span>Recon</span><span class="sg-empty">—</span><span class="sg-yellow">Pending</span></div>
								<div class="sg-row"><span>Review</span><span>???</span><span class="sg-empty">—</span></div>
							</div>
							<div class="source-sheet-tag source-sheet-tag--red">No one owns this file</div>
						</div>
					</div>

					<!-- CENTER: Convergence Animation -->
					<div class="convergence-center">
						<div class="conv-lines">
							<svg class="conv-svg" viewBox="0 0 120 400" preserveAspectRatio="none">
								<!-- Line from sheet 1 -->
								<path class="conv-path conv-path--1" d="M0,50 C60,50 60,200 120,200"/>
								<!-- Line from sheet 2 -->
								<path class="conv-path conv-path--2" d="M0,150 C60,150 60,200 120,200"/>
								<!-- Line from sheet 3 -->
								<path class="conv-path conv-path--3" d="M0,250 C60,250 60,200 120,200"/>
								<!-- Line from sheet 4 -->
								<path class="conv-path conv-path--4" d="M0,350 C60,350 60,200 120,200"/>
							</svg>
						</div>
						<div class="conv-node">
							<div class="conv-node-ring"></div>
							<div class="conv-node-inner">
								<span>AQ</span>
							</div>
						</div>
						<div class="conv-arrow-out">
							<svg width="40" height="16" viewBox="0 0 40 16" fill="none">
								<path d="M0 8 H32 M28 2 L38 8 L28 14" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
					</div>

					<!-- RIGHT: Unified System Output -->
					<div class="output-col">
						<div class="output-badge">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
							AquiferGrowth Systems Approach
						</div>

						<!-- Dashboard mockup -->
						<div class="output-dashboard">
							<div class="output-dash-chrome">
								<div class="ssc-dots ssc-dots--dark"><span></span><span></span><span></span></div>
								<div class="output-dash-title">
									<div class="status-dot-live"></div>
									<span>Operations Control Layer — LIVE</span>
								</div>
							</div>
							<div class="output-dash-body">
								<div class="output-instance-row">
									<div>
										<div class="sys-label">INSTANCE</div>
										<div class="sys-val">AQ-OPS-V3</div>
									</div>
									<div class="output-all-live">
										<div class="sys-live-dot"></div>
										<span>ALL SYSTEMS LIVE</span>
									</div>
								</div>
								<div class="output-stats">
									<div class="output-stat"><span class="os-val" style="color:#10b981">100%</span><span class="os-lbl">Data Accuracy</span></div>
									<div class="output-stat"><span class="os-val" style="color:#3b82f6">Real-time</span><span class="os-lbl">Sync Status</span></div>
									<div class="output-stat"><span class="os-val" style="color:#a78bfa">0</span><span class="os-lbl">Manual Steps</span></div>
								</div>
								<div class="output-feed-label">Live Operations Feed</div>
								<div class="output-feed">
									<div class="output-feed-item">
										<div class="feed-dot feed-dot--green"></div>
										<span>Finance reconciliation</span>
										<span class="feed-status feed-status--ok">Matched ✓</span>
									</div>
									<div class="output-feed-item">
										<div class="feed-dot feed-dot--green"></div>
										<span>CRM enrichment run</span>
										<span class="feed-status feed-status--ok">147 updated ✓</span>
									</div>
									<div class="output-feed-item">
										<div class="feed-dot feed-dot--amber"></div>
										<span>Inventory check</span>
										<span class="feed-status feed-status--warn">2 flagged →</span>
									</div>
									<div class="output-feed-item">
										<div class="feed-dot feed-dot--green"></div>
										<span>Weekly report</span>
										<span class="feed-status feed-status--ok">Sent ✓</span>
									</div>
								</div>
							</div>
						</div>

						<!-- Positive outcomes -->
						<div class="win-points">
							<div class="win-item">
								<div class="win-icon">✓</div>
								<div class="win-text">
									<strong>Always-live, accurate data</strong>
									<span>Every tool syncs automatically. No manual updates. No stale reports.</span>
								</div>
							</div>
							<div class="win-item">
								<div class="win-icon">✓</div>
								<div class="win-text">
									<strong>System-owned — not person-owned</strong>
									<span>Runs regardless of who's on holiday. No single point of failure.</span>
								</div>
							</div>
							<div class="win-item">
								<div class="win-icon">✓</div>
								<div class="win-text">
									<strong>One source of truth across teams</strong>
									<span>Finance, Ops, and Sales see the same live numbers, at the same time.</span>
								</div>
							</div>
							<div class="win-item">
								<div class="win-icon">✓</div>
								<div class="win-text">
									<strong>Zero admin busywork</strong>
									<span>Reconciliations, reports, and data entry run automatically, on schedule.</span>
								</div>
							</div>
							<div class="win-item">
								<div class="win-icon">✓</div>
								<div class="win-text">
									<strong>Your team works exceptions, not spreadsheets</strong>
									<span>Humans review what matters. The system handles the rest.</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="comparison-cta">
					<a href="/contact" class="btn btn-hero-pink"><span class="cta-full">Replace Your Spreadsheets → Let's Talk</span><span class="cta-mobile">Let's Talk</span>
						<span class="animated-dots">
							<span></span><span></span><span></span><span></span>
						</span>
					</a>
				</div>
			</div>

		</section>

		<!-- How We Build Your System Section -->
		<section class="how-we-build-section animate-fade-in">
			<div class="hwb-outer section-white-card">
				<div class="hwb-header">
					<h2 class="hwb-title">HOW WE BUILD YOUR SYSTEM</h2>
					<p class="hwb-subhead">You don't need another AI tool. You don't need another contractor. You need one system that runs your operations, built from the tools you already have, the workflows you already run, and whatever it actually takes to make it reliable.</p>
					</div>

				<div class="hwb-cards">
					<div class="hwb-card">
						<div class="hwb-card-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
