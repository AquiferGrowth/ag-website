	.btn-build-contact:hover {
		background: #e63e15;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(255, 71, 26, 0.25);
	}
	
	/* Responsive adjustments */
	@media (max-width: 768px) {
		.build-cards-grid {
			grid-template-columns: 1fr;
