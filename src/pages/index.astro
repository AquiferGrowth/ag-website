		gap: 0.75rem;
	}

	.panel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.03);
	}

	.panel-tag {
		font-size: 0.6rem;
		font-weight: 800;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 0.15em;
	}

	.panel-meta {
		font-size: 0.5rem;
		color: #475569;
		font-family: var(--font-mono, monospace);
	}

	/* Systems Source List */
	.systems-source-list {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.source-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.04);
		border-radius: 10px;
		position: relative;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.source-item.active {
		background: rgba(59, 130, 246, 0.05);
		border-color: rgba(59, 130, 246, 0.2);
	}

	.source-indicator {
		width: 6px;
		height: 6px;
		background: #1e293b;
		border-radius: 50%;
		flex-shrink: 0;
		transition: all 0.3s ease;
	}

	.source-item.active .source-indicator {
		background: #3b82f6;
		box-shadow: 0 0 8px #3b82f6;
	}

	.source-label {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.source-label span:first-child {
		font-size: 0.65rem;
		font-weight: 700;
		color: #94a3b8;
	}

	.source-item.active .source-label span:first-child { color: #f8fafc; }

	.s-type {
		font-size: 0.5rem;
		color: #475569;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.stream-anchor {
		position: absolute;
		right: 0;
		top: 50%;
		width: 1px;
		height: 1px;
	}

	.source-metrics {
		margin-top: auto;
		background: rgba(0,0,0,0.2);
		border-radius: 10px;
		padding: 0.75rem;
	}

	.mini-trend {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.mt-label { font-size: 0.5rem; color: #64748b; text-transform: uppercase; }
	.mt-footer { display: flex; justify-content: space-between; align-items: center; }
	.mt-val { font-family: var(--font-mono, monospace); font-size: 0.6rem; color: #3b82f6; }
	.mt-status { font-size: 0.5rem; color: #10b981; opacity: 0.8; }

	/* Execution Engine */
	.task-checklist {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.task-item {
		display: flex;
		gap: 1rem;
		opacity: 0.15;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		transform: translateX(-5px);
	}

	.task-item.is-active { opacity: 1; transform: translateX(0); }
	.task-item.is-done { opacity: 0.5; transform: translateX(0); }

	.checkbox-box {
		width: 16px;
		height: 16px;
		border: 1.5px solid rgba(255, 255, 255, 0.15);
		border-radius: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}

	.task-item.is-done .checkbox-box {
		background: #3b82f6;
		border-color: #3b82f6;
	}

	.checkbox-box svg { opacity: 0; transform: scale(0.6); transition: all 0.3s ease; }
	.task-item.is-done .checkbox-box svg { opacity: 1; transform: scale(1); }

	.task-label { font-size: 0.75rem; font-weight: 700; color: #f1f5f9; display: block; margin-bottom: 2px; }
	.task-detail { font-size: 0.6rem; color: #64748b; line-height: 1.3; }

	.oversight-column {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.oversight-dashboard {
		height: 100%;
		background: rgba(10, 15, 30, 0.9);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-top: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 16px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		transform-origin: center;
		transition: all 0.5s ease;
	}

	.oversight-dashboard.active {
		border-color: rgba(16, 185, 129, 0.3);
		box-shadow: 0 30px 60px -15px rgba(0, 185, 129, 0.1);
	}

	.dashboard-header {
		padding: 1rem 1.5rem;
		background: rgba(255,255,255,0.03);
		border-bottom: 1px solid rgba(255,255,255,0.06);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.dash-id { display: flex; flex-direction: column; }
	.dash-id .label { font-size: 0.5rem; color: #475569; letter-spacing: 0.05em; }
	.dash-id .val { font-family: var(--font-mono, monospace); font-size: 0.6rem; color: #94a3b8; }

	.dash-status { display: flex; align-items: center; gap: 0.75rem; }
	.ready-tag { font-size: 0.6rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; }
	.status-dot { width: 6px; height: 6px; background: #334155; border-radius: 50%; transition: all 0.5s ease; }
	.oversight-dashboard.active .status-dot { background: #10b981; box-shadow: 0 0 10px #10b981; }

	.dashboard-grid {
		padding: 1.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: auto 1fr;
		gap: 1.5rem;
		flex: 1;
	}

	.dash-main-chart { grid-column: span 2; display: flex; flex-direction: column; gap: 0.75rem; }
	.chart-header { display: flex; justify-content: space-between; align-items: flex-end; }
	.c-label { font-size: 0.6rem; color: #64748b; text-transform: uppercase; font-weight: 800; }
	.c-val { font-size: 1.2rem; font-weight: 800; color: #fff; font-family: var(--font-mono, monospace); }

	.confidence-bar { height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
	.confidence-bar-fill { width: 0%; height: 100%; background: linear-gradient(90deg, #3b82f6, #60a5fa); }
	.chart-axis { display: flex; justify-content: space-between; font-size: 0.5rem; color: #334155; padding-top: 4px; }

	.dash-stats { display: flex; align-items: center; justify-content: center; }
	.stat-circle { position: relative; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
	.stat-inner { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
	.stat-inner .s-val { font-family: var(--font-mono, monospace); font-size: 0.85rem; font-weight: 700; color: #fff; display: block; }
	.stat-inner .s-label { font-size: 0.4rem; color: #64748b; letter-spacing: 0.1em; font-weight: 800; }

	.stat-circle .ring-fill { transition: stroke-dashoffset 1s ease; }

	.dash-ledger { display: flex; flex-direction: column; gap: 0.5rem; }
	.dash-ledger .ledger-header { display: grid; grid-template-columns: 1fr 1fr 1fr; font-size: 0.5rem; color: #475569; font-weight: 800; text-transform: uppercase; padding-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,0.04); }
	.ledger-rows { display: flex; flex-direction: column; gap: 2px; }
	.l-row { display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: center; padding: 4px 0; font-size: 0.55rem; color: #94a3b8; }
	.l-row .l-status { font-weight: 700; color: #10b981; }
	.l-row.warn .l-status.highlight { color: #f59e0b; }

	.dash-activity { grid-column: span 1; }
	.activity-label { font-size: 0.5rem; color: #475569; text-transform: uppercase; font-weight: 800; margin-bottom: 6px; }
	.activity-viz { display: flex; align-items: flex-end; gap: 4px; height: 30px; }
	.a-bar { flex: 1; background: rgba(59, 130, 246, 0.1); border-radius: 1px; transition: all 0.3s ease; }

	.dash-details { grid-column: span 1; }
	.quality-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
	.q-item { background: rgba(255, 255, 255, 0.02); padding: 0.4rem; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.04); text-align: center; }
	.q-label { display: block; font-size: 0.35rem; color: #475569; text-transform: uppercase; margin-bottom: 2px; }
	.q-val { font-size: 0.6rem; font-weight: 700; color: #94a3b8; font-family: var(--font-mono, monospace); }

	.dash-audit { grid-column: span 2; }
	.audit-log { display: flex; flex-direction: column; gap: 4px; padding-top: 4px; border-top: 1px solid rgba(255,255,255,0.03); }
	.log-item { display: flex; gap: 8px; font-size: 0.5rem; color: #475569; }
	.log-time { color: #3b82f6; font-family: var(--font-mono, monospace); opacity: 0.6; }
	.log-txt { font-weight: 500; }

	.dashboard-footer { padding: 1rem 1.5rem; background: rgba(0,0,0,0.2); display: flex; justify-content: space-between; align-items: center; }
	.footer-meta { display: flex; gap: 1.5rem; }
	.meta-item { display: flex; flex-direction: column; }
	.m-label { font-size: 0.5rem; color: #475569; text-transform: uppercase; }
	.m-val { font-family: var(--font-mono, monospace); font-size: 0.8rem; font-weight: 700; color: #f8fafc; }

	.btn-approve-console {
		background: #3b82f6;
		color: #fff;
		border: none;
		padding: 0.75rem 1.25rem;
		border-radius: 8px;
		font-size: 0.65rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.1;
		transition: all 0.4s ease;
	}

	.oversight-dashboard.active .btn-approve-console {
		opacity: 1;
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
	}

	/* ── CRM Dashboard ────────────────────────────── */
	.crm-dashboard .dashboard-grid { display: none; } /* hide financial grid */

	.crm-stats-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5rem;
		margin-bottom: 0.75rem;
		padding: 0.75rem 1.25rem 0;
	}
	.crm-stat {
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 8px;
		padding: 0.5rem 0.6rem;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.crm-stat-val { font-size: 1rem; font-weight: 700; line-height: 1.2; }
	.crm-stat-label { font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; }

	.crm-table-section { margin-bottom: 0.6rem; padding: 0 1.25rem; }
	.crm-table-label {
		font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em;
		color: #64748b; margin-bottom: 0.4rem;
		display: flex; align-items: center; gap: 0.4rem;
	}
	.crm-badge {
		font-size: 0.5rem; background: rgba(59,130,246,0.15);
		color: #60a5fa; border: 1px solid rgba(59,130,246,0.3);
		border-radius: 4px; padding: 1px 5px; text-transform: uppercase;
	}
	.crm-table-wrapper { border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; overflow: hidden; }
	.crm-table-head {
		display: grid;
		grid-template-columns: 1.4fr 1.2fr 0.9fr 1.3fr 0.7fr;
		padding: 0.35rem 0.6rem;
		background: rgba(255,255,255,0.04);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		font-size: 0.52rem; text-transform: uppercase; letter-spacing: 0.06em; color: #475569;
	}
	.crm-table-body { display: flex; flex-direction: column; }
	.crm-row {
		display: grid;
		grid-template-columns: 1.4fr 1.2fr 0.9fr 1.3fr 0.7fr;
		padding: 0.4rem 0.6rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
		font-size: 0.62rem; align-items: center;
		transition: background 0.2s;
	}
	.crm-row:last-child { border-bottom: none; }
	.crm-row--new { background: rgba(59,130,246,0.05); }
	.crm-row--flag { background: rgba(245,158,11,0.05); }
	.crm-company { color: #e2e8f0; font-weight: 600; }
	.crm-contact { color: #94a3b8; }
	.crm-value { color: #a5b4fc; font-weight: 600; text-align: right; }

	.crm-source {
		font-size: 0.52rem; padding: 2px 6px; border-radius: 4px;
		font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
		display: inline-block; width: fit-content;
	}
	.src-web  { background: rgba(59,130,246,0.15); color: #60a5fa; }
	.src-li   { background: rgba(139,92,246,0.15); color: #a78bfa; }
	.src-apollo { background: rgba(245,158,11,0.15); color: #fbbf24; }

	.crm-stage {
		font-size: 0.55rem; padding: 2px 7px; border-radius: 20px;
		font-weight: 600; display: inline-block; width: fit-content;
	}
	.stage-qualified { background: rgba(59,130,246,0.15); color: #60a5fa; }
	.stage-proposal  { background: rgba(139,92,246,0.15); color: #a78bfa; }
	.stage-closed    { background: rgba(16,185,129,0.15); color: #34d399; }
	.stage-flag      { background: rgba(245,158,11,0.15); color: #fbbf24; }

	.crm-sources-section { margin-bottom: 0.6rem; padding: 0 1.25rem; }
	.crm-source-bars { display: flex; flex-direction: column; gap: 0.35rem; }
	.crm-src-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.6rem; }
	.crm-src-name { color: #94a3b8; width: 60px; flex-shrink: 0; }
	.crm-src-track {
		flex: 1; height: 5px; background: rgba(255,255,255,0.07);
		border-radius: 10px; overflow: hidden;
	}
	.crm-src-fill { height: 100%; border-radius: 10px; }
	.crm-src-pct { color: #64748b; font-size: 0.55rem; width: 28px; text-align: right; flex-shrink: 0; }


	/* ── Process Section ──────────────────────── */
	.process-section {
		padding: 8rem 0;
		background: transparent;
		overflow: visible;
		position: relative;
	}

	.process-container {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: flex-start;
	}

	.process-header {
		position: sticky;
		top: 15vh;
	}

	.step-tag {
		display: inline-flex;
		padding: 0.5rem 1rem;
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 700;
		color: #1A1A1A;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 2rem;
	}

	.process-title {
		font-size: clamp(3rem, 8vw, 5rem);
		line-height: 0.95;
		color: #1A1A1A;
		margin-bottom: 2rem;
		font-weight: 800;
	}

	.process-desc {
		font-size: 1.25rem;
		color: #555555;
		max-width: 480px;
		line-height: 1.6;
	}

	/* Success Path Indicator */
	.success-path-wrapper {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-top: 2rem;
		position: relative;
	}

	.path-line {
		position: absolute;
		left: 6px;
		top: 40px;
		bottom: 40px;
		width: 2px;
		background: #e5e7eb;
		z-index: 0;
	}

	.dots-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		z-index: 1;
	}

	.dot {
		width: 14px;
		height: 14px;
		background: #FFFFFF;
		border: 2px solid #e5e7eb;
		border-radius: 50%;
		position: relative;
		z-index: 1;
		transition: all 0.3s ease;
	}

	.dot.active {
		background: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: 0 0 10px rgba(255, 77, 109, 0.4);
	}

	/* Process steps cards */
	.process-steps {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.process-card {
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		padding: 3rem;
		position: relative;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
	}

	.process-card:hover {
		background: #FFFFFF;
		border-color: #d1d5db;
		transform: translateY(-5px);
	}

	.card-num {
		position: absolute;
		top: -20px;
		right: -10px;
		font-size: 12rem;
		font-weight: 900;
		color: rgba(0, 0, 0, 0.03);
		user-select: none;
		pointer-events: none;
		z-index: 0;
	}

	.card-content h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #1A1A1A;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		position: relative;
		z-index: 1;
	}

	.step-desc {
		font-size: 1.125rem;
		color: #555555;
		line-height: 1.6;
		margin-bottom: 2.5rem;
		position: relative;
		z-index: 1;
	}

	.step-features {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		list-style: none;
		padding: 0;
		position: relative;
		z-index: 1;
	}

	.step-features li {
		background: #F9F7F2;
		border: 1px solid #e5e7eb;
		padding: 0.4rem 0.8rem;
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 600;
		color: #1A1A1A;
	}

	@media (max-width: 1024px) {
		.process-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.process-header {
			position: relative;
			top: 0;
		}

		.process-desc {
			max-width: 100%;
		}
		
		.card-num { font-size: 5rem; top: 0; right: 20px; }
	}


	/* ── Order Fulfillment Dashboard ──────────────────────── */
	.ecom-dashboard .dashboard-grid { display: none; }
	
	.ecom-layout {
		display: flex;
		height: 290px;
		background: rgba(255,255,255,0.02);
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.ecom-sidebar {
		width: 100px;
		flex-shrink: 0;
		border-right: 1px solid rgba(255,255,255,0.07);
		background: rgba(0,0,0,0.2);
		padding: 1rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.sidebar-item {
		padding: 0.5rem 0.75rem;
		font-size: 0.65rem;
		font-weight: 600;
		color: #64748b;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		transition: all 0.2s;
		cursor: pointer;
	}

	.sidebar-item svg { opacity: 0.6; }
	.sidebar-item.active { color: #e2e8f0; background: rgba(255,255,255,0.04); }
	.sidebar-item.active svg { color: var(--primary-accent); opacity: 1; }

	.ecom-main {
		flex: 1;
		padding: 1.25rem;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.inventory-table {
		background: rgba(0,0,0,0.3);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 10px;
		overflow: hidden;
	}

	.inventory-table .table-head {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		padding: 0.5rem 0.75rem;
		background: rgba(255,255,255,0.03);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #475569;
	}

	.inventory-table .table-row {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid rgba(255,255,255,0.04);
		font-size: 0.65rem;
		align-items: center;
	}

	.inventory-table .table-row:last-child { border-bottom: none; }
	.inventory-table .table-row.highlight { background: rgba(239, 68, 68, 0.04); }

	.status-ok { color: #10b981; font-weight: 700; font-size: 0.55rem; }
	.status-warn { color: #ef4444; font-weight: 700; font-size: 0.55rem; animation: pulse-red 2s infinite; }

	@keyframes pulse-red {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.6; }
	}

	.exception-card {
		background: linear-gradient(to right, rgba(239, 68, 68, 0.08), transparent);
		border: 1px solid rgba(239, 68, 68, 0.2);
		border-radius: 10px;
		padding: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.exc-title {
