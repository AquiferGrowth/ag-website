	.btn-build-contact {
		background: #ff471a;
		color: #fff;
		padding: 0.65rem 1.75rem; /* Tighter button styling */
		border-radius: 100px;
		font-weight: 800;
		font-size: 0.85rem; 
		text-decoration: none;
		display: inline-block;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(255, 71, 26, 0.15);
	}

