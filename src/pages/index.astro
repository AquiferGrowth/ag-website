	.func-pill {
		background: #ffffff;
		border: 1.5px solid #e5e7eb;
		color: #111827;
		box-shadow: 0 2px 8px rgba(0,0,0,0.03);
	}

	.damage-pill {
		background: #fff7ed;
		border: 1.5px solid #fed7aa;
		color: #9a3412;
	}

	.progress-item.active .step-title {
		color: var(--accent-primary);
	}

	.step-text {
		font-size: 0.95rem;
		color: #cbd5e1;
		line-height: 1.5;
	}

	/* Liability Stack Visual Styles */
	.liability-stack-diagram.messy-mode {
		position: relative;
		overflow: hidden;
	}

	.fragmented-lines {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0;
		pointer-events: none;
		opacity: 0.15;
	}

	.f-line {
		fill: none;
		stroke: #f47b56;
		stroke-width: 1.5;
		stroke-dasharray: 4, 6;
		animation: lineDash 12s linear infinite, lineFlicker 3s infinite;
	}

	@keyframes lineFlicker {
		0%, 100% { opacity: 0.15; }
		50% { opacity: 0.05; }
		55% { opacity: 0.25; }
		60% { opacity: 0.15; }
	}

	@keyframes lineDash {
		to { stroke-dashoffset: -100; }
	}

	.liability-stack-diagram {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		padding: 1rem;
		width: 100%;
		position: relative;
		z-index: 1;
	}

	.operational-pills, .liability-pills {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.6rem;
		width: 100%;
	}

	.op-pill, .li-pill {
		padding: 0.5rem 1rem;
		border-radius: 100px;
		font-size: 0.85rem;
		font-weight: 500;
		white-space: nowrap;
		transition: all 0.3s ease;
		position: relative;
	}

	.op-pill {
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		color: #475569;
		opacity: 0;
	}

	.roadmap-step.is-visible .op-pill {
		animation: fadeInSlideUp 0.6s ease-out forwards, driftPill 6s ease-in-out infinite;
	}

	.li-pill {
		background: #fef2f2;
		border: 1px solid #fee2e2;
		color: #b91c1c;
		opacity: 0;
	}

	.roadmap-step.is-visible .li-pill {
		animation: fadeInSlideUp 0.6s ease-out 0.8s forwards, jitterPill 4s ease-in-out infinite 1.2s;
	}

	/* Chaotic Animations */
	@keyframes driftPill {
		0%, 100% { transform: translateY(0) translateX(0); }
		33% { transform: translateY(-3px) translateX(2px); }
		66% { transform: translateY(2px) translateX(-4px); }
	}

	@keyframes jitterPill {
		0%, 100% { transform: scale(1) rotate(0); }
		10%, 20% { transform: scale(0.98) rotate(-1deg); }
		15% { transform: scale(1.02) rotate(1deg); }
		50% { transform: scale(1.01) rotate(0.5deg); }
	}

	.icon-error { color: #f43f5e; margin-right: 0.4rem; font-size: 0.8rem; }
	.icon-warning { color: #f59e0b; margin-right: 0.4rem; font-size: 0.8rem; }
	.icon-bolt { color: #b91c1c; margin-left: 0.4rem; font-size: 0.8rem; animation: flicker 2s infinite; }

	.blink-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		background: #ef4444;
		border-radius: 50%;
		margin-left: 0.5rem;
		box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
		animation: pulseRed 1.5s infinite;
	}

	@keyframes flicker {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	@keyframes pulseRed {
		0% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.4); opacity: 0.5; }
		100% { transform: scale(1); opacity: 1; }
	}

	.result-divider {
		display: flex;
		align-items: center;
		width: 100%;
		gap: 1rem;
		margin: 0.25rem 0;
		opacity: 0;
	}

	.roadmap-step.is-visible .result-divider {
		animation: expandWidth 0.8s ease-out 0.4s forwards;
	}

	.divider-line {
		flex: 1;
		height: 1px;
		background: linear-gradient(to right, transparent, #fee2e2, transparent);
	}

	.divider-text {
		color: #94a3b8;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		white-space: nowrap;
	}

	@keyframes fadeInSlideUp {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@keyframes expandWidth {
		from { opacity: 0; transform: scaleX(0.5); }
		to { opacity: 1; transform: scaleX(1); }
	}

	/* Sequential Delays for Pills */
	.op-pill:nth-child(2) { animation-delay: 0.1s; }
	.op-pill:nth-child(3) { animation-delay: 0.2s; }
	.op-pill:nth-child(4) { animation-delay: 0.3s; }
	.op-pill:nth-child(5) { animation-delay: 0.4s; }

	.li-pill:nth-child(1) { animation-delay: 0.8s; }
	.li-pill:nth-child(2) { animation-delay: 0.9s; }
	.li-pill:nth-child(3) { animation-delay: 1.0s; }
	.li-pill:nth-child(4) { animation-delay: 1.1s; }
	.li-pill:nth-child(5) { animation-delay: 1.2s; }

	/* Chart Styles */
