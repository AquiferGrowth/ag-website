	/* Compact Execution Layer Styles */
	.compact-dashboard {
		width: 100%;
		padding: 0.5rem;
	}

	.dashboard-rows {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}

	.compact-item {
		display: flex;
		gap: 0.75rem;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.5);
		border-radius: 8px;
		border: 1px solid rgba(0, 0, 0, 0.05);
		opacity: 0;
		transform: translateY(10px);
	}

	.roadmap-step.is-visible .compact-item {
		animation: compactReveal 0.6s ease forwards;
	}

	.roadmap-step.is-visible .compact-item:nth-child(2) { animation-delay: 0.2s; }
	.roadmap-step.is-visible .compact-item:nth-child(3) { animation-delay: 0.4s; }

	@keyframes compactReveal {
		to { opacity: 1; transform: translateY(0); }
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		margin-top: 4px;
		flex-shrink: 0;
	}

	.status-dot.green { background: #10b981; }
	.status-dot.orange { background: #f97316; }

	.status-dot.pulse {
		box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
		animation: dotPulse 2s infinite;
	}

	@keyframes dotPulse {
		0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
		70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
		100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
	}

	.compact-label {
		display: block;
		font-size: 0.65rem;
		font-weight: 700;
		color: #64748b;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.15rem;
	}

	/* Step 3 Sleek Pills - Simple Connected System */
	.outcome-pills-container {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.75rem; /* Slightly tighter gap */
		justify-content: center;
		width: 100%;
		max-width: 650px; /* Narrower container */
		margin: 0 auto;
		padding: 1rem 0.5rem; /* Significantly tighter padding */
		position: relative;
	}

	.outcome-pill-item {
		display: flex;
		align-items: center;
		padding: 0.45rem 1rem; /* Back to sleek smaller size */
		background: #ffffff;
		border-radius: 100px;
		border: 1px solid rgba(15, 23, 42, 0.15);
		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
		opacity: 0;
		transform: translateY(10px);
		transition: all 0.3s ease;
		position: relative;
		z-index: 2;
	}

	/* Simple horizontal connector line after each pill */
	.outcome-pill-item::after {
		content: "";
		position: absolute;
		left: 100%;
		top: 50%;
		width: 1.75rem;
		height: 1px;
		background: rgba(15, 23, 42, 0.1);
		z-index: 1;
	}

	.outcome-pill-item:last-child::after {
		display: none;
	}

	.outcome-pill-item:hover {
		border-color: #0f172a;
		transform: translateY(-2px);
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
	}

	.roadmap-step.is-visible .outcome-pill-item {
		animation: pillReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.roadmap-step.is-visible .outcome-pill-item:nth-child(1) { animation-delay: 0.1s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(2) { animation-delay: 0.2s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(3) { animation-delay: 0.3s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(4) { animation-delay: 0.4s; }
	.roadmap-step.is-visible .outcome-pill-item:nth-child(5) { animation-delay: 0.5s; }

	@keyframes pillReveal {
		to { opacity: 1; transform: translateY(0); }
	}

	.outcome-pill-item span {
		font-size: 0.725rem; /* Sleek smaller font restored */
		font-weight: 700;
		color: #0f172a;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.outcome-pill-item::after {
			display: none;
		}
		.outcome-pills-container {
			gap: 0.75rem;
		}
	}

	.compact-title {
		font-size: 0.75rem;
		font-weight: 700;
		color: #1e293b;
		margin: 0 !important;
	}

	.compact-sub {
		font-size: 0.75rem;
		color: #64748b;
		line-height: 1.3;
	}

	.mini-rows {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.mini-rows p {
		font-size: 0.8rem;
		font-weight: 600;
		color: #334155;
		margin: 0 !important;
	}

	.compact-outcomes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
		opacity: 0;
	}

	.roadmap-step.is-visible .compact-outcomes {
		animation: compactReveal 0.6s ease forwards 0.8s;
	}

	.outcome-pill {
		background: #0f172a;
		color: #ffffff;
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.4rem 0.6rem;
		border-radius: 4px;
		text-align: center;
		white-space: nowrap;
	}

	.roadmap-step.is-visible .mapping-row {
		animation: rowSlideIn 0.5s ease-out forwards;
	}

	/* Staggered Row Entry */
	.roadmap-step.is-visible .mapping-row:nth-child(1) { animation-delay: 0.4s; }
	.roadmap-step.is-visible .mapping-row:nth-child(2) { animation-delay: 0.6s; }
	.roadmap-step.is-visible .mapping-row:nth-child(3) { animation-delay: 0.8s; }
	.roadmap-step.is-visible .mapping-row:nth-child(4) { animation-delay: 1.0s; }
	.roadmap-step.is-visible .mapping-row:nth-child(5) { animation-delay: 1.2s; }

	@keyframes rowSlideIn {
		to { opacity: 1; transform: translateX(0); }
	}

	.func-pill, .damage-pill {
		padding: 0.45rem 0.75rem;
		border-radius: 100px;
		font-size: 0.68rem; /* Further reduced to fit smaller card width */
		font-weight: 800;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		min-height: 36px;
		white-space: nowrap;
