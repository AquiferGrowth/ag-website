<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	window.addEventListener('load', () => {
		const masterTimeline = gsap.timeline();

		// Set initial states
		gsap.set([".hero h1", ".hero p", ".cta-group .btn", ".badge", ".framework-banner"], { opacity: 0, y: 30 });
		
		masterTimeline
			.to(".hero h1", { opacity: 1, y: 0, duration: 1.2, ease: "power4.out" })
			.to(".hero p", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, "-=0.8")
			.to(".badge", { opacity: 1, scale: 1, y: 0, duration: 0.6, ease: "back.out(1.7)" }, "-=0.8")
			.to(".cta-group .btn", { opacity: 1, y: 0, duration: 0.8, stagger: 0.2, ease: "power2.out" }, "-=0.4")
			.to(".framework-banner", { opacity: 1, y: 0, duration: 1, ease: "power3.out" });



		const createSlideTimeline = (slide) => {
			const dashboard = slide.querySelector(".oversight-dashboard");
			const tl = gsap.timeline();

			const counter = (selector, from, to, dur) => {
				const obj = { val: from };
				return gsap.to(obj, { val: to, duration: dur, ease: "power1.inOut",
					onUpdate: () => { slide.querySelector(selector).innerText = Math.round(obj.val) + "%"; }
				});
			};

			const reset = () => {
				slide.querySelectorAll('.task-item').forEach(el => el.classList.remove('is-done', 'is-active'));
				slide.querySelectorAll('.source-item').forEach(el => el.classList.remove('active'));
				slide.querySelectorAll('.a-bar').forEach(el => gsap.killTweensOf(el));
				slide.querySelectorAll('.dotted-stream').forEach(el => {
					gsap.killTweensOf(el);
					gsap.set(el, { visibility: "hidden" });
				});
				gsap.set(slide.querySelector(".confidence-bar-fill"), { width: "0%" });
				gsap.set(slide.querySelector(".ring-fill"), { strokeDashoffset: 163.3 });
				slide.querySelector(".confidence-val").innerText = "0%";
				slide.querySelector(".volume-val").innerText = "$0.00";
				dashboard.classList.remove('active');
			};

			const updatePaths = () => {
				const checklist = slide.querySelector(".execution-column");
				const container = slide.querySelector(".framework-console");
				if (!checklist || !container) return;
				
				const containerRect = container.getBoundingClientRect();
				const checklistRect = checklist.getBoundingClientRect();
				const targetX = checklistRect.left - containerRect.left;
				const targetY = (checklistRect.top - containerRect.top) + (checklistRect.height / 2);

				["src1", "src2", "src3", "src4", "src5"].forEach(id => {
					const anchor = slide.querySelector(`.anchor-${id}`);
					const path = slide.querySelector(`.stream-${id}`);
					if (!anchor || !path) return;
					
					const anchorRect = anchor.getBoundingClientRect();
					const startX = (anchorRect.left - containerRect.left) + 1;
					const startY = (anchorRect.top - containerRect.top) + (anchorRect.height / 2);
					
					const cp1x = startX + (targetX - startX) * 0.5;
					const cp2x = startX + (targetX - startX) * 0.5;
					path.setAttribute("d", `M ${startX} ${startY} C ${cp1x} ${startY}, ${cp2x} ${targetY}, ${targetX} ${targetY}`);
				});

				// Process Layer to Oversight connection
				const anchorProcess = slide.querySelector(".anchor-process");
				const anchorOversight = slide.querySelector(".anchor-oversight");
				const pathOutput = slide.querySelector(".stream-output");
				if (anchorProcess && anchorOversight && pathOutput) {
					const apRect = anchorProcess.getBoundingClientRect();
					const aoRect = anchorOversight.getBoundingClientRect();
					const startX = apRect.right - containerRect.left;
					const startY = apRect.top - containerRect.top + (apRect.height / 2);
					const targetX = aoRect.left - containerRect.left;
					const targetY = (aoRect.top - containerRect.top) + (aoRect.height / 2);
					
					const cp1x = startX + (targetX - startX) * 0.5;
					const cp2x = startX + (targetX - startX) * 0.5;
					pathOutput.setAttribute("d", `M ${startX} ${startY} C ${cp1x} ${startY}, ${cp2x} ${targetY}, ${targetX} ${targetY}`);
				}
			};

			updatePaths();
			window.addEventListener('resize', updatePaths);

			tl.add(reset);

			const tasks = slide.querySelectorAll('.task-item');
			const numTasks = tasks.length;
			if(numTasks === 0) return tl;

			const phase3Step = Math.ceil(numTasks / 2) + 1;

			// Phase 1 (Data ingest visual)
			tl.add(() => {
				const s1 = slide.querySelector(".source-item[data-source='src1']");
				const s2 = slide.querySelector(".source-item[data-source='src2']");
				if (s1) s1.classList.add('active');
				if (s2) s2.classList.add('active');
				
				const p1 = slide.querySelector(".stream-src1");
				const p2 = slide.querySelector(".stream-src2");
				if (p1) { gsap.set(p1, { visibility: "visible" }); gsap.to(p1, { attr: { strokeDashoffset: -200 }, duration: 3, ease: "none", repeat: -1 }); }
				if (p2) { gsap.set(p2, { visibility: "visible" }); gsap.to(p2, { attr: { strokeDashoffset: -200 }, duration: 3, ease: "none", repeat: -1 }); }
			});

			tasks.forEach((task, index) => {
				const step = index + 1;
				const isLast = (step === numTasks);
				const prevConf = Math.round(((step - 1) / numTasks) * 100);
				const targetConf = Math.round((step / numTasks) * 100);

				tl.to(task, {
					onStart: () => {
						task.classList.add('is-active');
						const confFill = slide.querySelector(".confidence-bar-fill");
						if (confFill) gsap.to(confFill, { width: targetConf + "%", duration: 1.5 });
						counter(".confidence-val", prevConf, targetConf, 1.5);

						if (step === 2) {
							// Phase 2 triggers (remaining sources)
							const sources = ["src3", "src4", "src5"];
							sources.forEach(sid => {
								const s = slide.querySelector(`.source-item[data-source='${sid}']`);
								const p = slide.querySelector(`.stream-${sid}`);
								if (s) s.classList.add('active');
								if (p) {
									gsap.set(p, { visibility: "visible" });
									gsap.to(p, { attr: { strokeDashoffset: -200 }, duration: 3, ease: "none", repeat: -1 });
								}
							});
						}

						if (step === phase3Step) {
							// Phase 3 triggers (activity/throughput)
							const bars = slide.querySelectorAll(".a-bar");
							if (bars.length) {
								gsap.to(bars, {
									height: () => (30 + Math.random() * 65) + "%",
									background: "rgba(59, 130, 246, 0.5)",
									stagger: 0.04, duration: 0.8, ease: "power2.out"
								});
							}
							const volObj = { val: 0 };
							const volEl = slide.querySelector(".volume-val");
							if (volEl) {
								gsap.to(volObj, { val: 1420500, duration: 2, ease: "power1.inOut",
									onUpdate: () => { volEl.innerText = "$" + Math.round(volObj.val).toLocaleString(); }
								});
							}
						}

						if (isLast) {
							// Phase 4 triggers (output line)
							const pathOutput = slide.querySelector(".stream-output");
							if (pathOutput) {
								gsap.set(pathOutput, { visibility: "visible" });
								gsap.to(pathOutput, { attr: { strokeDashoffset: -200 }, duration: 2, ease: "none", repeat: -1 });
							}
						}
					},
					duration: 2
				})
				.add(() => task.classList.replace('is-active', 'is-done'));
			});

			tl.add(() => {
				dashboard.classList.add('active');
			})
			.to({}, { duration: 2 }); // Faster hold over phase

			return tl;
		};

		// Start manual cyclic loop for each framework banner
		document.querySelectorAll('.framework-banner').forEach((banner) => {
			let loopStarted = false;
			const slides = banner.querySelectorAll('.use-case-slide');
			if(slides.length === 0) return;

			let activeSlideIdx = 0;
			let currentSlideTl = null;
			let timeoutId = null;

			// Initial states
			gsap.set(slides, { autoAlpha: 0, zIndex: 1 });

			let playSlide = (index) => {
				// Clear any pending transitions/animations
				if(currentSlideTl) currentSlideTl.kill();
				if(timeoutId) clearTimeout(timeoutId);

				// Fast crossfade: Use autoAlpha which toggles visibility:hidden and opacity seamlessly
				const otherSlides = Array.from(slides).filter((_, i) => i !== index);
				gsap.to(otherSlides, { autoAlpha: 0, zIndex: 1, duration: 0.3, overwrite: true });
				gsap.to(slides[index], { autoAlpha: 1, zIndex: 5, duration: 0.3, overwrite: true });

				// Animate slide
				currentSlideTl = createSlideTimeline(slides[index]);
				
				// Advance when slide animation (and its 2-second hold) finishes
				// We use a timeout tied to the timeline's duration instead of eventCallback which gets flaky when killed
				const tlDur = currentSlideTl.duration();
				timeoutId = setTimeout(() => {
					activeSlideIdx = (activeSlideIdx + 1) % slides.length;
					playSlide(activeSlideIdx);
				}, tlDur * 1000);
			};

			// Wire up Next/Prev buttons
			banner.querySelectorAll('.uc-nav-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					const dir = parseInt(btn.getAttribute('data-dir') || 1);
					activeSlideIdx = (activeSlideIdx + dir + slides.length) % slides.length;
					playSlide(activeSlideIdx);
				});
			});

			// Wire up Category Pills
			const catsContainer = banner.previousElementSibling;
			if (catsContainer && catsContainer.classList.contains('use-case-categories')) {
				const pills = catsContainer.querySelectorAll('.category-pill');
				
				// Function to update pills' active state
				const updatePills = (index) => {
					pills.forEach((pill, i) => {
						if (i === index) pill.classList.add('active');
						else pill.classList.remove('active');
					});
				};

				pills.forEach((pill, index) => {
					pill.addEventListener('click', () => {
						activeSlideIdx = index;
						playSlide(activeSlideIdx);
					});
				});

				// Inject state update into playSlide core
				const originalPlaySlide = playSlide;
				playSlide = (index) => {
					updatePills(index);
					originalPlaySlide(index);
				};
			}

			ScrollTrigger.create({
				trigger: banner,
				start: "top 80%",
				onEnter: () => { 
					if (!loopStarted) { 
						loopStarted = true; 
						playSlide(activeSlideIdx);
					} 
				}
			});
		});

		gsap.from(".solution-header h2", {
			scrollTrigger: { trigger: ".solution-header", start: "top 85%" },
			y: 30, opacity: 0, duration: 1, ease: "power3.out"
		});

		gsap.from(".roadmap-step", {
			scrollTrigger: { trigger: ".roadmap-container", start: "top 80%" },
			x: -30, opacity: 0, stagger: 0.3, duration: 1.2, ease: "power2.out"
		});

		// ── Process Section Animations ────────────────────────
		const processCards = gsap.utils.toArray('.process-card');
		const dots = gsap.utils.toArray('.dots-list .dot');
		const pathFill = document.querySelector('.path-fill');

		processCards.forEach((card, i) => {
			gsap.to(card, {
				scrollTrigger: {
					trigger: card,
					start: "top 85%",
					toggleActions: "play none none reverse",
					onEnter: () => {
						// Update dots
						dots.forEach(d => d.classList.remove('active'));
						if (dots[i]) dots[i].classList.add('active');
						// Update path fill (20% increments for 5 steps)
						if (pathFill) {
							gsap.to(pathFill, { height: ((i + 1) / processCards.length) * 100 + "%", duration: 0.6 });
						}
					},
					onEnterBack: () => {
						dots.forEach(d => d.classList.remove('active'));
						if (dots[i]) dots[i].classList.add('active');
						if (pathFill) {
							gsap.to(pathFill, { height: ((i + 1) / processCards.length) * 100 + "%", duration: 0.6 });
						}
					}
				},
				opacity: 1,
				y: 0,
				duration: 0.8,
				ease: "power2.out"
			});
		});

		gsap.from(".process-header .sticky-content > *", {
			scrollTrigger: { trigger: ".process-section", start: "top 70%" },
			y: 30, opacity: 0, stagger: 0.2, duration: 1, ease: "power3.out"
		});

	});
</script>

