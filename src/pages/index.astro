---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const testimonials = (await getCollection('testimonials'))
  .filter(t => t.data.featured);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<ParticleBackground />
	<Header />
	<main class="container">
		<div class="hero-fold">
			<section class="hero">
				<div class="badge">Make AI Your Operational Edge</div>
				<h1>
					WE BUILD AND MANAGE <span class="text-gradient">AI-POWERED SYSTEMS</span> FOR MODERN OPERATIONS
				</h1>
				<p class="hero-description">
					<span class="hero-text-light">Bloated spreadsheets, disconnected tools, and humans holding it all together is not a system, it's a liability. We build and manage the execution layer, so your team only touches what needs human judgment.</span>
				</p>
				<div class="cta-group">
					<a href="/contact" class="btn btn-hero-pink">
						Turn Your Operations Into Managed AI Systems &rarr; Let's Chat 
						<span class="animated-dots">
							<span></span><span></span><span></span><span></span>
						</span>
					</a>
				</div>
			</section>

				<div class="use-case-categories pb-relative">
					<button class="category-pill active" data-slide="0">Finance</button>
					<button class="category-pill" data-slide="1">CRM</button>
					<button class="category-pill" data-slide="2">E-commerce</button>
				</div>
				<section class="framework-banner pb-relative">
		<div class="use-cases-wrapper" style="display: grid; grid-template-columns: 1fr;">
        <!-- Slide 1 -->
        <div class="use-case-slide active-slide" data-slide="0" style="grid-area: 1 / 1;">
            <div class="banner-grid-overlay"></div>
				
				<div class="use-case-header">
					<div>
						<span class="uc-tag">Use case</span>
						<h2 class="uc-title">Financial Reporting & Reconciliation</h2>
					</div>
					<div class="uc-nav-controls">
						<button class="uc-nav-btn next" data-dir="1" title="Next Use Case" aria-label="Next Use Case">
							<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</button>
					</div>
				</div>

				<div class="framework-console">

					<!-- SVG Connections Layer -->
					<div class="stream-connections">
						<svg width="100%" height="100%" preserveAspectRatio="none" style="position: absolute; top:0; left:0; pointer-events:none; overflow:visible;">
							<path class="dotted-stream stream-src1" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(59, 130, 246, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src2" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(245, 158, 11, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src3" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(59, 130, 246, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src4" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(99, 179, 246, 0.4)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-output" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(16, 185, 129, 0.6)" stroke-width="2" stroke-dasharray="4 6" visibility="hidden" />
						</svg>
					</div>


					<!-- Column 1: Source Systems -->
					<div class="systems-column console-panel">
						<div class="panel-header">
							<span class="panel-tag">Source Nodes</span>
							<span class="panel-meta">4 Linked</span>
						</div>
						<div class="systems-source-list">
							<div class="source-item" data-source="src1">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>NetSuite ERP</span>
									<span class="s-type">Active Feed</span>
								</div>
								<div class="stream-anchor anchor-src1"></div>
							</div>
							<div class="source-item" data-source="src2">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>QuickBooks Online</span>
									<span class="s-type">Active Feed</span>
								</div>
								<div class="stream-anchor anchor-src2"></div>
							</div>
							<div class="source-item" data-source="src3">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>SVB Banking</span>
									<span class="s-type">Pending Ingest</span>
								</div>
								<div class="stream-anchor anchor-src3"></div>
							</div>
							<div class="source-item" data-source="src4">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>Stripe API</span>
									<span class="s-type">Active Stream</span>
								</div>
								<div class="stream-anchor anchor-src4"></div>
							</div>
						</div>
						

					</div>

					<!-- Column 2: Execution Logic -->
					<div class="execution-column console-panel">
						<div class="panel-header">
							<span class="panel-tag">Process Layer</span>
							<div class="status-pulse active"></div>
						</div>
						
						<ul class="task-checklist">
							<li class="task-item" data-step="1">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Identify Source Schemas</span>
									<span class="task-detail">Mapping NetSuite to Stripe structures</span>
								</div>
							</li>
							<li class="task-item" data-step="2">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Reconcile Line Items</span>
									<span class="task-detail">Matching $1.4M across 4 entities</span>
								</div>
							</li>
							<li class="task-item" data-step="3">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Anomaly Flagging</span>
									<span class="task-detail">0.02% drift detected for review</span>
								</div>
							</li>
							<li class="task-item" data-step="4">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Final Integrity Check</span>
									<span class="task-detail">Double-layer ledger validation</span>
								</div>
							</li>
						</ul>
						<div class="stream-anchor anchor-process" style="position: absolute; right: 0; top: 50%;"></div>
					</div>

					<!-- Column 3: Oversight Dashboard -->
					<div class="oversight-column" style="position: relative;">
						<div class="stream-anchor anchor-oversight" style="position: absolute; left: 0; top: 50%;"></div>
						<div class="oversight-dashboard">
							<div class="dashboard-header">
								<div class="dash-id">
									<span class="label">INSTANCE</span>
									<span class="val">AQ-449-X</span>
								</div>
								<div class="dash-status">
									<span class="ready-tag">READY FOR HUMAN OVERSIGHT</span>
									<div class="status-dot"></div>
								</div>
							</div>

							<div class="dashboard-grid">
								<!-- Precision Bar -->
								<div class="dash-main-chart">
									<div class="chart-header">
										<span class="c-label">Execution Precision</span>
										<span class="c-val confidence-val">0%</span>
									</div>
									<div class="confidence-bar">
										<div class="confidence-bar-fill"></div>
									</div>
									<div class="chart-axis">
										<span>0</span><span>25</span><span>50</span><span>75</span><span>100</span>
									</div>
								</div>

								<!-- Quality Ring -->
								<div class="dash-stats">
									<div class="stat-circle">
										<svg width="60" height="60" viewBox="0 0 60 60">
											<circle cx="30" cy="30" r="26" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="6"/>
											<circle class="ring-fill" cx="30" cy="30" r="26" fill="none" stroke="#10b981" stroke-width="6" stroke-dasharray="163.3 163.3" stroke-dashoffset="163.3"/>
										</svg>
										<div class="stat-inner">
											<span class="s-val">99%</span>
											<span class="s-label">QUALITY</span>
										</div>
									</div>
								</div>

								<!-- Transaction Ledger -->
								<div class="dash-ledger">
									<div class="ledger-header">
										<span>Transaction</span>
										<span>Precision</span>
										<span>Status</span>
									</div>
									<div class="ledger-rows">
										<div class="l-row">
											<span class="l-name">STRIPE_BATCH_9</span>
											<span class="l-prec">99.8%</span>
											<span class="l-status">MATCHED</span>
										</div>
										<div class="l-row">
											<span class="l-name">ERP_VOUCHER_12</span>
											<span class="l-prec">100%</span>
											<span class="l-status">MATCHED</span>
										</div>
										<div class="l-row warn">
											<span class="l-name">BANK_STMT_304</span>
											<span class="l-prec">94.2%</span>
											<span class="l-status highlight">FLAGGED</span>
										</div>
									</div>
								</div>

								<!-- Activity Chart -->
								<div class="dash-activity">
									<div class="activity-label">Mapping Activity</div>
									<div class="activity-viz">
										<div class="a-bar" style="height:30%"></div><div class="a-bar" style="height:60%"></div>
										<div class="a-bar" style="height:45%"></div><div class="a-bar" style="height:80%"></div>
										<div class="a-bar" style="height:55%"></div><div class="a-bar" style="height:70%"></div>
										<div class="a-bar" style="height:40%"></div><div class="a-bar" style="height:90%"></div>
										<div class="a-bar" style="height:65%"></div><div class="a-bar" style="height:75%"></div>
										<div class="a-bar" style="height:50%"></div><div class="a-bar" style="height:85%"></div>
										<div class="a-bar" style="height:35%"></div><div class="a-bar" style="height:60%"></div>
										<div class="a-bar" style="height:70%"></div><div class="a-bar" style="height:45%"></div>
										<div class="a-bar" style="height:80%"></div><div class="a-bar" style="height:55%"></div>
									</div>
								</div>

								<!-- AI Quality Report -->
								<div class="dash-details">
									<div class="activity-label">AI Quality Report</div>
									<div class="quality-grid">
										<div class="q-item">
											<span class="q-label">Entities</span>
											<span class="q-val">4</span>
										</div>
										<div class="q-item">
											<span class="q-label">Unmapped</span>
											<span class="q-val">0</span>
										</div>
										<div class="q-item">
											<span class="q-label">Verified</span>
											<span class="q-val">Pass</span>
										</div>
									</div>
								</div>

								<!-- Decision Audit -->
								<div class="dash-audit">
									<div class="activity-label">Decision Audit</div>
									<div class="audit-log">
										<div class="log-item">
											<span class="log-time">14:02:11</span>
											<span class="log-txt">GL Mapping verified via Stripe API</span>
										</div>
										<div class="log-item">
											<span class="log-time">14:02:08</span>
											<span class="log-txt">Anomaly #449 flagged — 0.02% drift</span>
										</div>
									</div>
								</div>
							</div>

							<div class="dashboard-footer">
								<div class="footer-meta">
									<div class="meta-item">
										<span class="m-label">Drift</span>
										<span class="m-val">0.02%</span>
									</div>
									<div class="meta-item">
										<span class="m-label">Volume</span>
										<span class="m-val volume-val">$0.00</span>
									</div>
								</div>
								<button class="btn-approve-console">Review & Sign Off</button>
							</div>
						</div>
					</div>

				</div><!-- /.framework-console -->
        </div>
        <!-- Slide 2 -->
        <div class="use-case-slide inactive-slide" data-slide="1" style="grid-area: 1 / 1;">
            <div class="banner-grid-overlay"></div>
				
				<div class="use-case-header">
					<div>
						<span class="uc-tag">Use case</span>
						<h2 class="uc-title">Sales Pipeline & CRM</h2>
					</div>
					<div class="uc-nav-controls">
						<button class="uc-nav-btn prev" data-dir="-1" title="Previous Use Case" aria-label="Previous Use Case">
							<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
						</button>
						<button class="uc-nav-btn next" data-dir="1" title="Next Use Case" aria-label="Next Use Case">
							<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" style="pointer-events: none;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</button>
					</div>
				</div>

				<div class="framework-console">

					<!-- SVG Connections Layer -->
					<div class="stream-connections">
						<svg width="100%" height="100%" preserveAspectRatio="none" style="position: absolute; top:0; left:0; pointer-events:none; overflow:visible;">
							<path class="dotted-stream stream-src1" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(59, 130, 246, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src2" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(245, 158, 11, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src3" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(59, 130, 246, 0.5)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src4" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(99, 179, 246, 0.4)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-src5" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(255, 122, 122, 0.4)" stroke-width="1.5" stroke-dasharray="3 5" visibility="hidden" />
							<path class="dotted-stream stream-output" d="M 0,0 C 0,0 0,0 0,0" fill="none" stroke="rgba(16, 185, 129, 0.6)" stroke-width="2" stroke-dasharray="4 6" visibility="hidden" />
						</svg>
					</div>


					<!-- Column 1: Source Nodes -->
					<div class="systems-column console-panel">
						<div class="panel-header">
							<span class="panel-tag">Source Nodes</span>
							<span class="panel-meta">4 Linked</span>
						</div>
						<div class="systems-source-list">
							<div class="source-item" data-source="src1">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>HubSpot CRM</span>
									<span class="s-type">API Sync</span>
								</div>
								<div class="stream-anchor anchor-src1"></div>
							</div>
							<div class="source-item" data-source="src2">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>Website Forms</span>
									<span class="s-type">Webhook Stream</span>
								</div>
								<div class="stream-anchor anchor-src2"></div>
							</div>
							<div class="source-item" data-source="src3">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>LinkedIn Data</span>
									<span class="s-type">Scraper Feed</span>
								</div>
								<div class="stream-anchor anchor-src3"></div>
							</div>
							<div class="source-item" data-source="src4">
								<div class="source-indicator"></div>
								<div class="source-label">
									<span>Apollo.io</span>
									<span class="s-type">Enrichment API</span>
								</div>
								<div class="stream-anchor anchor-src4"></div>
							</div>
						</div>
					</div>

					<!-- Column 2: Execution Logic -->
					<div class="execution-column console-panel">
						<div class="panel-header">
							<span class="panel-tag">Process Layer</span>
							<div class="status-pulse active"></div>
						</div>
						
						<ul class="task-checklist">
							<li class="task-item" data-step="1">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Identify Stale Records</span>
									<span class="task-detail">Scanning deals with no activity in 14+ days</span>
								</div>
							</li>
							<li class="task-item" data-step="2">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Enrich Missing Data</span>
									<span class="task-detail">Pulling contact info from source tools</span>
								</div>
							</li>
							<li class="task-item" data-step="3">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Normalise Deal Stages</span>
									<span class="task-detail">Aligning probabilities to pipeline rules</span>
								</div>
							</li>
							<li class="task-item" data-step="4">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Log Interaction History</span>
									<span class="task-detail">Matching calls and meetings to records</span>
								</div>
							</li>
							<li class="task-item" data-step="5">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Flag Exceptions</span>
									<span class="task-detail">Deals missing owner or value flagged</span>
								</div>
							</li>
							<li class="task-item" data-step="6">
								<div class="checkbox-container">
									<div class="checkbox-box future"><svg viewBox="0 0 24 24" width="10" height="10" stroke="#fff" stroke-width="4" fill="none"><polyline points="20 6 9 17 4 12"/></svg></div>
								</div>
								<div class="task-content">
									<span class="task-label">Final Integrity Check</span>
									<span class="task-detail">Reconciled against forecast model</span>
								</div>
							</li>
						</ul>
						<div class="stream-anchor anchor-process" style="position: absolute; right: 0; top: 50%;"></div>
					</div>

					<!-- Column 3: Oversight Dashboard -->
					<div class="oversight-column" style="position: relative;">
						<div class="stream-anchor anchor-oversight" style="position: absolute; left: 0; top: 50%;"></div>
						<div class="oversight-dashboard crm-dashboard">
							<div class="dashboard-header">
								<div class="dash-id">
									<span class="label">INSTANCE</span>
									<span class="val">SLS-992-CRM</span>
								</div>
								<div class="dash-status">
									<span class="ready-tag">READY FOR HUMAN OVERSIGHT</span>
									<div class="status-dot"></div>
								</div>
							</div>

							<!-- Pipeline Summary Stats -->
							<div class="crm-stats-row">
								<div class="crm-stat">
									<span class="crm-stat-val" style="color:#3b82f6;">$284k</span>
									<span class="crm-stat-label">Pipeline</span>
								</div>
								<div class="crm-stat">
									<span class="crm-stat-val" style="color:#a5b4fc;">147</span>
									<span class="crm-stat-label">Contacts</span>
								</div>
								<div class="crm-stat">
									<span class="crm-stat-val" style="color:#f59e0b;">3</span>
									<span class="crm-stat-label">Flagged</span>
								</div>
								<div class="crm-stat">
									<span class="crm-stat-val" style="color:#10b981;">94%</span>
									<span class="crm-stat-label">Coverage</span>
								</div>
							</div>

							<!-- Contacts Table -->
							<div class="crm-table-section">
								<div class="crm-table-label">Contact Records <span class="crm-badge">Live</span></div>
								<div class="crm-table-wrapper">
									<div class="crm-table-head">
										<span>Company</span>
										<span>Contact</span>
										<span>Source</span>
										<span>Stage</span>
										<span>Value</span>
									</div>
									<div class="crm-table-body">
										<div class="crm-row crm-row--new">
											<span class="crm-company">Acme Corp</span>
