		transform: translateY(0);
	}

	.visual-orange { border-color: #fce7db; background: #fffcfb; }
	.visual-blue { border-color: #e0e7ff; background: #f9faff; }
	.visual-teal { border-color: #d1fae5; background: #f0fdfa; }
	.visual-purple { border-color: #f3e8ff; background: #faf5ff; }

	.step-outer-line {
		width: 2px;
		height: 40px;
		background: #e5e7eb;
		margin: 0;
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.8s ease 0.6s;
	}

	.roadmap-step.is-visible .step-outer-line {
