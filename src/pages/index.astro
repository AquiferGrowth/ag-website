					<div class="badge">Social Proof</div>
					<h2>Trusted by <span class="text-gradient">Modern Operators</span></h2>
				</div>
				<div class="testimonials-grid" id="testimonials-grid">
					{testimonials.map((t, i) => {
						const quote = t.data.quote;
						const maxLen = 120;
						const needsTruncation = quote.length > maxLen;
						const truncated = needsTruncation ? quote.slice(0, maxLen).trimEnd() + '…' : quote;
						return (
						<div class={`testimonial-card${i >= 3 ? ' testimonial-extra' : ''}`}>
							<blockquote>
								<span class="quote-truncated">"{truncated}"</span>
								{needsTruncation && (
									<span class="quote-full" style="display:none;">"{quote}"</span>
								)}
							</blockquote>
							{needsTruncation && (
								<button class="quote-toggle-btn" type="button">Read more</button>
							)}
							<div class="testimonial-author">
								{t.data.avatar && (
									<img src={t.data.avatar} alt={t.data.author} class="author-avatar" />
								)}
								<div class="author-info">
									<strong>{t.data.author}</strong>
									{(t.data.role || t.data.company) && (
										<span>{t.data.role}{t.data.role && t.data.company ? ' · ' : ''}{t.data.company}</span>
									)}
								</div>
							</div>
						</div>
					);
					})}
				</div>

				<div class="testimonials-expand-wrap" id="testimonials-expand-wrap">
					<button class="testimonials-expand-btn" id="testimonials-expand-btn" aria-label="Show more reviews">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<span class="expand-label" id="expand-label">More reviews</span>
				</div>
			</section>
		)}

		<!-- ── Case Studies Section ──────────────── -->
		<section class="case-studies-section animate-fade-in" id="customers">
			<div class="section-header">
				<div class="badge">Case Studies</div>
				<h2 style="font-weight: 850; letter-spacing: -0.04em;">Work That <span class="text-gradient">Speaks</span></h2>
			</div>

			<div class="cs-grid">
				{allCaseStudies.slice(0, 3).map(cs => (
					<div class="cs-outer-card">
						<a href={`/case-study/${cs.slug}`} class={`cs-inner cs-inner--${cs.slug}`}>
							<!-- abstract SVG blob -->
							<svg class="cs-blob" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<ellipse cx="320" cy="60" rx="130" ry="100" opacity="0.18"/>
								<ellipse cx="80" cy="240" rx="110" ry="85" opacity="0.13"/>
								<ellipse cx="200" cy="150" rx="80" ry="60" opacity="0.10"/>
							</svg>
							<span class="cs-title">{cs.data.title}</span>
						</a>
						<a href={`/case-study/${cs.slug}`} class="cs-cta-btn">
							See Full Case Study <span class="cs-arrow">↗</span>
						</a>
					</div>
				))}
			</div>

			<div class="cs-view-more">
				<a href="/case-studies" class="btn btn-secondary">View All Case Studies →</a>
			</div>
		</section>
	</main>

	<Footer />
