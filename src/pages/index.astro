		/* Damage table — fit within mobile card */
		.mapping-header,
		.mapping-row {
			grid-template-columns: 1fr 20px 1fr;
			gap: 0.2rem;
		}
		.func-pill, .damage-pill {
			white-space: nowrap;
			font-size: 0.5rem;
			padding: 0.25rem 0.4rem;
			min-height: 26px;
			text-align: center;
		}
		.header-label { font-size: 0.52rem; }
		.mapping-arrow-spacer { width: 20px; }
		.arrow-svg { width: 20px; height: 12px; }
