	}

	/* Thinking Animation Styles */
	.thinking-animation-wrap {
		display: flex;
		justify-content: center;
		margin-bottom: 1.5rem; /* Reduced to pull cards closer */
	}

	.thinking-pill {
		background: rgba(255, 77, 109, 0.05); /* Light pink pill */
		padding: 0.75rem 1.5rem;
		border-radius: 999px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(255, 77, 109, 0.1);
		width: 64px; /* More compact pill */
		height: 36px;
		position: relative;
	}

	.thinking-dot {
		width: 5px; /* Exact match to roadmap-brand-icon dots */
		height: 5px; /* Exact match to roadmap-brand-icon dots */
		background: #FF4D6D;
		border-radius: 50%;
		position: absolute;
		animation: thinkingPulse 1.8s infinite ease-in-out both;
	}

	/* Diamond cluster positioning (5px dots with 4px relative spacing) */
	.thinking-dot:nth-child(1) { top: 11px; left: 29.5px; animation-delay: 0s; }    /* Top */
	.thinking-dot:nth-child(2) { top: 15.5px; left: 34px; animation-delay: 0.2s; }  /* Right */
	.thinking-dot:nth-child(3) { top: 20px; left: 29.5px; animation-delay: 0.4s; }  /* Bottom */
	.thinking-dot:nth-child(4) { top: 15.5px; left: 25px; animation-delay: 0.6s; }  /* Left */

	@keyframes thinkingPulse {
		0%, 80%, 100% { 
			transform: scale(0.6);
			opacity: 0.4;
		} 
		40% { 
			transform: scale(1.1);
			opacity: 1;
		}
	}

	.build-cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem; /* Micro gap */
		width: 100%;
		max-width: 800px; /* Expand slightly to fit text */
		margin: 0 auto;
	}

	.build-card {
		border-radius: 16px; 
		height: 250px; /* Reduced to mini profile */
		width: 100%;
		min-width: 235px; /* Force minimum space to avoid text wrap */
		position: relative;
		text-align: left;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		perspective: 1000px;
		cursor: pointer;
	}

	.flipper {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0; left: 0;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
		transform-style: preserve-3d;
	}
	
	.build-card.flipped .flipper {
		transform: rotateY(180deg);
	}
	
	.build-card-front, .build-card-back {
		position: absolute;
		width: 100%;
		height: 100%;
		top: 0; left: 0;
		box-sizing: border-box;
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		border-radius: 16px;
		overflow: hidden;
	}
	
	.build-card-front {
		z-index: 2;
		transform: rotateY(0deg);
	}
	
	.build-card-back {
		transform: rotateY(180deg);
		z-index: 1;
	}

	.back-desc {
		font-size: 0.85rem;
		line-height: 1.4;
		margin-top: 1rem;
		margin-bottom: 0.75rem;
		color: inherit;
		opacity: 0.9;
	}

	.back-pills-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: auto;
		margin-bottom: 2.75rem; /* Clears the 40px icon + 1.25rem bottom offset */
	}

	.back-pill {
		font-size: 0.75rem;
		padding: 0.3rem 0.6rem;
		border-radius: 4px;
		background: rgba(0,0,0,0.1);
		color: inherit;
		font-weight: 600;
		white-space: nowrap;
	}
	.card-dark .back-pill { background: rgba(255,255,255,0.15); }

	.build-card:hover {
		transform: translateY(-8px);
	}

	.card-dark { background: #111111; color: #fff; }
	.card-dark .card-main-text { color: #ffffff; } /* Force white for dark card stack text */
	
	.card-pink { background: var(--accent-primary); color: #fff; }
	.card-pink .card-main-text { color: #1a1a1a; } /* Black text on pink card */

	.card-cream {
		background: #f2f2ef; /* More distinct off-white compared to section container */
		color: #1a1a1a;
		border: 1px solid rgba(0,0,0,0.06);
	} /* Soft border for light card */
	.card-cream .card-main-text { color: #1a1a1a; } /* Black text on cream card */

	.card-tag {
		font-size: 0.8rem; /* Micro tag */
		font-weight: 750;
		display: block;
		margin-bottom: 0.05rem;
		letter-spacing: -0.2px;
	}

	.lime-text { color: #e5ff41; }

	.card-main-text {
		font-size: 1.25rem; /* Tight main text font */
		font-weight: 900;
		letter-spacing: -0.2px;
		line-height: 1;
	}

	/* Mimic the Distorted Font Style if possible with tracking */
	/* Liability Stack Visual (Broken Spreadsheet) */
	.broken-spreadsheet-visual {
		display: flex;
		flex-direction: column;
		gap: 3px;
		width: 75%;
		margin: 0 auto;
		transform: rotate(-3deg);
		opacity: 0.85;
	}
	.sheet-row {
		display: grid;
		grid-template-columns: 1fr 1.5fr 1fr;
		gap: 3px;
	}
	.header-row .sheet-cell {
		background: rgba(255, 255, 255, 0.4);
		height: 4px;
	}
	.sheet-cell {
		height: 6px;
		background: rgba(255, 255, 255, 0.15);
		border-radius: 1px;
	}
	.error-cell {
		background: rgba(255, 77, 109, 0.6);
	}
	.missing {
		background: transparent;
		border: 1px dashed rgba(255, 255, 255, 0.3);
		box-sizing: border-box;
	}
	.falling {
		transform: translateY(8px) translateX(-4px) rotate(-15deg);
		background: rgba(255, 77, 109, 0.6);
	}
	@keyframes flicker {
		0%, 100% { opacity: 0.1; }
		50% { opacity: 0.5; }
	}

	/* Card 2: Checkmarks & Tasks */
	.execution-checks-visual {
		display: flex;
		flex-direction: column;
		gap: 10px;
		align-items: flex-start;
		width: 100%;
		padding-left: 10%;
	}
	.check-row {
		display: flex;
		align-items: center;
		gap: 10px;
		opacity: 0;
	}
	.check-indicator {
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #000;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.check-indicator::after {
		content: '';
		width: 7px;
		height: 4px;
		border-bottom: 2px solid #fff;
		border-left: 2px solid #fff;
		transform: rotate(-45deg);
		margin-top: -2px;
		opacity: 0;
		clip-path: inset(0 100% 100% 0); /* Start hidden for draw effect */
	}
	.check-label {
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.5px;
		color: #1a1a1a;
		opacity: 0.8;
	}

	.cr-1 { animation: taskReadyLoop 4s infinite; }
	.cr-2 { animation: taskReadyLoop 4s 0.2s infinite; }
	.cr-3 { animation: taskReadyLoop 4s 0.4s infinite; }
	.cr-4 { animation: taskReadyLoop 4s 0.6s infinite; }

	/* Looping the actual checkmark inside the bubble */
	.cr-1 .check-indicator::after { animation: drawCheckLoop 4s 0.5s infinite; }
	.cr-2 .check-indicator::after { animation: drawCheckLoop 4s 0.7s infinite; }
	.cr-3 .check-indicator::after { animation: drawCheckLoop 4s 0.9s infinite; }
	.cr-4 .check-indicator::after { animation: drawCheckLoop 4s 1.1s infinite; }

	@keyframes taskReadyLoop {
		0%, 95% { transform: translateX(-10px); opacity: 0; }
		10%, 85% { transform: translateX(0); opacity: 1; }
	}

	@keyframes drawCheckLoop {
		0%, 15%, 95% { opacity: 0; clip-path: inset(0 100% 100% 0); }
		25%, 85% { opacity: 1; clip-path: inset(0 0 0 0); }
	}

	/* Card 3: Status Active */
	.ops-active-visual {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
