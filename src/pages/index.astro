	.solution-footer p {
		font-size: 1.25rem;
		color: #1a1a1a;
		line-height: 1.7;
		font-weight: 500;
		margin-bottom: 4rem;
	}

	.author-attribution {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
	}

	.small-logo { 
		width: 52px; 
		height: 52px; 
		border: 1.5px solid #1a1a1a;
		border-radius: 50%;
		padding: 6px;
	}

	.author-name { text-align: left; }
	.author-name strong { display: block; font-size: 1.25rem; color: #1a1a1a; font-weight: 800; }
	.author-name span { font-size: 1rem; color: #64748b; font-weight: 500; }

	/* Step 1: Pill Cloud */
	.diagram-pill-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		width: 100%;
	}

	.d-pill {
		background: white;
		border: 1.5px solid #1a1a1a;
		padding: 0.75rem 1.5rem;
		border-radius: 2rem;
		font-size: 0.95rem;
		font-weight: 700;
		color: #1a1a1a;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		box-shadow: 4px 4px 0 #1a1a1a;
		transition: transform 0.2s ease;
	}

	.d-pill:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #1a1a1a; }

	/* Step 2: Chart */
	.chart-box {
		display: flex;
		align-items: flex-end;
		gap: 3rem;
		height: 160px;
		width: 100%;
		justify-content: center;
	}
	.bar-group { display: flex; flex-direction: column; align-items: center; gap: 1rem; flex: 1; max-width: 110px; }
	.bar { width: 100%; border-radius: 8px; border: 2px solid #1a1a1a; }
	.bar-label { font-size: 0.9rem; color: #1a1a1a; font-weight: 700; }
	.bar-purple { background: #a5b4fc; }
	.bar-orange { background: #f47b56; }

	/* Step 3: Knowledge Map */
	.data-tech-diagram {
		position: relative;
		width: 100%;
		height: 240px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.diagram-dot {
		position: absolute;
		background: white;
		border: 2px solid #1a1a1a;
		padding: 0.6rem 1.2rem;
		border-radius: 1.25rem;
		font-size: 0.85rem;
		font-weight: 700;
		box-shadow: 4px 4px 0 #1a1a1a;
		white-space: nowrap;
		z-index: 10;
		color: #1a1a1a;
	}
	.diagram-dot.central {
		background: #f47b56;
		color: white;
		padding: 0.8rem 1.5rem;
		font-size: 1rem;
	}
	.b-1 { top: 10%; left: 10%; }
	.b-2 { top: 10%; right: 10%; }
	.b-3 { bottom: 10%; left: 50%; transform: translateX(-50%); }

	.diagram-line {
		position: absolute;
		background: #1a1a1a;
		height: 2px;
		transform-origin: left center;
		z-index: 1;
		opacity: 0.15;
	}
	.l-1 { top: 50%; left: 50%; width: 35%; transform: translate(-50%, -50%) rotate(-135deg); }
	.l-2 { top: 50%; left: 50%; width: 35%; transform: translate(-50%, -50%) rotate(-45deg); }
	.l-3 { top: 50%; left: 50%; width: 25%; transform: translate(-50%, -50%) rotate(90deg); }

	/* Step 4: Flow Diagram */
	.flow-diagram-custom { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: center; }
	.flow-box { 
		border: 2px solid #1a1a1a; 
		border-radius: 16px; 
		padding: 1rem 1.5rem; 
		font-size: 1rem; 
		font-weight: 800; 
		color: #1a1a1a;
		background: white;
		box-shadow: 4px 4px 0 #1a1a1a;
	}
	.flow-box.highlighted { background: #1a1a1a; color: white; box-shadow: 4px 4px 0 rgba(0,0,0,0.1); }
	.flow-line-short { width: 30px; height: 2px; background: #1a1a1a; opacity: 0.3; }

	@media (max-width: 768px) {
		.roadmap-main-title { font-size: 3.5rem; }
		.roadmap-main-subtitle { font-size: 1.25rem; margin-bottom: 4rem; }
		.solution-card { padding: 4rem 1.5rem; }
		.step-header-card { padding: 2rem 1.5rem; }
		.solution-header h2 { font-size: 2.5rem; }
		.step-visual-card { padding: 2rem 1rem; }
		.chart-box { gap: 1.5rem; }
	}


	/* Build, Launch, Iterate Section */
	.build-launch-section {
		padding: 3rem 1.5rem 6rem 1.5rem; /* Reduced at top to match gap above */
		background: transparent; /* Show through to global grid */
		text-align: center;
		color: #1a1a1a;
	}

	.build-title {
		font-family: 'Inter Tight', sans-serif;
		font-size: clamp(2.2rem, 5vw, 3.2rem); 
		font-weight: 850;
		margin-bottom: 0.5rem; 
		letter-spacing: -1.5px;
		line-height: 1;
		color: #1a1a1a;
		text-align: center;
	}

	.build-subtitle {
		font-family: 'Inter', sans-serif;
		font-size: 1.25rem;
		font-weight: 400;
		color: #1a1a1a;
		text-align: center;
		margin-bottom: 1.5rem; /* Reduced to accommodate animation pill */
		opacity: 0.8;
	}

	/* Thinking Animation Styles */
	.thinking-animation-wrap {
		display: flex;
		justify-content: center;
		margin-bottom: 1.5rem; /* Reduced to pull cards closer */
	}

	.thinking-pill {
		background: rgba(255, 77, 109, 0.05); /* Light pink pill */
		padding: 0.75rem 1.5rem;
		border-radius: 999px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(255, 77, 109, 0.1);
		width: 64px; /* More compact pill */
		height: 36px;
		position: relative;
	}

	.thinking-dot {
		width: 5px; /* Exact match to roadmap-brand-icon dots */
		height: 5px; /* Exact match to roadmap-brand-icon dots */
		background: #FF4D6D;
		border-radius: 50%;
		position: absolute;
		animation: thinkingPulse 1.8s infinite ease-in-out both;
	}

	/* Diamond cluster positioning (5px dots with 4px relative spacing) */
	.thinking-dot:nth-child(1) { top: 11px; left: 29.5px; animation-delay: 0s; }    /* Top */
	.thinking-dot:nth-child(2) { top: 15.5px; left: 34px; animation-delay: 0.2s; }  /* Right */
	.thinking-dot:nth-child(3) { top: 20px; left: 29.5px; animation-delay: 0.4s; }  /* Bottom */
	.thinking-dot:nth-child(4) { top: 15.5px; left: 25px; animation-delay: 0.6s; }  /* Left */

	@keyframes thinkingPulse {
		0%, 80%, 100% { 
			transform: scale(0.6);
			opacity: 0.4;
		} 
		40% { 
			transform: scale(1.1);
			opacity: 1;
		}
	}

	.build-cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem; /* Micro gap */
		max-width: 720px; /* Extremely tight grid */
		margin: 0 auto;
	}

	.build-card {
		border-radius: 16px; 
		padding: 1.25rem; 
		height: 250px; /* Reduced to mini profile */
		display: flex;
		flex-direction: column;
		justify-content: flex-start; 
		position: relative;
		overflow: hidden;
		text-align: left;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.build-card:hover {
		transform: translateY(-8px);
	}

	.card-dark { background: #111111; color: #fff; }
	.card-dark .card-main-text { color: #ffffff; } /* Force white for dark card stack text */
	
	.card-pink { background: var(--accent-primary); color: #fff; }
	.card-pink .card-main-text { color: #1a1a1a; } /* Black text on pink card */

	.card-cream {
		background: #f2f2ef; /* More distinct off-white compared to section container */
		color: #1a1a1a;
		border: 1px solid rgba(0,0,0,0.06);
	} /* Soft border for light card */
	.card-cream .card-main-text { color: #1a1a1a; } /* Black text on cream card */

	.card-tag {
		font-size: 0.8rem; /* Micro tag */
		font-weight: 750;
		display: block;
		margin-bottom: 0.05rem;
		letter-spacing: -0.2px;
	}

	.lime-text { color: #e5ff41; }

	.card-main-text {
		font-size: 1.25rem; /* Tight main text font */
		font-weight: 900;
		letter-spacing: -0.2px;
		line-height: 1;
	}

	/* Mimic the Distorted Font Style if possible with tracking */
	/* Card 1: Disconnected Systems (Reinforced) */
	.liability-systems-visual {
		width: 80px;
		height: 80px;
		position: relative;
	}
	.system-box {
		position: absolute;
		width: 20px;
		height: 20px;
		background: rgba(255,255,255,0.08);
		border: 1px solid rgba(255,255,255,0.15);
		border-radius: 4px;
	}
	/* Divergent Drift: System move away from each other */
	.s-1 { top: 10%; left: 0%; animation: driftAway1 6s infinite ease-in-out; }
	.s-2 { top: 20%; right: 10%; animation: driftAway2 5s infinite ease-in-out; }
	.s-3 { bottom: 10%; left: 40%; animation: driftAway3 7.5s infinite ease-in-out; }
	
	.disconnected-path {
		position: absolute;
		height: 1px;
		background: repeating-linear-gradient(to right, rgba(255,255,255,0.05), rgba(255,255,255,0.05) 4px, transparent 4px, transparent 8px);
		opacity: 0.3;
	}
	.path-1 { width: 40px; transform: rotate(45deg); top: 30px; left: 10px; }
	.path-2 { width: 35px; transform: rotate(-30deg); top: 50px; right: 15px; }

	@keyframes driftAway1 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-10px, -5px) rotate(-5deg); }
	}
	@keyframes driftAway2 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(8px, -10px) rotate(8deg); }
	}
	@keyframes driftAway3 {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(4px, 12px) rotate(3deg); }
	}
	@keyframes flicker {
		0%, 100% { opacity: 0.1; }
		50% { opacity: 0.5; }
	}

	/* Card 2: Checkmarks & Tasks */
	.execution-checks-visual {
		display: flex;
		flex-direction: column;
		gap: 10px;
		align-items: flex-start;
		width: 100%;
		padding-left: 10%;
	}
	.check-row {
		display: flex;
		align-items: center;
		gap: 10px;
		opacity: 0;
	}
	.check-indicator {
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #000;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.check-indicator::after {
		content: '';
		width: 7px;
		height: 4px;
		border-bottom: 2px solid #fff;
		border-left: 2px solid #fff;
		transform: rotate(-45deg);
		margin-top: -2px;
		opacity: 0;
		clip-path: inset(0 100% 100% 0); /* Start hidden for draw effect */
	}
	.check-label {
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.5px;
		color: #1a1a1a;
		opacity: 0.8;
	}

	.cr-1 { animation: taskReadyLoop 4s infinite; }
	.cr-2 { animation: taskReadyLoop 4s 0.2s infinite; }
	.cr-3 { animation: taskReadyLoop 4s 0.4s infinite; }
	.cr-4 { animation: taskReadyLoop 4s 0.6s infinite; }

	/* Looping the actual checkmark inside the bubble */
	.cr-1 .check-indicator::after { animation: drawCheckLoop 4s 0.5s infinite; }
	.cr-2 .check-indicator::after { animation: drawCheckLoop 4s 0.7s infinite; }
	.cr-3 .check-indicator::after { animation: drawCheckLoop 4s 0.9s infinite; }
	.cr-4 .check-indicator::after { animation: drawCheckLoop 4s 1.1s infinite; }

	@keyframes taskReadyLoop {
		0%, 95% { transform: translateX(-10px); opacity: 0; }
		10%, 85% { transform: translateX(0); opacity: 1; }
	}

	@keyframes drawCheckLoop {
		0%, 15%, 95% { opacity: 0; clip-path: inset(0 100% 100% 0); }
		25%, 85% { opacity: 1; clip-path: inset(0 0 0 0); }
	}

	/* Card 3: Status Active */
	.ops-active-visual {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}
	.status-pulse {
		width: 40px;
		height: 40px;
		background: rgba(0, 0, 0, 0.05);
		border-radius: 50%;
		position: relative;
	}
	.status-pulse::after {
