	/* Failure Mapping Visual Styles */
	.failure-mapping-diagram {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.mapping-header {
		display: grid;
		grid-template-columns: 1fr 40px 1.2fr;
		width: 100%;
		padding: 0;
		margin-bottom: 0.5rem;
	}

	.header-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #9ca3af;
		text-align: center; /* Center within grid column */
