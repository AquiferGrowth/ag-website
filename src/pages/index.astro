	/* Testimonials */
	.testimonials-section {
		padding: 4rem 0;
	}
	.section-header {
		text-align: center;
		margin-bottom: var(--space-lg);
	}
	.section-header h2 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin: 0.5rem 0 0;
	}
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
		align-items: start;
	}
	.testimonial-card {
		background: var(--bg-secondary);
		border: 2px solid var(--border-color);
		border-radius: var(--radius-lg);
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: var(--transition-fast);
	}
	.testimonial-card:hover {
		border-color: var(--accent-primary);
		transform: translateY(-4px);
	}
	blockquote {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text-primary);
		margin: 0;
		font-style: italic;
	}
	.quote-toggle-btn {
		background: none;
		border: none;
		color: var(--accent-primary, #FF7A7A);
		font-size: 0.82rem;
		font-weight: 700;
		cursor: pointer;
		padding: 0;
		margin-top: -0.25rem;
		transition: color 0.2s, opacity 0.2s;
		opacity: 0.85;
		align-self: flex-start;
	}
	.quote-toggle-btn:hover {
		opacity: 1;
		text-decoration: underline;
	}
	.testimonial-author {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding-top: 0.5rem;
		border-top: 1px solid var(--border-color);
	}
	.author-avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--accent-primary);
	}
	.author-info {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.author-info strong {
		font-size: 0.9rem;
		font-weight: 800;
	}
	.author-info span {
		font-size: 0.8rem;
		color: var(--text-secondary);
	}

	/* Testimonials expand arrow */
	.testimonial-extra {
		display: none;
	}
	.testimonial-extra.visible {
		display: flex;
	}
	.testimonials-expand-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		margin-top: 2rem;
		cursor: pointer;
	}
	.testimonials-expand-btn {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: 2px solid var(--border-color);
		background: var(--bg-secondary);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		animation: bounce-arrow 2s ease-in-out infinite;
		color: var(--text-primary);
	}
	.testimonials-expand-btn:hover {
		background: #FF7A7A;
		border-color: #000;
		box-shadow: 3px 3px 0 #000;
		transform: translateY(-2px);
		animation: none;
	}
	.testimonials-expand-btn.expanded {
		animation: none;
		transform: rotate(180deg);
		background: #FF7A7A;
		border-color: #000;
		box-shadow: 3px 3px 0 #000;
	}
	.expand-label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-secondary);
		transition: color 0.2s;
	}
	.testimonials-expand-wrap:hover .expand-label {
		color: var(--text-primary);
	}
	@keyframes bounce-arrow {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(5px); }
	}

	/* Roadmap Section Styles Refined */
	.solution-roadmap-section {
		padding: 5rem 1.5rem 2.5rem 1.5rem; /* Standardized transition gap */
		display: flex;
		justify-content: center;
		background: transparent;
	}

	.section-white-card {
		background: #fdfcf9 !important; /* Premium off-white to match screenshot */
		border-radius: 32px; 
		padding: 2.5rem 2rem; 
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
		border: 1px solid rgba(0, 0, 0, 0.05);
		width: 100%;
		max-width: 800px; /* Highly focused profile */
		margin: 0 auto;
	}

	.roadmap-outer-content {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.roadmap-main-title {
		font-size: clamp(2rem, 6vw, 3.8rem); /* Matches global H1 size */
		font-weight: 800;
		color: #1a1a1a;
		margin-bottom: 0.5rem;
		letter-spacing: -0.04em;
		text-align: center;
		line-height: 1.1;
	}

	.roadmap-main-subtitle {
		font-size: 1.25rem; /* 20px approx */
		font-weight: 400;
		color: #1a1a1a;
		margin-bottom: 0.5rem;
		text-align: center;
		opacity: 0.8;
	}

	.solution-card {
		background: transparent;
		padding: 1rem 0rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
	}

	.roadmap-brand-icon {
		margin-bottom: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.brand-icon-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.1rem;
		background: rgba(255, 77, 109, 0.05);
		border-radius: 100px;
		border: 1px solid rgba(255, 77, 109, 0.1);
	}

	.roadmap-brand-icon svg {
		width: 24px;
		height: 24px;
		color: var(--accent-primary);
		animation: soft-pulse 4s ease-in-out infinite;
	}

	.roadmap-brand-icon .animated-dots {
		margin-left: 0;
		transform: rotate(45deg);
	}

	.roadmap-brand-icon .animated-dots span {
		background-color: var(--accent-primary);
	}

	@keyframes soft-pulse {
		0%, 100% { transform: scale(1); opacity: 0.9; }
		50% { transform: scale(1.08); opacity: 1; }
	}

	.intro-step {
		margin-bottom: 0;
	}

	.intro-step .step-header-card {
		max-width: 720px;
		background: #ffffff;
		border-color: #1a1a1a;
		padding: 2.5rem 3rem;
	}


	.roadmap-container {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.roadmap-step {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.step-header-card {
		background: #ffffff;
		border: 1.5px solid #1a1a1a;
		border-radius: 28px;
		padding: 1.75rem 2.25rem;
		text-align: center;
		max-width: 600px;
		width: 100%;
		box-shadow: 0 4px 30px rgba(0,0,0,0.02);
		z-index: 2;
		opacity: 0;
		transform: translateY(20px);
		transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.roadmap-step.is-visible .step-header-card {
		opacity: 1;
		transform: translateY(0);
	}

	.step-header-card .step-title {
		font-size: 1.4rem;
		font-weight: 800;
		margin-bottom: 0.8rem;
		color: #1a1a1a;
		letter-spacing: -0.02em;
	}

	.step-header-card p {
		font-size: 1.1rem;
		color: #4b5563;
		line-height: 1.5;
	}

	.step-connector-line {
		width: 2px;
		height: 40px;
		background: #f47b56; 
		opacity: 0.5;
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.8s ease 0.4s;
	}

	.roadmap-step.is-visible .step-connector-line {
		transform: scaleY(1);
	}

	.step-visual-card {
		border: 1.5px solid #e5e7eb;
		border-radius: 24px;
		padding: 1.25rem 1.5rem;
		width: 100%;
		max-width: 580px; /* Reduced to be smaller than the 600px header card */
		background: #ffffff;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 140px;
		position: relative;
		opacity: 0;
		transform: translateY(20px);
		transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
	}

	.roadmap-step.is-visible .step-visual-card {
		opacity: 1;
		transform: translateY(0);
	}

	.visual-orange { border-color: #fce7db; background: #fffcfb; }
	.visual-blue { border-color: #e0e7ff; background: #f9faff; }
	.visual-teal { border-color: #d1fae5; background: #f0fdfa; }
	.visual-purple { border-color: #f3e8ff; background: #faf5ff; }

	.step-outer-line {
		width: 2px;
		height: 40px;
		background: #e5e7eb;
		margin: 0;
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.8s ease 0.6s;
	}

	.roadmap-step.is-visible .step-outer-line {
		transform: scaleY(1);
	}

	.solution-footer {
		margin-top: 6rem;
		text-align: center;
		max-width: 850px;
		padding-top: 5rem;
		border-top: 1.5px solid #f3f4f6;
	}

	.solution-footer p {
		font-size: 1.25rem;
		color: #1a1a1a;
		line-height: 1.7;
		font-weight: 500;
		margin-bottom: 4rem;
	}

	.author-attribution {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
	}

	.small-logo { 
		width: 52px; 
		height: 52px; 
		border: 1.5px solid #1a1a1a;
		border-radius: 50%;
		padding: 6px;
	}

	.author-name { text-align: left; }
	.author-name strong { display: block; font-size: 1.25rem; color: #1a1a1a; font-weight: 800; }
	.author-name span { font-size: 1rem; color: #64748b; font-weight: 500; }

	/* Step 1: Pill Cloud */
	.diagram-pill-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		width: 100%;
	}

	.d-pill {
		background: white;
		border: 1.5px solid #1a1a1a;
		padding: 0.75rem 1.5rem;
		border-radius: 2rem;
		font-size: 0.95rem;
		font-weight: 700;
		color: #1a1a1a;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		box-shadow: 4px 4px 0 #1a1a1a;
		transition: transform 0.2s ease;
	}

	.d-pill:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #1a1a1a; }

	/* Step 2: Chart */
	.chart-box {
		display: flex;
		align-items: flex-end;
		gap: 3rem;
		height: 160px;
		width: 100%;
		justify-content: center;
	}
	.bar-group { display: flex; flex-direction: column; align-items: center; gap: 1rem; flex: 1; max-width: 110px; }
	.bar { width: 100%; border-radius: 8px; border: 2px solid #1a1a1a; }
	.bar-label { font-size: 0.9rem; color: #1a1a1a; font-weight: 700; }
	.bar-purple { background: #a5b4fc; }
	.bar-orange { background: #f47b56; }

	/* Step 3: Knowledge Map */
	.data-tech-diagram {
		position: relative;
		width: 100%;
		height: 240px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.diagram-dot {
		position: absolute;
		background: white;
		border: 2px solid #1a1a1a;
		padding: 0.6rem 1.2rem;
		border-radius: 1.25rem;
		font-size: 0.85rem;
		font-weight: 700;
		box-shadow: 4px 4px 0 #1a1a1a;
		white-space: nowrap;
		z-index: 10;
		color: #1a1a1a;
	}
	.diagram-dot.central {
		background: #f47b56;
		color: white;
		padding: 0.8rem 1.5rem;
		font-size: 1rem;
	}
	.b-1 { top: 10%; left: 10%; }
	.b-2 { top: 10%; right: 10%; }
	.b-3 { bottom: 10%; left: 50%; transform: translateX(-50%); }

	.diagram-line {
		position: absolute;
		background: #1a1a1a;
		height: 2px;
		transform-origin: left center;
		z-index: 1;
		opacity: 0.15;
	}
	.l-1 { top: 50%; left: 50%; width: 35%; transform: translate(-50%, -50%) rotate(-135deg); }
	.l-2 { top: 50%; left: 50%; width: 35%; transform: translate(-50%, -50%) rotate(-45deg); }
	.l-3 { top: 50%; left: 50%; width: 25%; transform: translate(-50%, -50%) rotate(90deg); }

	/* Step 4: Flow Diagram */
	.flow-diagram-custom { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: center; }
	.flow-box { 
		border: 2px solid #1a1a1a; 
		border-radius: 16px; 
		padding: 1rem 1.5rem; 
		font-size: 1rem; 
		font-weight: 800; 
		color: #1a1a1a;
		background: white;
		box-shadow: 4px 4px 0 #1a1a1a;
	}
	.flow-box.highlighted { background: #1a1a1a; color: white; box-shadow: 4px 4px 0 rgba(0,0,0,0.1); }
	.flow-line-short { width: 30px; height: 2px; background: #1a1a1a; opacity: 0.3; }

	@media (max-width: 768px) {
		.roadmap-main-title { font-size: 3.5rem; }
		.roadmap-main-subtitle { font-size: 1.25rem; margin-bottom: 4rem; }
		.solution-card { padding: 4rem 1.5rem; }
		.step-header-card { padding: 2rem 1.5rem; }
		.solution-header h2 { font-size: 2.5rem; }
		.step-visual-card { padding: 2rem 1rem; }
		.chart-box { gap: 1.5rem; }
	}
	@media (max-width: 640px) {
		.roadmap-main-title { font-size: 1.75rem; }
		.roadmap-main-subtitle { font-size: 0.95rem; margin-bottom: 1.5rem; }
		.roadmap-outer-content { padding: 2rem 1rem !important; }
		.solution-card { padding: 1.5rem 0.5rem; }
		.intro-step .step-header-card { padding: 1.25rem 1rem; }
