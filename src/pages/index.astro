	.stage-proposal  { background: rgba(139,92,246,0.15); color: #a78bfa; }
	.stage-closed    { background: rgba(16,185,129,0.15); color: #34d399; }
	.stage-flag      { background: rgba(245,158,11,0.15); color: #fbbf24; }

	.crm-sources-section { margin-bottom: 0.6rem; padding: 0 1.25rem; }
	.crm-source-bars { display: flex; flex-direction: column; gap: 0.35rem; }
	.crm-src-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.6rem; }
	.crm-src-name { color: #94a3b8; width: 60px; flex-shrink: 0; }
	.crm-src-track {
		flex: 1; height: 5px; background: rgba(255,255,255,0.07);
		border-radius: 10px; overflow: hidden;
	}
	.crm-src-fill { height: 100%; border-radius: 10px; }
	.crm-src-pct { color: #64748b; font-size: 0.55rem; width: 28px; text-align: right; flex-shrink: 0; }


	/* ── Process Section ──────────────────────── */
	.process-section {
		padding: 8rem 0;
		background: transparent;
		overflow: visible;
		position: relative;
	}

	.process-container {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: flex-start;
	}

	.process-header {
		position: sticky;
		top: 15vh;
	}

	.step-tag {
		display: inline-flex;
		padding: 0.5rem 1rem;
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 700;
		color: #1A1A1A;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 2rem;
	}

	.process-title {
		font-size: clamp(3rem, 8vw, 5rem);
		line-height: 0.95;
		color: #1A1A1A;
		margin-bottom: 2rem;
		font-weight: 800;
	}

	.process-desc {
		font-size: 1.25rem;
		color: #555555;
		max-width: 480px;
		line-height: 1.6;
	}

	/* Success Path Indicator */
	.success-path-wrapper {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-top: 2rem;
		position: relative;
	}

	.path-line {
		position: absolute;
		left: 6px;
		top: 40px;
		bottom: 40px;
		width: 2px;
		background: #e5e7eb;
		z-index: 0;
	}

	.dots-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		z-index: 1;
	}

	.dot {
		width: 14px;
		height: 14px;
		background: #FFFFFF;
		border: 2px solid #e5e7eb;
		border-radius: 50%;
		position: relative;
		z-index: 1;
		transition: all 0.3s ease;
	}

	.dot.active {
		background: var(--accent-primary);
		border-color: var(--accent-primary);
		box-shadow: 0 0 10px rgba(255, 77, 109, 0.4);
	}

	/* Process steps cards */
	.process-steps {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.process-card {
		background: #FFFFFF;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		padding: 3rem;
		position: relative;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
	}

	.process-card:hover {
		background: #FFFFFF;
		border-color: #d1d5db;
		transform: translateY(-5px);
	}

	.card-num {
		position: absolute;
		top: -20px;
		right: -10px;
		font-size: 12rem;
		font-weight: 900;
		color: rgba(0, 0, 0, 0.03);
		user-select: none;
		pointer-events: none;
		z-index: 0;
	}

	.card-content h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #1A1A1A;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		position: relative;
		z-index: 1;
	}

	.step-desc {
		font-size: 1.125rem;
		color: #555555;
		line-height: 1.6;
		margin-bottom: 2.5rem;
		position: relative;
		z-index: 1;
	}

	.step-features {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		list-style: none;
		padding: 0;
		position: relative;
		z-index: 1;
	}

	.step-features li {
		background: #F9F7F2;
		border: 1px solid #e5e7eb;
		padding: 0.4rem 0.8rem;
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 600;
		color: #1A1A1A;
	}

	@media (max-width: 1024px) {
		.process-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.process-header {
			position: relative;
			top: 0;
		}

		.process-desc {
			max-width: 100%;
		}
		
		.card-num { font-size: 5rem; top: 0; right: 20px; }
	}


