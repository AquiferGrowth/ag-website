  /* Simple prev/next carousel — used by featured case studies + ownership quotes */
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = [
      {
        rootId: 'ddFeatureCarousel',
        trackSel: '.dd-feature__track',
        slideSel: '.dd-feature__slide',
        prevSel: '.dd-feature__nav--prev',
        nextSel: '.dd-feature__nav--next',
        counterSel: '.dd-feature__counter b',
      },
      {
        rootId: 'ddOwnsCarousel',
        trackSel: '.dd-owns-track',
        slideSel: '.dd-own-slide',
        prevSel: '.dd-owns-nav--prev',
        nextSel: '.dd-owns-nav--next',
        counterSel: '.dd-owns-counter b',
      },
      {
        rootId: 'ddPdpCarousel',
        trackSel: '.dd-pdp-track',
        slideSel: '.dd-pdp-slide',
        prevSel: '.dd-pdp-nav--prev',
        nextSel: '.dd-pdp-nav--next',
        counterSel: '.dd-pdp-counter b',
      },
    ];

    carousels.forEach((cfg) => {
      const root = document.getElementById(cfg.rootId);
      if (!root) return;
      const track = root.querySelector(cfg.trackSel);
      const slides = root.querySelectorAll(cfg.slideSel);
      const prev = root.querySelector(cfg.prevSel);
      const next = root.querySelector(cfg.nextSel);
      const counter = root.querySelector(cfg.counterSel);
      if (!track || slides.length < 2 || !prev || !next || !counter) return;

      let index = 0;
      const total = slides.length;

      const render = () => {
        track.style.transform = 'translateX(-' + (index * 100) + '%)';
        counter.textContent = String(index + 1);
        prev.disabled = index === 0;
        next.disabled = index === total - 1;
        slides.forEach((s, i) => s.setAttribute('aria-hidden', i === index ? 'false' : 'true'));
      };

      prev.addEventListener('click', () => {
        if (index > 0) { index--; render(); }
      });
      next.addEventListener('click', () => {
        if (index < total - 1) { index++; render(); }
      });
      root.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          if (index > 0) { index--; render(); }
          e.preventDefault();
          e.stopPropagation();
        }
        if (e.key === 'ArrowRight') {
          if (index < total - 1) { index++; render(); }
          e.preventDefault();
          e.stopPropagation();
        }
      });

      render();
    });
  });
</script>

