---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Prettier didn't sell more. | AquiferGrowth Design & Development"
  description="We design and build Shopify storefronts against one number: revenue. And we own them after launch. The design & dev arm of AquiferGrowth."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- HERO                                        -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-hero">
      <div class="dd-hero__bg-blur"></div>
      <div class="dd-hero__bg-blur dd-hero__bg-blur--right"></div>
      <div class="dd-hero__inner container">
        <div class="dd-hero__copy">
          <h1 class="dd-hero__title">Your storefront, handled.<br /><span class="text-gradient">Your revenue, up.</span></h1>
          <p class="dd-hero__subtitle">Design, build, and the data underneath &rarr; owned end to end. You stop managing an agency and start reading the numbers.</p>
          <div class="dd-hero__cta-row">
            <a href="/contact" class="dd-btn">
              <span>Let's Chat</span>
              <span class="dd-animated-dots"><span></span><span></span><span></span></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 02 · EMOTIONAL REALITY                     -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-section">
      <div class="container">
        <div class="dd-sheet">
          <div class="dd-intro">
            <h2 class="dd-h2">Where your storefront <span class="text-gradient">is stuck.</span></h2>
          </div>

          <div class="dd-argument">
            <div class="dd-arg">
              <!-- Single graphic: Slack thread with no replies (silence = the pain) -->
              <div class="dd-arg__viz">
                <div class="dd-viz-slack">
                  <div class="dd-viz-slack__head">
                    <span class="dd-viz-slack__hash">#</span>storefront-issues
                  </div>
                  <div class="dd-viz-slack__msg">
                    <div class="dd-viz-slack__avatar" aria-hidden="true">S</div>
                    <div class="dd-viz-slack__body">
                      <div class="dd-viz-slack__meta">
                        <b>Sarah</b> <em>Founder</em> <time>16d ago</time>
                      </div>
                      <p class="dd-viz-slack__text">Store's broken on mobile. Who's on it?</p>
                      <div class="dd-viz-slack__silence">
                        <span class="dd-viz-slack__seen">Seen by 4</span>
                        <span class="dd-viz-slack__replies">0 replies</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="dd-arg__num">01</div>
              <div class="dd-arg__title">Nobody owns your storefront.</div>
              <p class="dd-arg__body">The freelancer moved on. The agency ghosted. Now it's on a dev's list, a marketer's list, and your list, which means it's on nobody's list.</p>
            </div>

            <div class="dd-arg">
              <!-- Single graphic: 10x10 dots — 5 coral (converted), 95 ghosted -->
              <div class="dd-arg__viz">
                <div class="dd-viz-dots">
                  <div class="dd-viz-dots__grid" aria-hidden="true">
                    <span class="on"></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span class="on"></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span class="on"></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span class="on"></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span class="on"></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                  </div>
                  <div class="dd-viz-dots__caption">
                    <b>5</b> bought &nbsp;&middot;&nbsp; <em>95 left</em>
                  </div>
                </div>
              </div>
              <div class="dd-arg__num">02</div>
              <div class="dd-arg__title">Traffic's fine. Conversion isn't.</div>
              <p class="dd-arg__body">You're paying for the visits. They land on a PDP that hesitates, a PLP that can't filter, and a catalog with no real structure underneath it.</p>
            </div>

            <div class="dd-arg">
              <!-- Single graphic: Shopify Plus receipt with a big lock -->
              <div class="dd-arg__viz">
                <div class="dd-viz-locked">
                  <span class="dd-viz-locked__badge">Shopify Plus</span>
                  <span class="dd-viz-locked__price">$2,300<em>/mo</em></span>
                  <span class="dd-viz-locked__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="12" width="18" height="14" rx="1.5"/>
                      <path d="M7 12V7a5 5 0 0110 0v5"/>
                      <circle cx="12" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                    </svg>
                  </span>
                  <span class="dd-viz-locked__state">Features unused</span>
                </div>
              </div>
              <div class="dd-arg__num">03</div>
              <div class="dd-arg__title">You moved to Shopify Plus. Nothing changed.</div>
              <p class="dd-arg__body">Enterprise pricing, and you're still running a theme a Basic store could run. Custom templates, scripts, checkout, all of it still on the shelf.</p>
            </div>

            <div class="dd-arg">
              <!-- Single graphic: socket + 3 branded apps floating disconnected -->
              <div class="dd-arg__viz">
                <div class="dd-viz-unplugged">
                  <div class="dd-viz-unplugged__socket" aria-hidden="true">
                    <span></span>
                    <span></span>
                  </div>
                  <div class="dd-viz-unplugged__gap" aria-hidden="true">
                    <svg viewBox="0 0 40 4" preserveAspectRatio="none"><line x1="0" y1="2" x2="40" y2="2" stroke="currentColor" stroke-width="2" stroke-dasharray="3 4" stroke-linecap="round"/></svg>
                  </div>
                  <div class="dd-viz-unplugged__apps" aria-label="Recharge, Rebuy, Klaviyo">
                    <div class="dd-viz-unplugged__app dd-viz-unplugged__app--recharge" title="Recharge">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/></svg>
                    </div>
                    <div class="dd-viz-unplugged__app dd-viz-unplugged__app--rebuy" title="Rebuy">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12a8 8 0 0114-5.3L20 8"/><path d="M20 4v4h-4"/><path d="M20 12a8 8 0 01-14 5.3L4 16"/><path d="M4 20v-4h4"/></svg>
                    </div>
                    <div class="dd-viz-unplugged__app dd-viz-unplugged__app--klaviyo" title="Klaviyo">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 6.5a1 1 0 011.6-.8l6.4 4.8 6.4-4.8a1 1 0 011.6.8v11a1 1 0 01-1.6.8l-4.8-3.6-1.6 1.2-1.6-1.2L5.6 18.3A1 1 0 014 17.5v-11z"/></svg>
                    </div>
                  </div>
                  <div class="dd-viz-unplugged__status">Not connected</div>
                </div>
              </div>
              <div class="dd-arg__num">04</div>
              <div class="dd-arg__title">The apps are installed. Nobody wired them up.</div>
              <p class="dd-arg__body">Recharge, Rebuy, Klaviyo, thousands a month in subscriptions, doing a fraction of what you bought them for.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 03 · YOU'RE ALREADY PAYING FOR THE FIX     -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-section">
      <div class="container">
        <div class="dd-sheet">
          <div class="dd-intro">
            <h2 class="dd-h2">You're <span class="text-gradient">leaking money.</span></h2>
            <p class="dd-intro__sub">$10,300 a month, already leaving your account. Barely any of it working.</p>
          </div>

          <div class="dd-pay-grid">
            <div class="dd-pay-card">
              <div class="dd-pay-card__value">~$2,300<em>/mo</em></div>
              <p class="dd-pay-card__body"><b>Shopify Plus.</b> You're on the plan. You're running a theme a Basic store could run.</p>
            </div>
            <div class="dd-pay-card">
              <div class="dd-pay-card__value">~$3,000<em>/mo</em></div>
              <p class="dd-pay-card__body"><b>Recharge, Rebuy, Klaviyo.</b> Installed. Barely wired.</p>
            </div>
            <div class="dd-pay-card">
              <div class="dd-pay-card__value">~$5,000<em>/mo</em></div>
              <p class="dd-pay-card__body"><b>Missed conversion.</b> Paid clicks landing on a store that doesn't close.</p>
            </div>
          </div>

          <p class="dd-pay-note">Typical mid-market DTC stack. Yours may be worse.</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 04 · THE FIX (formerly "What we do")       -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-section">
      <div class="container">
        <div class="dd-sheet">
          <div class="dd-intro">
            <h2 class="dd-h2">The fix is one team <span class="text-gradient">that owns all of it.</span></h2>
          </div>

          <div class="dd-services">
            <div class="dd-service">
              <div class="dd-service__title">Storefronts, Build or Improve</div>
              <p class="dd-service__body">Shopify and Shopify Plus, themed or custom. A new store from a blank file, or a rescue on the one you've got. Plus migrations included.</p>
              <div class="dd-service__tags">
                <span>Shopify</span><span>Shopify Plus</span><span>Custom code</span><span>Migrations</span>
              </div>
            </div>

            <div class="dd-service">
              <div class="dd-service__title">Product Pages &amp; UX Design</div>
              <p class="dd-service__body">PDPs, collection pages, and the buy box. We rebuild the moments where buyers hesitate, then check the number 60 days after launch.</p>
              <div class="dd-service__tags">
                <span>PDP</span><span>Collection pages</span><span>Subscribe &amp; save</span><span>Mobile checkout</span>
              </div>
            </div>

            <div class="dd-service">
              <div class="dd-service__title">Catalog, Data &amp; Merchandising</div>
              <p class="dd-service__body">Filtering only works if your product data does. Same colour spelled three ways, half the catalog missing tags. We fix what's underneath.</p>
              <div class="dd-service__tags">
                <span>Product data</span><span>Taxonomy</span><span>Filtering</span><span>On-site search</span><span>Merchandising</span>
              </div>
            </div>

            <div class="dd-service">
              <div class="dd-service__title">Motion &amp; Interactive</div>
              <p class="dd-service__body">Hero animation, PDP video, interactive demos. Built in code, not After Effects, so they load fast instead of tanking your page speed.</p>
              <div class="dd-service__tags">
                <span>Hero animation</span><span>PDP video</span><span>Interactive demos</span><span>Launch pages</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- FEATURED CASE STUDY (carousel · 5 slides)  -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-section">
      <div class="container">
        <div class="dd-sheet dd-sheet--dark">
          <h2 class="dd-feature__title">Featured work &middot; <span class="text-gradient">Live Healthillie.</span></h2>

          <div class="dd-feature__carousel" id="ddFeatureCarousel" role="region" aria-roledescription="carousel" aria-label="Live Healthillie initiatives" tabindex="0">
            <div class="dd-feature__viewport">
              <div class="dd-feature__track" id="ddFeatureTrack">

                <!-- ── Slide 1 · Minerals & Chill PDP ── -->
                <article class="dd-feature__slide" role="group" aria-roledescription="slide" aria-label="1 of 5: Minerals & Chill PDP">
                  <div class="dd-feature__slide-head">
                    <span class="dd-feature__slide-num">01 &middot; Minerals &amp; Chill PDP</span>
                  </div>
                  <div class="dd-feature__grid">
                    <div class="dd-feature__copy">
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The problem</div>
                        <p class="dd-feature__block-body">Minerals &amp; Chill is Live Healthillie's hero SKU, driving subscriptions, wholesale, and loyalty. It was selling on the same generic template as every other product. No flavor merchandising, no dedicated social proof, variant imagery slowing down the store's most-trafficked page.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The build</div>
                        <p class="dd-feature__block-body">Figma prototype, then a bespoke PDP template on Shopify Plus. Custom reviews with star and attribute filtering. Flavor variant swatches, quantity ticker, quick-add that opens the cart tray. Variant images on the CDN, Route protection suppressed, clinical-study link.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The result</div>
                        <div class="dd-feature__metrics">
                          <div class="dd-feature__metric">
                            <div class="dd-feature__metric-num">+42<span>%</span></div>
                            <div class="dd-feature__metric-label">add-to-carts</div>
                          </div>
                          <div class="dd-feature__metric">
                            <div class="dd-feature__metric-num">+47<span>%</span></div>
                            <div class="dd-feature__metric-label">completed checkouts</div>
                          </div>
                        </div>
                        <p class="dd-feature__metric-note">First 60 days live, against the 60 days prior.</p>
                      </div>
                    </div>
                    <div class="dd-pdp-carousel" id="ddPdpCarousel" role="region" aria-roledescription="carousel" aria-label="Minerals & Chill PDP screenshots" tabindex="0">
                      <div class="dd-pdp-viewport">
                        <div class="dd-pdp-track">
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-1.webp" alt="Minerals & Chill PDP · top" loading="lazy" /></div>
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-2.webp" alt="Minerals & Chill PDP · buy box" loading="lazy" /></div>
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-3.webp" alt="Minerals & Chill PDP · details" loading="lazy" /></div>
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-4.webp" alt="Minerals & Chill PDP · description" loading="lazy" /></div>
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-5.webp" alt="Minerals & Chill PDP · reviews" loading="lazy" /></div>
                          <div class="dd-pdp-slide"><img src="/images/design/mc-pdp-6.webp" alt="Minerals & Chill PDP · footer" loading="lazy" /></div>
                        </div>
                      </div>
                      <div class="dd-pdp-controls">
                        <button class="dd-pdp-nav dd-pdp-nav--prev" type="button" aria-label="Previous PDP view" disabled>
                          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4l-6 6 6 6"/></svg>
                        </button>
                        <div class="dd-pdp-counter" aria-live="polite"><b>1</b><span>/ 6</span></div>
                        <button class="dd-pdp-nav dd-pdp-nav--next" type="button" aria-label="Next PDP view">
                          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 4l6 6-6 6"/></svg>
                        </button>
                      </div>
                    </div>
                  </div>
                </article>

                <!-- ── Slide 2 · Subscription portal + loyalty ── -->
                <article class="dd-feature__slide" role="group" aria-roledescription="slide" aria-label="2 of 5: Subscription portal and loyalty">
                  <div class="dd-feature__slide-head">
                    <span class="dd-feature__slide-num">02 &middot; Subscription portal &amp; loyalty</span>
                  </div>
                  <div class="dd-feature__grid">
                    <div class="dd-feature__copy">
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The problem</div>
                        <p class="dd-feature__block-body">Recharge (Affinity) is a closed platform. No native custom code, no way to build a proper loyalty engine inside it &mdash; and the existing portal was doing nothing to hold subscribers.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The build</div>
                        <p class="dd-feature__block-body">Rebuilt the Recharge customer portal from scratch. Shipped a 4-tier subscription punch card &mdash; order 3, frother + sample pack; order 6, free shipping; order 9, surprise merch; order 12, 20% off. Reward-email flow, tabbed upsell system (Best Sellers, Supplements, Skin &amp; Body, Home), full cancel/manage flow. Under the hood: moved JS/HTML out of Recharge into a Shopify snippet, pushed CSS to Recharge global, rebuilt the Cloudflare worker.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The result</div>
                        <p class="dd-feature__block-body dd-feature__block-body--em">Launched June 18, 2026. Built to raise LTV on the subscription base.</p>
                      </div>
                    </div>
                    <figure class="dd-feature__figure dd-feature__figure--placeholder">
                      <span class="dd-feature__figure-ph">Portal &amp; loyalty visual</span>
                    </figure>
                  </div>
                </article>

                <!-- ── Slide 3 · Wholesale B2B ── -->
                <article class="dd-feature__slide" role="group" aria-roledescription="slide" aria-label="3 of 5: Wholesale B2B storefront">
                  <div class="dd-feature__slide-head">
                    <span class="dd-feature__slide-num">03 &middot; Wholesale B2B storefront</span>
                  </div>
                  <div class="dd-feature__grid">
                    <div class="dd-feature__copy">
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The problem</div>
                        <p class="dd-feature__block-body">Live Healthillie needed a wholesale channel. The retail store couldn't carry B2B pricing, MOQ logic, application-based access, or reseller compliance.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The build</div>
                        <p class="dd-feature__block-body">A separate Shopify Plus B2B store at wholesale.livehealthillie.com. Application &rarr; B2B-draft &rarr; approval &rarr; email-access pipeline. Reseller agreement and cert capture. 16-unit mix-and-match MOQ. Wholesale PDP mirroring retail. Klaviyo flows on top.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The result</div>
                        <p class="dd-feature__block-body dd-feature__block-body--em">A live commerce channel, standing on its own.</p>
                      </div>
                    </div>
                    <figure class="dd-feature__figure dd-feature__figure--placeholder">
                      <span class="dd-feature__figure-ph">Wholesale storefront visual</span>
                    </figure>
                  </div>
                </article>

                <!-- ── Slide 4 · Checkout redesign ── -->
                <article class="dd-feature__slide" role="group" aria-roledescription="slide" aria-label="4 of 5: Checkout experience">
                  <div class="dd-feature__slide-head">
                    <span class="dd-feature__slide-num">04 &middot; Checkout experience</span>
                  </div>
                  <div class="dd-feature__grid">
                    <div class="dd-feature__copy">
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The problem</div>
                        <p class="dd-feature__block-body">Checkout was where the funnel was leaking. Too much friction, too little proof at the moment of decision.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The build</div>
                        <p class="dd-feature__block-body">Multi-step Shopify Plus checkout with trust signals (130k &rarr; 150k customers), testimonials, Toki loyalty integration, product recommendations, and free-shipping / weight-tier logic fixes.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The result</div>
                        <p class="dd-feature__block-body dd-feature__block-body--em">A checkout that closes instead of leaking.</p>
                      </div>
                    </div>
                    <figure class="dd-feature__figure dd-feature__figure--placeholder">
                      <span class="dd-feature__figure-ph">Checkout visual</span>
                    </figure>
                  </div>
                </article>

                <!-- ── Slide 5 · ADA accessibility ── -->
                <article class="dd-feature__slide" role="group" aria-roledescription="slide" aria-label="5 of 5: Accessibility remediation">
                  <div class="dd-feature__slide-head">
                    <span class="dd-feature__slide-num">05 &middot; Accessibility remediation</span>
                  </div>
                  <div class="dd-feature__grid">
                    <div class="dd-feature__copy">
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The problem</div>
                        <p class="dd-feature__block-body">Compliance requirements weren't being met, and most agencies handle it by installing a plug-in and calling it done.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The build</div>
                        <p class="dd-feature__block-body">A full accessibility audit and a dedicated ADA theme layer. Ongoing remediation instead of a one-shot patch.</p>
                      </div>
                      <div class="dd-feature__block">
                        <div class="dd-feature__block-label">The result</div>
                        <p class="dd-feature__block-body dd-feature__block-body--em">Live, ongoing, and defensible.</p>
                      </div>
                    </div>
                    <figure class="dd-feature__figure dd-feature__figure--placeholder">
                      <span class="dd-feature__figure-ph">Accessibility visual</span>
                    </figure>
                  </div>
                </article>

              </div>
            </div>

            <div class="dd-feature__controls">
              <button class="dd-feature__nav dd-feature__nav--prev" type="button" aria-label="Previous initiative" disabled>
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4l-6 6 6 6"/></svg>
              </button>
              <div class="dd-feature__counter" aria-live="polite"><b>1</b><span>/ 5</span></div>
              <button class="dd-feature__nav dd-feature__nav--next" type="button" aria-label="Next initiative">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 4l6 6-6 6"/></svg>
              </button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- THE MACHINE · THE WORK                     -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dd-section" id="the-work">
      <div class="container">
        <div class="dd-sheet">
          <div class="dd-intro">
            <h2 class="dd-h2">More work. <span class="text-gradient">Same standard.</span></h2>
            <p class="dd-intro__sub">Storefronts, product pages, and the systems behind them.</p>
          </div>

          <div class="dd-work-grid">
