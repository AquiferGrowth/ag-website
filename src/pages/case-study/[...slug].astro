---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const caseStudies = await getCollection('caseStudies');
	return caseStudies.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, headline, description, roi, info, industry, platform, image, challenges, solutions, results, highlights, clientUrl } = entry.data;
---

<Layout title={`${title} | Case Study`} description={description}>
	<Header />
	
	<main class="cs-page">
		<!-- Hero Section -->
		<section class="cs-hero">
			<div class="cs-container">
				<div class="cs-hero-grid">
					<div class="cs-hero-text">
						<h1>{title} {headline}</h1>
						<p class="cs-desc">{description}</p>

						{highlights && highlights.length > 0 && (
							<ul class="cs-highlights">
								{highlights.map(h => (
									<li>
										<span class="cs-check">
											<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
												<rect width="20" height="20" rx="4" fill="#E8364E"/>
												<path d="M6 10l2.5 2.5L14 7.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</span>
										<span>{h}</span>
									</li>
								))}
							</ul>
						)}
					</div>

					<div class="cs-hero-card">
						<div class="cs-card-inner">
							<!-- Branded colour block -->
							<div class={`cs-card-colour cs-colour--${entry.slug}`}>
								<svg class="cs-card-blob" viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
									<ellipse cx="320" cy="40" rx="130" ry="90" opacity="0.18"/>
									<ellipse cx="70" cy="170" rx="100" ry="75" opacity="0.13"/>
								</svg>
								<span class="cs-card-name">{title}</span>
								{clientUrl && (
									<a href={clientUrl} target="_blank" rel="noopener" class="cs-visit-btn">
										Visit Website ↗
									</a>
								)}
							</div>
							<!-- CMS meta -->
							<div class="cs-card-meta">
								<div class="cs-meta-row">
									<div class="cs-meta-item">
										<span class="cs-meta-label">Industry</span>
										<span class="cs-meta-value">{industry}</span>
									</div>
									{platform && (
										<div class="cs-meta-item">
											<span class="cs-meta-label">Platform</span>
											<span class="cs-meta-value">{platform}</span>
										</div>
									)}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Timeline Section -->
		{(challenges || solutions || results) && (
			<section class="cs-timeline">
				<div class="cs-container">
					<div class="cs-timeline-inner">
						<!-- The Problem -->
						{challenges && challenges.length > 0 && (
							<div class="cs-tl-section">
								<div class="cs-tl-marker"></div>
								<div class="cs-tl-content">
									<h2>The Problem</h2>
									<p class="cs-tl-intro">
										Before working with Aquifer Growth, {title} struggled to keep up with the operational demands of their catalog. Manual processes couldn't scale.
									</p>
									{challenges.map(c => (
										<div class="cs-tl-item">
											<h3>{c.title}</h3>
											<p>{c.body}</p>
										</div>
									))}
								</div>
							</div>
						)}

						<!-- The Solution -->
						{solutions && solutions.length > 0 && (
							<div class="cs-tl-section">
								<div class="cs-tl-marker"></div>
								<div class="cs-tl-content">
									<h2>The Solution</h2>
									{solutions.map(s => (
										<div class="cs-tl-item">
											<h3>{s.title}</h3>
											<p>{s.body}</p>
										</div>
									))}
								</div>
							</div>
						)}

						<!-- The Results -->
						{results && (
							<div class="cs-tl-section">
								<div class="cs-tl-marker"></div>
								<div class="cs-tl-content">
									<h2>The Results</h2>
									<p class="cs-tl-results">{results}</p>
								</div>
							</div>
						)}
					</div>
				</div>
			</section>
		)}
	</main>

	<Footer />
</Layout>

<style>
	/* ─── Page ─── */
	.cs-page {
		padding-top: 2rem;
	}
	/* Reset heavy global heading defaults for this page */
	.cs-page h1, .cs-page h2, .cs-page h3 {
		font-family: var(--font-sans);
		text-transform: none;
		letter-spacing: normal;
		line-height: 1.3;
	}
	.cs-container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* ─── Hero ─── */
	.cs-hero {
		padding: 3rem 0 4rem;
		background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
	}

	.cs-hero-grid {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 3rem;
		align-items: start;
	}

	.cs-hero-text h1 {
		font-size: clamp(1.6rem, 3.5vw, 2.2rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.3;
		color: #1a1a1a;
		margin-bottom: 1.5rem;
	}

	.cs-desc {
		font-size: 0.9rem;
		line-height: 1.75;
		color: #555;
		margin-bottom: 2rem;
	}

	/* Highlights (checkmark list) */
	.cs-highlights {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.cs-highlights li {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		font-size: 0.88rem;
		font-weight: 400;
		color: #333;
		line-height: 1.4;
	}
	.cs-check {
		flex-shrink: 0;
		display: flex;
		align-items: center;
	}

	/* ─── Info Card ─── */
	.cs-card-inner {
		background: #fff;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 8px 30px rgba(0,0,0,0.06);
		border: 1px solid rgba(0,0,0,0.06);
	}

	/* Branded colour block */
	.cs-card-colour {
		position: relative;
		height: 180px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		overflow: hidden;
		background: #1a1a1a;
	}
	.cs-colour--inoki        { background: #2d6a4a; }
	.cs-colour--pulsefx      { background: #3b2d7a; }
	.cs-colour--spotlightavi { background: #7a4a1a; }

	.cs-card-blob {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}
	.cs-colour--inoki        .cs-card-blob ellipse { fill: #a7f3d0; }
	.cs-colour--pulsefx      .cs-card-blob ellipse { fill: #c4b5fd; }
	.cs-colour--spotlightavi .cs-card-blob ellipse { fill: #fde68a; }

	.cs-card-name {
		position: relative;
		z-index: 1;
		color: #fff;
		font-family: var(--font-display, 'Inter Tight', sans-serif);
		font-size: 1.4rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		text-transform: uppercase;
		text-align: center;
		padding: 0 1.25rem;
	}
	.cs-visit-btn {
		position: relative;
		z-index: 1;
		background: rgba(255,255,255,0.18);
		border: 1px solid rgba(255,255,255,0.35);
		color: #fff;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.35rem 0.9rem;
		border-radius: 999px;
		text-decoration: none;
		transition: background 0.2s;
	}
	.cs-visit-btn:hover { background: rgba(255,255,255,0.28); }

	/* Meta section */
	.cs-card-meta {
		padding: 1.25rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}
	.cs-meta-item--stat {
		text-align: center;
	}
	.cs-meta-stat {
		display: block;
		font-size: 1.8rem;
		font-weight: 800;
		color: #1a1a1a;
		letter-spacing: -0.03em;
		line-height: 1;
	}
	.cs-meta-divider {
		height: 1px;
		background: #f0f0f0;
	}
	.cs-meta-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
	.cs-meta-label {
		display: block;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 600;
		color: #aaa;
		margin-bottom: 0.2rem;
	}
	.cs-meta-value {
		display: block;
		font-size: 0.9rem;
		font-weight: 700;
		color: #1a1a1a;
	}

	/* ─── Timeline ─── */
	.cs-timeline {
		padding: 3rem 0 5rem;
		background: #fff;
	}

	.cs-timeline-inner {
		position: relative;
		padding-left: 3rem;
	}

	/* Vertical line */
	.cs-timeline-inner::before {
		content: '';
		position: absolute;
		left: 8px;
		top: 10px;
		bottom: 10px;
		width: 2px;
		background: #e5e5e5;
	}

	.cs-tl-section {
		position: relative;
		margin-bottom: 3rem;
	}
	.cs-tl-section:last-child {
		margin-bottom: 0;
	}

	/* Red dot marker */
	.cs-tl-marker {
		position: absolute;
		left: -3rem;
		top: 0.35rem;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: #E8364E;
		transform: translateX(-1px);
	}

	.cs-tl-content h2 {
		font-size: 1.35rem;
		font-weight: 600;
		color: #1a1a1a;
		margin-bottom: 1rem;
		letter-spacing: -0.01em;
		text-transform: none;
	}

	.cs-tl-intro {
		font-size: 0.9rem;
		line-height: 1.75;
		color: #555;
		margin-bottom: 1.75rem;
	}

	.cs-tl-item {
		margin-bottom: 1.5rem;
	}
	.cs-tl-item:last-child {
		margin-bottom: 0;
	}
	.cs-tl-item h3 {
		font-size: 1rem;
		font-weight: 650;
		color: #1a1a1a;
		margin-bottom: 0.35rem;
		text-transform: none;
		letter-spacing: normal;
	}
	.cs-tl-item p {
		font-size: 0.9rem;
		line-height: 1.75;
		color: #555;
	}

	.cs-tl-results {
		font-size: 0.9rem;
		line-height: 1.75;
		color: #444;
	}

	/* ─── Responsive ─── */
	@media (max-width: 768px) {
		.cs-hero-grid {
			grid-template-columns: 1fr;
		}
		.cs-hero-text h1 {
			font-size: 1.5rem;
		}
		.cs-timeline-inner {
			padding-left: 2.5rem;
		}
		.cs-tl-marker {
			left: -2.5rem;
		}
	}
</style>
