---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Stocky is Retiring. The Work Isn't. | AquiferGrowth"
  description="Stocky's shutting down. The counts, POs, transfers, and forecasts don't stop. Instead of switching apps, hand the whole function to us. Managed ecommerce ops for Shopify brands."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!-- HERO                                        -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="st-hero">
      <div class="st-hero__bg-blur"></div>
      <div class="st-hero__bg-blur st-hero__bg-blur--right"></div>
      <div class="st-hero__inner container">
        <span class="st-hero__eyebrow">For Shopify Stocky Users</span>
        <h1 class="st-hero__title">
          Stocky's Retiring.<br /><span class="text-gradient">The Work Isn't.</span>
        </h1>
        <p class="st-hero__subtitle">
          The counts, POs, transfers, and forecasts don't stop when the app does. Instead of switching to another tool, hand the whole function to us.
        </p>
        <div class="st-hero__cta-row">
          <a href="/contact" class="st-btn">
            <span>Let's Chat</span>
            <span class="st-animated-dots"><span></span><span></span><span></span></span>
          </a>
          <a href="#how" class="st-hero__link">See how it works &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- WHAT STOCKY WAS DOING                       -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="st-section">
      <div class="container">
        <div class="st-sheet">
          <div class="st-section__intro">
            <h2 class="st-section__title">What Stocky Was Actually <span class="text-gradient">Doing</span></h2>
            <p class="st-section__subtitle">Every one of these still needs to happen on the day Stocky goes dark. Someone has to run them.</p>
          </div>
          <div class="st-jobs">
            <div class="st-job">
              <div class="st-job__num">01</div>
              <div class="st-job__title">Inventory counts</div>
              <p class="st-job__body">Weekly and monthly counts, variance flagging, ledger sync.</p>
            </div>
            <div class="st-job">
              <div class="st-job__num">02</div>
              <div class="st-job__title">Purchase orders</div>
              <p class="st-job__body">Cutting POs, tracking status, chasing suppliers on the outstanding balance.</p>
            </div>
            <div class="st-job">
              <div class="st-job__num">03</div>
              <div class="st-job__title">Receiving &amp; shorts</div>
              <p class="st-job__body">Checking deliveries against the PO, logging shorts, requesting credits.</p>
            </div>
            <div class="st-job">
              <div class="st-job__num">04</div>
              <div class="st-job__title">Location transfers</div>
              <p class="st-job__body">Moving stock between the warehouse, POS locations, and your 3PL.</p>
            </div>
            <div class="st-job">
              <div class="st-job__num">05</div>
              <div class="st-job__title">Demand forecasting</div>
              <p class="st-job__body">Reorder points, seasonality, lead-time math against real sell-through.</p>
            </div>
            <div class="st-job">
              <div class="st-job__num">06</div>
              <div class="st-job__title">Low-stock alerts</div>
              <p class="st-job__body">Catching what's about to run out before the store oversells it.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- THE PITCH                                   -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="st-section" id="how">
      <div class="container">
        <div class="st-sheet">
          <div class="st-section__intro">
            <h2 class="st-section__title">You Don't Need Another App. <span class="text-gradient">You Need Someone Running It.</span></h2>
            <p class="st-section__subtitle">Every Stocky alternative sells you a login. We sell you the function.</p>
          </div>
          <div class="st-pitch-grid">
            <div class="st-pitch-card">
              <div class="st-pitch-card__label">Same Cadences</div>
              <h3 class="st-pitch-card__title">The rhythm doesn't change.</h3>
              <p class="st-pitch-card__body">We run the weekly counts, PO cycles, and monthly reports on the schedule Stocky had. Nothing shifts for your team, the reports just start coming from us.</p>
            </div>
            <div class="st-pitch-card">
              <div class="st-pitch-card__label">In Your Slack</div>
              <h3 class="st-pitch-card__title">Your warehouse never learns a new app.</h3>
              <p class="st-pitch-card__body">They message the channel the way they already do. We log every event into the tool, flag variances, and reply in the thread. No logins, no training.</p>
            </div>
            <div class="st-pitch-card">
              <div class="st-pitch-card__label">The Work Stocky Couldn't Do</div>
              <h3 class="st-pitch-card__title">Human eyes on the numbers.</h3>
              <p class="st-pitch-card__body">Variance investigation, supplier follow-up, credit chasing, ledger reconciliation. The senior operator work that never fit in an app.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- MIGRATION IN 2 WEEKS                        -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="st-section">
      <div class="container">
        <div class="st-sheet">
          <div class="st-section__intro">
            <h2 class="st-section__title">Off Stocky. <span class="text-gradient">In Two Weeks.</span></h2>
            <p class="st-section__subtitle">The migration is us taking it over. You don't touch the export, you don't set anything up, you don't retrain your team.</p>
          </div>
          <div class="st-steps">
            <div class="st-step">
              <div class="st-step__num">Week 1 &middot; Day 1</div>
              <h3 class="st-step__title">Export.</h3>
              <p class="st-step__body">We pull everything from Stocky, POs, suppliers, count history, transfers, reorder points. You don't touch it.</p>
            </div>
            <div class="st-step">
              <div class="st-step__num">Week 1 &middot; Days 2&ndash;5</div>
              <h3 class="st-step__title">Set up.</h3>
              <p class="st-step__body">Slack channel goes live with your team, 3PL, and suppliers. Our tool loads your data. Your first count runs on our stack.</p>
            </div>
            <div class="st-step">
              <div class="st-step__num">Week 2</div>
              <h3 class="st-step__title">Run.</h3>
              <p class="st-step__body">We run the full cadence with you watching. You approve variances and adjustments. After that, we own the function, you hear from us when something needs a yes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!-- FINAL CTA                                   -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="st-final-cta">
      <div class="container">
        <div class="st-final-cta__inner">
          <h2 class="st-final-cta__title">Ready to <span class="text-gradient">hand it over?</span></h2>
          <p class="st-final-cta__body">One call. We scope your setup, quote the tier, and you're off Stocky in two weeks, without your team ever noticing the switch.</p>
          <a href="/contact" class="st-btn">
            <span>Let's Chat</span>
            <span class="st-animated-dots"><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  main { overflow-x: hidden; }

  .text-gradient {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  /* ─── HERO ─── */
  .st-hero {
    position: relative;
    padding: 5rem 0 4rem;
    overflow: hidden;
    background: var(--bg-primary);
  }
  .st-hero__bg-blur {
    position: absolute;
    top: -140px;
    left: -140px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 77, 109, 0.16), rgba(255, 77, 109, 0) 65%);
    filter: blur(60px);
    pointer-events: none;
  }
  .st-hero__bg-blur--right {
    top: auto;
    left: auto;
    right: -160px;
    bottom: -180px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(255, 126, 95, 0.14), rgba(255, 126, 95, 0) 65%);
  }
  .st-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 900px;
    z-index: 2;
    gap: 1.35rem;
  }
  .st-hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-primary);
    padding: 0.4rem 0.85rem;
    background: rgba(255, 77, 109, 0.08);
    border-radius: 999px;
    border: 1px solid rgba(255, 77, 109, 0.2);
  }
  .st-hero__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .st-hero__subtitle {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0;
  }
  .st-hero__cta-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .st-hero__link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .st-hero__link:hover {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }

  /* ─── SHARED BUTTON ─── */
  .st-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1.85rem;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-orange));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 999px;
    box-shadow: 0 8px 20px rgba(255, 77, 109, 0.28);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .st-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(255, 77, 109, 0.36);
  }
  .st-animated-dots {
    display: inline-flex;
    gap: 3px;
  }
  .st-animated-dots span {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #fff;
    animation: st-dot 1.4s infinite ease-in-out both;
  }
  .st-animated-dots span:nth-child(2) { animation-delay: 0.2s; }
  .st-animated-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes st-dot {
    0%, 80%, 100% { opacity: 0.4; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-3px); }
  }

  /* ─── SHARED SECTION + SHEET ─── */
  .st-section {
    padding: 2rem 0;
  }
  .st-sheet {
    background: var(--bg-secondary);
    border-radius: 44px;
    padding: 3.25rem 2.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
    max-width: 1200px;
    margin: 0 auto;
  }
  .st-section__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .st-section__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }
  .st-section__subtitle {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
    text-wrap: balance;
  }

  /* ─── WHAT STOCKY WAS DOING (jobs grid) ─── */
  .st-jobs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .st-job {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: 1.5rem 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .st-job__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent-primary);
  }
  .st-job__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
  .st-job__body {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ─── PITCH (3 cards) ─── */
  .st-pitch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }
  .st-pitch-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    padding: 1.85rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    overflow: hidden;
  }
  .st-pitch-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-orange));
  }
  .st-pitch-card__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-primary);
  }
  .st-pitch-card__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    margin: 0;
  }
  .st-pitch-card__body {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ─── STEPS (3 numbered) ─── */
  .st-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .st-step {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    padding: 1.85rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .st-step__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-primary);
    padding: 0.35rem 0.65rem;
    background: rgba(255, 77, 109, 0.08);
    border-radius: 999px;
    align-self: flex-start;
  }
  .st-step__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
  }
  .st-step__body {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ─── FINAL CTA ─── */
  .st-final-cta {
    padding: 4rem 0 5rem;
  }
  .st-final-cta__inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .st-final-cta__title {
    font-family: var(--font-display);
    font-weight: 850;
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
  }
  .st-final-cta__body {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .st-hero { padding: 3.5rem 0 3rem; }
    .st-sheet { padding: 2rem 1.25rem; border-radius: 24px; }
    .st-jobs,
    .st-pitch-grid,
    .st-steps {
      grid-template-columns: 1fr;
    }
    .st-final-cta { padding: 2.5rem 0 3.5rem; }
  }
  @media (max-width: 640px) {
    .st-hero__cta-row { gap: 1rem; }
  }
</style>
